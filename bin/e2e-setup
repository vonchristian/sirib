  Management::RoleAssignment.create!(user: admin_user, role: admin_role, branch: hq_branch, cooperative: cooperative, active_from: Date.current)
end

# Create branch performance snapshots
perf_data = [
  { branch_code: "HQ", metrics: { loan_portfolio_cents: 8_500_000_00, savings_balance_cents: 3_200_000_00, delinquency_rate: 2.1, collection_efficiency: 95.3, cash_flow_position_cents: 4_100_000_00, estimated_profitability_cents: 1_200_000_00, total_members: 45 } },
  { branch_code: "MKT", metrics: { loan_portfolio_cents: 5_200_000_00, savings_balance_cents: 2_800_000_00, delinquency_rate: 3.8, collection_efficiency: 91.7, cash_flow_position_cents: 2_300_000_00, estimated_profitability_cents: 780_000_00, total_members: 32 } },
  { branch_code: "QC", metrics: { loan_portfolio_cents: 3_800_000_00, savings_balance_cents: 1_900_000_00, delinquency_rate: 5.2, collection_efficiency: 88.4, cash_flow_position_cents: 1_600_000_00, estimated_profitability_cents: 520_000_00, total_members: 28 } }
]
perf_data.each do |data|
  branch = Management::Branch.find_by(code: data[:branch_code])
  next unless branch
  Management::BranchPerformanceSnapshot.find_or_create_by!(branch: branch, snapshot_date: Date.current) do |s|
    s.metrics = data[:metrics]
  end
end

# Create risk indicators
risk_data = [
  { type: "credit_risk_delinquency", value: 3.5, threshold: 5.0, status: :elevated, branch: nil },
  { type: "liquidity_ratio", value: 0.35, threshold: 0.2, status: :normal, branch: nil },
  { type: "portfolio_at_risk", value: 4.2, threshold: 5.0, status: :elevated, branch: nil },
  { type: "credit_risk_delinquency", value: 2.1, threshold: 5.0, status: :normal, branch_code: "HQ" },
  { type: "credit_risk_delinquency", value: 5.2, threshold: 5.0, status: :critical, branch_code: "QC" },
]
risk_data.each do |data|
  branch = data[:branch_code] ? Management::Branch.find_by(code: data[:branch_code]) : nil
  Management::RiskIndicator.find_or_create_by!(indicator_type: data[:type], branch: branch, as_of_date: Date.current) do |r|
    r.value = data[:value]
    r.threshold = data[:threshold]
    r.status = data[:status]
  end
end

# Create system health snapshots
health_metrics = [
  { name: "transaction_throughput", value: 142.5, unit: "tps", status: :healthy },
  { name: "queue_depth", value: 8, unit: "jobs", status: :healthy },
  { name: "error_rate", value: 0.5, unit: "percent", status: :healthy },
  { name: "memory_usage_mb", value: 456, unit: "MB", status: :healthy },
]
health_metrics.each do |m|
  Management::SystemHealthSnapshot.find_or_create_by!(metric_name: m[:name], captured_at: Time.current.beginning_of_hour) do |s|
    s.value = m[:value]
    s.unit = m[:unit]
    s.status = m[:status]
  end
end

# Create alerts
alerts = [
  { alert_type: "loan_delinquency", severity: :warning, title: "QC Branch delinquency rate exceeded 5%", message: "QC delinquency rate is at 5.2%.", source: "risk_monitoring" },
  { alert_type: "cash_shortage", severity: :critical, title: "Low cash balance in Makati Branch", message: "MKT cash on hand is below minimum.", source: "system" },
  { alert_type: "system_health", severity: :warning, title: "High memory usage detected", message: "Memory usage at 85%.", source: "system_health" },
]
alerts.each do |attrs|
  Management::Alert.find_or_create_by!(alert_type: attrs[:alert_type], title: attrs[:title]) do |a|
    a.severity = attrs[:severity]
    a.message = attrs[:message]
    a.source = attrs[:source]
    a.status = :active
  end
end

# Create configurations
configs = {
  "loan_default_interest_rate" => { value: { rate: 1.5, unit: "percent" } },
  "savings_base_interest_rate" => { value: { rate: 0.25, unit: "percent" } },
  "late_payment_penalty_rate" => { value: { rate: 3.0, unit: "percent" } },
}
configs.each do |key, val|
  Management::Configuration.find_or_create_by!(key: key) do |c|
    c.value = val[:value]
    c.status = :active
    c.changed_by = admin_user
  end
end

# Create audit logs
unless Management::AuditLog.exists?
  first_policy = Management::Policy.first
  [
    { action: "user_login", auditable: admin_user },
    { action: "policy_created", auditable: first_policy },
    { action: "configuration_updated", auditable: Management::Configuration.first },
  ].each_with_index do |attrs, i|
    Management::AuditLog.create!(
      auditable: attrs[:auditable],
      action: attrs[:action],
      actor: admin_user,
      actor_role: "system_admin",
      ip_address: "192.168.1.#{100 + i}",
      user_agent: "E2E Test",
      before_state: {},
      after_state: {},
      created_at: (3 - i).hours.ago
    )
  end
end

# ── IDENTITY LAYER TEST DATA ──────────────────────────────────────────
teller_role = Management::Role.find_by(code: "teller")
mkt_branch = Management::Branch.find_by(code: "MKT")
if teller_role && mkt_branch && !Management::RoleAssignment.exists?(user: teller_user, role: teller_role)
  Management::RoleAssignment.create!(user: teller_user, role: teller_role, branch: mkt_branch, cooperative: cooperative, active_from: Date.current)
end

bm_role = Management::Role.find_by(code: "branch_manager")
if bm_role && mkt_branch && !Management::RoleAssignment.exists?(user: bm_user, role: bm_role)
  Management::RoleAssignment.create!(user: bm_user, role: bm_role, branch: mkt_branch, cooperative: cooperative, active_from: Date.current)
end

# ── MEMBER PORTAL E2E TEST DATA ─────────────────────────────────────────
portal_member = Membership::Member.find_or_create_by!(first_name: "Portal", last_name: "User") do |m|
  m.middle_name = "M"
  m.gender = "male"
  m.civil_status = "single"
  m.birth_date = Date.new(1990, 1, 15)
  m.mobile_number = "09170000001"
  m.email_address = "portal@example.com"
  m.identifications_attributes = [ { id_type: "BIR", id_number: "BIR-PORTAL-001" } ]
end
portal_member.update!(
  member_identifier: "MBR-PORTAL-001",
  password: "password123",
  otp_secret: nil,
  otp_enabled: false,
  portal_status: "active"
)

pending_member = Membership::Member.find_or_create_by!(first_name: "Pending", last_name: "Enrollee") do |m|
  m.middle_name = "E"
  m.gender = "female"
  m.civil_status = "married"
  m.birth_date = Date.new(1992, 6, 20)
  m.mobile_number = "09170000002"
  m.email_address = "pending@example.com"
  m.identifications_attributes = [ { id_type: "BIR", id_number: "BIR-PENDING-001" } ]
end
pending_member.update!(
  member_identifier: "MBR-PENDING-001",
  password_digest: nil,
  otp_secret: nil,
  otp_enabled: false,
  portal_status: "inactive"
)
Identity::EnrollmentService.create_enrollment(pending_member)

Portal::Announcement.find_or_create_by!(title: "Welcome to the Member Portal") do |a|
  a.body = "We are pleased to announce the launch of our new member portal. You can now view your savings, share capital, and loan information online."
  a.status = "published"
  a.published_at = Time.current
  a.cooperative = cooperative
  a.author = test_user
end

Portal::Announcement.find_or_create_by!(title: "Quarterly Dividend Declaration") do |a|
  a.body = "The board has declared a 3% dividend for all common shareholders for the current quarter. Dividends will be credited to your share capital accounts by end of month."
  a.status = "published"
  a.published_at = 1.day.ago
  a.cooperative = cooperative
  a.author = test_user
end
  # ── AI AGENT E2E TEST DATA ────────────────────────────────────────
  seeded_observations = []
  observation_data = [
    { category: "collections", severity: "critical", title: "High delinquency rate in HQ Branch", summary: "Delinquency rate exceeds 5% threshold. Immediate collection action required.", detected_at: 2.hours.ago },
    { category: "liquidity", severity: "high", title: "Low cash position detected", summary: "Cash position is below the minimum reserve requirement.", detected_at: 4.hours.ago },
    { category: "operations", severity: "medium", title: "Staff overtime increasing", summary: "Staff overtime has increased 20% this week across teller operations.", detected_at: 6.hours.ago },
    { category: "membership", severity: "low", title: "New member applications pending", summary: "5 new member applications pending review for more than 3 days.", detected_at: 1.day.ago },
    { category: "compliance", severity: "critical", title: "Overdue compliance report", summary: "Monthly compliance report for regulatory submission is overdue.", detected_at: 3.hours.ago },
  ]
  observation_data.each do |data|
    obs = ::Ai::Observation.find_or_create_by!(title: data[:title], branch: hq_branch) do |o|
      o.category = data[:category]
      o.severity = data[:severity]
      o.summary = data[:summary]
      o.detected_at = data[:detected_at]
    end
    seeded_observations << obs
  end
  puts "  AI Observations: #{seeded_observations.size} created"

  seeded_recommendations = []
  recommendation_data = [
    { priority: "critical", title: "Initiate special collection drive", summary: "Launch a targeted collection drive for accounts over 30 days past due.", action_text: "Schedule collection drive with branch managers", status: "open", confidence_score: 0.92, observation_index: 0 },
    { priority: "high", title: "Review cash reserve policy", summary: "Current cash reserves are insufficient for projected member withdrawals.", action_text: "Review and adjust cash reserve thresholds", status: "open", confidence_score: 0.85, observation_index: 1 },
    { priority: "medium", title: "Optimize teller scheduling", summary: "Adjust teller schedules to reduce overtime costs while maintaining service levels.", status: "acknowledged", confidence_score: 0.78, observation_index: 2 },
    { priority: "low", title: "Process pending applications", summary: "Assign staff to process the 5 pending membership applications.", status: "dismissed", confidence_score: 0.65, observation_index: 3 },
    { priority: "critical", title: "File compliance report immediately", summary: "Prepare and submit the monthly compliance report to regulatory body.", status: "completed", confidence_score: 0.95, observation_index: 4 },
  ]
  recommendation_data.each do |data|
    rec = ::Ai::Recommendation.find_or_create_by!(title: data[:title], branch: hq_branch) do |r|
      r.priority = data[:priority]
      r.summary = data[:summary]
      r.action_text = data[:action_text]
      r.status = data[:status]
      r.confidence_score = data[:confidence_score]
      r.observation = seeded_observations[data[:observation_index]]
    end
    seeded_recommendations << rec
  end
  puts "  AI Recommendations: #{seeded_recommendations.size} created"

  ::Ai::Digest.find_or_create_by!(generated_at: Date.current.midnight + 6.hours, branch: hq_branch) do |d|
    d.summary = "Branch operations summary for today. Cash position is below threshold. Delinquency rate requires attention. Staff overtime is within acceptable limits."
    d.risk_summary = "High: Cash position below minimum. Medium: Delinquency rate elevated. Low: Staff overtime."
    d.observation_count = seeded_observations.size
    d.recommendation_count = seeded_recommendations.size
  end
  puts "  AI Digest: created for today"

  # ── BUSINESS HOURS & HOLIDAYS E2E TEST DATA ────────────────────────
  business_hours_config = {
    "business_hours_open"   => { value: 8,  unit: "hour" },
    "business_hours_close"  => { value: 17, unit: "hour" },
    "business_hours_cutoff" => { value: 17, unit: "hour" }
  }
  business_hours_config.each do |key, val|
    Management::Configuration.find_or_create_by!(key: key) do |c|
      c.value = val
      c.status = :active
      c.changed_by = admin_user
    end
  end

  unless Management::Holiday.exists?
    e2e_holidays = [
      { date: Date.new(Date.current.year, 12, 25), name: "Christmas Day", recurring: true },
      { date: Date.new(Date.current.year, 1, 1),   name: "New Year's Day", recurring: true },
      { date: Date.new(Date.current.year, 12, 30), name: "E2E Test Holiday", recurring: false },
    ]
    e2e_holidays.each do |attrs|
      Management::Holiday.find_or_create_by!(date: attrs[:date]) do |h|
        h.name = attrs[:name]
        h.recurring = attrs[:recurring]
      end
    end
    puts "  Holidays: #{e2e_holidays.size} created"
  end

  # Ensure admin_user has ai_dashboard permission
  ai_perm = Management::Permission.find_by(action: "view", subject: "ai_dashboard")
  if admin_role && ai_perm && !Management::RolePermission.exists?(role: admin_role, permission: ai_perm)
    Management::RolePermission.create!(role: admin_role, permission: ai_perm)
  end
  puts "  AI Dashboard permission: assigned to system_admin"
end

puts ""
puts "E2E setup complete for #{cooperative.name}"
