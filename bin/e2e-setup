#!/usr/bin/env ruby
ENV["RAILS_ENV"] = "test"
require_relative "../config/environment"

User.find_or_create_by!(email_address: "test@example.com") do |user|
  user.password = "password123"
  user.role = :manager
end
User.find_by(email_address: "test@example.com")&.update!(role: :manager)

# Seed time deposit product
Treasury::TimeDepositProduct.find_or_create_by!(name: "30-Day Time Deposit") do |p|
  p.minimum_deposit_cents = 1_000_00
  p.interest_rate = 0.0350
  p.term_in_days = 30
  p.status = "active"
end

# Seed accounting accounts for treasury journal entries
cash_ledger = Accounting::Ledger.find_or_create_by!(account_code: "11100") do |l|
  l.name = "Cash"
  l.account_type = "asset"
end

deposit_ledger = Accounting::Ledger.find_or_create_by!(account_code: "21100") do |l|
  l.name = "Deposit Liabilities"
  l.account_type = "liability"
end

Accounting::Account.find_or_create_by!(account_code: "11110") do |a|
  a.name = "Cash on Hand"
  a.account_type = "asset"
  a.ledger = cash_ledger
end

Accounting::Account.find_or_create_by!(account_code: "21120") do |a|
  a.name = "Time Deposits"
  a.account_type = "liability"
  a.ledger = deposit_ledger
end

# Seed members for loan application wizard test
members_seeded = 0
20.times do |i|
  first = %w[Maria Juan Elena Jose Ana Pedro Sofia Carlos Luz Ramon Isabel Antonio Carmen Victor Lorna Danilo Gloria Fernando Rosario Miguel][i]
  last  = %w[Cruz Reyes Villanueva Mercado Dimagiba Santos Gonzales Yulo Macapagal Alcantara Samson Lopez Natividad Mendoza Fernandez Rivera Romero Ramos Castillo Angeles][i]
  unless Member.exists?(first_name: first, last_name: last)
    Member.create!(
      first_name: first,
      last_name: last,
      middle_name: "M",
      gender: i.even? ? "female" : "male",
      civil_status: %w[single married married single widowed married single married married divorced married single widowed married single married divorced single married single][i],
      birth_date: Date.new(1980 + (i % 20), 1 + (i % 12), 1 + (i % 28)),
      mobile_number: "0917#{format('%07d', i)}",
      identifications_attributes: [ { id_type: "BIR", id_number: "BIR-#{format('%09d', i)}" } ]
    )
  end
  members_seeded += 1
end

# Seed loan products
products = [
  { name: "Regular Salary Loan",    interest_rate: 1.5,  interest_calculation: "declining_balance", max_term_months: 24, requires_collateral: false },
  { name: "Emergency Loan",         interest_rate: 2.0,  interest_calculation: "declining_balance", max_term_months: 6,  requires_collateral: false },
  { name: "Educational Loan",       interest_rate: 1.0,  interest_calculation: "straight_line",     max_term_months: 36, requires_collateral: false },
]
products.each do |attrs|
  Lending::LoanProduct.find_or_create_by!(name: attrs[:name]) do |p|
    p.assign_attributes(attrs)
  end
end

# Seed charges on loan products
charges_by_product = {
  "Regular Salary Loan" => [{ name: "Service Fee", charge_type: "percentage", value: 2.0 }, { name: "Application Fee", charge_type: "fixed", value: 200 }],
  "Emergency Loan"      => [{ name: "Service Fee", charge_type: "percentage", value: 3.0 }, { name: "Processing Fee",  charge_type: "fixed", value: 150 }],
  "Educational Loan"    => [{ name: "Service Fee", charge_type: "percentage", value: 1.5 }, { name: "Application Fee", charge_type: "fixed", value: 250 }],
}
charges_by_product.each do |product_name, product_charges|
  product = Lending::LoanProduct.find_by(name: product_name)
  next unless product
  product_charges.each do |charge_attrs|
    product.loan_charges.find_or_create_by!(name: charge_attrs[:name]) do |c|
      c.assign_attributes(charge_attrs)
    end
  end
end

puts "Seeded: #{members_seeded} members, #{products.length} loan products"

# Seed savings products
savings_ledger = Accounting::Ledger.find_or_create_by!(account_code: "21100") do |l|
  l.name = "Deposit Liabilities"
  l.account_type = "liability"
end

expense_ledger = Accounting::Ledger.find_or_create_by!(account_code: "61100") do |l|
  l.name = "Interest Expense"
  l.account_type = "expense"
end

savings_product = Treasury::SavingsProduct.find_or_create_by!(name: "Regular Savings") do |p|
  p.description = "Standard savings account"
  p.liability_ledger = savings_ledger
  p.interest_expense_ledger = expense_ledger
end
savings_product.interest_rates.find_or_create_by!(current: true) { |ir| ir.rate = 0.0025 }

# Create cash account for test user
test_user = User.find_by!(email_address: "test@example.com")
cash_account = Accounting::Account.find_or_create_by!(account_code: "11110") do |a|
  cash_ledger = Accounting::Ledger.find_or_create_by!(account_code: "11100") { |l| l.name = "Cash"; l.account_type = "asset" }
  a.name = "Cash on Hand"
  a.account_type = "asset"
  a.ledger = cash_ledger
end
Accounting::CashAccount.find_or_create_by!(user: test_user, account: cash_account)

# Seed share capital products
share_capital_product = Equity::Product.find_or_create_by!(product_code: "COMMON") do |p|
  p.name = "Common Shares"
  p.description = "Standard common shares for member ownership"
  p.share_type = :common
  p.status = "active"
  p.price_per_share_cents = 100_00
  p.minimum_required_shares = 50
  p.maximum_allowed_shares = 500
  p.minimum_initial_purchase = 10
  p.allow_fractional_shares = false
  p.redeemable = true
  p.dividend_eligible = true
  p.voting_rights = true
end

Equity::Product.find_or_create_by!(product_code: "PREF") do |p|
  p.name = "Preferred Shares"
  p.description = "Preferred shares with dividend priority"
  p.share_type = :preferred
  p.status = "active"
  p.price_per_share_cents = 150_00
  p.minimum_required_shares = 25
  p.maximum_allowed_shares = 300
  p.minimum_initial_purchase = 5
  p.allow_fractional_shares = false
  p.redeemable = true
  p.dividend_eligible = true
  p.voting_rights = false
end

# Create cash session for admin user (used by cash_count e2e tests)
admin_user = User.find_by!(email_address: "admin@example.com")
admin_account = admin_user.cash_accounts.includes(:account).first&.account
if admin_account
  Treasury::CashSession.find_or_create_by!(
    user: admin_user,
    cash_account: admin_account,
    date: Date.current
  ) do |s|
    s.opened_at = Time.current - 4.hours
    s.status = "open"
    s.beginning_balance_cents = 1_035_000 # ₱10,350.00 in centavos
  end
end

puts "E2E setup complete: #{Treasury::SavingsProduct.count} savings products, #{Equity::Product.count} share capital products, cash account created"
