    cash_account: admin_account,
    date: Date.current
  ) do |s|
    s.opened_at = Time.current - 4.hours
    s.status = "open"
    s.beginning_balance_cents = 1_035_000
  end
end

# ── MANAGEMENT E2E TEST DATA ───────────────────────────────────────────
# Ensure E2E cooperative has at least one branch
