#!/usr/bin/env ruby
ENV["RAILS_ENV"] = "test"
require_relative "../config/environment"

cooperative = Cooperative.find_by!(name: "Main Cooperative")

puts "E2E setup for #{cooperative.name}"

# Create test users associated with the cooperative
def create_e2e_user(email:, password: "password123", role: :manager, cooperative:, full_name: nil)
  user = User.find_or_initialize_by(email_address: email)
  user.assign_attributes(
    password: password,
    role: role,
    status: "active",
    cooperative: cooperative,
    otp_enabled: false,
    otp_secret: nil,
    otp_verified_at: nil,
    full_name: full_name || email.split("@").first.titleize
  )
  user.employee_id ||= SecureRandom.hex(4).upcase
  user.save!
  user
end

test_user   = create_e2e_user(email: "test@example.com", cooperative: cooperative)
admin_user  = create_e2e_user(email: "admin@example.com", cooperative: cooperative)
teller_user = create_e2e_user(email: "teller@example.com", cooperative: cooperative, full_name: "Juan Teller")
bm_user     = create_e2e_user(email: "branch_manager@example.com", cooperative: cooperative, full_name: "Maria Manager")

puts "  Users: 4 created/updated for #{cooperative.name}"

# Everything below is cooperative-scoped
Current.set(cooperative: cooperative) do
# Seed time deposit product
Treasury::TimeDepositProduct.find_or_create_by!(name: "30-Day Time Deposit") do |p|
  p.minimum_deposit_cents = 1_000_00
  p.interest_rate = 0.0350
  p.term_in_days = 30
  p.status = "active"
end

# Seed accounting accounts for treasury journal entries
