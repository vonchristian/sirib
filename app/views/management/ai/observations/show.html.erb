<% content_for :page_title,"Observation Details" %> <% content_for :page_subtitle, @observation.title %> 
<div class="max-w-2xl"> 
  <div class="rounded-lg border border-border bg-surface p-6"> 
    <div class="flex items-center gap-2 mb-4"> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full <%= @observation.severity == 'critical' ? 'bg-danger/10 text-danger' : @observation.severity == 'high' ? 'bg-warning/10 text-warning' : @observation.severity == 'medium' ? 'bg-info/10 text-info' : 'bg-surface-secondary text-text-tertiary' %>"> <%= @observation.severity.titleize %> </span> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full bg-surface-secondary text-text-tertiary"> <%= @observation.category.titleize %> </span> <% if @observation.resolved? %> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full bg-positive/10 text-positive">Resolved</span> <% else %> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full bg-warning/10 text-warning">Unresolved</span> <% end %> </div>
 
    <h3 class="text-lg font-semibold text-text-primary mb-2"><%= @observation.title %></h3>
 
    <p class="text-sm text-text-secondary mb-6"><%= @observation.summary %></p>
 
    <div class="grid grid-cols-2 gap-4 text-sm"> 
      <div> 
        <p class="text-xs text-text-tertiary">Branch</p>
 
        <p class="text-text-primary"><%= @observation.branch.name %></p>
 </div>
 
      <div> 
        <p class="text-xs text-text-tertiary">Detected At</p>
 
        <p class="text-text-primary"><%= @observation.detected_at.to_fs(:long) %></p>
 </div>
 <% if @observation.resolved_at %> 
        <div> 
          <p class="text-xs text-text-tertiary">Resolved At</p>
 
          <p class="text-text-primary"><%= @observation.resolved_at.to_fs(:long) %></p>
 </div>
 <% end %> </div>
 <% if @observation.metadata.present? %> 
      <div class="mt-6 pt-6 border-t border-border"> 
        <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-2">Metadata</h4>
 
        <pre class="text-xs text-text-secondary bg-surface-secondary rounded-md p-3 overflow-x-auto"><%= JSON.pretty_generate(@observation.metadata) %></pre>
 </div>
 <% end %> 
    <div class="mt-6 pt-6 border-t border-border flex items-center gap-3"> <%= link_to"Back", management_ai_observations_path, class:"text-sm px-4 py-2 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> <% unless @observation.resolved? %> <%= button_to"Resolve", resolve_management_ai_observation_path(@observation), method: :post, class:"text-sm px-4 py-2 rounded-md bg-accent text-white hover:bg-accent-hover" %> <% end %> </div>
 </div>
 <% if @observation.recommendations.any? %> 
    <div class="mt-6 rounded-lg border border-border bg-surface p-6"> 
      <h3 class="text-sm font-semibold text-text-primary mb-4">Related Recommendations</h3>
 
      <div class="space-y-3"> <% @observation.recommendations.each do |rec| %> 
          <div class="flex items-center justify-between p-3 rounded-md bg-surface-secondary"> 
            <div> 
              <p class="text-sm font-medium text-text-primary"><%= rec.title %></p>
 
              <p class="text-xs text-text-tertiary"><%= rec.priority.titleize %> Priority · <%= rec.status.titleize %></p>
 </div>
 <%= link_to"View", management_ai_recommendation_path(rec), class:"text-xs px-3 py-1 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> </div>
 <% end %> </div>
 </div>
 <% end %> </div>
 
