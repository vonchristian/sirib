<% content_for :page_title,"AI Observations" %> <% content_for :page_subtitle, @branch.name %> <%= form_tag management_ai_observations_path, method: :get, data: { turbo_frame:"observations-list", controller:"filter-form", action:"change->filter-form#submit" } do %> <div class="flex items-center gap-4 mb-6"> <div> <%= label_tag :category,"Category", class:"block text-xs font-medium text-text-tertiary mb-1" %> <%= select_tag :category, options_for_select(::Ai::Observation.distinct.pluck(:category).map { |c| [c.titleize, c] }, params[:category]), include_blank:"All Categories", class:"text-sm rounded-md border border-border bg-surface px-3 py-1.5 text-text-primary" %> </div> <div> <%= label_tag :severity,"Severity", class:"block text-xs font-medium text-text-tertiary mb-1" %> <%= select_tag :severity, options_for_select(%w[critical high medium low].map { |s| [s.titleize, s] }, params[:severity]), include_blank:"All Severities", class:"text-sm rounded-md border border-border bg-surface px-3 py-1.5 text-text-primary" %> </div> <div> <%= label_tag :status,"Status", class:"block text-xs font-medium text-text-tertiary mb-1" %> <%= select_tag :status, options_for_select([["Unresolved","unresolved"], ["Resolved","resolved"]], params[:status]), include_blank:"All Statuses", class:"text-sm rounded-md border border-border bg-surface px-3 py-1.5 text-text-primary" %> </div> </div> <% end %> <%= turbo_frame_tag"observations-list" do %> <div class="rounded-lg border border-border bg-surface"> <div class="divide-y divide-border"> <% @observations.each do |obs| %> <div class="px-5 py-4"> <div class="flex items-start justify-between"> <div class="flex-1 min-w-0"> <div class="flex items-center gap-2 mb-1"> <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full <%= obs.severity == 'critical' ? 'bg-danger/10 text-danger' : obs.severity == 'high' ? 'bg-warning/10 text-warning' : obs.severity == 'medium' ? 'bg-info/10 text-info' : 'bg-surface-secondary text-text-tertiary' %>"> <%= obs.severity.titleize %> </span> <span class="text-xs text-text-tertiary"><%= obs.category.titleize %></span> <% if obs.resolved? %> <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full bg-positive/10 text-positive">Resolved</span> <% end %> </div> <p class="text-sm font-medium text-text-primary"><%= obs.title %></p> <p class="text-xs text-text-tertiary mt-1"><%= obs.summary %></p> <div class="flex items-center gap-4 mt-2 text-xs text-text-tertiary"> <span>Detected: <%= time_ago_in_words(obs.detected_at) %> ago</span> <% if obs.resolved? %> <span>Resolved: <%= time_ago_in_words(obs.resolved_at) %> ago</span> <% end %> </div> </div> <div class="flex items-center gap-2 ml-4 shrink-0"> <%= link_to"View", management_ai_observation_path(obs), data: { turbo_frame:"_top" }, class:"text-xs px-3 py-1 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> <% unless obs.resolved? %> <%= button_to"Resolve", resolve_management_ai_observation_path(obs), method: :post, class:"text-xs px-3 py-1 rounded-md bg-accent text-white hover:bg-accent-hover" %> <% end %> </div> </div> </div> <% end %> <% if @observations.empty? %> <p class="px-5 py-8 text-sm text-text-tertiary text-center">No observations found.</p> <% end %> </div> </div> <% if defined?(@pagy) && @pagy.pages > 1 %> <div class="mt-4"> <%== pagy_nav(@pagy) %> </div> <% end %> <% end %> 