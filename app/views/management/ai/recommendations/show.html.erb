<% content_for :page_title,"Recommendation Details" %> <% content_for :page_subtitle, @recommendation.title %> <div class="max-w-2xl"> <div class="rounded-lg border border-border bg-surface p-6"> <div class="flex items-center gap-2 mb-4"> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full <%= @recommendation.priority == 'critical' ? 'bg-danger/10 text-danger' : @recommendation.priority == 'high' ? 'bg-warning/10 text-warning' : 'bg-info/10 text-info' %>"> <%= @recommendation.priority.titleize %> </span> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full <%= @recommendation.status == 'completed' ? 'bg-positive/10 text-positive' : @recommendation.status == 'dismissed' ? 'bg-surface-secondary text-text-tertiary' : 'bg-warning/10 text-warning' %>"> <%= @recommendation.status.titleize %> </span> <% if @recommendation.confidence_score > 0 %> <span class="inline-flex items-center px-2.5 py-1 text-xs font-medium rounded-full bg-surface-secondary text-text-tertiary"> <%= (@recommendation.confidence_score * 100).to_i %>% confidence </span> <% end %> </div> <h3 class="text-lg font-semibold text-text-primary mb-2"><%= @recommendation.title %></h3> <p class="text-sm text-text-secondary mb-4"><%= @recommendation.summary %></p> <% if @recommendation.action_text.present? %> <div class="mb-6 p-4 rounded-md bg-surface-secondary"> <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-1">Suggested Action</p> <p class="text-sm text-text-primary"><%= @recommendation.action_text %></p> </div> <% end %> <div class="grid grid-cols-2 gap-4 text-sm"> <div> <p class="text-xs text-text-tertiary">Branch</p> <p class="text-text-primary"><%= @recommendation.branch.name %></p> </div> <div> <p class="text-xs text-text-tertiary">Created At</p> <p class="text-text-primary"><%= @recommendation.created_at.to_fs(:long) %></p> </div> <% if @recommendation.acknowledged_at %> <div> <p class="text-xs text-text-tertiary">Acknowledged At</p> <p class="text-text-primary"><%= @recommendation.acknowledged_at.to_fs(:long) %></p> </div> <% end %> <% if @recommendation.completed_at %> <div> <p class="text-xs text-text-tertiary">Completed At</p> <p class="text-text-primary"><%= @recommendation.completed_at.to_fs(:long) %></p> </div> <% end %> </div> <% if @recommendation.observation %> <div class="mt-6 pt-6 border-t border-border"> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-2">Source Observation</h4> <div class="p-3 rounded-md bg-surface-secondary"> <p class="text-sm font-medium text-text-primary"><%= @recommendation.observation.title %></p> <p class="text-xs text-text-tertiary mt-1"><%= @recommendation.observation.summary %></p> <%= link_to"View Observation", management_ai_observation_path(@recommendation.observation), class:"text-xs text-accent hover:text-accent-hover mt-2 inline-block" %> </div> </div> <% end %> <div class="mt-6 pt-6 border-t border-border flex items-center gap-3"> <%= link_to"Back", management_ai_recommendations_path, class:"text-sm px-4 py-2 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> <% if @recommendation.active? %> <%= button_to"Acknowledge", acknowledge_management_ai_recommendation_path(@recommendation), method: :post, class:"text-sm px-4 py-2 rounded-md bg-accent text-white hover:bg-accent-hover" %> <%= button_to"Mark Complete", complete_management_ai_recommendation_path(@recommendation), method: :post, class:"text-sm px-4 py-2 rounded-md bg-positive text-white hover:bg-positive-hover" %> <%= button_to"Dismiss", dismiss_management_ai_recommendation_path(@recommendation), method: :post, class:"text-sm px-4 py-2 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> <% end %> </div> </div> </div> 