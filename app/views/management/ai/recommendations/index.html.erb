<% content_for :page_title,"AI Recommendations" %> <% content_for :page_subtitle, @branch.name %> <%= form_tag management_ai_recommendations_path, method: :get, data: { turbo_frame:"recommendations-list", controller:"filter-form", action:"change->filter-form#submit" } do %> 
  <div class="flex items-center gap-4 mb-6"> 
    <div> <%= label_tag :priority,"Priority", class:"block text-xs font-medium text-text-tertiary mb-1" %> <%= select_tag :priority, options_for_select(%w[critical high medium low].map { |s| [s.titleize, s] }, params[:priority]), include_blank:"All Priorities", class:"text-sm rounded-md border border-border bg-surface px-3 py-1.5 text-text-primary" %> </div>
 
    <div> <%= label_tag :status,"Status", class:"block text-xs font-medium text-text-tertiary mb-1" %> <%= select_tag :status, options_for_select(%w[open acknowledged dismissed completed].map { |s| [s.titleize, s] }, params[:status]), include_blank:"All Statuses", class:"text-sm rounded-md border border-border bg-surface px-3 py-1.5 text-text-primary" %> </div>
 </div>
 <% end %> <%= turbo_frame_tag"recommendations-list" do %> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="divide-y divide-border"> <% @recommendations.each do |rec| %> 
        <div class="px-5 py-4"> 
          <div class="flex items-start justify-between"> 
            <div class="flex-1 min-w-0"> 
              <div class="flex items-center gap-2 mb-1"> <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full <%= rec.priority == 'critical' ? 'bg-danger/10 text-danger' : rec.priority == 'high' ? 'bg-warning/10 text-warning' : 'bg-info/10 text-info' %>"> <%= rec.priority.titleize %> </span> <span class="inline-flex items-center px-2 py-0.5 text-xs font-medium rounded-full <%= rec.status == 'open' ? 'bg-info/10 text-info' : rec.status == 'acknowledged' ? 'bg-warning/10 text-warning' : rec.status == 'completed' ? 'bg-positive/10 text-positive' : 'bg-surface-secondary text-text-tertiary' %>"> <%= rec.status.titleize %> </span> <% if rec.confidence_score > 0 %> <span class="text-xs text-text-tertiary"><%= (rec.confidence_score * 100).to_i %>% confidence</span> <% end %> </div>
 
              <p class="text-sm font-medium text-text-primary"><%= rec.title %></p>
 
              <p class="text-xs text-text-tertiary mt-1"><%= rec.summary %></p>
 <% if rec.action_text.present? %> 
                <p class="text-xs text-accent mt-1"><%= rec.action_text %></p>
 <% end %> </div>
 
            <div class="flex items-center gap-2 ml-4 shrink-0"> <%= link_to"View", management_ai_recommendation_path(rec), data: { turbo_frame:"_top" }, class:"text-xs px-3 py-1 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> <% if rec.active? %> <%= button_to"Acknowledge", acknowledge_management_ai_recommendation_path(rec), method: :post, class:"text-xs px-3 py-1 rounded-md bg-accent text-white hover:bg-accent-hover" %> <%= button_to"Dismiss", dismiss_management_ai_recommendation_path(rec), method: :post, class:"text-xs px-3 py-1 rounded-md border border-border text-text-tertiary hover:text-text-primary" %> <% end %> </div>
 </div>
 </div>
 <% end %> <% if @recommendations.empty? %> 
        <p class="px-5 py-8 text-sm text-text-tertiary text-center">No recommendations found.</p>
 <% end %> </div>
 </div>
 <%= render "shared/pagination", pagy: @pagy if defined?(@pagy) && @pagy.pages > 1 %> <% end %> 
