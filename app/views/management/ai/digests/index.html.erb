<% content_for :page_title,"AI Daily Digests" %> <% content_for :page_subtitle, @branch.name %> <div class="space-y-4"> <% @digests.each do |digest| %> <div class="rounded-lg border border-border bg-surface p-5"> <div class="flex items-start justify-between mb-3"> <div> <h3 class="text-sm font-semibold text-text-primary">Digest — <%= digest.generated_at.to_date.to_fs(:long) %></h3> <p class="text-xs text-text-tertiary">Generated <%= time_ago_in_words(digest.generated_at) %> ago</p> </div> <div class="flex items-center gap-3 text-xs text-text-tertiary"> <span><%= digest.observation_count %> observations</span> <span><%= digest.recommendation_count %> recommendations</span> <%= link_to"View", management_ai_digest_path(digest), class:"text-accent hover:text-accent-hover" %> </div> </div> <pre class="text-sm text-text-secondary whitespace-pre-wrap font-sans"><%= truncate(digest.summary, length: 300) %></pre> </div> <% end %> <% if @digests.empty? %> <div class="rounded-lg border border-border bg-surface p-8 text-center"> <p class="text-sm text-text-tertiary">No digests generated yet. The daily digest is generated at 6:00 AM.</p> </div> <% end %> <% if defined?(@pagy) && @pagy.pages > 1 %> <div class="mt-4"> <%== pagy_nav(@pagy) %> </div> <% end %> </div> 