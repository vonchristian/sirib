<% content_for :page_title, page_title %> <% content_for :page_subtitle, page_subtitle %> <%= form_with model: holiday, class: "space-y-4" do |f| %> <% if holiday.errors.any? %> 
    <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> 
      <ul class="list-inside list-disc"> <% holiday.errors.each do |error| %> 
          <li><%= error.full_message %></li>
 <% end %> </ul>
 </div>
 <% end %> 
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"> 
    <div> <%= f.label :date, class: "block text-xs font-medium text-text-secondary mb-1" %> <%= f.date_field :date, class: "w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
    <div> <%= f.label :name, class: "block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :name, class: "w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 
  <div class="flex items-center gap-2"> <%= f.check_box :recurring, class: "rounded border-border bg-surface text-primary focus:ring-primary outline-none" %> <%= f.label :recurring, "Recurring (every year)", class: "text-sm text-text-secondary" %> </div>
 
  <div class="flex items-center gap-3 pt-2"> <%= f.submit class: "rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <%= link_to "Cancel", management_holidays_path, class: "text-xs text-text-secondary hover:text-primary transition-colors" %> </div>
 <% end %>
