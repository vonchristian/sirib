<% content_for :page_title, @holiday.name %> <% content_for :page_subtitle, "Holiday details" %> <div class="flex items-center justify-end gap-2 mb-6"> <%= link_to "Edit", edit_management_holiday_path(@holiday), class: "rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <%= button_to "Delete", management_holiday_path(@holiday), method: :delete, class: "rounded-md border border-danger/30 bg-surface px-4 py-2 text-xs font-semibold text-danger hover:bg-danger-50 transition-colors", data: { turbo_confirm: "Are you sure you want to delete this holiday?" } %> <%= link_to "Back", management_holidays_path, class: "rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Details</h3> </div> <div class="p-5 space-y-3"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Date</span> <span class="text-sm font-medium text-text-primary"><%= l(@holiday.date, format: :long) %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Name</span> <span class="text-sm text-text-primary"><%= @holiday.name %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Type</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @holiday.recurring? ? 'bg-primary-50 text-primary' : 'bg-surface-alt text-text-tertiary' %>"> <%= @holiday.recurring? ? "Recurring (every year)" : "One-off" %> </span> </div> </div> </div> </div>
