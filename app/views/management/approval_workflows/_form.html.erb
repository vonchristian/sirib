<%= form_with model: workflow, class:"space-y-4" do |f| %> <% if workflow.errors.any? %> 
    <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> 
      <ul class="list-inside list-disc"> <% workflow.errors.each do |error| %> 
          <li><%= error.full_message %></li>
 <% end %> </ul>
 </div>
 <% end %> 
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"> 
    <div> <%= f.label :name, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :name, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
    <div> <%= f.label :code, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :code, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 
  <div> <%= f.label :category, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :category, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div> <%= f.label :description, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_area :description, rows: 3, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div> 
    <p class="block text-xs font-medium text-text-secondary mb-2">Approval Steps</p>
 
    <div id="workflow-steps"> <%= f.fields_for :steps do |sf| %> 
        <div class="border border-border rounded-md p-3 mb-2 bg-surface"> 
          <div class="grid grid-cols-2 sm:grid-cols-4 gap-2"> 
            <div> <%= sf.label :sequence, class:"block text-xs text-text-tertiary mb-0.5" %> <%= sf.number_field :sequence, class:"w-full rounded-md border border-border bg-surface py-1.5 px-2 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
            <div> <%= sf.label :approver_role_id,"Role", class:"block text-xs text-text-tertiary mb-0.5" %> <%= sf.collection_select :approver_role_id, Management::Role.by_rank, :id, :name, { include_blank:"Any" }, class:"w-full rounded-md border border-border bg-surface py-1.5 px-2 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
            <div> <%= sf.label :threshold_cents_min,"Min (cents)", class:"block text-xs text-text-tertiary mb-0.5" %> <%= sf.number_field :threshold_cents_min, class:"w-full rounded-md border border-border bg-surface py-1.5 px-2 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
            <div> <%= sf.label :threshold_cents_max,"Max (cents)", class:"block text-xs text-text-tertiary mb-0.5" %> <%= sf.number_field :threshold_cents_max, class:"w-full rounded-md border border-border bg-surface py-1.5 px-2 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 <% if sf.object.persisted? %> 
            <div class="mt-2"> <%= sf.check_box :_destroy, class:"rounded border-border text-primary focus:ring-primary" %> <%= sf.label :_destroy,"Remove", class:"text-xs text-text-tertiary" %> </div>
 <% end %> </div>
 <% end %> </div>
 </div>
 
  <div class="flex items-center gap-3 pt-2"> <%= f.submit class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <%= link_to"Cancel", management_approval_workflows_path, class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </div>
 <% end %> 
