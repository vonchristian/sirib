<% content_for :page_title, @workflow.name %> <% content_for :page_subtitle,"Workflow ##{@workflow.code}" %> 
<div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Edit", edit_management_approval_workflow_path(@workflow), class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <%= link_to"Back", management_approval_workflows_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div>
 
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Details</h3>
 </div>
 
    <div class="p-5 space-y-3"> 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Name</span> <span class="text-sm font-medium text-text-primary"><%= @workflow.name %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Code</span> <span class="text-sm text-text-primary"><%= @workflow.code %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Category</span> <span class="text-sm text-text-primary"><%= @workflow.category %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Description</span> <span class="text-sm text-text-primary"><%= @workflow.description ||"—" %></span> </div>
 </div>
 
    <div class="border-t border-border px-5 py-4"> 
      <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Steps</h4>
 
      <div class="space-y-2"> <% @workflow.steps.each do |step| %> 
          <div class="flex items-center gap-3 rounded-md border border-border bg-surface-alt px-4 py-2.5"> <span class="flex h-6 w-6 items-center justify-center rounded-full bg-primary text-xs font-semibold text-white"><%= step.sequence %></span> 
            <div class="flex-1"> 
              <p class="text-sm text-text-primary"><%= step.approver_role&.name || step.approver_user&.email_address ||"Any" %></p>
 
              <p class="text-xs text-text-tertiary">Sequence <%= step.sequence %></p>
 </div>
 </div>
 <% end %> <% if @workflow.steps.empty? %> 
          <p class="text-sm text-text-tertiary">No steps defined.</p>
 <% end %> </div>
 </div>
 </div>
 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4 flex items-center justify-between"> 
      <h3 class="text-sm font-semibold text-text-primary">Pending Requests</h3>
 <%= link_to"View All", management_approval_workflow_approval_requests_path(@workflow), class:"text-xs text-primary hover:text-primary-700 transition-colors" %> </div>
 
    <div class="divide-y divide-border"> <% @pending_requests.each do |req| %> 
        <div class="flex items-center justify-between px-5 py-3"> 
          <div> 
            <p class="text-sm text-text-primary">#<%= req.id %></p>
 
            <p class="text-xs text-text-tertiary">by <%= req.requested_by.email_address %></p>
 </div>
 <span class="text-xs text-text-tertiary"><%= time_ago_in_words(req.created_at) %> ago</span> </div>
 <% end %> <% if @pending_requests.empty? %> 
        <p class="px-5 py-4 text-sm text-text-tertiary">No pending requests.</p>
 <% end %> </div>
 </div>
 </div>
 
