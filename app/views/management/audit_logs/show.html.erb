<% content_for :page_title, "Audit Log ##{@audit_log.id}" %>
<% content_for :page_subtitle, "Detailed audit record" %>

<div class="flex items-center justify-end gap-2 mb-6">
  <%= link_to "Back", management_audit_logs_path, class: "rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %>
</div>

<div class="max-w-2xl">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Audit Record</h3>
    </div>
    <div class="p-5 space-y-3">
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Action</span>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-surface-alt text-text-secondary"><%= @audit_log.action %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Actor</span>
        <span class="text-sm text-text-primary"><%= @audit_log.actor&.email_address || "System" %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Actor IP</span>
        <span class="text-sm text-text-primary"><%= @audit_log.ip_address || "—" %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Subject</span>
        <span class="text-sm text-text-primary"><%= @audit_log.auditable_type %> #<%= @audit_log.auditable_id %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Branch</span>
        <span class="text-sm text-text-primary"><%= @audit_log.branch&.name || "—" %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Timestamp</span>
        <span class="text-sm text-text-primary"><%= @audit_log.created_at.strftime("%b %d, %Y %H:%M:%S") %></span>
      </div>
      <% if @audit_log.changes.present? %>
        <div class="border-t border-border pt-3 mt-3 dark:border-gray-800">
          <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-2">Changes</p>
          <pre class="text-xs text-text-secondary bg-surface-alt rounded-md p-3 overflow-x-auto"><%= JSON.pretty_generate(@audit_log.changes) %></pre>
        </div>
      <% end %>
    </div>
  </div>
</div>
