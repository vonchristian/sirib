<% content_for :page_title, @user.email_address %>
<% content_for :page_subtitle, "User details and role assignments" %>

<div class="flex items-center justify-end gap-2 mb-6">
  <%= link_to "Edit", edit_management_user_path(@user), class: "rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %>
  <%= link_to "Back", management_users_path, class: "rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Account Details</h3>
    </div>
    <div class="p-5 space-y-3">
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Employee ID</span>
        <span class="text-sm font-medium font-mono text-text-primary"><%= @user.employee_id %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Full Name</span>
        <span class="text-sm font-medium text-text-primary"><%= @user.full_name %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Status</span>
        <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @user.status_active? ? "bg-green-50 text-green-700" : "bg-red-50 text-red-700" %>"><%= @user.status.titleize %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Email</span>
        <span class="text-sm font-medium text-text-primary"><%= @user.email_address %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Role</span>
        <span class="inline-flex items-center rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700"><%= @user.role.titleize %></span>
      </div>
    </div>
  </div>

  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 flex items-center justify-between dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Role Assignments</h3>
      <%= link_to "Assign Role", new_management_user_role_assignment_path(@user), class: "rounded-md bg-primary px-3 py-1.5 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %>
    </div>
    <div class="divide-y divide-border dark:divide-gray-800">
      <% @role_assignments.each do |ra| %>
        <div class="flex items-center justify-between px-5 py-3">
          <div>
            <p class="text-sm text-text-primary"><%= ra.role.name %></p>
            <p class="text-xs text-text-tertiary"><%= ra.branch&.name || "All Branches" %></p>
          </div>
          <div class="flex items-center gap-2">
            <span class="text-xs text-text-tertiary"><%= ra.active_from.strftime("%b %d, %Y") %></span>
            <%= button_to "Remove", management_user_role_assignment_path(@user, ra), method: :delete, class: "text-xs text-danger hover:text-danger-700 transition-colors", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
      <% end %>
      <% if @role_assignments.empty? %>
        <p class="px-5 py-4 text-sm text-text-tertiary">No role assignments.</p>
      <% end %>
    </div>
  </div>
</div>
