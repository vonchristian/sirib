<% content_for :page_title,"Branches" %> <% content_for :page_subtitle,"Manage organizational branches" %> 
<div class="flex items-center justify-between mb-6"> 
  <div> <%= form_tag management_branches_path, method: :get, class:"flex items-center gap-2" do %> <%= text_field_tag :search, params[:search], placeholder:"Search by name or code...", class:"rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none w-60" %> <%= submit_tag"Search", class:"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <% end %> </div>
 <%= link_to"New Branch", new_management_branch_path, class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> </div>
 
<div class="rounded-lg border border-border bg-surface overflow-hidden"> 
  <table class="w-full text-sm"> 
    <thead> 
      <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> 
        <th class="px-5 py-3 font-medium">Name</th>
 
        <th class="px-5 py-3 font-medium">Code</th>
 
        <th class="px-5 py-3 font-medium">Status</th>
 
        <th class="px-5 py-3 font-medium">Departments</th>
 
        <th class="px-5 py-3 font-medium text-right">Actions</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% @branches.each do |branch| %> 
        <tr class="hover:bg-surface-alt transition-colors"> 
          <td class="px-5 py-3"> <%= link_to branch.name, management_branch_path(branch), class:"font-medium text-text-primary hover:text-primary transition-colors" %> </td>
 
          <td class="px-5 py-3 text-text-secondary"><%= branch.code %></td>
 
          <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= branch.active? ? 'bg-positive-50 text-positive' : 'bg-surface-alt text-text-tertiary' %>"> <%= branch.status.titleize %> </span> </td>
 
          <td class="px-5 py-3 text-text-secondary"><%= branch.departments.count %></td>
 
          <td class="px-5 py-3 text-right"> <%= link_to"Edit", edit_management_branch_path(branch), class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </td>
 </tr>
 <% end %> <% if @branches.empty? %> 
        <tr>
          <td colspan="5" class="px-5 py-8 text-center text-text-tertiary">No branches found.</td>
        </tr>
 <% end %> </tbody>
 </table>
 </div>
 
<div class="mt-4"> <%= render"shared/pagination", pagy: @pagy if defined?(@pagy) %> </div>
 
