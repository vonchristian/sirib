<%= form_with model: branch, class:"space-y-4" do |f| %> <% if branch.errors.any? %> 
    <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> 
      <ul class="list-inside list-disc"> <% branch.errors.each do |error| %> 
          <li><%= error.full_message %></li>
 <% end %> </ul>
 </div>
 <% end %> 
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"> 
    <div> <%= f.label :name, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :name, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
    <div> <%= f.label :code, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :code, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 
  <div> <%= f.label :parent_id,"Parent Branch", class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.collection_select :parent_id, Management::Branch.active.by_name, :id, :name, { include_blank:"None" }, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div> <%= f.label :address, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_area :address, rows: 2, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"> 
    <div> <%= f.label :phone, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.telephone_field :phone, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
    <div> <%= f.label :email, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.email_field :email, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 
  <div> <%= f.label :status, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.select :status, Management::Branch.statuses.keys.map { |s| [s.titleize, s] }, {}, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div class="flex items-center gap-3 pt-2"> <%= f.submit class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <%= link_to"Cancel", management_branches_path, class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </div>
 <% end %> 
