<% content_for :page_title, @alert.title %> <% content_for :page_subtitle,"Alert details" %> <div class="flex items-center justify-end gap-2 mb-6"> <% if @alert.active? %> <%= button_to"Resolve", resolve_management_alert_path(@alert), method: :post, class:"rounded-md bg-positive px-4 py-2 text-xs font-semibold text-white hover:bg-positive-700 transition-colors" %> <% end %> <%= link_to"Back", management_alerts_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="max-w-2xl"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Alert Information</h3> </div> <div class="p-5 space-y-3"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Title</span> <span class="text-sm font-medium text-text-primary"><%= @alert.title %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Type</span> <span class="text-sm text-text-primary"><%= @alert.alert_type.humanize %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Severity</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @alert.critical? ? 'bg-danger-50 text-danger' : @alert.warning? ? 'bg-warning-50 text-warning' : 'bg-primary-50 text-primary' %>"> <%= @alert.severity.titleize %> </span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @alert.active? ? 'bg-warning-50 text-warning' : 'bg-positive-50 text-positive' %>"> <%= @alert.status.titleize %> </span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Created</span> <span class="text-sm text-text-primary"><%= @alert.created_at.strftime("%b %d, %Y %H:%M") %></span> </div> <% if @alert.resolved? %> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Resolved By</span> <span class="text-sm text-text-primary"><%= @alert.resolved_by&.email_address ||"—" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Resolved At</span> <span class="text-sm text-text-primary"><%= @alert.resolved_at&.strftime("%b %d, %Y %H:%M") ||"—" %></span> </div> <% end %> </div> </div> </div> 