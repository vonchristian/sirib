<% content_for :page_title, "Roles" %>
<% content_for :page_subtitle, "Manage roles and permissions" %>

<div class="flex items-center justify-end mb-6">
  <%= link_to "New Role", new_management_role_path, class: "rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %>
</div>

<div class="rounded-lg border border-border bg-surface dark:border-gray-800 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-border dark:border-gray-800 text-left text-xs text-text-tertiary uppercase tracking-wider">
        <th class="px-5 py-3 font-medium">Name</th>
        <th class="px-5 py-3 font-medium">Code</th>
        <th class="px-5 py-3 font-medium">Rank</th>
        <th class="px-5 py-3 font-medium">Permissions</th>
        <th class="px-5 py-3 font-medium text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-border dark:divide-gray-800">
      <% @roles.each do |role| %>
        <tr class="hover:bg-surface-alt transition-colors">
          <td class="px-5 py-3">
            <%= link_to role.name, management_role_path(role), class: "font-medium text-text-primary hover:text-primary transition-colors" %>
          </td>
          <td class="px-5 py-3 text-text-secondary"><%= role.code %></td>
          <td class="px-5 py-3 text-text-secondary"><%= role.rank %></td>
          <td class="px-5 py-3 text-text-secondary"><%= role.permissions.count %></td>
          <td class="px-5 py-3 text-right">
            <%= link_to "Edit", edit_management_role_path(role), class: "text-xs text-text-secondary hover:text-primary transition-colors" %>
          </td>
        </tr>
      <% end %>
      <% if @roles.empty? %>
        <tr><td colspan="5" class="px-5 py-8 text-center text-text-tertiary">No roles found.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%= render "shared/pagination", pagy: @pagy if defined?(@pagy) %>
</div>
