<% content_for :page_title, @role.name %>
<% content_for :page_subtitle, "Role ##{@role.code}" %>

<div class="flex items-center justify-end gap-2 mb-6">
  <%= link_to "Edit", edit_management_role_path(@role), class: "rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %>
  <%= link_to "Back", management_roles_path, class: "rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Details</h3>
    </div>
    <div class="p-5 space-y-3">
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Name</span>
        <span class="text-sm font-medium text-text-primary"><%= @role.name %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Code</span>
        <span class="text-sm text-text-primary"><%= @role.code %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Rank</span>
        <span class="text-sm text-text-primary"><%= @role.rank %></span>
      </div>
      <div class="flex justify-between">
        <span class="text-sm text-text-tertiary">Description</span>
        <span class="text-sm text-text-primary"><%= @role.description || "—" %></span>
      </div>
    </div>
  </div>

  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Permissions</h3>
    </div>
    <div class="divide-y divide-border dark:divide-gray-800">
      <% @permissions.each do |perm| %>
        <div class="flex items-center justify-between px-5 py-3">
          <div>
            <p class="text-sm text-text-primary"><%= perm.action.titleize %> <%= perm.subject.titleize %></p>
            <p class="text-xs text-text-tertiary"><%= perm.subject %>#<%= perm.action %></p>
          </div>
          <svg class="h-4 w-4 text-positive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
        </div>
      <% end %>
      <% if @permissions.empty? %>
        <p class="px-5 py-4 text-sm text-text-tertiary">No permissions assigned.</p>
      <% end %>
    </div>
  </div>
</div>
