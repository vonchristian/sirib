<%= form_with model: role, class:"space-y-4" do |f| %> <% if role.errors.any? %> 
    <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> 
      <ul class="list-inside list-disc"> <% role.errors.each do |error| %> 
          <li><%= error.full_message %></li>
 <% end %> </ul>
 </div>
 <% end %> 
  <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"> 
    <div> <%= f.label :name, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :name, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
    <div> <%= f.label :code, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :code, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 
  <div> <%= f.label :rank, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.number_field :rank, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div> <%= f.label :description, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_area :description, rows: 3, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
  <div> 
    <p class="block text-xs font-medium text-text-secondary mb-2">Permissions</p>
 
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2 max-h-60 overflow-y-auto border border-border rounded-md p-3 bg-surface"> <%= f.collection_check_boxes :permission_ids, Management::Permission.order(:subject, :action), :id, ->(p) {"#{p.subject.titleize}: #{p.action.titleize}" } do |b| %> <label class="flex items-center gap-2 text-sm text-text-secondary hover:text-text-primary cursor-pointer"> <%= b.check_box class:"rounded border-border text-primary focus:ring-primary" %> <%= b.text %> </label> <% end %> </div>
 </div>
 
  <div class="flex items-center gap-3 pt-2"> <%= f.submit class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <%= link_to"Cancel", management_roles_path, class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </div>
 <% end %> 
