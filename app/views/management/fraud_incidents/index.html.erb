<% content_for :page_title,"Fraud Incidents" %> <% content_for :page_subtitle,"Detected suspicious activity" %> 
<div class="flex items-center gap-2 mb-6"> <%= form_tag management_fraud_incidents_path, method: :get, class:"flex items-center gap-2 flex-wrap" do %> <%= select_tag :severity, options_for_select([["Low","low"], ["Medium","medium"], ["High","high"], ["Critical","critical"]], params[:severity]), include_blank:"All Severities", class:"rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> <%= select_tag :status, options_for_select([["Unresolved","unresolved"], ["Resolved","resolved"]], params[:status]), include_blank:"All Statuses", class:"rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> <%= submit_tag"Filter", class:"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <% end %> </div>
 
<div class="rounded-lg border border-border bg-surface overflow-hidden"> 
  <table class="w-full text-sm"> 
    <thead> 
      <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> 
        <th class="px-5 py-3 font-medium">Timestamp</th>
 
        <th class="px-5 py-3 font-medium">Type</th>
 
        <th class="px-5 py-3 font-medium">Rule</th>
 
        <th class="px-5 py-3 font-medium">Severity</th>
 
        <th class="px-5 py-3 font-medium">Status</th>
 
        <th class="px-5 py-3 font-medium text-right">Actions</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% @incidents.each do |incident| %> 
        <tr class="hover:bg-surface-alt transition-colors"> 
          <td class="px-5 py-3 text-text-secondary whitespace-nowrap"><%= incident.created_at.strftime("%b %d %H:%M") %></td>
 
          <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-surface-alt text-text-secondary"><%= incident.incident_type.humanize %></span> </td>
 
          <td class="px-5 py-3 text-text-secondary"><%= incident.rule&.name ||"—" %></td>
 
          <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= incident.severity =="critical" ? "bg-red-50 text-red-700" : incident.severity =="high" ? "bg-orange-50 text-orange-700" : incident.severity =="medium" ? "bg-yellow-50 text-yellow-700" :"bg-primary-50 text-primary-700" %>"> <%= incident.severity.titleize %> </span> </td>
 
          <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= incident.resolved? ? "bg-green-50 text-green-700" :"bg-red-50 text-red-700" %>"> <%= incident.resolved? ? "Resolved" :"Unresolved" %> </span> </td>
 
          <td class="px-5 py-3 text-right"> <%= link_to"View", management_fraud_incident_path(incident), class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </td>
 </tr>
 <% end %> <% if @incidents.empty? %> 
        <tr>
          <td colspan="6" class="px-5 py-8 text-center text-text-tertiary">No fraud incidents found.</td>
        </tr>
 <% end %> </tbody>
 </table>
 </div>
 
<div class="mt-4"> <%= render"shared/pagination", pagy: @pagy if defined?(@pagy) %> </div>
 
