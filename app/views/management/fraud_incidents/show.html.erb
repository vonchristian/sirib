<% content_for :page_title,"Fraud Incident ##{@incident.id}" %> <% content_for :page_subtitle, @incident.description&.truncate(80) %> <div class="flex items-center justify-end gap-2 mb-6"> <% unless @incident.resolved? %> <%= button_to"Resolve", resolve_management_fraud_incident_path(@incident), method: :post, class:"rounded-md bg-positive px-4 py-2 text-xs font-semibold text-white hover:bg-positive-700 transition-colors" %> <% end %> <%= link_to"Back", management_fraud_incidents_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Incident Details</h3> </div> <div class="p-5 space-y-3"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Type</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-surface-alt text-text-secondary"><%= @incident.incident_type.humanize %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Severity</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @incident.severity =="critical" ? "bg-red-50 text-red-700" : @incident.severity =="high" ? "bg-orange-50 text-orange-700" : @incident.severity =="medium" ? "bg-yellow-50 text-yellow-700" :"bg-primary-50 text-primary-700" %>"> <%= @incident.severity.titleize %> </span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Rule</span> <span class="text-sm text-text-primary"><%= @incident.rule&.name ||"—" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @incident.resolved? ? "bg-green-50 text-green-700" :"bg-red-50 text-red-700" %>"> <%= @incident.resolved? ? "Resolved" :"Unresolved" %> </span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Actor</span> <span class="text-sm text-text-primary"><%= @incident.actor&.respond_to?(:email_address) ? @incident.actor.email_address : @incident.actor_id %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Timestamp</span> <span class="text-sm text-text-primary"><%= @incident.created_at.strftime("%b %d, %Y %H:%M:%S") %></span> </div> <% if @incident.resolved? %> <div class="border-t border-border pt-3 mt-3"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-2">Resolution</p> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Resolved By</span> <span class="text-sm text-text-primary"><%= @incident.resolved_by&.respond_to?(:email_address) ? @incident.resolved_by.email_address :"—" %></span> </div> <div class="flex justify-between mt-2"> <span class="text-sm text-text-tertiary">Resolved At</span> <span class="text-sm text-text-primary"><%= @incident.resolved_at&.strftime("%b %d, %Y %H:%M") ||"—" %></span> </div> <% if @incident.resolution.present? %> <div class="mt-2"> <span class="text-sm text-text-tertiary block mb-1">Resolution Note</span> <p class="text-sm text-text-primary bg-surface-alt rounded-md p-3"><%= @incident.resolution %></p> </div> <% end %> </div> <% end %> </div> </div> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Metadata</h3> </div> <div class="p-5"> <% if @incident.metadata.present? %> <pre class="text-xs text-text-secondary bg-surface-alt rounded-md p-3 overflow-x-auto"><%= JSON.pretty_generate(@incident.metadata) %></pre> <% else %> <p class="text-sm text-text-tertiary">No metadata available.</p> <% end %> </div> </div> </div> 