<% content_for :page_title,"Assign Role" %> <% content_for :page_subtitle,"Assign role to #{@user.email_address}" %> 
<div class="max-w-2xl mx-auto"> 
  <div class="rounded-lg border border-border bg-surface p-6"> <%= form_with model: [:management, @user, @role_assignment], class:"space-y-4" do |f| %> 
      <div> <%= f.label :role_id, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.collection_select :role_id, Management::Role.by_rank, :id, :name, { include_blank:"Select Role" }, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
      <div> <%= f.label :branch_id, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.collection_select :branch_id, Management::Branch.active.by_name, :id, :name, { include_blank:"All Branches" }, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
      <div> <%= f.label :department_id, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.collection_select :department_id, Management::Department.by_name, :id, :name, { include_blank:"All Departments" }, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4"> 
        <div> <%= f.label :active_from, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.date_field :active_from, value: Date.current, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
        <div> <%= f.label :active_until, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.date_field :active_until, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 
      <div class="flex items-center gap-3 pt-2"> <%= f.submit class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <%= link_to"Cancel", management_user_path(@user), class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </div>
 <% end %> </div>
 </div>
 
