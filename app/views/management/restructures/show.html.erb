<% content_for :page_title, "Restructure Case ##{@case.id}" %>
<% content_for :page_subtitle, "Management review" %>

<div class="animate-fade-in max-w-5xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold text-text-primary dark:text-white">Case ##{@case.id}</h2>
      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium capitalize
        <%= case @case.status
        when 'draft' then 'bg-gray-100 text-text-tertiary'
        when 'submitted', 'under_review' then 'bg-amber-50 text-amber-500'
        when 'approved' then 'bg-primary-50 text-primary'
        when 'rejected' then 'bg-danger-50 text-danger'
        when 'executed' then 'bg-positive-50 text-positive'
        end %>">
        <%= @case.status %>
      </span>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "All Cases", management_restructures_path, class: "btn-ghost text-sm" %>
      <%= link_to "Loan ##{@loan.reference_number}", loans_loan_path(@loan), class: "btn-ghost text-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
        <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Case Details</h3>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Loan</dt>
            <dd class="mt-1 text-sm font-medium text-text-primary"><%= @loan.reference_number %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Member</dt>
            <dd class="mt-1 text-sm text-text-primary"><%= @loan.member.name %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Type</dt>
            <dd class="mt-1 text-sm capitalize text-text-primary"><%= @case.restructure_type %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Status</dt>
            <dd class="mt-1 text-sm capitalize text-text-primary"><%= @case.status %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Requested By</dt>
            <dd class="mt-1 text-sm text-text-primary"><%= @case.requested_by&.email_address || "System" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Submitted</dt>
            <dd class="mt-1 text-sm text-text-primary"><%= @case.submitted_at&.strftime("%b %d, %Y %H:%M") || "Not yet" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Outstanding Balance</dt>
            <dd class="mt-1 text-sm font-medium text-text-primary"><%= number_to_currency(@loan.outstanding_principal_cents.to_f / 100, unit: "PHP ") %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Interest Rate</dt>
            <dd class="mt-1 text-sm text-text-primary"><%= @loan.interest_rate %>%</dd>
          </div>
        </dl>

        <% if @case.notes.present? %>
          <div class="mt-4 pt-4 border-t border-border dark:border-gray-700">
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-1">Notes</dt>
            <dd class="text-sm text-text-secondary"><%= @case.notes %></dd>
          </div>
        <% end %>
      </div>

      <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
        <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Proposed Changes</h3>
        <% if @case.proposed_changes.present? %>
          <dl class="grid grid-cols-2 gap-x-6 gap-y-3">
            <% @case.proposed_changes.each do |key, value| %>
              <div>
                <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider"><%= key.titleize %></dt>
                <dd class="mt-1 text-sm text-text-primary">
                  <% if key.include?("cents") || key.include?("amount") %>
                    <%= number_to_currency(value.to_f / 100, unit: "PHP ") %>
                  <% else %>
                    <%= value %>
                  <% end %>
                </dd>
              </div>
            <% end %>
          </dl>
        <% else %>
          <p class="text-sm text-text-tertiary italic">No proposed changes recorded.</p>
        <% end %>
      </div>

      <% if @events.any? %>
        <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
          <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Event History</h3>
          <div class="space-y-3">
            <% @events.each do |event| %>
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 mt-2 rounded-full
                  <%= event.event_type.include?('approved') ? 'bg-positive' : event.event_type.include?('rejected') ? 'bg-danger' : 'bg-text-tertiary' %>">
                </div>
                <div>
                  <p class="text-sm text-text-primary"><%= event.event_type.titleize %></p>
                  <p class="text-xs text-text-tertiary"><%= time_ago_in_words(event.created_at) %> ago</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <% if @case.submitted? || @case.under_review? %>
        <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-4">
          <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-3">Decision</h3>
          <div class="space-y-2">
            <%= button_to "Approve Restructure", approve_management_restructure_path(@case), method: :post,
              class: "btn-primary w-full text-sm",
              data: { turbo_confirm: "Approve this restructure case? This will allow execution." } %>
            <%= button_to "Reject Restructure", reject_management_restructure_path(@case), method: :post,
              class: "btn-danger w-full text-sm",
              data: { turbo_confirm: "Reject this restructure case?" } %>
          </div>
        </div>
      <% end %>

      <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-4">
        <h3 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Loan Summary</h3>
        <dl class="space-y-2">
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Reference</dt>
            <dd class="text-xs font-mono text-text-primary"><%= @loan.reference_number %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Principal</dt>
            <dd class="text-xs font-medium text-text-primary"><%= number_to_currency(@loan.principal_cents.to_f / 100, unit: "PHP ") %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Outstanding</dt>
            <dd class="text-xs font-medium text-text-primary"><%= number_to_currency(@loan.outstanding_principal_cents.to_f / 100, unit: "PHP ") %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Term</dt>
            <dd class="text-xs text-text-primary"><%= @loan.term_months %> months</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Rate</dt>
            <dd class="text-xs text-text-primary"><%= @loan.interest_rate %>%</dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Restructures</dt>
            <dd class="text-xs text-text-primary"><%= @loan.restructures_count %> / <%= @loan.max_restructures %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
