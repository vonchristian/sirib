<% content_for :page_title,"Restructure Cases" %> <% content_for :page_subtitle,"Management dashboard" %> <div class="animate-fade-in"> <div class="grid grid-cols-4 gap-4 mb-6"> <div class="rounded-xl border border-border bg-surface p-4"> <span class="text-xs text-text-tertiary uppercase tracking-wider">Pending</span> <p class="text-2xl font-bold text-amber-500 mt-1"><%= @pending_count %></p> </div> <div class="rounded-xl border border-border bg-surface p-4"> <span class="text-xs text-text-tertiary uppercase tracking-wider">Approved</span> <p class="text-2xl font-bold text-primary mt-1"><%= @approved_count %></p> </div> <div class="rounded-xl border border-border bg-surface p-4"> <span class="text-xs text-text-tertiary uppercase tracking-wider">Executed</span> <p class="text-2xl font-bold text-positive mt-1"><%= @executed_count %></p> </div> <div class="rounded-xl border border-border bg-surface p-4"> <span class="text-xs text-text-tertiary uppercase tracking-wider">Rejected</span> <p class="text-2xl font-bold text-danger mt-1"><%= @rejected_count %></p> </div> </div> <div class="mb-4 flex items-center gap-4"> <%= link_to"All", management_restructures_path, class:"text-xs font-medium #{params[:status].blank? ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %> <%= link_to"Pending", management_restructures_path(status:"submitted"), class:"text-xs font-medium #{params[:status] == 'submitted' ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %> <%= link_to"Under Review", management_restructures_path(status:"under_review"), class:"text-xs font-medium #{params[:status] == 'under_review' ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %> <%= link_to"Approved", management_restructures_path(status:"approved"), class:"text-xs font-medium #{params[:status] == 'approved' ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %> </div> <div class="rounded-lg border border-border bg-surface overflow-hidden"> <table class="min-w-full text-sm"> <thead> <tr class="border-b border-border bg-surface-alt"> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Case</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Loan</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Member</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Type</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Status</th> <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Amount</th> <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Date</th> <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Actions</th> </tr> </thead> <tbody class="divide-y divide-border"> <% if @cases.any? %> <% @cases.each do |c| %> <tr class="hover:bg-surface-alt /30 transition-colors"> <td class="px-4 py-3 font-mono text-xs">#<%= c.id %></td> <td class="px-4 py-3 font-medium text-text-primary"><%= c.loan.reference_number %></td> <td class="px-4 py-3 text-text-secondary"><%= c.loan.member.name %></td> <td class="px-4 py-3"> <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize <%= c.modification? ? 'bg-primary-50 text-primary' : c.refinance? ? 'bg-positive-50 text-positive' : 'bg-purple-50 text-purple-500' %>"> <%= c.restructure_type %> </span> </td> <td class="px-4 py-3"> <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize <%= case c.status when 'draft' then 'bg-surface-alt text-text-tertiary' when 'submitted', 'under_review' then 'bg-amber-50 text-amber-500' when 'approved' then 'bg-primary-50 text-primary' when 'rejected' then 'bg-danger-50 text-danger' when 'executed' then 'bg-positive-50 text-positive' else 'bg-surface-alt text-text-tertiary' end %>"> <%= c.status %> </span> </td> <td class="px-4 py-3 text-right text-text-secondary"><%= number_to_currency(c.loan.outstanding_principal_cents.to_f / 100, unit:"PHP") %></td> <td class="px-4 py-3 text-right text-text-tertiary"><%= c.created_at.strftime("%b %d, %Y") %></td> <td class="px-4 py-3 text-right"> <%= link_to"View", management_restructure_path(c), class:"text-sm font-medium text-primary hover:text-primary-700" %> </td> </tr> <% end %> <% else %> <tr> <td colspan="8" class="px-4 py-12 text-center text-sm text-text-tertiary">No restructure cases found.</td> </tr> <% end %> </tbody> </table> </div> <% if defined?(@pagy) && @pagy.present? && @pagy.pages > 1 %> <div class="mt-4"><%== pagy_nav(@pagy) %></div> <% end %> </div> 