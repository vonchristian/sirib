<% content_for :page_title,"Departments" %> <% content_for :page_subtitle,"Manage departments per branch" %> 
<div class="flex items-center justify-between mb-6"> 
  <div class="flex items-center gap-2"> <%= form_tag management_departments_path, method: :get, class:"flex items-center gap-2" do %> <%= select_tag :branch_id, options_from_collection_for_select(Management::Branch.active.by_name, :id, :name, params[:branch_id]), include_blank:"All Branches", class:"rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> <%= submit_tag"Filter", class:"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <% end %> </div>
 <%= link_to"New Department", new_management_department_path, class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> </div>
 
<div class="rounded-lg border border-border bg-surface overflow-hidden"> 
  <table class="w-full text-sm"> 
    <thead> 
      <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> 
        <th class="px-5 py-3 font-medium">Name</th>
 
        <th class="px-5 py-3 font-medium">Code</th>
 
        <th class="px-5 py-3 font-medium">Branch</th>
 
        <th class="px-5 py-3 font-medium">Teams</th>
 
        <th class="px-5 py-3 font-medium text-right">Actions</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% @departments.each do |dept| %> 
        <tr class="hover:bg-surface-alt transition-colors"> 
          <td class="px-5 py-3 font-medium text-text-primary"><%= dept.name %></td>
 
          <td class="px-5 py-3 text-text-secondary"><%= dept.code %></td>
 
          <td class="px-5 py-3 text-text-secondary"><%= dept.branch.name %></td>
 
          <td class="px-5 py-3 text-text-secondary"><%= dept.teams.count %></td>
 
          <td class="px-5 py-3 text-right"> <%= link_to"Edit", edit_management_department_path(dept), class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </td>
 </tr>
 <% end %> <% if @departments.empty? %> 
        <tr>
          <td colspan="5" class="px-5 py-8 text-center text-text-tertiary">No departments found.</td>
        </tr>
 <% end %> </tbody>
 </table>
 </div>
 
<div class="mt-4"> <%= render"shared/pagination", pagy: @pagy if defined?(@pagy) %> </div>
 
