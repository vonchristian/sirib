<% content_for :page_title,"System Health" %> <% content_for :page_subtitle,"System health metrics dashboard" %> 
<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8"> 
  <div class="stat-card"> 
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Healthy</p>
 
    <p class="mt-1.5 text-2xl font-bold text-positive"><%= @healthy_count %></p>
 </div>
 
  <div class="stat-card"> 
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Warning</p>
 
    <p class="mt-1.5 text-2xl font-bold text-warning"><%= @warning_count %></p>
 </div>
 
  <div class="stat-card"> 
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Critical</p>
 
    <p class="mt-1.5 text-2xl font-bold text-danger"><%= @critical_count %></p>
 </div>
 </div>
 
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Current Status</h3>
 </div>
 
    <div class="p-5"> <% if @latest_snapshot %> 
        <div class="flex items-center gap-3 mb-4"> <span class="flex h-3 w-3 rounded-full <%= @latest_snapshot.healthy? ? 'bg-positive' : @latest_snapshot.warning? ? 'bg-warning' : 'bg-danger' %>"></span> <span class="text-lg font-semibold text-text-primary"><%= @latest_snapshot.status.titleize %></span> </div>
 
        <p class="text-sm text-text-tertiary">Metric: <%= @latest_snapshot.metric_name %></p>
 
        <p class="text-sm text-text-tertiary">Captured: <%= @latest_snapshot.captured_at.strftime("%b %d, %Y %H:%M") %></p>
 
        <p class="text-sm text-text-tertiary">Value: <%= @latest_snapshot.value %></p>
 <% else %> 
        <p class="text-sm text-text-tertiary">No health data available.</p>
 <% end %> </div>
 </div>
 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Recent Snapshots</h3>
 </div>
 
    <div class="divide-y divide-border"> <% @recent_snapshots.each do |snap| %> 
        <div class="flex items-center justify-between px-5 py-3"> 
          <div class="flex items-center gap-3"> <span class="flex h-2 w-2 rounded-full <%= snap.healthy? ? 'bg-positive' : snap.warning? ? 'bg-warning' : 'bg-danger' %>"></span> 
            <div> 
              <p class="text-sm text-text-primary"><%= snap.metric_name %></p>
 
              <p class="text-xs text-text-tertiary"><%= snap.value %></p>
 </div>
 </div>
 <span class="text-xs text-text-tertiary"><%= time_ago_in_words(snap.captured_at) %> ago</span> </div>
 <% end %> <% if @recent_snapshots.empty? %> 
        <p class="px-5 py-4 text-sm text-text-tertiary">No recent snapshots.</p>
 <% end %> </div>
 </div>
 </div>
 
