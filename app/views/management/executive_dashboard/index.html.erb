<% content_for :page_title,"Executive Dashboard" %> <% content_for :page_subtitle,"High-level organizational overview" %> <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-4 mb-8"> <div class="rounded-lg border border-border bg-surface p-5"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Branches</p> <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= @branch_count %></p> </div> <div class="rounded-lg border border-border bg-surface p-5"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Total Members</p> <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= @total_members %></p> </div> <div class="rounded-lg border border-border bg-surface p-5"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Total Assets</p> <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@total_assets, unit:"₱") %></p> </div> <div class="rounded-lg border border-border bg-surface p-5"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Loan Portfolio</p> <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@loan_portfolio, unit:"₱") %></p> </div> <div class="rounded-lg border border-border bg-surface p-5"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Share Capital</p> <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@share_capital, unit:"₱") %></p> </div> </div> <div class="grid grid-cols-1 lg:grid-cols-3 gap-6"> <div class="lg:col-span-2 rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Branch Ranking</h3> </div> <div class="overflow-x-auto"> <table class="w-full text-sm"> <thead> <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> <th class="px-5 py-3 font-medium">Rank</th> <th class="px-5 py-3 font-medium">Branch</th> <th class="px-5 py-3 font-medium text-right">Total Assets</th> <th class="px-5 py-3 font-medium text-right">Loans</th> <th class="px-5 py-3 font-medium text-right">Savings</th> <th class="px-5 py-3 font-medium text-right">Members</th> </tr> </thead> <tbody class="divide-y divide-border"> <% @branch_rankings.each_with_index do |b, i| %> <tr class="hover:bg-surface-alt transition-colors"> <td class="px-5 py-3 text-text-secondary"><%= i + 1 %></td> <td class="px-5 py-3 font-medium text-text-primary"><%= b[:branch].name %></td> <td class="px-5 py-3 text-right text-text-primary"><%= number_to_currency(b[:total_assets].to_f / 100, unit:"₱") %></td> <td class="px-5 py-3 text-right text-text-primary"><%= number_to_currency(b[:loan_portfolio].to_f / 100, unit:"₱") %></td> <td class="px-5 py-3 text-right text-text-primary"><%= number_to_currency(b[:savings_deposits].to_f / 100, unit:"₱") %></td> <td class="px-5 py-3 text-right text-text-primary"><%= b[:member_count] %></td> </tr> <% end %> <% if @branch_rankings.empty? %> <tr><td colspan="6" class="px-5 py-8 text-center text-text-tertiary">No branch data available.</td></tr> <% end %> </tbody> </table> </div> </div> <div class="space-y-6"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Risk Overview</h3> </div> <div class="p-5 space-y-3"> <div class="flex items-center justify-between"> <span class="text-sm text-text-secondary">Critical</span> <span class="text-sm font-semibold text-danger"><%= @risk_indicators.select { |r| r.critical? }.size %></span> </div> <div class="flex items-center justify-between"> <span class="text-sm text-text-secondary">Elevated</span> <span class="text-sm font-semibold text-warning"><%= @risk_indicators.select { |r| r.elevated? }.size %></span> </div> <div class="flex items-center justify-between"> <span class="text-sm text-text-secondary">Normal</span> <span class="text-sm font-semibold text-positive"><%= @risk_indicators.select { |r| r.normal? }.size %></span> </div> </div> </div> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">System Health</h3> </div> <div class="p-5"> <% if @system_health %> <div class="flex items-center gap-2"> <span class="flex h-2.5 w-2.5 rounded-full <%= @system_health.healthy? ? 'bg-positive' : @system_health.warning? ? 'bg-warning' : 'bg-danger' %>"></span> <span class="text-sm font-medium text-text-primary"><%= @system_health.status.titleize %></span> </div> <p class="mt-1 text-xs text-text-tertiary">Last checked <%= time_ago_in_words(@system_health.captured_at) %> ago</p> <% else %> <p class="text-sm text-text-tertiary">No health data available.</p> <% end %> </div> </div> </div> </div> 