<% content_for :page_title, @control.name %> <% content_for :page_subtitle,"Compliance control details" %> 
<div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Back", management_compliance_controls_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div>
 
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Control Information</h3>
 </div>
 
    <div class="p-5 space-y-3"> 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Name</span> <span class="text-sm font-medium text-text-primary"><%= @control.name %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Category</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium bg-surface-alt text-text-secondary"><%= @control.category.humanize %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Frequency</span> <span class="text-sm text-text-primary"><%= @control.frequency.titleize %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @control.active ? "bg-green-50 text-green-700" :"bg-surface-alt text-text-tertiary" %>"> <%= @control.active ? "Active" :"Inactive" %> </span> </div>
 <% if @control.description.present? %> 
        <div class="border-t border-border pt-3 mt-3"> 
          <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-2">Description</p>
 
          <p class="text-sm text-text-primary"><%= @control.description %></p>
 </div>
 <% end %> </div>
 </div>
 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Configuration</h3>
 </div>
 
    <div class="p-5"> <% if @control.config.present? %> 
        <pre class="text-xs text-text-secondary bg-surface-alt rounded-md p-3 overflow-x-auto"><%= JSON.pretty_generate(@control.config) %></pre>
 <% else %> 
        <p class="text-sm text-text-tertiary">No configuration.</p>
 <% end %> </div>
 </div>
 </div>
 
<div class="mt-6"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Evidence History</h3>
 </div>
 
    <div class="overflow-hidden"> 
      <table class="w-full text-sm"> 
        <thead> 
          <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> 
            <th class="px-5 py-3 font-medium">Date</th>
 
            <th class="px-5 py-3 font-medium">Status</th>
 
            <th class="px-5 py-3 font-medium">Type</th>
 
            <th class="px-5 py-3 font-medium">Verified By</th>
 </tr>
 </thead>
 
        <tbody class="divide-y divide-border"> <% @evidences.each do |evidence| %> 
            <tr class="hover:bg-surface-alt transition-colors"> 
              <td class="px-5 py-3 text-text-secondary whitespace-nowrap"><%= evidence.created_at.strftime("%b %d %H:%M") %></td>
 
              <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= evidence.status =="passed" ? "bg-green-50 text-green-700" : evidence.status =="failed" ? "bg-red-50 text-red-700" :"bg-yellow-50 text-yellow-700" %>"> <%= evidence.status.titleize %> </span> </td>
 
              <td class="px-5 py-3 text-text-secondary"><%= evidence.evidence_type.humanize %></td>
 
              <td class="px-5 py-3 text-text-secondary"><%= evidence.verified_by&.respond_to?(:email_address) ? evidence.verified_by.email_address :"—" %></td>
 </tr>
 <% end %> <% if @evidences.empty? %> 
            <tr>
              <td colspan="4" class="px-5 py-8 text-center text-text-tertiary">No evidence records found.</td>
            </tr>
 <% end %> </tbody>
 </table>
 </div>
 </div>
 </div>
 
