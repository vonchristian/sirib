<% content_for :page_title, @permission.action.titleize %> <% content_for :page_subtitle,"#{@permission.subject} permission" %> 
<div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Back", management_permissions_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div>
 
<div class="max-w-2xl"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Permission Details</h3>
 </div>
 
    <div class="p-5 space-y-3"> 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Subject</span> <span class="text-sm font-medium text-text-primary"><%= @permission.subject.titleize %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Action</span> <span class="inline-flex items-center rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary-700"><%= @permission.action %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Description</span> <span class="text-sm text-text-primary"><%= @permission.description ||"—" %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Roles</span> <span class="text-sm text-text-primary"><%= @permission.roles.count %></span> </div>
 </div>
 </div>
 </div>
 
