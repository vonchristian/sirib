<div class="mt-4 p-4 rounded-lg border border-border bg-surface"> 
  <h4 class="text-xs font-semibold text-text-primary mb-3">Preview for <%= number_to_currency(amount.to_f, unit:"") %></h4>
 
  <table class="w-full text-sm"> 
    <thead> 
      <tr class="text-left text-xs text-text-tertiary uppercase tracking-wider"> 
        <th class="pb-2 font-medium">Account</th>
 
        <th class="pb-2 font-medium">Direction</th>
 
        <th class="pb-2 font-medium text-right">Amount</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% lines.each do |line| %> 
        <tr> 
          <td class="py-2 text-text-primary"><%= line[:account].name %></td>
 
          <td class="py-2"> <span class="<%= line[:direction] =="debit" ? 'text-danger' : 'text-success' %>"><%= line[:direction].titleize %></span> </td>
 
          <td class="py-2 text-right font-mono text-text-primary"><%= number_to_currency(line[:amount_cents].to_f / 100, unit:"") %></td>
 </tr>
 <% end %> </tbody>
 </table>
 <%= form_tag execute_management_entry_template_path(@template), method: :post, class:"mt-4 pt-3 border-t border-border" do %> <%= hidden_field_tag :amount, amount %> <%= submit_tag"Post Entry", class:"rounded-md bg-positive px-4 py-2 text-xs font-semibold text-white hover:bg-positive-700 transition-colors cursor-pointer" %> <% end %> </div>
 
