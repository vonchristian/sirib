<div class="nested-fields rounded-lg border border-border bg-surface-alt p-3"> <div class="grid grid-cols-6 gap-3 items-end"> <div> <%= f.label :account_id,"Account", class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.collection_select :account_id, Accounting::Account.order(:name), :id, :name, { include_blank:"Select" }, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div> <%= f.label :direction, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.select :direction, options_for_select([["Debit","debit"], ["Credit","credit"]], f.object.direction), {}, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div> <%= f.label :amount_mode,"Mode", class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.select :amount_mode, options_for_select([["Variable","variable"], ["Fixed","fixed"]], f.object.amount_mode), {}, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none", data: { controller:"toggle-fixed" } %> </div> <div> <%= f.label :fixed_amount,"Fixed Amt", class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.number_field :fixed_amount, step: 0.01, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none", data: { target:"toggle-fixed.amount" } %> </div> <div> <%= f.label :sequence_index,"Seq", class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.number_field :sequence_index, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div class="flex items-end pb-1"> <%= f.hidden_field :_destroy %> <%= button_tag"Remove", type:"button", class:"text-xs text-danger hover:text-danger-700 transition-colors", data: { action:"click->nested-form#remove" } %> </div> </div> </div> 