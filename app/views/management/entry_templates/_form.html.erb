<%= form_with model: template, url: template.persisted? ? management_entry_template_path(template) : management_entry_templates_path, class:"space-y-4" do |f| %> <% if template.errors.any? %> <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> <ul class="list-inside list-disc"> <% template.errors.each do |error| %> <li><%= error.full_message %></li> <% end %> </ul> </div> <% end %> <div> <%= f.label :name, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_field :name, required: true, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div> <%= f.label :description, class:"block text-xs font-medium text-text-secondary mb-1" %> <%= f.text_area :description, rows: 2, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-sm text-text-primary placeholder:text-text-tertiary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div> <%= f.label :is_active, class:"flex items-center gap-2" do %> <%= f.check_box :is_active, class:"rounded border-border bg-surface text-primary focus:ring-primary" %> <span class="text-xs text-text-secondary">Active</span> <% end %> </div> <div class="border-t border-border pt-4"> <div class="flex items-center justify-between mb-3"> <h3 class="text-xs font-semibold text-text-primary uppercase tracking-wider">Template Lines</h3> </div> <div id="template-lines" class="space-y-3" data-controller="nested-form"> <%= f.fields_for :lines do |lf| %> <%= render"management/entry_templates/line_fields", f: lf %> <% end %> </div> <%= link_to_add_fields"Add Line", f, :lines, class:"text-xs text-primary hover:text-primary-700 transition-colors" %> </div> <div class="flex items-center gap-3 pt-4 border-t border-border"> <%= f.submit class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <%= link_to"Cancel", management_entry_templates_path, class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </div> <% end %> 