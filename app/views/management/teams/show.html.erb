<% content_for :page_title, @team.name %> <% content_for :page_subtitle,"Team details" %> 
<div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Edit", edit_management_team_path(@team), class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <%= link_to"Back", management_teams_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div>
 
<div class="max-w-2xl"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Details</h3>
 </div>
 
    <div class="p-5 space-y-3"> 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Name</span> <span class="text-sm font-medium text-text-primary"><%= @team.name %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Department</span> <span class="text-sm text-text-primary"><%= @team.department.name %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Description</span> <span class="text-sm text-text-primary"><%= @team.description ||"—" %></span> </div>
 </div>
 </div>
 </div>
 
