<% content_for :page_title,"Policies" %> <% content_for :page_subtitle,"Manage system policies and rules" %> 
<div class="flex items-center justify-between mb-6"> 
  <div> <%= form_tag management_policies_path, method: :get, class:"flex items-center gap-2" do %> <%= select_tag :category, options_for_select(Management::Policy.distinct.pluck(:category), params[:category]), include_blank:"All Categories", class:"rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> <%= submit_tag"Filter", class:"rounded-md bg-primary px-3 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> <% end %> </div>
 <%= link_to"New Policy", new_management_policy_path, class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> </div>
 
<div class="rounded-lg border border-border bg-surface overflow-hidden"> 
  <table class="w-full text-sm"> 
    <thead> 
      <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> 
        <th class="px-5 py-3 font-medium">Name</th>
 
        <th class="px-5 py-3 font-medium">Code</th>
 
        <th class="px-5 py-3 font-medium">Category</th>
 
        <th class="px-5 py-3 font-medium">Status</th>
 
        <th class="px-5 py-3 font-medium">Rules</th>
 
        <th class="px-5 py-3 font-medium text-right">Actions</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% @policies.each do |policy| %> 
        <tr class="hover:bg-surface-alt transition-colors"> 
          <td class="px-5 py-3"> <%= link_to policy.name, management_policy_path(policy), class:"font-medium text-text-primary hover:text-primary transition-colors" %> </td>
 
          <td class="px-5 py-3 text-text-secondary"><%= policy.code %></td>
 
          <td class="px-5 py-3"><span class="inline-flex items-center rounded-full bg-surface-alt px-2.5 py-0.5 text-xs text-text-secondary"><%= policy.category %></span></td>
 
          <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= policy.active? ? 'bg-positive-50 text-positive' : policy.draft? ? 'bg-surface-alt text-text-tertiary' : 'bg-danger-50 text-danger' %>"> <%= policy.status.titleize %> </span> </td>
 
          <td class="px-5 py-3 text-text-secondary"><%= policy.rules.count %></td>
 
          <td class="px-5 py-3 text-right"> <%= link_to"Edit", edit_management_policy_path(policy), class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </td>
 </tr>
 <% end %> <% if @policies.empty? %> 
        <tr>
          <td colspan="6" class="px-5 py-8 text-center text-text-tertiary">No policies found.</td>
        </tr>
 <% end %> </tbody>
 </table>
 </div>
 
<div class="mt-4"> <%= render"shared/pagination", pagy: @pagy if defined?(@pagy) %> </div>
 
