<% content_for :page_title, @policy.name %> <% content_for :page_subtitle,"Policy ##{@policy.code}" %> 
<div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Edit", edit_management_policy_path(@policy), class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <% if @policy.draft? || @policy.inactive? %> <%= button_to"Activate", activate_management_policy_path(@policy), method: :post, class:"rounded-md bg-positive px-4 py-2 text-xs font-semibold text-white hover:bg-positive-700 transition-colors" %> <% end %> <% if @policy.active? %> <%= button_to"Deactivate", deactivate_management_policy_path(@policy), method: :post, class:"rounded-md border border-danger text-danger px-4 py-2 text-xs font-semibold hover:bg-danger-50 transition-colors" %> <% end %> <%= link_to"Back", management_policies_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div>
 
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Details</h3>
 </div>
 
    <div class="p-5 space-y-3"> 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Name</span> <span class="text-sm font-medium text-text-primary"><%= @policy.name %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Code</span> <span class="text-sm text-text-primary"><%= @policy.code %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Category</span> <span class="text-sm text-text-primary"><%= @policy.category %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @policy.active? ? 'bg-positive-50 text-positive' : @policy.draft? ? 'bg-surface-alt text-text-tertiary' : 'bg-danger-50 text-danger' %>"><%= @policy.status.titleize %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Description</span> <span class="text-sm text-text-primary"><%= @policy.description ||"—" %></span> </div>
 </div>
 </div>
 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Rules</h3>
 </div>
 
    <div class="divide-y divide-border"> <% @policy.rules.each do |rule| %> 
        <div class="px-5 py-3"> 
          <div class="flex items-center justify-between"> 
            <p class="text-sm font-medium text-text-primary"><%= rule.field %> <%= rule.operator %> <%= rule.value %></p>
 <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= rule.allow? ? 'bg-positive-50 text-positive' : rule.deny? ? 'bg-danger-50 text-danger' : 'bg-warning-50 text-warning' %>"><%= rule.effect.titleize %></span> </div>
 </div>
 <% end %> <% if @policy.rules.empty? %> 
        <p class="px-5 py-4 text-sm text-text-tertiary">No rules defined.</p>
 <% end %> </div>
 </div>
 </div>
 
