<% content_for :page_title,"Approval Request ##{@approval_request.id}" %> <% content_for :page_subtitle, @workflow.name %> <div class="flex items-center justify-end gap-2 mb-6"> <% if @approval_request.pending? %> <%= button_to"Approve", approve_management_approval_workflow_approval_request_path(@workflow, @approval_request), method: :post, class:"rounded-md bg-positive px-4 py-2 text-xs font-semibold text-white hover:bg-positive-700 transition-colors" %> <%= button_to"Reject", reject_management_approval_workflow_approval_request_path(@workflow, @approval_request), method: :post, class:"rounded-md border border-danger text-danger px-4 py-2 text-xs font-semibold hover:bg-danger-50 transition-colors" %> <% end %> <%= link_to"Back", management_approval_workflow_approval_requests_path(@workflow), class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Request Details</h3> </div> <div class="p-5 space-y-3"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">ID</span> <span class="text-sm font-medium text-text-primary">#<%= @approval_request.id %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Requested By</span> <span class="text-sm text-text-primary"><%= @approval_request.requested_by.email_address %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @approval_request.pending? ? 'bg-warning-50 text-warning' : @approval_request.approved? ? 'bg-positive-50 text-positive' : @approval_request.rejected? ? 'bg-danger-50 text-danger' : 'bg-surface-alt text-text-tertiary' %>"> <%= @approval_request.status.titleize %> </span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Created</span> <span class="text-sm text-text-primary"><%= @approval_request.created_at.strftime("%b %d, %Y %H:%M") %></span> </div> </div> </div> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Approval Chain</h3> </div> <div class="divide-y divide-border"> <% @approvals.each do |approval| %> <div class="px-5 py-3"> <div class="flex items-center justify-between"> <div class="flex items-center gap-3"> <span class="flex h-6 w-6 items-center justify-center rounded-full <%= approval.approved? ? 'bg-positive-50 text-positive' : 'bg-danger-50 text-danger' %> text-xs font-semibold"> <%= approval.approved? ? 'Y' : 'N' %> </span> <div> <p class="text-sm text-text-primary"><%= approval.approver.email_address %></p> <p class="text-xs text-text-tertiary">Step <%= approval.step.sequence %></p> </div> </div> <span class="text-xs text-text-tertiary"><%= approval.signed_at.strftime("%b %d, %H:%M") %></span> </div> </div> <% end %> <% if @approvals.empty? %> <p class="px-5 py-4 text-sm text-text-tertiary">No approvals yet.</p> <% end %> </div> </div> </div> 