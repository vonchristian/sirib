<% content_for :page_title, "Management Dashboard" %>
<% content_for :page_subtitle, "Key performance indicators and system overview" %>

<div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 mb-8">
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Total Assets</p>
    <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@total_assets, unit: "₱") %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Loan Portfolio</p>
    <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@loan_portfolio, unit: "₱") %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Savings Deposits</p>
    <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@savings_deposits, unit: "₱") %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Share Capital</p>
    <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@share_capital, unit: "₱") %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Net Income</p>
    <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@net_income, unit: "₱") %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Cash Position</p>
    <p class="mt-1.5 text-2xl font-bold text-text-primary"><%= number_to_currency(@cash_position, unit: "₱") %></p>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Recent Alerts</h3>
    </div>
    <div class="divide-y divide-border dark:divide-gray-800">
      <% @recent_alerts.each do |alert| %>
        <div class="flex items-center gap-3 px-5 py-3">
          <span class="flex h-2 w-2 rounded-full <%= alert.critical? ? 'bg-danger' : alert.warning? ? 'bg-warning' : 'bg-positive' %>"></span>
          <div class="flex-1 min-w-0">
            <p class="text-sm text-text-primary truncate"><%= alert.title %></p>
            <p class="text-xs text-text-tertiary"><%= alert.alert_type.humanize %></p>
          </div>
          <span class="text-xs text-text-tertiary"><%= time_ago_in_words(alert.created_at) %> ago</span>
        </div>
      <% end %>
      <% if @recent_alerts.empty? %>
        <p class="px-5 py-4 text-sm text-text-tertiary">No active alerts.</p>
      <% end %>
    </div>
  </div>

  <div class="rounded-lg border border-border bg-surface dark:border-gray-800">
    <div class="border-b border-border px-5 py-4 dark:border-gray-800">
      <h3 class="text-sm font-semibold text-text-primary">Pending Approvals</h3>
    </div>
    <div class="divide-y divide-border dark:divide-gray-800">
      <% @pending_approvals.each do |request| %>
        <div class="flex items-center gap-3 px-5 py-3">
          <div class="flex-1 min-w-0">
            <p class="text-sm text-text-primary truncate"><%= request.workflow.name %></p>
            <p class="text-xs text-text-tertiary">by <%= request.requested_by.email_address %></p>
          </div>
          <span class="text-xs text-text-tertiary"><%= time_ago_in_words(request.created_at) %> ago</span>
        </div>
      <% end %>
      <% if @pending_approvals.empty? %>
        <p class="px-5 py-4 text-sm text-text-tertiary">No pending approvals.</p>
      <% end %>
    </div>
  </div>
</div>
