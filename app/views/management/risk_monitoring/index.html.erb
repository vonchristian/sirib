<% content_for :page_title, "Risk Monitoring" %>
<% content_for :page_subtitle, "Risk indicators dashboard" %>

<div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Critical</p>
    <p class="mt-1.5 text-2xl font-bold text-danger"><%= @critical_count %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Elevated</p>
    <p class="mt-1.5 text-2xl font-bold text-warning"><%= @elevated_count %></p>
  </div>
  <div class="rounded-lg border border-border bg-surface p-5 dark:border-gray-800">
    <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Normal</p>
    <p class="mt-1.5 text-2xl font-bold text-positive"><%= @normal_count %></p>
  </div>
</div>

<div class="rounded-lg border border-border bg-surface dark:border-gray-800">
  <div class="border-b border-border px-5 py-4 dark:border-gray-800">
    <h3 class="text-sm font-semibold text-text-primary">Risk Indicators</h3>
  </div>
  <div class="overflow-x-auto">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border dark:border-gray-800 text-left text-xs text-text-tertiary uppercase tracking-wider">
          <th class="px-5 py-3 font-medium">Indicator</th>
          <th class="px-5 py-3 font-medium">Branch</th>
          <th class="px-5 py-3 font-medium">Value</th>
          <th class="px-5 py-3 font-medium">Status</th>
          <th class="px-5 py-3 font-medium">As of Date</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border dark:divide-gray-800">
        <% @risk_indicators.each do |ri| %>
          <tr class="hover:bg-surface-alt transition-colors">
            <td class="px-5 py-3 font-medium text-text-primary"><%= ri.indicator_type.humanize %></td>
            <td class="px-5 py-3 text-text-secondary"><%= ri.branch&.name || "Organization-wide" %></td>
            <td class="px-5 py-3 text-text-primary"><%= ri.value %></td>
            <td class="px-5 py-3">
              <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= ri.normal? ? 'bg-positive-50 text-positive' : ri.elevated? ? 'bg-warning-50 text-warning' : 'bg-danger-50 text-danger' %>">
                <%= ri.status.titleize %>
              </span>
            </td>
            <td class="px-5 py-3 text-text-secondary"><%= ri.as_of_date.strftime("%b %d, %Y") %></td>
          </tr>
        <% end %>
        <% if @risk_indicators.empty? %>
          <tr><td colspan="5" class="px-5 py-8 text-center text-text-tertiary">No risk indicators for today.</td></tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
