<% content_for :page_title,"Configurations" %> <% content_for :page_subtitle,"Manage system configurations" %> 
<div class="flex items-center justify-end mb-6"> <%= link_to"New Configuration", new_management_configuration_path, class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> </div>
 
<div class="rounded-lg border border-border bg-surface overflow-hidden"> 
  <table class="w-full text-sm"> 
    <thead> 
      <tr class="border-b border-border text-left text-xs text-text-tertiary uppercase tracking-wider"> 
        <th class="px-5 py-3 font-medium">Key</th>
 
        <th class="px-5 py-3 font-medium">Value</th>
 
        <th class="px-5 py-3 font-medium">Status</th>
 
        <th class="px-5 py-3 font-medium">Changed By</th>
 
        <th class="px-5 py-3 font-medium text-right">Actions</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% @configurations.each do |config| %> 
        <tr class="hover:bg-surface-alt transition-colors"> 
          <td class="px-5 py-3"> <%= link_to config.key, management_configuration_path(config), class:"font-medium text-text-primary hover:text-primary transition-colors" %> </td>
 
          <td class="px-5 py-3 text-text-secondary max-w-[200px] truncate"><%= config.value %></td>
 
          <td class="px-5 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= config.active? ? 'bg-positive-50 text-positive' : config.draft? ? 'bg-warning-50 text-warning' : 'bg-surface-alt text-text-tertiary' %>"> <%= config.status.titleize %> </span> </td>
 
          <td class="px-5 py-3 text-text-secondary"><%= config.changed_by&.email_address ||"—" %></td>
 
          <td class="px-5 py-3 text-right"> <%= link_to"Edit", edit_management_configuration_path(config), class:"text-xs text-text-secondary hover:text-primary transition-colors" %> </td>
 </tr>
 <% end %> <% if @configurations.empty? %> 
        <tr>
          <td colspan="5" class="px-5 py-8 text-center text-text-tertiary">No configurations found.</td>
        </tr>
 <% end %> </tbody>
 </table>
 </div>
 
<div class="mt-4"> <%= render"shared/pagination", pagy: @pagy if defined?(@pagy) %> </div>
 
