<% content_for :page_title, @configuration.key %> <% content_for :page_subtitle,"Configuration details" %> 
<div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Edit", edit_management_configuration_path(@configuration), class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <% if @configuration.draft? %> <%= button_to"Approve", approve_management_configuration_path(@configuration), method: :post, class:"rounded-md bg-positive px-4 py-2 text-xs font-semibold text-white hover:bg-positive-700 transition-colors" %> <%= button_to"Activate", activate_management_configuration_path(@configuration), method: :post, class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <% end %> <%= link_to"Back", management_configurations_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div>
 
<div class="grid grid-cols-1 lg:grid-cols-2 gap-6"> 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Details</h3>
 </div>
 
    <div class="p-5 space-y-3"> 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Key</span> <span class="text-sm font-medium text-text-primary"><%= @configuration.key %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Value</span> <span class="text-sm text-text-primary"><%= @configuration.value %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @configuration.active? ? 'bg-positive-50 text-positive' : @configuration.draft? ? 'bg-warning-50 text-warning' : 'bg-surface-alt text-text-tertiary' %>"> <%= @configuration.status.titleize %> </span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Changed By</span> <span class="text-sm text-text-primary"><%= @configuration.changed_by&.email_address ||"—" %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Approved By</span> <span class="text-sm text-text-primary"><%= @configuration.approved_by&.email_address ||"—" %></span> </div>
 
      <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Description</span> <span class="text-sm text-text-primary"><%= @configuration.description ||"—" %></span> </div>
 </div>
 </div>
 
  <div class="rounded-lg border border-border bg-surface"> 
    <div class="border-b border-border px-5 py-4"> 
      <h3 class="text-sm font-semibold text-text-primary">Version History</h3>
 </div>
 
    <div class="divide-y divide-border"> <% @versions.each do |version| %> 
        <div class="px-5 py-3"> 
          <p class="text-sm text-text-primary">Version <%= version.version %></p>
 
          <p class="text-xs text-text-tertiary"><%= version.changed_at.strftime("%b %d, %Y %H:%M") if version.changed_at %></p>
 </div>
 <% end %> <% if @versions.empty? %> 
        <p class="px-5 py-4 text-sm text-text-tertiary">No version history.</p>
 <% end %> </div>
 </div>
 </div>
 
