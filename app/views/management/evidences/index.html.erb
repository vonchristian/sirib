<% content_for :page_title, "Evidence for #{@control.name}" %>
<% content_for :page_subtitle, "Compliance evidence records" %>

<div class="flex items-center justify-end gap-2 mb-6">
  <%= link_to "Back to Control", management_compliance_control_path(@control), class: "rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %>
</div>

<div class="rounded-lg border border-border bg-surface dark:border-gray-800 overflow-hidden">
  <table class="w-full text-sm">
    <thead>
      <tr class="border-b border-border dark:border-gray-800 text-left text-xs text-text-tertiary uppercase tracking-wider">
        <th class="px-5 py-3 font-medium">Date</th>
        <th class="px-5 py-3 font-medium">Status</th>
        <th class="px-5 py-3 font-medium">Type</th>
        <th class="px-5 py-3 font-medium">Verified By</th>
        <th class="px-5 py-3 font-medium">Expires</th>
        <th class="px-5 py-3 font-medium text-right">Actions</th>
      </tr>
    </thead>
    <tbody class="divide-y divide-border dark:divide-gray-800">
      <% @evidences.each do |evidence| %>
        <tr class="hover:bg-surface-alt transition-colors">
          <td class="px-5 py-3 text-text-secondary whitespace-nowrap"><%= evidence.created_at.strftime("%b %d %H:%M") %></td>
          <td class="px-5 py-3">
            <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= evidence.status == "passed" ? "bg-green-50 text-green-700" : evidence.status == "failed" ? "bg-red-50 text-red-700" : "bg-yellow-50 text-yellow-700" %>">
              <%= evidence.status.titleize %>
            </span>
          </td>
          <td class="px-5 py-3 text-text-secondary"><%= evidence.evidence_type.humanize %></td>
          <td class="px-5 py-3 text-text-secondary"><%= evidence.verified_by&.respond_to?(:email_address) ? evidence.verified_by.email_address : "—" %></td>
          <td class="px-5 py-3 text-text-secondary"><%= evidence.expires_at&.strftime("%b %d, %Y") || "—" %></td>
          <td class="px-5 py-3 text-right">
            <%= link_to "View", management_compliance_control_evidence_path(@control, evidence), class: "text-xs text-text-secondary hover:text-primary transition-colors" %>
          </td>
        </tr>
      <% end %>
      <% if @evidences.empty? %>
        <tr><td colspan="6" class="px-5 py-8 text-center text-text-tertiary">No evidence records found.</td></tr>
      <% end %>
    </tbody>
  </table>
</div>

<div class="mt-4">
  <%= render "shared/pagination", pagy: @pagy if defined?(@pagy) %>
</div>
