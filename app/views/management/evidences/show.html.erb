<% content_for :page_title,"Evidence ##{@evidence.id}" %> <% content_for :page_subtitle,"Compliance evidence details" %> <div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Back to Evidence", management_compliance_control_evidences_path(@control), class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="max-w-2xl"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Evidence Record</h3> </div> <div class="p-5 space-y-3"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Control</span> <span class="text-sm font-medium text-text-primary"><%= @evidence.control.name %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @evidence.status =="passed" ? "bg-green-50 text-green-700" : @evidence.status =="failed" ? "bg-red-50 text-red-700" :"bg-yellow-50 text-yellow-700" %>"> <%= @evidence.status.titleize %> </span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Type</span> <span class="text-sm text-text-primary"><%= @evidence.evidence_type.humanize %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Verified By</span> <span class="text-sm text-text-primary"><%= @evidence.verified_by&.respond_to?(:email_address) ? @evidence.verified_by.email_address :"—" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Verified At</span> <span class="text-sm text-text-primary"><%= @evidence.verified_at&.strftime("%b %d, %Y %H:%M") ||"—" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Expires</span> <span class="text-sm text-text-primary"><%= @evidence.expires_at&.strftime("%b %d, %Y") ||"Never" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Created</span> <span class="text-sm text-text-primary"><%= @evidence.created_at.strftime("%b %d, %Y %H:%M:%S") %></span> </div> <% if @evidence.metadata.present? %> <div class="border-t border-border pt-3 mt-3"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-2">Metadata</p> <pre class="text-xs text-text-secondary bg-surface-alt rounded-md p-3 overflow-x-auto"><%= JSON.pretty_generate(@evidence.metadata) %></pre> </div> <% end %> </div> </div> </div> 