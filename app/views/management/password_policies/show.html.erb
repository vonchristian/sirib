<% content_for :page_title, @policy.name %> <% content_for :page_subtitle,"Password policy details" %> <div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Edit", edit_management_password_policy_path(@policy), class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors" %> <%= link_to"Back", management_password_policies_path, class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="max-w-2xl"> <div class="rounded-lg border border-border bg-surface"> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Policy Configuration</h3> </div> <div class="p-5 space-y-3"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Name</span> <span class="text-sm font-medium text-text-primary"><%= @policy.name %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Status</span> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= @policy.active ? "bg-green-50 text-green-700" :"bg-surface-alt text-text-tertiary" %>"> <%= @policy.active ? "Active" :"Inactive" %> </span> </div> <div class="border-t border-border pt-3 mt-3"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-3">Password Requirements</p> <div class="space-y-2"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Minimum Length</span> <span class="text-sm text-text-primary"><%= @policy.min_length ||"Not set" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Require Uppercase</span> <span class="text-sm <%= @policy.require_uppercase ? "text-positive" :"text-text-tertiary" %>"><%= @policy.require_uppercase ? "Yes" :"No" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Require Lowercase</span> <span class="text-sm <%= @policy.require_lowercase ? "text-positive" :"text-text-tertiary" %>"><%= @policy.require_lowercase ? "Yes" :"No" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Require Digits</span> <span class="text-sm <%= @policy.require_digits ? "text-positive" :"text-text-tertiary" %>"><%= @policy.require_digits ? "Yes" :"No" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Require Symbols</span> <span class="text-sm <%= @policy.require_symbols ? "text-positive" :"text-text-tertiary" %>"><%= @policy.require_symbols ? "Yes" :"No" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Password History</span> <span class="text-sm text-text-primary"><%= @policy.password_history_count ? "#{@policy.password_history_count} recent" :"Not set" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Expiry (Days)</span> <span class="text-sm text-text-primary"><%= @policy.password_expiry_days ||"Never" %></span> </div> </div> </div> <div class="border-t border-border pt-3 mt-3"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-3">Lockout Settings</p> <div class="space-y-2"> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Max Failed Attempts</span> <span class="text-sm text-text-primary"><%= @policy.max_failed_attempts ||"Not set" %></span> </div> <div class="flex justify-between"> <span class="text-sm text-text-tertiary">Lockout Duration</span> <span class="text-sm text-text-primary"><%= @policy.lockout_duration ? "#{@policy.lockout_duration} minutes" :"Not set" %></span> </div> </div> </div> </div> </div> </div> 