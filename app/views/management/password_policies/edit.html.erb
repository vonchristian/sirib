<% content_for :page_title,"Edit #{@policy.name}" %> <% content_for :page_subtitle,"Update password policy configuration" %> <div class="flex items-center justify-end gap-2 mb-6"> <%= link_to"Back", management_password_policy_path(@policy), class:"rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %> </div> <div class="max-w-2xl"> <%= form_with model: @policy, url: management_password_policy_path(@policy), method: :patch, class:"rounded-lg border border-border bg-surface" do |f| %> <div class="border-b border-border px-5 py-4"> <h3 class="text-sm font-semibold text-text-primary">Policy Details</h3> </div> <div class="p-5 space-y-4"> <div> <%= f.label :name, class:"block text-xs font-medium text-text-tertiary mb-1.5" %> <%= f.text_field :name, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div class="border-t border-border pt-4"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-3">Password Requirements</p> <div class="grid grid-cols-2 gap-4"> <div> <%= f.label :min_length,"Min Length", class:"block text-xs font-medium text-text-tertiary mb-1.5" %> <%= f.number_field :min_length, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div> <%= f.label :password_expiry_days,"Expiry (Days)", class:"block text-xs font-medium text-text-tertiary mb-1.5" %> <%= f.number_field :password_expiry_days, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> </div> </div> <div class="grid grid-cols-2 gap-4"> <label class="flex items-center gap-2"> <%= f.check_box :require_uppercase, class:"rounded border-border bg-surface text-primary focus:ring-primary" %> <span class="text-xs text-text-primary">Require Uppercase</span> </label> <label class="flex items-center gap-2"> <%= f.check_box :require_lowercase, class:"rounded border-border bg-surface text-primary focus:ring-primary" %> <span class="text-xs text-text-primary">Require Lowercase</span> </label> <label class="flex items-center gap-2"> <%= f.check_box :require_digits, class:"rounded border-border bg-surface text-primary focus:ring-primary" %> <span class="text-xs text-text-primary">Require Digits</span> </label> <label class="flex items-center gap-2"> <%= f.check_box :require_symbols, class:"rounded border-border bg-surface text-primary focus:ring-primary" %> <span class="text-xs text-text-primary">Require Symbols</span> </label> </div> <div> <%= f.label :password_history_count,"Password History Count", class:"block text-xs font-medium text-text-tertiary mb-1.5" %> <%= f.number_field :password_history_count, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div class="border-t border-border pt-4"> <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-3">Lockout Settings</p> <div class="grid grid-cols-2 gap-4"> <div> <%= f.label :max_failed_attempts,"Max Failed Attempts", class:"block text-xs font-medium text-text-tertiary mb-1.5" %> <%= f.number_field :max_failed_attempts, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> <div> <%= f.label :lockout_duration,"Lockout (Minutes)", class:"block text-xs font-medium text-text-tertiary mb-1.5" %> <%= f.number_field :lockout_duration, class:"w-full rounded-md border border-border bg-surface py-2 px-3 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div> </div> </div> <div> <label class="flex items-center gap-2"> <%= f.check_box :active, class:"rounded border-border bg-surface text-primary focus:ring-primary" %> <span class="text-xs text-text-primary">Active</span> </label> </div> </div> <div class="border-t border-border px-5 py-4 flex justify-end"> <%= f.submit"Update Policy", class:"rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer" %> </div> <% end %> </div> 