<% if loan_products.any? %>
  <% loan_products.each do |product| %>
    <button type="button"
            class="w-full text-left px-3 py-2 text-sm hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors border-b border-border dark:border-gray-700 last:border-0"
            data-autocomplete-id="<%= product.id %>"
            data-autocomplete-label="<%= product.name %>"
            data-action="autocomplete#select"
            data-product-rate="<%= product.interest_rate %>"
            data-product-charges="<%= product.loan_charges.ordered.map { |c| { name: c.name, charge_type: c.charge_type, value: c.value.to_f } }.to_json %>"
            data-product-calculation="<%= product.interest_calculation %>">
      <span class="font-medium text-text-primary dark:text-white"><%= product.name %></span>
      <span class="ml-2 text-xs text-text-tertiary"><%= number_to_percentage(product.interest_rate, precision: 1) %> · up to <%= product.max_term_months %> months</span>
      <% if product.loan_charges.any? %>
        <span class="block mt-0.5 text-[11px] text-text-tertiary/70"><%= product.loan_charges.ordered.map { |c| "#{c.name} (#{c.charge_type == 'percentage' ? number_to_percentage(c.value, precision: 1) : number_to_currency(c.value, unit: 'PHP ')})" }.join(" · ") %></span>
      <% end %>
    </button>
  <% end %>
<% else %>
  <div class="px-3 py-4 text-center text-sm text-text-tertiary">No products found</div>
<% end %>
