<% if members.any? %>
  <% members.each do |member| %>
    <button type="button"
            class="w-full text-left px-3 py-2 flex items-center gap-3 hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors border-b border-border dark:border-gray-700 last:border-0"
            data-autocomplete-id="<%= member.id %>"
            data-autocomplete-label="<%= member.name %>"
            data-action="autocomplete#select">
      <% if member.profile_image.attached? %>
        <%= image_tag member.profile_image.variant(:thumb), class: "h-8 w-8 rounded-full object-cover flex-shrink-0" %>
      <% else %>
        <span class="h-8 w-8 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0">
          <span class="text-xs font-semibold text-primary dark:text-primary-300"><%= member.name.split.map(&:first).first(2).join.upcase %></span>
        </span>
      <% end %>
      <div class="min-w-0">
        <div class="font-medium text-text-primary dark:text-white truncate"><%= member.name %></div>
        <div class="text-xs text-text-tertiary truncate"><%= member.mobile_number %></div>
      </div>
    </button>
  <% end %>
<% else %>
  <div class="px-3 py-4 text-center text-sm text-text-tertiary">No members found</div>
<% end %>
