<% if simulation.present? %> 
  <div class="space-y-4"> 
    <div class="grid grid-cols-2 gap-3"> 
      <div style="background: var(--bg-tertiary); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px;"> <span style="font-size: 12px; color: var(--text-muted);">Old Monthly Payment</span> 
        <p style="font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 4px 0 0;"><%= number_to_currency(simulation[:old_monthly_payment].to_f, unit:"PHP") %></p>
 </div>
 
      <div style="background: var(--bg-tertiary); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px;"> <span style="font-size: 12px; color: var(--text-muted);">New Monthly Payment</span> 
        <p style="font-size: 18px; font-weight: 700; margin: 4px 0 0; color: <%= simulation[:payment_change].to_f < 0 ? '#22c55e' : '#ef4444' %>;"> <%= number_to_currency(simulation[:new_monthly_payment].to_f, unit:"PHP") %> </p>
 </div>
 </div>
 
    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-tertiary); padding: 8px 12px; border-radius: 8px;"> <span style="font-size: 12px; color: var(--text-muted);">Difference</span> <span style="font-size: 13px; font-weight: 500; color: <%= simulation[:payment_change].to_f < 0 ? '#22c55e' : '#ef4444' %>;"> <%= simulation[:payment_change_pct] %>% (<%= number_to_currency(simulation[:payment_change].to_f.abs, unit:"PHP") %>) </span> </div>
 
    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-tertiary); padding: 8px 12px; border-radius: 8px;"> <span style="font-size: 12px; color: var(--text-muted);">Total Interest Impact</span> <span style="font-size: 13px; font-weight: 500; color: <%= simulation[:interest_impact].to_f < 0 ? '#22c55e' : simulation[:interest_impact].to_f > 0 ? '#ef4444' : 'var(--text-primary)' %>;"> <%= number_to_currency(simulation[:interest_impact].to_f.abs, unit:"PHP") %> <%= simulation[:interest_impact].to_f < 0 ? 'saved' : simulation[:interest_impact].to_f > 0 ? 'increase' : 'unchanged' %> </span> </div>
 <% if simulation[:payoff_amount].present? %> 
      <div style="background: var(--bg-tertiary); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px;"> <span style="font-size: 12px; color: var(--text-muted);">Payoff Amount</span> 
        <p style="font-size: 18px; font-weight: 700; color: var(--text-primary); margin: 4px 0 0;"><%= number_to_currency(simulation[:payoff_amount].to_f, unit:"PHP") %></p>
 <% if simulation[:payoff_breakdown].present? %> 
          <div class="mt-1" style="font-size: 12px; color: var(--text-muted);"> <span>Principal: <%= number_to_currency(simulation[:payoff_breakdown][:outstanding_principal].to_f, unit:"PHP") %></span> <span>Interest: <%= number_to_currency(simulation[:payoff_breakdown][:accrued_interest].to_f, unit:"PHP") %></span> <span>Penalties: <%= number_to_currency(simulation[:payoff_breakdown][:penalties].to_f, unit:"PHP") %></span> </div>
 <% end %> </div>
 <% end %> 
    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-tertiary); padding: 8px 12px; border-radius: 8px;"> <span style="font-size: 12px; color: var(--text-muted);">New Term</span> <span style="font-size: 13px; font-weight: 500; color: var(--text-primary);"><%= simulation[:new_term_months] %> months</span> </div>
 
    <div style="display: flex; align-items: center; justify-content: space-between; background: var(--bg-tertiary); padding: 8px 12px; border-radius: 8px;"> <span style="font-size: 12px; color: var(--text-muted);">New Interest Rate</span> <span style="font-size: 13px; font-weight: 500; color: var(--text-primary);"><%= simulation[:new_interest_rate] %>%</span> </div>
 </div>
 <% else %> 
  <div class="text-center py-8"> <svg style="width: 40px; height: 40px; margin: 0 auto 8px; color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"> <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 0 0 6 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0 1 18 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/> </svg> 
    <p style="font-size: 13px; color: var(--text-muted); font-style: italic;">Fill in the proposed changes to see simulation.</p>
 </div>
 <% end %> 
