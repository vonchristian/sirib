<% content_for :page_title, "Restructure Case ##{@case.id}" %>
<% content_for :page_subtitle, @loan.member.name %>

<div class="animate-fade-in max-w-5xl mx-auto space-y-6">
  <div class="flex items-center justify-between">
    <div class="flex items-center gap-3">
      <h2 class="text-lg font-semibold text-text-primary dark:text-white">Restructure Case ##{@case.id}</h2>
      <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium capitalize
        <%= case @case.status
        when 'draft' then 'bg-gray-100 text-text-tertiary'
        when 'submitted', 'under_review' then 'bg-amber-50 text-amber-500'
        when 'approved' then 'bg-primary-50 text-primary'
        when 'rejected' then 'bg-danger-50 text-danger'
        when 'executed' then 'bg-positive-50 text-positive'
        when 'failed' then 'bg-danger-50 text-danger'
        end %>">
        <%= @case.status %>
      </span>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Loan ##{@loan.reference_number}", loans_loan_path(@loan), class: "btn-ghost text-sm" %>
      <%= link_to "Cases", loans_restructure_cases_path, class: "btn-ghost text-sm" %>
    </div>
  </div>

  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
        <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Case Details</h3>
        <dl class="grid grid-cols-2 gap-x-6 gap-y-4">
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Type</dt>
            <dd class="mt-1 text-sm font-medium text-text-primary capitalize"><%= @case.restructure_type %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Status</dt>
            <dd class="mt-1 text-sm capitalize text-text-primary"><%= @case.status %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Requested By</dt>
            <dd class="mt-1 text-sm text-text-primary"><%= @case.requested_by&.email_address || "System" %></dd>
          </div>
          <div>
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Submitted</dt>
            <dd class="mt-1 text-sm text-text-primary"><%= @case.submitted_at&.strftime("%b %d, %Y %H:%M") || "Not yet" %></dd>
          </div>
          <% if @case.reviewed_at %>
            <div>
              <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Reviewed At</dt>
              <dd class="mt-1 text-sm text-text-primary"><%= @case.reviewed_at.strftime("%b %d, %Y %H:%M") %></dd>
            </div>
          <% end %>
          <% if @case.approved_by %>
            <div>
              <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Reviewed By</dt>
              <dd class="mt-1 text-sm text-text-primary"><%= @case.approved_by.email_address %></dd>
            </div>
          <% end %>
          <% if @case.executed_at %>
            <div>
              <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Executed</dt>
              <dd class="mt-1 text-sm text-text-primary"><%= @case.executed_at.strftime("%b %d, %Y %H:%M") %></dd>
            </div>
          <% end %>
        </dl>

        <% if @case.notes.present? %>
          <div class="mt-4 pt-4 border-t border-border dark:border-gray-700">
            <dt class="text-xs font-medium text-text-tertiary uppercase tracking-wider mb-1">Notes</dt>
            <dd class="text-sm text-text-secondary"><%= @case.notes %></dd>
          </div>
        <% end %>
      </div>

      <% if @simulation.present? %>
        <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
          <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Simulation Preview</h3>
          <%= render partial: "loans/restructures/simulation_panel", locals: { simulation: @simulation } %>
        </div>
      <% end %>
    </div>

    <div class="space-y-4">
      <% if @case.draft? || @case.rejected? %>
        <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-4">
          <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-3">Actions</h3>
          <div class="space-y-2">
            <%= button_to "Submit for Approval", submit_loans_restructure_path(@case), method: :post, class: "btn-primary w-full text-sm", data: { turbo_confirm: "Submit this restructure case for approval?" } %>
            <%= link_to "Edit Case", new_loans_restructure_path(loan_id: @loan.id, type: @case.restructure_type), class: "btn-secondary w-full text-sm text-center block" %>
          </div>
        </div>
      <% end %>

      <% if @case.submitted? || @case.under_review? %>
        <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-4">
          <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-3">Review</h3>
          <div class="space-y-2">
            <%= button_to "Approve", approve_loans_restructure_path(@case), method: :post, class: "btn-primary w-full text-sm", data: { turbo_confirm: "Approve this restructure case?" } %>
            <%= button_to "Reject", reject_loans_restructure_path(@case), method: :post, class: "btn-danger w-full text-sm", data: { turbo_confirm: "Reject this restructure case?" } %>
          </div>
        </div>
      <% end %>

      <% if @case.approved? %>
        <div class="rounded-xl border border-emerald-500/30 bg-emerald-500/10 p-4">
          <h3 class="text-sm font-semibold text-emerald-400 mb-3">Ready to Execute</h3>
          <p class="text-xs text-text-tertiary mb-3">This restructure case has been approved and is ready for execution.</p>
          <%= button_to "Execute Restructure", execute_loans_restructure_path(@case), method: :post, class: "btn-primary w-full text-sm", data: { turbo_confirm: "Execute this restructure? This action cannot be undone." } %>
        </div>
      <% end %>

      <% if @case.executed? %>
        <div class="rounded-xl border border-positive-500/30 bg-positive-500/10 p-4">
          <div class="flex items-center gap-2 text-positive-400">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
            </svg>
            <span class="text-sm font-semibold">Executed Successfully</span>
          </div>
          <p class="text-xs text-emerald-400/70 mt-1">Completed <%= time_ago_in_words(@case.executed_at) %> ago</p>
        </div>
      <% end %>

      <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-4">
        <h3 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-2">Loan Info</h3>
        <dl class="space-y-2">
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Reference</dt>
            <dd class="text-xs font-mono text-text-primary"><%= @loan.reference_number %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Outstanding</dt>
            <dd class="text-xs font-medium text-text-primary"><%= number_to_currency(@loan.outstanding_principal_cents.to_f / 100, unit: "PHP ") %></dd>
          </div>
          <div class="flex justify-between">
            <dt class="text-xs text-text-tertiary">Status</dt>
            <dd class="text-xs capitalize text-text-primary"><%= @loan.status %></dd>
          </div>
        </dl>
      </div>
    </div>
  </div>
</div>
