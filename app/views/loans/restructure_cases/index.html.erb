<% content_for :page_title, "Restructure Cases" %>
<% content_for :page_subtitle, "All loan restructure requests" %>

<div class="animate-fade-in">
  <div class="mb-4 flex items-center justify-between">
    <div class="flex items-center gap-4">
      <span class="text-sm text-text-secondary"><%= @total_cases %> case(s)</span>
      <%= link_to "Pending (#{@pending_count})", loans_restructure_cases_path(status: "submitted"), class: "text-xs font-medium #{params[:status] == 'submitted' ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %>
      <%= link_to "Approved (#{@approved_count})", loans_restructure_cases_path(status: "approved"), class: "text-xs font-medium #{params[:status] == 'approved' ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %>
      <%= link_to "Executed (#{@executed_count})", loans_restructure_cases_path(status: "executed"), class: "text-xs font-medium #{params[:status] == 'executed' ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %>
      <%= link_to "All", loans_restructure_cases_path, class: "text-xs font-medium #{params[:status].blank? ? 'text-primary' : 'text-text-tertiary hover:text-text-secondary'}" %>
    </div>
  </div>

  <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 overflow-hidden">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="border-b border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50">
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">ID</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Loan</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Type</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Status</th>
          <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Requested By</th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Date</th>
          <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Actions</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border dark:divide-gray-800">
        <% if @cases.any? %>
          <% @cases.each do |c| %>
            <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors">
              <td class="px-4 py-3"><span class="font-mono text-xs">#<%= c.id %></span></td>
              <td class="px-4 py-3 font-medium text-text-primary"><%= c.loan.reference_number %></td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize
                  <%= c.modification? ? 'bg-primary-50 text-primary' : c.refinance? ? 'bg-positive-50 text-positive' : 'bg-purple-50 text-purple-500' %>">
                  <%= c.restructure_type %>
                </span>
              </td>
              <td class="px-4 py-3">
                <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize
                  <%= case c.status
                  when 'draft' then 'bg-gray-100 text-text-tertiary'
                  when 'submitted', 'under_review' then 'bg-amber-50 text-amber-500'
                  when 'approved' then 'bg-primary-50 text-primary'
                  when 'rejected' then 'bg-danger-50 text-danger'
                  when 'executed' then 'bg-positive-50 text-positive'
                  else 'bg-gray-100 text-text-tertiary'
                  end %>">
                  <%= c.status %>
                </span>
              </td>
              <td class="px-4 py-3 text-text-secondary"><%= c.requested_by&.email_address || "System" %></td>
              <td class="px-4 py-3 text-right text-text-tertiary"><%= c.created_at.strftime("%b %d, %Y") %></td>
              <td class="px-4 py-3 text-right">
                <%= link_to "View", loans_restructure_path(c), class: "text-sm font-medium text-primary hover:text-primary-700" %>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="7" class="px-4 py-12 text-center text-sm text-text-tertiary">No restructure cases found.</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.present? %>
    <div class="mt-4">
      <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
    </div>
  <% end %>
</div>
