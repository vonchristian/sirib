<%= form_with model: [:loans, product], class: "space-y-6", data: { controller: "loan-product-form" } do |f| %>
  <% if product.errors.any? %>
    <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger">
      <ul class="list-inside list-disc">
        <% product.errors.each do |error| %>
          <li><%= error.full_message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6 sm:p-8 space-y-6">
    <div>
      <h3 class="text-base font-semibold text-text-primary dark:text-white">Product Details</h3>
      <p class="mt-1 text-sm text-text-tertiary">Define the terms and conditions for this loan product.</p>
    </div>

    <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
      <div class="sm:col-span-2">
        <%= f.label :name, class: "field-label" %>
        <%= f.text_field :name, required: true, placeholder: "e.g. Regular Salary Loan", class: "field-input" %>
      </div>
      <div class="sm:col-span-2">
        <%= f.label :description, class: "field-label" %>
        <%= f.text_area :description, rows: 3, placeholder: "Describe the loan product...", class: "field-input" %>
      </div>
      <div>
        <%= f.label :interest_rate, class: "field-label" %>
        <div class="relative">
          <%= f.number_field :interest_rate, required: true, step: 0.01, min: 0.01, max: 100, placeholder: "5.0", class: "field-input pr-8" %>
          <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-sm text-text-tertiary">%</span>
        </div>
      </div>
      <div>
        <%= f.label :interest_calculation, class: "field-label" %>
        <%= f.select :interest_calculation,
              options_for_select([["Straight Line", "straight_line"], ["Declining Balance", "declining_balance"]], product.interest_calculation),
              {}, class: "field-input" %>
      </div>
      <div>
        <%= f.label :max_term_months, class: "field-label" %>
        <%= f.number_field :max_term_months, required: true, min: 1, placeholder: "12", class: "field-input" %>
      </div>
      <div>
        <label class="field-label">&nbsp;</label>
        <label class="flex items-center gap-2 text-sm text-text-primary dark:text-white cursor-pointer">
          <%= f.check_box :requires_collateral, class: "h-4 w-4 rounded border-border text-primary focus:ring-primary" %>
          Requires collateral
        </label>
      </div>
      <div>
        <%= f.label :status, class: "field-label" %>
        <%= f.select :status, options_for_select([["Active", "active"], ["Inactive", "inactive"]], product.status), {}, class: "field-input" %>
      </div>
    </div>
  </div>

  <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6 sm:p-8 space-y-4" data-controller="charges-form">
    <div>
      <h3 class="text-base font-semibold text-text-primary dark:text-white">Charges & Fees</h3>
      <p class="mt-1 text-sm text-text-tertiary">Define fees applied when this product is used (e.g. Service Fee, Application Fee).</p>
    </div>

    <div class="space-y-3" data-charges-form-target="list">
      <%= f.fields_for :loan_charges do |cf| %>
        <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 items-end p-3 rounded-lg bg-surface-alt dark:bg-gray-800/50">
          <div class="sm:col-span-1">
            <%= cf.label :name, class: "field-label" %>
            <%= cf.text_field :name, placeholder: "Fee name", class: "field-input" %>
          </div>
          <div>
            <%= cf.label :charge_type, class: "field-label" %>
            <%= cf.select :charge_type, options_for_select([["Fixed (PHP)", "fixed"], ["Percentage (%)", "percentage"]], cf.object.charge_type), {}, class: "field-input" %>
          </div>
          <div>
            <%= cf.label :value, class: "field-label" %>
            <%= cf.number_field :value, step: 0.01, min: 0.01, placeholder: "0.00", class: "field-input" %>
          </div>
          <div class="flex items-end pb-1">
            <%= cf.hidden_field :_destroy, value: "0" %>
            <button type="button" data-action="charges-form#remove"
                    class="text-sm text-danger hover:text-danger-700 transition-colors">
              <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
              </svg>
            </button>
          </div>
        </div>
      <% end %>
    </div>

    <template data-charges-form-target="template">
      <div class="grid grid-cols-1 sm:grid-cols-4 gap-3 items-end p-3 rounded-lg bg-surface-alt dark:bg-gray-800/50">
        <div class="sm:col-span-1">
          <label class="field-label">Fee Name</label>
          <input type="text" name="loan_product[loan_charges_attributes][__INDEX__][name]" placeholder="Fee name" class="field-input">
        </div>
        <div>
          <label class="field-label">Type</label>
          <select name="loan_product[loan_charges_attributes][__INDEX__][charge_type]" class="field-input">
            <option value="fixed">Fixed (PHP)</option>
            <option value="percentage">Percentage (%)</option>
          </select>
        </div>
        <div>
          <label class="field-label">Value</label>
          <input type="number" name="loan_product[loan_charges_attributes][__INDEX__][value]" step="0.01" min="0.01" placeholder="0.00" class="field-input">
        </div>
        <div class="flex items-end pb-1">
          <button type="button" data-action="charges-form#remove"
                  class="text-sm text-danger hover:text-danger-700 transition-colors">
            <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12"/>
            </svg>
          </button>
        </div>
      </div>
    </template>

    <button type="button" data-action="charges-form#add"
            class="btn-ghost">
      <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3"/>
      </svg>
      Add Charge
    </button>
  </div>

  <div class="flex items-center justify-between">
    <%= link_to "Cancel", loans_products_path, class: "btn-secondary" %>
    <%= f.submit product.new_record? ? "Create Product" : "Update Product", class: "btn-primary" %>
  </div>
<% end %>
