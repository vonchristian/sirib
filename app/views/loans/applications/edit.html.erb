<% content_for :page_title, "Loan Application" %>
<% content_for :page_subtitle, "#{@application.reference_number || 'New'}" %>



<div class="animate-fade-in max-w-5xl mx-auto" data-controller="loan-wizard" data-current-step="<%= @initial_step %>" data-action="autocomplete:selected->loan-wizard#onProductSelected">
  <%= form_with model: @application, url: loans_application_path(@application.uuid), method: :patch, html: { class: "space-y-6" } do |f| %>
    <% if @application.errors.any? %>
      <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger">
        <ul class="list-inside list-disc">
          <% @application.errors.each do |error| %>
            <li><%= error.full_message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.hidden_field :current_step, data: { loan_wizard_target: "currentStep" } %>

    <div data-loan-wizard-target="stepper" class="hidden sm:block">
      <div class="flex items-center justify-between">
        <% step_labels = ["Loan Details", "Income Sources", "Co-Makers", "Collaterals", "Schedule"] %>
        <% step_labels.each_with_index do |label, i| %>
          <div class="flex flex-col items-center flex-1 min-w-0" data-step-index="<%= i %>">
            <div class="flex items-center w-full">
              <div class="flex-1 h-px <%= i.zero? ? 'invisible' : '' %>" data-step-connector data-step-index="<%= i %>"></div>
              <div class="relative flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border-2 text-xs font-semibold transition-all duration-300" data-step-circle data-step-index="<%= i %>">
                <span data-step-number><%= i + 1 %></span>
                <svg data-step-check class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"/></svg>
              </div>
              <div class="flex-1 h-px <%= i == step_labels.length - 1 ? 'invisible' : '' %>" data-step-connector data-step-index="<%= i %>"></div>
            </div>
            <span class="mt-1.5 text-[11px] font-medium leading-tight text-center truncate max-w-[6rem] transition-colors duration-200" data-step-label data-step-index="<%= i %>"><%= label %></span>
          </div>
        <% end %>
      </div>
    </div>
    <div class="sm:hidden flex items-center justify-between">
      <div class="flex items-center gap-1.5 flex-1">
        <% 5.times do |i| %>
          <div class="flex-1 h-1.5 rounded-full transition-colors duration-300" data-loan-wizard-target="dotMobile"></div>
        <% end %>
      </div>
      <span class="text-xs text-text-tertiary ml-3" data-loan-wizard-target="counter">Step 1 of 5</span>
    </div>

    <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6 sm:p-8">

      <%# Step 1: Loan Details %>
      <div data-loan-wizard-target="step">
        <h2 class="text-lg font-semibold text-text-primary dark:text-white mb-4">Loan Details</h2>
        <p class="mb-4 text-sm text-text-secondary">Select product, set amount, and term. The calculator below updates in real time.</p>

        <div class="grid grid-cols-1 gap-4 lg:grid-cols-3">
          <div class="lg:col-span-2 space-y-4">
            <div class="field-group" data-controller="autocomplete" data-autocomplete-url-value="/loans/searches/members">
              <%= f.label :member_id, "Member", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
              <div class="relative">
                <%= f.hidden_field :member_id, required: true, data: { autocomplete_target: "hidden" } %>
                <input type="text" name="member_search"
                       value="<%= @application.member&.name %>"
                       placeholder="Search by name or mobile number..."
                       class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                       data-autocomplete-target="input"
                       data-action="input->autocomplete#search keydown->autocomplete#keyboard">
                <div data-autocomplete-target="results"
                     class="hidden absolute z-50 mt-1 w-full rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 shadow-lg overflow-hidden max-h-60 overflow-y-auto"></div>
              </div>
            </div>
            <div class="field-group" data-controller="autocomplete" data-autocomplete-url-value="/loans/searches/loan_products">
              <%= f.label :loan_product_id, "Loan Product", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
              <div class="relative">
                <%= f.hidden_field :loan_product_id, required: true, data: { autocomplete_target: "hidden", loan_wizard_target: "productAutocomplete" } %>
                <input type="text" name="product_search"
                       value="<%= @application.loan_product&.name %>"
                       placeholder="Search product name..."
                       class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                       data-autocomplete-target="input"
                       data-action="input->autocomplete#search keydown->autocomplete#keyboard">
                <div data-autocomplete-target="results"
                     class="hidden absolute z-50 mt-1 w-full rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 shadow-lg overflow-hidden max-h-60 overflow-y-auto"></div>
              </div>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="field-group">
                <%= f.label :amount_cents, "Loan Amount (PHP)", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                <%= f.number_field :amount_cents, required: true, min: 1, step: 0.01,
                      placeholder: "e.g. 50000",
                      class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none", data: { loan_wizard_target: "amountField", action: "input->loan-wizard#recalculate" } %>
              </div>
              <div class="field-group">
                <%= f.label :term_months, "Term (months)", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                <%= f.number_field :term_months, required: true, min: 1,
                      placeholder: "e.g. 12",
                      class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none", data: { loan_wizard_target: "termField", action: "input->loan-wizard#recalculate" } %>
              </div>
            </div>
            <div class="field-group">
              <%= f.label :interest_rate, "Interest Rate (%)", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
              <div class="relative">
                <%= f.number_field :interest_rate, required: true, step: 0.01, min: 0.01, max: 100,
                      class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none pr-8", data: { loan_wizard_target: "rateField", action: "input->loan-wizard#recalculate" } %>
                <span class="pointer-events-none absolute inset-y-0 right-3 flex items-center text-sm text-text-tertiary">%</span>
              </div>
              <p class="mt-1 text-xs text-text-tertiary">Pre-filled from product. Adjust if needed.</p>
            </div>
            <div>
              <%= f.label :notes, class: "block mb-1.5 text-xs font-medium text-text-primary" %>
              <%= f.text_area :notes, rows: 2, placeholder: "Any additional notes...", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
            </div>
          </div>

          <div class="lg:col-span-1">
            <div class="rounded-lg border border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50 p-4 sticky top-4">
              <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-3 flex items-center gap-1.5">
                <svg class="h-4 w-4 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
                </svg>
                Loan Calculator
              </h3>

              <div data-loan-wizard-target="calculatorSummary" class="space-y-2 text-sm">
                <div class="flex justify-between text-text-secondary">
                  <span>Loan Amount</span>
                  <span class="font-medium text-text-primary" data-loan-wizard-target="displayAmount">PHP 0.00</span>
                </div>

                <div data-loan-wizard-target="chargesList" class="space-y-1">
                  <div class="flex justify-between text-xs text-text-tertiary">
                    <span>Charges & Fees</span>
                    <span>—</span>
                  </div>
                </div>

                <div class="border-t border-border dark:border-gray-700 pt-2 flex justify-between text-sm font-medium">
                  <span>Total Charges</span>
                  <span data-loan-wizard-target="totalCharges" class="text-danger">PHP 0.00</span>
                </div>

                <div class="border-t-2 border-primary/30 pt-2 flex justify-between text-sm font-semibold">
                  <span>Net Proceeds (Cash Out)</span>
                  <span data-loan-wizard-target="netProceeds" class="text-positive">PHP 0.00</span>
                </div>

                <div class="border-t border-border dark:border-gray-700 pt-2 flex justify-between text-xs text-text-secondary">
                  <span>Est. Monthly Amortization</span>
                  <span data-loan-wizard-target="monthlyAmort" class="font-medium text-text-primary">PHP 0.00</span>
                </div>
              </div>

              <div data-loan-wizard-target="calculatorEmpty" class="text-center py-6 text-xs text-text-tertiary">
                <svg class="mx-auto h-8 w-8 text-text-tertiary/50 mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 6h9.75M10.5 6a1.5 1.5 0 1 1-3 0m3 0a1.5 1.5 0 1 0-3 0M3.75 6H7.5m3 12h9.75m-9.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-3.75 0H7.5m9-6h3.75m-3.75 0a1.5 1.5 0 0 1-3 0m3 0a1.5 1.5 0 0 0-3 0m-9.75 0h3.75m9-6h.008v.008h-.008V6Z"/>
                </svg>
                Select a product and enter the loan amount to see the breakdown.
              </div>
            </div>
          </div>
        </div>
      </div>

      <%# Step 2: Sources of Income %>
      <div data-loan-wizard-target="step" class="hidden">
        <h2 class="text-lg font-semibold text-text-primary dark:text-white mb-4">Sources of Income</h2>
        <p class="mb-4 text-sm text-text-secondary">List all sources of income for this application.</p>

        <div id="income-sources" class="space-y-4">
          <% entries = @application.sources_of_income.presence || [{}] %>
          <% entries.each_with_index do |src, idx| %>
            <div class="rounded-lg border border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50 p-4 income-entry">
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                  <label class="block mb-1.5 text-xs font-medium text-text-primary">Source Type</label>
                  <select name="lending_loan_application[sources_of_income][][source_type]"
                          required class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                    <option value="">Select type</option>
                    <% %w[Employment Self-Employed Business Remittances Pension Investment Others].each do |t| %>
                      <option value="<%= t %>" <%= "selected" if src["source_type"] == t %>><%= t %></option>
                    <% end %>
                  </select>
                </div>
                <div>
                  <label class="block mb-1.5 text-xs font-medium text-text-primary">Monthly Income (PHP)</label>
                  <input type="number" name="lending_loan_application[sources_of_income][][monthly_income]"
                         value="<%= src["monthly_income"] %>" required min="0" step="0.01"
                         placeholder="0.00" class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none">
                </div>
              </div>
            </div>
          <% end %>
        </div>

        <button type="button" data-action="loan-wizard#addIncome"
                class="inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors mt-3">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3"/>
          </svg>
          Add Income Source
        </button>
      </div>

      <%# Step 3: Co-Makers %>
      <div data-loan-wizard-target="step" class="hidden">
        <h2 class="text-lg font-semibold text-text-primary dark:text-white mb-4">Co-Makers</h2>
        <p class="mb-4 text-sm text-text-secondary">Add other members as co-makers for this loan application.</p>

        <div id="co-makers" class="space-y-4">
          <%= f.fields_for :loan_co_makers do |cf| %>
            <div class="co-maker-entry rounded-lg border border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50 p-4">
              <div class="field-group" data-controller="autocomplete" data-autocomplete-url-value="/loans/searches/members">
                <%= cf.label :member_id, "Co-Maker", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                <div class="relative">
                  <%= cf.hidden_field :member_id, required: true, data: { autocomplete_target: "hidden" } %>
                  <input type="text" name="lending_loan_application[loan_co_makers_attributes][<%= cf.index %>][member_search]"
                         value="<%= cf.object.member&.name %>"
                         placeholder="Search by name or mobile number..."
                         class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                         data-autocomplete-target="input"
                         data-action="input->autocomplete#search keydown->autocomplete#keyboard">
                  <div data-autocomplete-target="results"
                       class="hidden absolute z-50 mt-1 w-full rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 shadow-lg overflow-hidden max-h-60 overflow-y-auto"></div>
                </div>
              </div>
              <% if cf.object.persisted? %>
                <div class="mt-3">
                  <label class="flex items-center gap-2 text-sm text-danger cursor-pointer">
                    <%= cf.check_box :_destroy, class: "h-4 w-4 rounded border-border text-danger focus:ring-danger" %>
                    Remove this co-maker
                  </label>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>

        <button type="button" data-action="loan-wizard#addCoMaker"
                class="inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors mt-3">
          <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3"/>
          </svg>
          Add Co-Maker
        </button>
      </div>

      <%# Step 4: Collaterals %>
      <div data-loan-wizard-target="step" class="hidden">
        <h2 class="text-lg font-semibold text-text-primary dark:text-white mb-4">Collaterals</h2>
        <p class="mb-4 text-sm text-text-secondary">Add property or asset details used as collateral.</p>

        <div id="collaterals">
          <%= f.fields_for :loan_collaterals do |cf| %>
            <div class="rounded-lg border border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50 p-4 mb-4 collateral-entry">
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-2">
                <div>
                  <%= cf.label :category, class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.select :category,
                        options_for_select(Lending::LoanCollateral::CATEGORIES.map { |c| [c.titleize, c] }, cf.object.category),
                        { prompt: "Select category" }, required: true, class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none",
                        data: { action: "change->loan-wizard#toggleCollateralDetails" } %>
                </div>
                <div>
                  <%= cf.label :name, class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.text_field :name, required: true, placeholder: "e.g. Lot 123, Brgy. San Jose", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
                </div>
                <div class="sm:col-span-2">
                  <%= cf.label :description, class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.text_area :description, rows: 2, placeholder: "Describe the property...", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
                </div>
                <div>
                  <%= cf.label :assessed_value_cents, "Assessed Value (PHP)", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.number_field :assessed_value_cents, step: 0.01, min: 0,
                        placeholder: "0.00", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
                </div>
                <div>
                  <%= cf.label :address, class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.text_field :address, placeholder: "Property address", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
                </div>
                <div>
                  <%= cf.label :pin_lat, "Latitude", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.text_field :pin_lat, placeholder: "e.g. 14.5995", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
                </div>
                <div>
                  <%= cf.label :pin_lng, "Longitude", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.text_field :pin_lng, placeholder: "e.g. 120.9842", class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %>
                </div>
                <div class="sm:col-span-2">
                  <%= cf.label :images, "Property Images", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.file_field :images, multiple: true, accept: "image/*",
                        class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-1 file:text-xs file:font-medium file:text-white hover:file:bg-primary-700" %>
                </div>
                <div class="sm:col-span-2">
                  <%= cf.label :details, "Additional Details (JSON)", class: "block mb-1.5 text-xs font-medium text-text-primary" %>
                  <%= cf.text_area :details, rows: 2,
                        value: cf.object.details.is_a?(Hash) ? cf.object.details.to_json : cf.object.details,
                        placeholder: '{"lot_area": "200 sqm", "zoning": "residential"}',
                        class: "block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none font-mono text-xs" %>
                </div>
              </div>
              <% if cf.object.persisted? %>
                <div class="mt-3">
                  <label class="flex items-center gap-2 text-sm text-danger cursor-pointer">
                    <%= cf.check_box :_destroy, class: "h-4 w-4 rounded border-border text-danger focus:ring-danger" %>
                    Remove this collateral
                  </label>
                </div>
              <% end %>
            </div>
          <% end %>
        </div>
      </div>

      <%# Step 4: Repayment Schedule %>
      <div data-loan-wizard-target="step" class="hidden">
        <h2 class="text-lg font-semibold text-text-primary dark:text-white mb-4">Repayment Schedule</h2>
        <p class="mb-4 text-sm text-text-secondary">Review and generate the repayment schedule.</p>

        <% if @application.loan_repayment_schedules.any? %>
          <div class="rounded-lg border border-border overflow-hidden">
            <table class="min-w-full text-sm">
              <thead>
                <tr class="bg-surface-alt border-b border-border dark:bg-gray-800/50 dark:border-gray-700">
                  <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">#</th>
                  <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Due Date</th>
                  <th class="px-4 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Principal</th>
                  <th class="px-4 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Interest</th>
                  <th class="px-4 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Total</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-border dark:divide-gray-800">
                <% @application.loan_repayment_schedules.order(:sequence).each do |sched| %>
                  <tr>
                    <td class="px-4 py-2 text-text-secondary"><%= sched.sequence %></td>
                    <td class="px-4 py-2 text-text-primary"><%= sched.due_date.strftime("%b %d, %Y") %></td>
                    <td class="px-4 py-2 text-right text-text-primary"><%= number_to_currency(sched.principal_cents.to_f / 100, unit: "PHP ") %></td>
                    <td class="px-4 py-2 text-right text-text-primary"><%= number_to_currency(sched.interest_cents.to_f / 100, unit: "PHP ") %></td>
                    <td class="px-4 py-2 text-right font-medium text-text-primary"><%= number_to_currency(sched.total_cents.to_f / 100, unit: "PHP ") %></td>
                  </tr>
                <% end %>
              </tbody>
              <tfoot class="bg-surface-alt dark:bg-gray-800/50">
                <tr class="border-t border-border dark:border-gray-700">
                  <td colspan="2" class="px-4 py-2 text-xs font-semibold text-text-tertiary uppercase">Total</td>
                  <td class="px-4 py-2 text-right font-semibold text-text-primary">
                    <%= number_to_currency(@application.loan_repayment_schedules.sum(:principal_cents).to_f / 100, unit: "PHP ") %>
                  </td>
                  <td class="px-4 py-2 text-right font-semibold text-text-primary">
                    <%= number_to_currency(@application.loan_repayment_schedules.sum(:interest_cents).to_f / 100, unit: "PHP ") %>
                  </td>
                  <td class="px-4 py-2 text-right font-semibold text-text-primary">
                    <%= number_to_currency(@application.loan_repayment_schedules.sum { |s| s.total_cents }.to_f / 100, unit: "PHP ") %>
                  </td>
                </tr>
              </tfoot>
            </table>
          </div>
        <% else %>
          <div class="rounded-lg border-2 border-dashed border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50 px-6 py-12 text-center">
            <svg class="mx-auto h-10 w-10 text-text-tertiary mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5m-9-6h.008v.008H12v-.008ZM12 15h.008v.008H12V15Zm0 2.25h.008v.008H12v-.008ZM9.75 15h.008v.008H9.75V15Zm0 2.25h.008v.008H9.75v-.008ZM7.5 15h.008v.008H7.5V15Zm0 2.25h.008v.008H7.5v-.008Zm6.75-4.5h.008v.008h-.008v-.008Zm0 2.25h.008v.008h-.008V15Zm0 2.25h.008v.008h-.008v-.008Zm2.25-4.5h.008v.008H16.5v-.008Zm0 2.25h.008v.008H16.5V15Z" />
            </svg>
            <p class="text-sm text-text-tertiary mb-1">No repayment schedule generated yet.</p>
            <p class="text-xs text-text-tertiary">Fill in the loan details and click "Generate Schedule" below.</p>
          </div>
        <% end %>

        <%= f.submit "Generate Schedule",
              name: "commit", value: "Generate Schedule",
              class: "inline-flex items-center justify-center gap-2 rounded-md border border-border bg-surface px-5 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors mt-4" %>
      </div>
    </div>

    <div class="flex items-center justify-between">
      <div class="flex gap-2">
        <button type="button" data-loan-wizard-target="backBtn" data-action="loan-wizard#back"
                class="inline-flex items-center justify-center gap-2 rounded-md border border-border bg-surface px-5 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors hidden">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18"/>
          </svg>
          Back
        </button>
        <%= f.submit "Save Progress", class: "inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors" %>
      </div>
      <div class="flex gap-2">
        <button type="button" data-loan-wizard-target="nextBtn" data-action="loan-wizard#next"
                class="inline-flex items-center justify-center gap-2 rounded-md bg-primary px-5 py-2 text-xs font-medium text-white hover:bg-primary-700 transition-colors">
          Next
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/>
          </svg>
        </button>
        <%= f.submit "Complete Application",
              data: { loan_wizard_target: "submitBtn" },
              class: "hidden inline-flex items-center justify-center gap-2 rounded-md bg-positive px-5 py-2 text-xs font-medium text-white hover:bg-positive-700 transition-colors" %>
      </div>
    </div>
  <% end %>
</div>
