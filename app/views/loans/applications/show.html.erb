<% content_for :page_title,"Loan Application" %> <% content_for :page_subtitle, @application.reference_number %> <div class="animate-fade-in max-w-5xl mx-auto space-y-6"> <div class="flex items-center justify-between no-print"> <div> <h2 class="text-lg font-semibold text-text-primary">Loan Application</h2> <div class="mt-1 flex items-center gap-2"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset capitalize <%= case @application.status when 'draft' then 'bg-warning-50 text-warning ring-warning/20' when 'submitted' then 'bg-primary-50 text-primary ring-primary/20' when 'verified' then 'bg-primary-50 text-primary-700 ring-blue-700/20' when 'approved' then 'bg-positive-50 text-positive ring-positive/20' when 'rejected' then 'bg-danger-50 text-danger ring-danger/20' end %>"> <%= @application.status %> </span> <span class="text-xs text-text-tertiary"><%= @application.reference_number %></span> </div> </div> <div class="flex items-center gap-2"> <%= link_to download_pdf_loans_application_path(@application.uuid), class:"btn-secondary" do %> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z"/> </svg> Download PDF <% end %> <% if @application.draft? %> <%= link_to"Resume", edit_loans_application_path(@application.uuid), class:"btn-primary" %> <% end %> <% if @application.draft? && @application.complete? %> <%= button_to"Submit", submit_loans_application_path(@application.uuid), method: :post, class:"btn-positive" %> <% end %> </div> </div> <div class="rounded-xl border border-border bg-surface overflow-hidden"> <div class="p-6 sm:p-8 space-y-8"> <div> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Loan Details</h4> <dl class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-8 gap-y-3"> <div> <dt class="text-xs font-medium text-text-tertiary">Member</dt> <dd class="text-sm text-text-primary"><%= @application.member.name %></dd> </div> <div> <dt class="text-xs font-medium text-text-tertiary">Product</dt> <dd class="text-sm text-text-primary"><%= @application.loan_product.name %></dd> </div> <div> <dt class="text-xs font-medium text-text-tertiary">Amount</dt> <dd class="text-sm font-medium text-text-primary"><%= number_to_currency(@application.amount_cents.to_f / 100, unit:"PHP") %></dd> </div> <div> <dt class="text-xs font-medium text-text-tertiary">Interest Rate</dt> <dd class="text-sm text-text-primary"><%= @application.interest_rate %>%</dd> </div> <div> <dt class="text-xs font-medium text-text-tertiary">Term</dt> <dd class="text-sm text-text-primary"><%= @application.term_months %> months</dd> </div> <div> <dt class="text-xs font-medium text-text-tertiary">Calculation</dt> <dd class="text-sm capitalize text-text-primary"><%= @application.loan_product.interest_calculation.titleize %></dd> </div> </dl> </div> <hr class="border-border"> <div> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Sources of Income</h4> <% if @application.sources_of_income.any? %> <div class="space-y-2"> <% @application.sources_of_income.each do |src| %> <div class="flex items-center justify-between rounded-lg border border-border bg-surface-alt px-4 py-3"> <div> <p class="text-sm font-medium text-text-primary"><%= src["source_type"] %></p> <p class="text-xs text-text-tertiary">PHP <%= number_with_delimiter(src["monthly_income"].to_f, delimiter:",") %> / month</p> </div> </div> <% end %> </div> <% else %> <p class="text-sm text-text-tertiary italic">None provided</p> <% end %> </div> <hr class="border-border"> <div> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Collaterals</h4> <% if @application.loan_collaterals.any? %> <div class="space-y-4"> <% @application.loan_collaterals.each do |collateral| %> <div class="rounded-lg border border-border bg-surface-alt p-4"> <div class="flex items-start justify-between"> <div> <div class="flex items-center gap-2"> <span class="inline-flex items-center rounded-full bg-primary-50 px-2 py-0.5 text-xs font-medium text-primary"><%= collateral.category.titleize %></span> <span class="text-sm font-medium text-text-primary"><%= collateral.name %></span> </div> <% if collateral.description.present? %> <p class="mt-1 text-xs text-text-tertiary"><%= collateral.description %></p> <% end %> </div> <% if collateral.assessed_value_cents.present? %> <span class="text-sm font-semibold text-text-primary"><%= number_to_currency(collateral.assessed_value_cents.to_f / 100, unit:"PHP") %></span> <% end %> </div> <% if collateral.pin_lat.present? && collateral.pin_lng.present? %> <p class="mt-2 text-xs text-text-tertiary">📍 <%= collateral.pin_lat %>, <%= collateral.pin_lng %> <% if collateral.address.present? %>— <%= collateral.address %><% end %></p> <% end %> <% if collateral.images.any? %> <div class="mt-2 flex gap-2"> <% collateral.images.each do |img| %> <%= image_tag img, class:"h-16 w-20 rounded-md border border-border object-cover" %> <% end %> </div> <% end %> </div> <% end %> </div> <% else %> <p class="text-sm text-text-tertiary italic">None provided</p> <% end %> </div> <hr class="border-border"> <div> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Repayment Schedule</h4> <% if @application.loan_repayment_schedules.any? %> <div class="rounded-lg border border-border overflow-hidden"> <table class="min-w-full text-sm"> <thead> <tr class="bg-surface-alt border-b border-border"> <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">#</th> <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Due Date</th> <th class="px-4 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Principal</th> <th class="px-4 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Interest</th> <th class="px-4 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Total</th> </tr> </thead> <tbody class="divide-y divide-border"> <% @application.loan_repayment_schedules.order(:sequence).each do |sched| %> <tr> <td class="px-4 py-2 text-text-secondary"><%= sched.sequence %></td> <td class="px-4 py-2 text-text-primary"><%= sched.due_date.strftime("%b %d, %Y") %></td> <td class="px-4 py-2 text-right text-text-primary"><%= number_to_currency(sched.principal_cents.to_f / 100, unit:"PHP") %></td> <td class="px-4 py-2 text-right text-text-primary"><%= number_to_currency(sched.interest_cents.to_f / 100, unit:"PHP") %></td> <td class="px-4 py-2 text-right font-medium text-text-primary"><%= number_to_currency(sched.total_cents.to_f / 100, unit:"PHP") %></td> </tr> <% end %> </tbody> </table> </div> <% else %> <p class="text-sm text-text-tertiary italic">Not yet generated</p> <% end %> </div> <% if @application.notes.present? %> <hr class="border-border"> <div> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Notes</h4> <p class="text-sm text-text-primary"><%= @application.notes %></p> </div> <% end %> </div> </div> </div> 