<% cooperative = @application.cooperative %> 
<div style="max-width: 800px; margin: 0 auto; padding: 40px; font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #1a1a1a;"> 
  <div style="text-align: center; margin-bottom: 32px; padding-bottom: 24px; border-bottom: 2px solid #1a1a1a;"> 
    <h1 style="font-size: 18px; font-weight: 700; margin: 0; text-transform: uppercase;"><%= cooperative.name %></h1>
 
    <p style="font-size: 11px; color: #666; margin-top: 4px;"><%= cooperative.address %></p>
 
    <p style="font-size: 11px; color: #666;">Contact: <%= cooperative.contact_number %> | Reg# <%= cooperative.registration_number %></p>
 </div>
 
  <h2 style="font-size: 16px; font-weight: 700; text-align: center; margin-bottom: 24px;">LOAN APPLICATION</h2>
 
  <table style="width: 100%; border-collapse: collapse; font-size: 11px; margin-bottom: 24px;"> 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; width: 40%; background: #f5f5f5;">Application ID</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= @application.uuid %></td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Status</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc; text-transform: capitalize;"><%= @application.status %></td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Member</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= @application.member.name %></td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Loan Product</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= @application.loan_product.name %></td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Amount</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= number_to_currency(@application.amount_cents.to_f / 100, unit:"PHP") %></td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Interest Rate</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= @application.interest_rate %>% (<%= @application.loan_product.interest_calculation.titleize %>)</td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Term</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= @application.term_months %> months</td>
 </tr>
 
    <tr> 
      <td style="padding: 6px 12px; border: 1px solid #ccc; font-weight: 600; background: #f5f5f5;">Date Filed</td>
 
      <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= @application.created_at.strftime("%B %d, %Y") %></td>
 </tr>
 </table>
 
  <h3 style="font-size: 13px; font-weight: 700; margin-bottom: 8px;">Sources of Income</h3>
 <% if @application.sources_of_income.any? %> 
    <table style="width: 100%; border-collapse: collapse; font-size: 11px; margin-bottom: 24px;"> 
      <thead> 
        <tr style="background: #f5f5f5;"> 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: left; font-weight: 600;">Source</th>
 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: right; font-weight: 600;">Monthly Income</th>
 </tr>
 </thead>
 
      <tbody> <% @application.sources_of_income.each do |src| %> 
          <tr> 
            <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= src["source_type"] %></td>
 
            <td style="padding: 6px 12px; border: 1px solid #ccc; text-align: right;">PHP <%= number_with_delimiter(src["monthly_income"].to_f, delimiter:",") %></td>
 </tr>
 <% end %> </tbody>
 </table>
 <% else %> 
    <p style="font-size: 11px; color: #999; font-style: italic; margin-bottom: 24px;">None provided</p>
 <% end %> 
  <h3 style="font-size: 13px; font-weight: 700; margin-bottom: 8px;">Collaterals</h3>
 <% if @application.loan_collaterals.any? %> <% @application.loan_collaterals.each do |collateral| %> 
      <div style="border: 1px solid #ccc; padding: 12px; margin-bottom: 8px; border-radius: 4px;"> 
        <p style="font-size: 11px; margin: 0;"><strong><%= collateral.category.titleize %>:</strong> <%= collateral.name %></p>
 <% if collateral.description.present? %> 
          <p style="font-size: 11px; color: #666; margin: 4px 0 0;"><%= collateral.description %></p>
 <% end %> <% if collateral.assessed_value_cents.present? %> 
          <p style="font-size: 11px; margin: 4px 0 0;">Assessed Value: <strong><%= number_to_currency(collateral.assessed_value_cents.to_f / 100, unit:"PHP") %></strong></p>
 <% end %> <% if collateral.pin_lat.present? %> 
          <p style="font-size: 11px; color: #666; margin: 4px 0 0;">Location: <%= collateral.pin_lat %>, <%= collateral.pin_lng %></p>
 <% end %> </div>
 <% end %> <% else %> 
    <p style="font-size: 11px; color: #999; font-style: italic; margin-bottom: 24px;">None provided</p>
 <% end %> 
  <h3 style="font-size: 13px; font-weight: 700; margin-bottom: 8px;">Repayment Schedule</h3>
 <% if @application.loan_repayment_schedules.any? %> 
    <table style="width: 100%; border-collapse: collapse; font-size: 11px; margin-bottom: 24px;"> 
      <thead> 
        <tr style="background: #f5f5f5;"> 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: left; font-weight: 600;">#</th>
 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: left; font-weight: 600;">Due Date</th>
 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: right; font-weight: 600;">Principal</th>
 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: right; font-weight: 600;">Interest</th>
 
          <th style="padding: 6px 12px; border: 1px solid #ccc; text-align: right; font-weight: 600;">Total</th>
 </tr>
 </thead>
 
      <tbody> <% @application.loan_repayment_schedules.order(:sequence).each do |sched| %> 
          <tr> 
            <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= sched.sequence %></td>
 
            <td style="padding: 6px 12px; border: 1px solid #ccc;"><%= sched.due_date.strftime("%b %d, %Y") %></td>
 
            <td style="padding: 6px 12px; border: 1px solid #ccc; text-align: right;"><%= number_to_currency(sched.principal_cents.to_f / 100, unit:"PHP") %></td>
 
            <td style="padding: 6px 12px; border: 1px solid #ccc; text-align: right;"><%= number_to_currency(sched.interest_cents.to_f / 100, unit:"PHP") %></td>
 
            <td style="padding: 6px 12px; border: 1px solid #ccc; text-align: right;"><%= number_to_currency(sched.total_cents.to_f / 100, unit:"PHP") %></td>
 </tr>
 <% end %> </tbody>
 </table>
 <% else %> 
    <p style="font-size: 11px; color: #999; font-style: italic; margin-bottom: 24px;">Not yet generated</p>
 <% end %> 
  <div style="margin-top: 48px; padding-top: 24px; border-top: 2px solid #1a1a1a;"> 
    <h3 style="font-size: 13px; font-weight: 700; margin-bottom: 16px; text-align: center;">SIGNATORIES</h3>
 
    <div style="display: flex; justify-content: space-between;"> 
      <div style="text-align: center; width: 30%;"> 
        <div style="border-bottom: 1px solid #333; margin-bottom: 4px; height: 40px;"></div>
 
        <p style="font-size: 10px; color: #666; margin: 0;">Member / Applicant</p>
 </div>
 
      <div style="text-align: center; width: 30%;"> 
        <div style="border-bottom: 1px solid #333; margin-bottom: 4px; height: 40px;"></div>
 
        <p style="font-size: 10px; color: #666; margin: 0;">Loan Officer</p>
 </div>
 
      <div style="text-align: center; width: 30%;"> 
        <div style="border-bottom: 1px solid #333; margin-bottom: 4px; height: 40px;"></div>
 
        <p style="font-size: 10px; color: #666; margin: 0;">Manager / Treasurer</p>
 </div>
 </div>
 </div>
 
  <div style="margin-top: 32px; padding-top: 16px; border-top: 1px solid #ccc; font-size: 10px; color: #999; text-align: center;"> 
    <p>Printed on <%= Date.current.strftime("%B %d, %Y") %> | UUID: <%= @application.uuid %></p>
 </div>
 </div>
 
