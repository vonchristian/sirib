<% content_for :page_title, @product.name %>
<% content_for :page_subtitle, @product.product_code %>

<div class="animate-fade-in">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-xl border border-border bg-surface p-6">
        <div class="flex items-center justify-between mb-4">
          <h2 class="text-sm font-semibold text-text-primary">Product Details</h2>
          <div class="flex items-center gap-2">
            <%= link_to "Edit", edit_equity_product_path(@product), class: "inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-medium text-text-tertiary hover:text-primary hover:bg-primary-50 transition-colors no-underline" %>
            <%= button_to "Delete", equity_product_path(@product), method: :delete, class: "inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-medium text-danger hover:bg-danger-50 transition-colors", data: { turbo_confirm: "Are you sure?" } %>
          </div>
        </div>
        <dl class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-text-tertiary text-xs">Product Code</dt>
            <dd class="text-text-primary font-medium"><%= @product.product_code %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Status</dt>
            <dd class="text-text-primary"><span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize <%= @product.status == 'active' ? 'bg-positive-50 text-positive' : 'bg-surface-alt text-text-tertiary' %>"><%= @product.status %></span></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Share Type</dt>
            <dd class="text-text-primary capitalize"><%= @product.share_type %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Effective Date</dt>
            <dd class="text-text-primary"><%= @product.effective_date&.strftime("%b %d, %Y") || "Not set" %></dd>
          </div>
          <div class="col-span-2">
            <dt class="text-text-tertiary text-xs">Description</dt>
            <dd class="text-text-primary"><%= @product.description.presence || "No description" %></dd>
          </div>
        </dl>
      </div>

      <div class="rounded-xl border border-border bg-surface p-6">
        <h2 class="text-sm font-semibold text-text-primary mb-4">Share Rules</h2>
        <dl class="grid grid-cols-2 gap-4 text-sm">
          <div>
            <dt class="text-text-tertiary text-xs">Price Per Share</dt>
            <dd class="text-text-primary font-semibold text-lg"><%= @product.price_per_share.format %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Minimum Required Shares</dt>
            <dd class="text-text-primary font-medium"><%= @product.minimum_required_shares %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Maximum Allowed Shares</dt>
            <dd class="text-text-primary font-medium"><%= @product.maximum_allowed_shares || "Unlimited" %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Minimum Initial Purchase</dt>
            <dd class="text-text-primary font-medium"><%= @product.minimum_initial_purchase %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Fractional Shares</dt>
            <dd class="text-text-primary"><%= @product.allow_fractional_shares? ? "Allowed" : "Not Allowed" %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Redeemable</dt>
            <dd class="text-text-primary"><%= @product.redeemable? ? "Yes" : "No" %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Dividend Eligible</dt>
            <dd class="text-text-primary"><%= @product.dividend_eligible? ? "Yes" : "No" %></dd>
          </div>
          <div>
            <dt class="text-text-tertiary text-xs">Voting Rights</dt>
            <dd class="text-text-primary"><%= @product.voting_rights? ? "Yes" : "No" %></dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="space-y-4">
      <div class="rounded-lg border border-border bg-surface p-4 text-xs text-text-tertiary">
        <h3 class="font-semibold text-text-primary mb-2">Accounting</h3>
        <dl class="space-y-1">
          <dt class="text-text-tertiary">Equity Ledger</dt>
          <dd class="text-text-primary"><%= @product.equity_ledger&.name || "—" %></dd>
          <dt class="text-text-tertiary mt-1">Ledger Code</dt>
          <dd class="text-text-primary"><%= @product.equity_ledger&.account_code || "—" %></dd>
        </dl>
      </div>

      <div class="rounded-lg border border-border bg-surface p-4">
        <h3 class="font-semibold text-text-primary text-xs mb-2">Accounts</h3>
        <p class="text-2xl font-semibold text-text-primary"><%= @product.share_capital_accounts.count %></p>
        <p class="text-xs text-text-tertiary">member accounts</p>
      </div>
    </div>
  </div>
</div>
