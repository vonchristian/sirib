<% content_for :page_title,"Open Share Capital Account" %> <div class="animate-fade-in max-w-2xl mx-auto"> <div class="rounded-xl border border-border bg-surface p-6 sm:p-8"> <h1 class="text-lg font-semibold text-text-primary mb-6">Open Share Capital Account</h1> <%= form_with model: @account, url: equity_accounts_path, class:"space-y-5" do |f| %> <% if flash[:alert] %> <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> <ul class="list-inside list-disc"> <li><%= flash[:alert] %></li> </ul> </div> <% end %> <div> <%= f.label :share_product_id,"Share Capital Product", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.collection_select :share_product_id, @products, :id, :name, { prompt:"Select product" }, required: true, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2216%22%20height%3D%2216%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2394a3b8%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[right_0.75rem_center] pr-10" %> </div> <div> <%= f.label :member_id,"Member", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.collection_select :member_id, @members, :id, :name, { prompt:"Select member" }, required: true, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none appearance-none bg-[url('data:image/svg+xml;charset=utf-8,%3Csvg%20xmlns%3D%22http%3A%2F%2Fwww.w3.org%2F2000%2Fsvg%22%20width%3D%2216%22%20height%3D%2216%22%20viewBox%3D%220%200%2024%2024%22%20fill%3D%22none%22%20stroke%3D%22%2394a3b8%22%20stroke-width%3D%222%22%20stroke-linecap%3D%22round%22%20stroke-linejoin%3D%22round%22%3E%3Cpolyline%20points%3D%226%209%2012%2015%2018%209%22%3E%3C%2Fpolyline%3E%3C%2Fsvg%3E')] bg-no-repeat bg-[right_0.75rem_center] pr-10" %> </div> <div> <%= f.label :branch,"Branch", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :branch, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none", placeholder:"Optional" %> </div> <div> <%= f.label :remarks,"Remarks", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_area :remarks, rows: 2, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none resize-y min-h-[2.5rem]", placeholder:"Optional remarks..." %> </div> <div class="flex items-center justify-between pt-4 border-t border-border"> <%= link_to"Cancel", equity_accounts_path, class:"inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors" %> <%= f.submit"Open Account", class:"inline-flex items-center justify-center gap-2 rounded-md bg-primary px-5 py-2 text-xs font-medium text-white hover:bg-primary-700 transition-colors" %> </div> <% end %> </div> </div> 