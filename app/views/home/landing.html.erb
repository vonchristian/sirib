<%# Hero — Green drench with gradient blobs + product mockup %>
<section class="landing-hero-drench relative overflow-hidden pt-20" data-controller="reveal">
  <div class="landing-hero-pattern"></div>
  <div class="landing-blob landing-blob-1"></div>
  <div class="landing-blob landing-blob-2"></div>
  <div class="relative z-10 mx-auto max-w-7xl px-6 pt-20 pb-16">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <h1 class="landing-hero-title text-balance text-5xl leading-none sm:text-6xl lg:text-7xl">
          Cooperative banking<br>
          <span class="landing-hero-accent">without the busywork.</span>
        </h1>
        <p class="landing-hero-body mt-6 max-w-xl text-balance text-lg leading-relaxed">
          Sirib handles the repetition so your tellers, loan officers, and finance team can focus
          on the people they serve. One system for member accounts, loans, savings, cash sessions,
          and financial reporting — with zero data re-entry.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="#features" class="landing-hero-cta landing-hero-cta-primary">See What It Does</a>
          <a href="<%= new_session_path %>" class="landing-hero-cta landing-hero-cta-outline">Sign In</a>
        </div>
      </div>
      <div class="hidden lg:block">
        <div class="landing-browser-frame">
          <div class="landing-browser-toolbar">
            <span class="landing-browser-dot" style="background:#ff5f57"></span>
            <span class="landing-browser-dot" style="background:#ffbd2e"></span>
            <span class="landing-browser-dot" style="background:#28c840"></span>
          </div>
          <img src="<%= image_path('screenshots/dashboard.svg') %>" alt="Sirib dashboard">
        </div>
      </div>
    </div>
  </div>
</section>

