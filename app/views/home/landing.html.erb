      <div class="grid gap-6 sm:grid-cols-2">
        <div class="overflow-hidden rounded-lg border landing-border shadow-lg">
          <img src="<%= image_path('screenshots/members.png') %>" alt="Member management screen" class="w-full">
        </div>
