<div class="flex min-h-screen flex-col bg-surface-alt">
  <header class="border-b border-border bg-surface">
    <div class="mx-auto flex max-w-7xl items-center justify-between px-4 py-3 sm:px-6 lg:px-8">
      <div class="flex items-center gap-2">
        <div class="flex h-7 w-7 items-center justify-center rounded-md bg-primary">
          <svg class="h-4 w-4 text-white" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/>
            <circle cx="20" cy="20" r="10" fill="currentColor" opacity="0.85"/>
            <circle cx="20" cy="20" r="4" fill="white"/>
          </svg>
        </div>
        <span class="text-base font-semibold text-text-primary">Sirib</span>
      </div>

      <div class="flex items-center gap-3">
        <span class="text-sm text-text-secondary"><%= Current.user.email_address %></span>
        <%= button_to "Sign out", session_path, method: :delete, class: "rounded-lg bg-surface px-3 py-1.5 text-sm font-medium text-text-secondary ring-1 ring-inset ring-border hover:bg-gray-50 dark:hover:bg-gray-800 transition-colors" %>
      </div>
    </div>
  </header>

  <main class="flex-1">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8">
      <div class="animate-fade-in text-center">
        <div class="mx-auto flex h-14 w-14 items-center justify-center rounded-2xl bg-primary-50 dark:bg-primary-900/30">
          <svg class="h-8 w-8 text-primary" viewBox="0 0 40 40" fill="none">
            <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/>
            <circle cx="20" cy="20" r="10" fill="currentColor" opacity="0.85"/>
            <circle cx="20" cy="20" r="4" fill="white"/>
          </svg>
        </div>
        <h1 class="mt-4 text-2xl font-semibold tracking-tight text-text-primary sm:text-3xl">Welcome to Sirib</h1>
        <p class="mt-1 text-base text-text-secondary">Cooperative Banking &amp; Payments Platform</p>
      </div>

      <div class="animate-fade-in-up-1 mt-12 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        <div class="rounded-lg border border-border bg-surface px-6 py-7 transition-shadow hover:shadow-sm dark:border-gray-700 dark:bg-gray-900">
          <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 0 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125V9.75c0 .621-.504 1.125-1.125 1.125H20.25m0 0v.75c0 .414-.336.75-.75.75H3.75" />
          </svg>
          <h3 class="mt-4 text-sm font-semibold text-text-primary">Loans</h3>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">Manage loan applications, disbursements, and repayment schedules.</p>
        </div>

        <div class="rounded-lg border border-border bg-surface px-6 py-7 transition-shadow hover:shadow-sm dark:border-gray-700 dark:bg-gray-900">
          <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <h3 class="mt-4 text-sm font-semibold text-text-primary">Payments</h3>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">Process transactions, manage repayments, and track cash sessions.</p>
        </div>

        <div class="rounded-lg border border-border bg-surface px-6 py-7 transition-shadow hover:shadow-sm dark:border-gray-700 dark:bg-gray-900">
          <svg class="h-6 w-6 text-primary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
          <h3 class="mt-4 text-sm font-semibold text-text-primary">Members</h3>
          <p class="mt-1 text-sm text-text-secondary leading-relaxed">Manage cooperative member profiles, identity, and account relationships.</p>
        </div>
      </div>
    </div>
  </main>

  <footer class="border-t border-border bg-surface">
    <div class="mx-auto max-w-7xl px-4 py-5 sm:px-6 lg:px-8">
      <p class="text-center text-xs text-text-tertiary">Sirib</p>
    </div>
  </footer>
</div>
