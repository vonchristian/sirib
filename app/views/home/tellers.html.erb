<%= render "marketing_nav" %>

<%# Hero — teller-focused, green drench with gradient blobs %>
<section class="relative overflow-hidden landing-hero-drench pt-24 pb-20" data-controller="reveal">
  <div class="landing-hero-pattern"></div>
  <div class="landing-blob landing-blob-1"></div>
  <div class="landing-blob landing-blob-2"></div>
  <div class="relative z-10 mx-auto max-w-7xl px-6 pt-16">
    <div class="grid items-center gap-12 lg:grid-cols-2">
      <div>
        <p class="text-xs font-medium tracking-widest text-[#b8d4b5] uppercase mb-4" style="font-family: var(--font-mono);">For Tellers</p>
        <h1 class="landing-hero-title text-balance text-5xl leading-none sm:text-6xl lg:text-7xl">
          Process once.<br>
          <span class="landing-hero-accent">The system handles the rest.</span>
        </h1>
        <p class="landing-hero-body mt-6 max-w-xl text-balance text-lg leading-relaxed">
          Every deposit, withdrawal, and payment is entered once. Cash position, member balance,
          passbook, journal entry, and daily totals — all update simultaneously. Your tellers
          do their actual job instead of re-entering data.
        </p>
        <div class="mt-10 flex flex-wrap items-center gap-4">
          <a href="#demo" class="landing-hero-cta landing-hero-cta-primary">See It in Action</a>
          <a href="/session/new" class="landing-hero-cta landing-hero-cta-outline">Try a Demo</a>
        </div>
      </div>
      <div class="hidden lg:block">
        <div class="landing-browser-frame">
          <div class="landing-browser-toolbar">
            <span class="landing-browser-dot" style="background:#ff5f57"></span>
            <span class="landing-browser-dot" style="background:#ffbd2e"></span>
            <span class="landing-browser-dot" style="background:#28c840"></span>
          </div>
          <img src="<%= image_path('screenshots/cash_sessions.svg') %>" alt="Teller cash session screen in Sirib">
        </div>
      </div>
    </div>
  </div>
</section>

<%# Stats Strip — teller-specific metrics %>
<section class="bg-[#f0f7ef] border-b border-[#e7e5e4] py-12" data-controller="reveal">
  <div class="mx-auto max-w-7xl px-6">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-3">
      <div class="text-center">
        <p class="landing-stats-value">500+</p>
        <p class="landing-stats-label">transactions per teller per day</p>
      </div>
      <div class="text-center">
        <p class="landing-stats-value">30 min</p>
        <p class="landing-stats-label">saved per teller each day</p>
      </div>
      <div class="text-center">
        <p class="landing-stats-value">90%</p>
        <p class="landing-stats-label">reduction in reconciliation time</p>
      </div>
    </div>
  </div>
</section>

<%# Transaction Flow — horizontal 4-step visual %>
<section class="border-b border-[#e7e5e4] py-24 bg-white relative overflow-hidden" data-controller="reveal">
  <div class="landing-blob landing-blob-3" style="top: -5rem; right: 15%; opacity: 0.6;"></div>
  <div class="mx-auto max-w-7xl px-6 relative z-10">
    <div class="text-center max-w-2xl mx-auto mb-16">
      <p class="text-xs font-medium tracking-widest text-[#5b8c5a] uppercase mb-3" style="font-family: var(--font-mono);">The Flow</p>
      <h2 class="text-balance text-3xl font-normal tracking-[-0.03em] text-[#1c1917] sm:text-4xl">
        What a teller's transaction looks like in Sirib
      </h2>
    </div>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-4" data-reveal-item>
      <div class="text-center relative">
        <div class="mx-auto w-14 h-14 rounded-full bg-[#f0f7ef] flex items-center justify-center mb-4 text-[#5b8c5a]">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/></svg>
        </div>
        <p class="text-xs font-medium text-[#3d6b3c] mb-2" style="font-family: var(--font-mono); letter-spacing: 0.1em;">STEP 1</p>
        <h3 class="text-base font-medium text-[#1c1917] mb-2">Member walks in</h3>
        <p class="text-sm leading-relaxed text-[#6e6358]">Teller looks up member by name, account number, or ID. All information — savings, loans, share capital — on one screen.</p>
      </div>
      <div class="text-center relative">
        <div class="mx-auto w-14 h-14 rounded-full bg-[#f0f7ef] flex items-center justify-center mb-4 text-[#5b8c5a]">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 5H7a2 2 0 0 0-2 2v12a2 2 0 0 0 2 2h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2h-2"/><path d="M9 5a2 2 0 0 1 2-2h2a2 2 0 0 1 2 2v0a2 2 0 0 1-2 2h-2a2 2 0 0 1-2-2z"/><path d="M9 12h6M9 12a2 2 0 1 0 0 4h6a2 2 0 1 0 0-4M9 12v4"/></svg>
        </div>
        <p class="text-xs font-medium text-[#3d6b3c] mb-2" style="font-family: var(--font-mono); letter-spacing: 0.1em;">STEP 2</p>
        <h3 class="text-base font-medium text-[#1c1917] mb-2">Transaction entered</h3>
        <p class="text-sm leading-relaxed text-[#6e6358]">Deposit, withdrawal, or payment. Sirib validates against account limits, cash position, and member standing before proceeding.</p>
      </div>
      <div class="text-center relative">
        <div class="mx-auto w-14 h-14 rounded-full bg-[#f0f7ef] flex items-center justify-center mb-4 text-[#5b8c5a]">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M6 9V2h12v7"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
        </div>
        <p class="text-xs font-medium text-[#3d6b3c] mb-2" style="font-family: var(--font-mono); letter-spacing: 0.1em;">STEP 3</p>
        <h3 class="text-base font-medium text-[#1c1917] mb-2">Passbook prints</h3>
        <p class="text-sm leading-relaxed text-[#6e6358]">Updated balance prints automatically. No handwriting, no errors. Each line is clear and matches exactly what's in the system.</p>
      </div>
      <div class="text-center relative">
        <div class="mx-auto w-14 h-14 rounded-full bg-[#f0f7ef] flex items-center justify-center mb-4 text-[#5b8c5a]">
          <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5.586a1 1 0 0 1 .707.293l5.414 5.414a1 1 0 0 1 .293.707V19a2 2 0 0 1-2 2z"/></svg>
        </div>
        <p class="text-xs font-medium text-[#3d6b3c] mb-2" style="font-family: var(--font-mono); letter-spacing: 0.1em;">STEP 4</p>
        <h3 class="text-base font-medium text-[#1c1917] mb-2">Everything updates</h3>
        <p class="text-sm leading-relaxed text-[#6e6358]">Cash position, daily totals, and journal entry — all as part of the same action. No separate entries, no end-of-day catch-up.</p>
      </div>
    </div>
  </div>
</section>

<%# What Gets Automated — 4-card grid %>
