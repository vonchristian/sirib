<% content_for :page_title, "Two-Factor Authentication" %>

<div class="min-h-screen flex items-center justify-center px-4" style="background: var(--bg-primary);">
  <div class="w-full max-w-sm">
    <div class="text-center mb-8">
      <div class="flex items-center justify-center mb-4">
        <div class="flex h-12 w-12 items-center justify-center rounded-xl" style="background: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);">
          <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
          </svg>
        </div>
      </div>
      <h1 class="text-xl font-semibold" style="color: var(--text-primary);">Two-Factor Authentication</h1>
      <p class="text-sm mt-1" style="color: var(--text-secondary);">Enter the code from your authenticator app or a recovery code.</p>
    </div>

    <% if flash[:alert] %>
      <div class="mb-4 rounded-md border border-danger/20 bg-danger-50 p-3 text-sm text-danger">
        <%= flash[:alert] %>
      </div>
    <% end %>

    <%= form_tag verify_mfa_path, class: "space-y-4", data: { turbo: false, controller: "otp-input", otp_auto_submit: "true" } do %>
      <div>
        <%= text_field_tag :code, nil,
            class: "input text-center text-2xl font-mono tracking-[0.5em] h-14",
            placeholder: "000000",
            inputmode: "numeric",
            autocomplete: "one-time-code",
            required: true,
            autofocus: true,
            data: { otp_input_target: "input" } %>
      </div>
      <%= submit_tag "Verify", class: "btn-primary w-full h-11 text-base", data: { disable_with: "Verifying..." } %>
    <% end %>

    <div class="mt-6 text-center">
      <%= link_to "Back to sign in", new_session_path, class: "text-xs font-medium underline", style: "color: var(--text-muted);" %>
    </div>
  </div>
</div>
