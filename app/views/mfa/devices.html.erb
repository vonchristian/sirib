<% content_for :page_title,"Trusted Devices" %> <% content_for :page_subtitle,"Manage devices that can bypass two-factor authentication" %> <div class="animate-fade-in"> <div class="flex items-center justify-between mb-6"> <div> <h2 class="text-lg font-semibold" style="color: var(--text-primary);">Trusted Devices</h2> <p class="text-sm mt-1" style="color: var(--text-secondary);">Devices trusted for <%= Access::TrustedDevice::TRUST_DURATION.in_days.to_i %> days after MFA verification.</p> </div> <% if @devices.any? %> <%= button_to"Revoke All", revoke_all_devices_mfa_path, method: :delete, class:"rounded-md border border-danger/30 bg-danger-50 px-4 py-2 text-xs font-semibold text-danger hover:bg-danger hover:text-white transition-colors", data: { turbo_confirm:"Are you sure? This will require MFA on all devices on next login." } %> <% end %> </div> <% if @devices.any? %> <div class="rounded-lg border border-border bg-surface overflow-hidden"> <table class="w-full text-sm"> <thead> <tr class="border-b border-border bg-surface-alt"> <th class="text-left px-4 py-3 font-medium" style="color: var(--text-secondary);">Device</th> <th class="text-left px-4 py-3 font-medium" style="color: var(--text-secondary);">Last Used</th> <th class="text-left px-4 py-3 font-medium" style="color: var(--text-secondary);">Expires</th> <th class="text-right px-4 py-3 font-medium" style="color: var(--text-secondary);">Actions</th> </tr> </thead> <tbody class="divide-y divide-border"> <% @devices.each do |device| %> <tr class="hover:bg-surface-alt/50 transition-colors"> <td class="px-4 py-3"> <div class="flex items-center gap-3"> <svg class="w-5 h-5 flex-shrink-0" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"> <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 0 0 6 3.75v16.5a2.25 2.25 0 0 0 2.25 2.25h7.5A2.25 2.25 0 0 0 18 20.25V3.75a2.25 2.25 0 0 0-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3"/> </svg> <div> <p class="font-medium text-sm" style="color: var(--text-primary);"> <%= device.user_agent.present? ? device.user_agent.truncate(60) :"Unknown device" %> </p> <p class="text-xs" style="color: var(--text-muted);"> <%= device.ip_address.presence ||"IP not recorded" %> </p> </div> </div> </td> <td class="px-4 py-3 text-sm" style="color: var(--text-secondary);"> <%= time_ago_in_words(device.last_used_at) %> ago </td> <td class="px-4 py-3 text-sm" style="color: var(--text-secondary);"> <% if device.expires_at > 7.days.from_now %> <span class="text-green-600"><%= time_ago_in_words(device.expires_at) %> from now</span> <% elsif device.expires_at > Time.current %> <span class="text-amber-600"><%= time_ago_in_words(device.expires_at) %> from now</span> <% else %> <span class="text-danger">Expired</span> <% end %> </td> <td class="px-4 py-3 text-right"> <%= button_to"Revoke", revoke_device_mfa_path(device), method: :delete, class:"text-xs font-medium text-danger hover:text-danger-700 transition-colors", data: { turbo_confirm:"Revoke this device?" } %> </td> </tr> <% end %> </tbody> </table> </div> <% else %> <div class="rounded-lg border border-border bg-surface p-8 text-center"> <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"> <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/> </svg> <p class="text-sm font-medium" style="color: var(--text-primary);">No trusted devices</p> <p class="text-xs mt-1" style="color: var(--text-secondary);">Devices will appear here after you verify your identity with MFA.</p> </div> <% end %> <div class="mt-6"> <%= link_to"Back to Settings", dashboard_settings_path(tab:"security"), class:"text-sm font-medium text-primary hover:text-primary-700 transition-colors" %> </div> </div> 