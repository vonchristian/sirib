<div class="p-6" data-controller="otp-input">
  <div class="text-center mb-6">
    <div class="flex items-center justify-center mb-3">
      <div class="flex h-10 w-10 items-center justify-center rounded-xl" style="background: linear-gradient(135deg, var(--accent) 0%, #0099cc 100%);">
        <svg class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z"/>
        </svg>
      </div>
    </div>
    <h3 class="text-lg font-semibold" style="color: var(--text-primary);">Verify it's you</h3>
    <p class="text-sm mt-1" style="color: var(--text-secondary);">Enter the code from your authenticator app to continue.</p>
  </div>

  <div id="step-up-error" class="mb-4 rounded-md border border-danger/20 bg-danger-50 p-3 text-sm text-danger hidden"></div>

  <%= form_tag step_up_verify_mfa_path, method: :post, data: { turbo: false, controller: "otp-input", action: "submit->mfa-step-up#verify" }, id: "step-up-form", class: "space-y-4" do %>
    <div>
      <%= text_field_tag :code, nil,
          class: "input text-center text-2xl font-mono tracking-[0.5em] h-14 w-full",
          placeholder: "000000",
          inputmode: "numeric",
          autocomplete: "one-time-code",
          required: true,
          autofocus: true,
          data: { otp_input_target: "input" } %>
    </div>
    <%= submit_tag "Verify", class: "btn-primary w-full h-11 text-base", data: { disable_with: "Verifying..." } %>
  <% end %>

  <div class="mt-4 text-center">
    <button type="button" class="text-xs font-medium underline" style="color: var(--text-muted);" data-action="click->mfa-step-up#cancel">
      Cancel
    </button>
  </div>
</div>
