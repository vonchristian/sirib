<% content_for :page_title, "Set Up Two-Factor Authentication" %>

<div class="max-w-lg mx-auto mt-12 animate-fade-in">
  <div class="card">
    <div class="card-header">
      <h2 class="card-header-title">Set Up Two-Factor Authentication</h2>
    </div>
    <div class="card-body space-y-6">
      <div class="space-y-2">
        <p class="text-sm text-text-secondary">Scan the QR code below with your authenticator app (Google Authenticator, Authy, or Microsoft Authenticator).</p>
      </div>

      <div class="flex justify-center py-4">
        <%= raw RQRCode::QRCode.new(@provisioning_uri).as_svg(module_size: 4, standalone: true) %>
      </div>

      <div class="rounded-md border border-border bg-surface-alt p-3">
        <p class="text-xs font-medium text-text-tertiary mb-1">Or enter this key manually:</p>
        <p class="text-sm font-mono text-text-primary select-all break-all"><%= @secret.scan(/.{4}/).join(" ") %></p>
      </div>

      <%= form_tag enable_mfa_path, class: "space-y-4", data: { turbo: false } do %>
        <div>
          <%= label_tag :code, "Verification Code", class: "input-label" %>
          <%= text_field_tag :code, nil, class: "input", placeholder: "000000", inputmode: "numeric", autocomplete: "off", required: true, pattern: "[0-9]*", maxlength: 6 %>
        </div>
        <%= submit_tag "Enable Two-Factor Authentication", class: "btn-primary w-full" %>
      <% end %>

      <div class="text-center">
        <%= link_to "Cancel", :back, class: "text-sm text-text-tertiary hover:text-text-primary transition-colors" %>
      </div>
    </div>
  </div>
</div>