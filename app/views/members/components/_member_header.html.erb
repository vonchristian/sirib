<div class="card">
  <div class="flex items-center gap-4 p-5">
    <div class="flex h-14 w-14 flex-shrink-0 items-center justify-center rounded-full bg-primary-50 text-lg font-semibold text-primary dark:bg-primary-900/30 dark:text-primary-300 overflow-hidden">
      <% if member.profile_image.attached? %>
        <%= image_tag member.profile_image, class: "h-full w-full object-cover" %>
      <% else %>
        <%= "#{member.first_name.first}#{member.last_name.first}" %>
      <% end %>
    </div>

    <div class="min-w-0 flex-1">
      <div class="flex items-center gap-2 flex-wrap">
        <h1 class="text-lg font-semibold text-text-primary"><%= member.name %></h1>
        <span class="badge badge-success">Active Member</span>
        <span class="text-xs text-text-tertiary font-mono">No. <%= member.member_identifier %></span>
      </div>

      <div class="flex items-center gap-3 mt-1 text-sm text-text-tertiary flex-wrap">
        <span><%= member.mobile_number %></span>
        <% if member.email_address.present? %>
          <span class="hidden sm:inline">·</span>
          <span class="hidden sm:inline"><%= member.email_address %></span>
        <% end %>
        <span class="hidden sm:inline">·</span>
        <span class="hidden sm:inline">Member since <%= member.created_at.strftime("%b %d, %Y") %></span>
        <% if member.address&.city.present? %>
          <span class="hidden md:inline">·</span>
          <span class="hidden md:inline"><%= member.address.city %></span>
        <% end %>
      </div>
    </div>

    <div class="flex items-center gap-2 flex-shrink-0">
      <%= link_to edit_member_path(member), class: "btn btn-secondary" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" />
        </svg>
        Edit
      <% end %>
      <%= link_to new_member_transaction_path(member), class: "btn btn-primary" do %>
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
        New Transaction
      <% end %>
    </div>
  </div>
</div>
 
