<div class="grid grid-cols-1 gap-6 lg:grid-cols-2 xl:grid-cols-4">
  <div class="stat-card">
    <p class="stat-label">Savings</p>
    <p class="stat-value"><%= number_to_currency(summary[:savings_balance] / 100.0, unit: "₱") %></p>
    <p class="text-xs text-text-tertiary mt-0.5"><%= summary[:savings_active_count] %> active account<%= "s" unless summary[:savings_active_count] == 1 %></p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Time Deposits</p>
    <p class="stat-value"><%= number_to_currency(summary[:time_deposit_total] / 100.0, unit: "₱") %></p>
    <p class="text-xs text-text-tertiary mt-0.5"><%= summary[:time_deposit_active_count] %> active</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Loans</p>
    <p class="stat-value"><%= number_to_currency(summary[:loan_outstanding] / 100.0, unit: "₱") %></p>
    <p class="text-xs text-text-tertiary mt-0.5"><%= summary[:loan_active_count] %> active</p>
  </div>
  <div class="stat-card">
    <p class="stat-label">Share Capital</p>
    <p class="stat-value"><%= number_to_currency(summary[:share_capital_paid_up] / 100.0, unit: "₱") %></p>
    <p class="text-xs text-text-tertiary mt-0.5"><%= summary[:share_capital_total_shares] %> shares</p>
  </div>
</div>
