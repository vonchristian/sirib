<div class="space-y-6"> <% if @loan_summary[:loans].any? %> 
    <div class="card"> 
      <div class="card-header"> 
        <h3 class="card-header-title">Loans</h3>
 <%= link_to"View all", loans_loans_path, class:"text-xs font-medium text-primary hover:text-primary-700" %> </div>
 
      <div class="table-container" style="border: none; border-radius: 0;"> 
        <table class="table"> 
          <thead> 
            <tr> 
              <th>Loan Number</th>
 
              <th>Product</th>
 
              <th class="text-right">Principal</th>
 
              <th class="text-right">Outstanding</th>
 
              <th class="text-right">Interest Rate</th>
 
              <th>Due Date</th>
 
              <th>Status</th>
 
              <th class="text-right">Actions</th>
 </tr>
 </thead>
 
          <tbody data-controller="clickable-row"> <% @loan_summary[:loans].each do |loan| %> 
              <tr data-clickable-row-target="row" data-href="<%= loans_loan_path(loan) %>" class="cursor-pointer"> 
                <td class="font-mono text-text-primary"><%= loan.reference_number %></td>
 
                <td class="text-text-secondary"><%= loan.loan_product.name %></td>
 
                <td class="font-medium tabular-nums text-right text-text-primary"><%= Money.new(loan.principal_cents,"PHP").format %></td>
 
                <td class="font-medium tabular-nums text-right text-text-primary"><%= Money.new(loan.outstanding_principal_cents,"PHP").format %></td>
 
                <td class="tabular-nums text-right text-text-secondary"><%= number_to_percentage(loan.interest_rate, precision: 1) %></td>
 
                <td class="text-text-secondary"><%= loan.payment_schedule.first&.due_date&.strftime("%b %d, %Y") ||"—" %></td>
 
                <td> <span class="badge <%= loan.active? ? 'badge-success' : 'badge-warning' %>"><%= loan.status %></span> </td>
 
                <td class="text-right"><%= link_to"View", loans_loan_path(loan), class:"text-xs font-medium text-primary hover:text-primary-700" %></td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 </div>
 <% end %> <% if @loan_summary[:loan_applications].any? %> 
    <div class="card"> 
      <div class="card-header"> 
        <h3 class="card-header-title">Loan Applications</h3>
 <%= link_to"View all", loans_applications_path, class:"text-xs font-medium text-primary hover:text-primary-700" %> </div>
 
      <div class="table-container" style="border: none; border-radius: 0;"> 
        <table class="table"> 
          <thead> 
            <tr> 
              <th>Reference</th>
 
              <th>Product</th>
 
              <th class="text-right">Amount</th>
 
              <th>Status</th>
 
              <th>Created</th>
 
              <th class="text-right">Actions</th>
 </tr>
 </thead>
 
          <tbody data-controller="clickable-row"> <% @loan_summary[:loan_applications].each do |app| %> 
              <tr data-clickable-row-target="row" data-href="<%= app.draft? ? edit_loans_application_path(app.uuid) : loans_application_path(app.uuid) %>" class="cursor-pointer"> 
                <td class="font-mono text-text-primary"><%= app.reference_number || app.uuid.first(8).upcase %></td>
 
                <td class="text-text-secondary"><%= app.loan_product&.name ||"—" %></td>
 
                <td class="font-medium tabular-nums text-right text-text-primary"><%= app.amount_cents ? Money.new(app.amount_cents,"PHP").format :"—" %></td>
 
                <td> <span class="badge <%= case app.status; when 'draft' then 'badge-warning'; when 'submitted' then 'badge-primary'; when 'approved' then 'badge-success'; when 'rejected' then 'badge-danger'; else 'badge-warning'; end %>"><%= app.status %></span> </td>
 
                <td class="text-text-secondary"><%= app.created_at.strftime("%b %d, %Y") %></td>
 
                <td class="text-right"> <% if app.draft? %> <%= link_to"Resume", edit_loans_application_path(app.uuid), class:"text-xs font-medium text-primary hover:text-primary-700" %> <% else %> <%= link_to"View", loans_application_path(app.uuid), class:"text-xs font-medium text-primary hover:text-primary-700" %> <% end %> </td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 </div>
 <% end %> <% if @loan_summary[:loans].none? && @loan_summary[:loan_applications].none? %> 
    <div class="card"> 
      <div class="card-body text-center"> 
        <p class="text-sm text-text-tertiary mb-4">No loans.</p>
 <%= link_to new_loans_application_path, class:"btn btn-primary" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /> </svg> Create Loan <% end %> </div>
 </div>
 <% end %> </div>
 
