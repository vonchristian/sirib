<div class="space-y-6"> <div class="card"> <div class="card-header"> <h3 class="card-header-title">Online Portal Access</h3> </div> <div class="card-body"> <div class="flex items-center justify-between"> <div> <p class="text-sm font-medium text-text-primary">Member Portal Access</p> <p class="text-xs text-text-tertiary mt-0.5">Allow this member to access the online member portal</p> </div> <div class="flex items-center gap-3"> <% if @member.portal_active? %> <span class="badge badge-success">Active</span> <% elsif @member.portal_suspended? %> <span class="badge badge-danger">Suspended</span> <% else %> <span class="badge badge-warning">Inactive</span> <% end %> <%= button_to toggle_portal_access_member_path(@member, enabled: !@member.portal_active?), method: :post, data: { turbo_confirm: @member.portal_active? ? "Suspend portal access for this member?" :"Enable portal access for this member?" }, class:"relative inline-flex h-6 w-11 items-center rounded-full transition-colors focus:outline-none focus:ring-2 focus:ring-primary focus:ring-offset-2 #{@member.portal_active? ? 'bg-primary' : 'bg-surface-alt '}" do %> <span class="inline-block h-4 w-4 transform rounded-full bg-surface transition-transform shadow-sm <%= @member.portal_active? ? 'translate-x-6' : 'translate-x-1' %>"></span> <% end %> </div> </div> <% if @member.portal_active? && @member.portal_enrollment_tokens.valid.any? %> <div class="mt-4 rounded-md bg-primary-50 border border-primary-100 dark:bg-primary-900/20 dark:border-primary-800 p-3"> <p class="text-xs text-primary font-medium">Enrollment link sent</p> <p class="text-xs text-primary-700 dark:text-primary-300 mt-0.5">Member can enroll using their email or member ID.</p> </div> <% elsif @member.portal_active? && !@member.portal_enabled? %> <div class="mt-4 rounded-md bg-warning-50 border border-warning-100 dark:bg-warning-900/20 dark:border-warning-800 p-3"> <p class="text-xs text-warning font-medium">Pending enrollment</p> <p class="text-xs text-warning-700 dark:text-warning-300 mt-0.5">Member hasn't completed portal registration yet.</p> </div> <% elsif !@member.portal_active? && @member.portal_enrollment_tokens.valid.any? %> <div class="mt-4 rounded-md bg-surface-alt border border-border p-3"> <p class="text-xs text-text-tertiary">Enrollment token available but portal access is disabled.</p> </div> <% end %> </div> </div> <div class="card"> <div class="card-header"> <h3 class="card-header-title">Audit Information</h3> </div> <div class="card-body"> <dl class="space-y-2.5 text-sm"> <div class="flex justify-between"> <dt class="text-text-tertiary">Created</dt> <dd class="text-text-primary font-medium"><%= @member.created_at.strftime("%b %d, %Y %H:%M") %></dd> </div> <div class="flex justify-between"> <dt class="text-text-tertiary">Last Updated</dt> <dd class="text-text-primary font-medium"><%= @member.updated_at.strftime("%b %d, %Y %H:%M") %></dd> </div> </dl> </div> </div> <div class="card"> <div class="card-header"> <h3 class="card-header-title">Profile Settings</h3> </div> <div class="card-body"> <div class="space-y-1.5"> <%= link_to edit_member_path(@member), class:"flex items-center gap-2 rounded-md px-3 py-2 text-sm text-text-secondary hover:bg-surface-alt transition-colors" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="m16.862 4.487 1.687-1.688a1.875 1.875 0 1 1 2.652 2.652L10.582 16.07a4.5 4.5 0 0 1-1.897 1.13L6 18l.8-2.685a4.5 4.5 0 0 1 1.13-1.897l8.932-8.931Zm0 0L19.5 7.125M18 14v4.75A2.25 2.25 0 0 1 15.75 21H5.25A2.25 2.25 0 0 1 3 18.75V8.25A2.25 2.25 0 0 1 5.25 6H10" /> </svg> Edit Profile <% end %> <%= link_to edit_member_path(@member, anchor:"identifications"), class:"flex items-center gap-2 rounded-md px-3 py-2 text-sm text-text-secondary hover:bg-surface-alt transition-colors" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z" /> </svg> Upload ID <% end %> <%= link_to edit_member_path(@member), class:"flex items-center gap-2 rounded-md px-3 py-2 text-sm text-text-secondary hover:bg-surface-alt transition-colors" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /> <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" /> </svg> Update Address <% end %> </div> </div> </div> <div class="card" style="border-color: var(--color-danger);"> <div class="card-header" style="border-bottom-color: var(--color-danger);"> <h3 class="card-header-title" style="color: var(--color-danger);">Danger Zone</h3> </div> <div class="card-body"> <p class="text-sm text-danger mb-4">Deactivating a member will restrict their ability to perform transactions.</p> <%= button_to deactivate_member_path(@member), method: :post, data: { turbo_confirm:"Are you sure you want to deactivate this member? This action cannot be undone." }, class:"btn btn-danger" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M18.364 18.364A9 9 0 0 0 5.636 5.636m12.728 12.728A9 9 0 0 1 5.636 5.636m12.728 12.728L5.636 5.636" /> </svg> Deactivate Member <% end %> </div> </div> </div> 