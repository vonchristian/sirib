<% total_shares = @share_capital_accounts.sum(&:shares_owned) %>
<% paid_up_capital = @share_capital_accounts.sum { |a| a.paid_up_capital.cents } %>

<div class="space-y-6">
  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="stat-card">
      <p class="stat-label">Total Shares</p>
      <p class="stat-value"><%= total_shares %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Paid Share Capital</p>
      <p class="stat-value"><%= number_to_currency(paid_up_capital / 100.0, unit: "₱") %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Active Accounts</p>
      <p class="stat-value"><%= @share_capital_accounts.active.count %></p>
    </div>
  </div>

  <% if @share_transactions.any? %>
    <div class="card">
      <div class="card-header">
        <h3 class="card-header-title">Share Transactions</h3>
        <%= link_to "View all", equity_accounts_path, class: "text-xs font-medium text-primary hover:text-primary-700" %>
      </div>
      <div class="table-container" style="border: none; border-radius: 0;">
        <table class="table">
          <thead>
            <tr>
              <th>Certificate</th>
              <th>Date</th>
              <th class="text-right">Shares</th>
              <th class="text-right">Amount</th>
              <th>Status</th>
            </tr>
          </thead>
          <tbody>
            <% @share_transactions.each do |txn| %>
              <tr>
                <td class="font-mono text-text-primary"><%= txn.reference_number %></td>
                <td class="text-text-secondary"><%= txn.posted_at.strftime("%b %d, %Y") %></td>
                <td class="tabular-nums text-right text-text-primary"><%= txn.shares %></td>
                <td class="font-medium tabular-nums text-right text-text-primary"><%= txn.total_amount.format %></td>
                <td>
                  <span class="badge <%= txn.status == "completed" ? 'badge-success' : 'badge-warning' %>"><%= txn.status %></span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  <% else %>
    <div class="card">
      <div class="card-body text-center">
        <p class="text-sm text-text-tertiary mb-4">No share capital transactions.</p>
        <%= link_to new_equity_account_path, class: "btn btn-primary" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
          </svg>
          Purchase Shares
        <% end %>
      </div>
    </div>
  <% end %>
</div>
