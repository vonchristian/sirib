<% content_for :page_title,"Edit #{@member.name}" %> <% content_for :page_subtitle,"Update member information" %> 
<div class="animate-fade-in max-w-3xl mx-auto"> <%= form_with model: @member, local: true, html: { multipart: true, class:"space-y-6" } do |f| %> <% if @member.errors.any? %> 
      <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger dark:border-danger-900/30 dark:bg-danger-900/20 dark:text-danger-400"> 
        <p class="font-medium"><%= pluralize(@member.errors.count,"error") %> prevented this member from being saved:</p>
 
        <ul class="mt-1 list-inside list-disc"> <% @member.errors.each do |error| %> 
            <li><%= error.full_message %></li>
 <% end %> </ul>
 </div>
 <% end %> 
    <div class="rounded-lg border border-border bg-surface p-6"> 
      <h2 class="text-lg font-semibold text-text-primary mb-4">Personal Details</h2>
 
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2"> 
        <div class="field-group sm:col-span-2"> <%= f.label :first_name, class:"input-label" %> <%= f.text_field :first_name, required: true, placeholder:"First name", class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :middle_name, class:"input-label" %> <%= f.text_field :middle_name, placeholder:"Middle name", class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :last_name, class:"input-label" %> <%= f.text_field :last_name, required: true, placeholder:"Last name", class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :suffix, class:"input-label" %> <%= f.select :suffix, options_for_select([["None",""],"Jr.","Sr.","II","III","IV"], @member.suffix), {}, class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :birth_date, class:"input-label" %> <%= f.date_field :birth_date, required: true, max: Date.current.to_s, class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :gender, class:"input-label" %> <%= f.select :gender, options_for_select([["Select gender",""],"male","female"], @member.gender), {}, required: true, class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :civil_status, class:"input-label" %> <%= f.select :civil_status, options_for_select([["Select civil status",""],"single","married","divorced","widowed"], @member.civil_status), {}, required: true, class:"input" %> </div>
 
        <div class="field-group"> <%= f.label :mobile_number, class:"input-label" %> <%= f.text_field :mobile_number, required: true, placeholder:"09171234567", class:"input" %> </div>
 
        <div class="field-group sm:col-span-2"> <%= f.label :email_address, class:"input-label" %> <%= f.email_field :email_address, placeholder:"email@example.com", class:"input" %> </div>
 </div>
 </div>
 
    <div class="rounded-lg border border-border bg-surface p-6"> 
      <h2 class="text-lg font-semibold text-text-primary mb-4">Address</h2>
 <%= f.fields_for :address do |af| %> 
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2"> 
          <div class="field-group sm:col-span-2"> <%= af.label :house_street,"House / Street", class:"input-label" %> <%= af.text_field :house_street, placeholder:"House number and street name", class:"input" %> </div>
 
          <div class="field-group"> <%= af.label :barangay, class:"input-label" %> <%= af.text_field :barangay, placeholder:"Barangay", class:"input" %> </div>
 
          <div class="field-group"> <%= af.label :city, class:"input-label" %> <%= af.text_field :city, placeholder:"City / Municipality", class:"input" %> </div>
 
          <div class="field-group"> <%= af.label :province, class:"input-label" %> <%= af.text_field :province, placeholder:"Province", class:"input" %> </div>
 
          <div class="field-group"> <%= af.label :region, class:"input-label" %> <%= af.text_field :region, placeholder:"Region (e.g. NCR)", class:"input" %> </div>
 
          <div class="field-group"> <%= af.label :zip_code, class:"input-label" %> <%= af.text_field :zip_code, placeholder:"ZIP code", class:"input" %> </div>
 </div>
 <% end %> </div>
 
    <div class="rounded-lg border border-border bg-surface p-6" id="identifications"> 
      <h2 class="text-lg font-semibold text-text-primary mb-4">Identifications</h2>
 
      <p class="mb-4 text-sm text-text-secondary">At least one BIR identification is required.</p>
 
      <div id="identifications"> <%= f.fields_for :identifications do |idf| %> 
          <div class="rounded-lg border border-border bg-surface-alt p-4 mb-4"> 
            <div class="grid grid-cols-1 gap-4 sm:grid-cols-2"> 
              <div class="field-group"> <%= idf.label :id_type,"ID Type", class:"input-label" %> <%= idf.select :id_type, options_for_select(Membership::Identification::ID_TYPES, idf.object.id_type), { include_blank:"Select ID type" }, required: true, class:"input" %> </div>
 
              <div class="field-group"> <%= idf.label :id_number,"ID Number", class:"input-label" %> <%= idf.text_field :id_number, required: true, placeholder:"ID number", class:"input" %> </div>
 
              <div class="field-group sm:col-span-2"> <%= idf.label :file,"Upload File (photo or scan)", class:"input-label" %> <%= idf.file_field :file, accept:"image/*,.pdf", class:"block w-full text-sm text-text-secondary file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-1.5 file:text-xs file:font-medium file:text-white hover:file:bg-primary-700" %> </div>
 </div>
 </div>
 <% end %> </div>
 </div>
 <% if @member.signatures.attached? %> 
      <div class="rounded-lg border border-border bg-surface p-6"> 
        <h2 class="text-lg font-semibold text-text-primary mb-4">Signature</h2>
 
        <p class="text-sm text-text-secondary mb-3">Current signature on file.</p>
 
        <div class="grid grid-cols-3 gap-2"> <% @member.signatures.each do |sig| %> <%= image_tag sig, class:"h-14 w-full rounded border border-border object-contain bg-surface" %> <% end %> </div>
 </div>
 <% end %> 
    <div class="flex items-center justify-between"> <%= link_to"Cancel", @member, class:"btn btn-secondary" %> <%= f.submit"Save Changes", class:"btn btn-primary" %> </div>
 <% end %> </div>
 
