<% content_for :page_title, "Members" %>
<% content_for :page_subtitle, "Manage cooperative member profiles" %>

<div class="animate-fade-in">
  <div class="mb-4 flex items-center justify-between">
    <div>
      <input type="text" placeholder="Search members..." class="rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder-text-tertiary focus:border-primary focus:outline-none focus:ring-1 focus:ring-primary dark:border-gray-600 dark:bg-gray-800 dark:text-white dark:placeholder-gray-500 w-72">
    </div>
    <%= link_to "Register Member", new_member_path, class: "inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 transition-colors" %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-6">
    <div class="rounded-lg border border-border bg-surface p-4 dark:border-gray-700 dark:bg-gray-900">
      <p class="text-xs font-medium uppercase tracking-wider text-text-tertiary">Total Members</p>
      <p class="text-xl font-semibold text-text-primary tabular-nums mt-1"><%= @total_members %></p>
    </div>
    <div class="rounded-lg border border-border bg-surface p-4 dark:border-gray-700 dark:bg-gray-900">
      <p class="text-xs font-medium uppercase tracking-wider text-text-tertiary">Male</p>
      <p class="text-xl font-semibold text-text-primary tabular-nums mt-1"><%= @male_count %></p>
    </div>
    <div class="rounded-lg border border-border bg-surface p-4 dark:border-gray-700 dark:bg-gray-900">
      <p class="text-xs font-medium uppercase tracking-wider text-text-tertiary">Female</p>
      <p class="text-xl font-semibold text-text-primary tabular-nums mt-1"><%= @female_count %></p>
    </div>
  </div>

  <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-border bg-surface-alt dark:border-gray-700 dark:bg-gray-800/50">
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary dark:text-gray-500">Name</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary dark:text-gray-500">Gender</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary dark:text-gray-500">Mobile</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary dark:text-gray-500">Email</th>
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary dark:text-gray-500">Member Since</th>
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary dark:text-gray-500">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-gray-800">
          <% if @members.any? %>
            <% @members.each do |member| %>
              <tr class="hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors">
                <td class="px-4 py-3">
                  <div class="flex items-center gap-3">
                    <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary-50 text-xs font-semibold text-primary dark:bg-primary-900/30 dark:text-primary-300">
                      <%= member.first_name.first.upcase %><%= member.last_name.first.upcase %>
                    </div>
                    <div>
                      <p class="font-medium text-text-primary dark:text-white"><%= member.name %></p>
                      <p class="text-xs text-text-tertiary dark:text-gray-500"><%= member.address&.city&.titleize %></p>
                    </div>
                  </div>
                </td>
                <td class="px-4 py-3 text-sm text-text-secondary dark:text-gray-400 capitalize"><%= member.gender %></td>
                <td class="px-4 py-3 text-sm text-text-secondary dark:text-gray-400"><%= member.mobile_number %></td>
                <td class="px-4 py-3 text-sm text-text-secondary dark:text-gray-400"><%= member.email_address || "—" %></td>
                <td class="px-4 py-3 text-sm text-text-secondary dark:text-gray-400"><%= member.created_at.strftime("%b %d, %Y") %></td>
                <td class="px-4 py-3 text-right">
                  <%= link_to "View", member, class: "text-sm font-medium text-primary hover:text-primary-700 dark:text-primary-400 transition-colors" %>
                </td>
              </tr>
            <% end %>
          <% else %>
            <tr>
              <td colspan="6" class="px-4 py-12 text-center text-sm text-text-tertiary dark:text-gray-500">
                No members registered yet.
                <%= link_to "Register the first member", new_member_path, class: "font-medium text-primary hover:text-primary-700 dark:text-primary-400" %>.
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
    <% if @pagy.pages > 1 %>
      <div class="flex items-center justify-between border-t border-border px-4 py-3 dark:border-gray-700">
        <p class="text-xs text-text-tertiary dark:text-gray-500">Showing <%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %> members</p>
        <div class="flex items-center gap-1">
          <% if @pagy.prev %>
            <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "rounded-md px-2.5 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
            <% end %>
          <% end %>
          <% @pagy.series.each do |item| %>
            <% if item.is_a?(Integer) %>
              <%= link_to pagy_url_for(@pagy, item), class: "rounded-md px-2.5 py-1.5 text-xs font-medium #{item == @pagy.page ? 'bg-primary text-white' : 'text-text-secondary hover:bg-surface-alt dark:hover:bg-gray-800'} transition-colors" do %>
                <%= item %>
              <% end %>
            <% elsif item.is_a?(String) %>
              <span class="px-2 text-xs text-text-tertiary"><%= item %></span>
            <% end %>
          <% end %>
          <% if @pagy.next %>
            <%= link_to pagy_url_for(@pagy, @pagy.next), class: "rounded-md px-2.5 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt dark:hover:bg-gray-800 transition-colors" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>
