<% content_for :page_title, "Members" %>
<% content_for :page_subtitle, "Manage cooperative member profiles" %>

<div class="animate-fade-in" data-controller="members-search" data-members-search-url-value="<%= members_path %>">
  <div class="mb-4 flex items-center justify-between gap-4">
    <div class="flex-1 max-w-md">
      <input type="text"
             placeholder="Search by name, email, mobile, address..."
             class="input w-full"
             data-members-search-target="input"
             data-action="input->members-search#search">
      <p id="members-count" class="mt-1 text-xs text-text-tertiary">
        <%= pluralize(@members.count, "member") %> shown
      </p>
    </div>
    <%= link_to "Register Member", new_member_path, class: "btn-primary text-sm flex-shrink-0" %>
  </div>

  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-6">
    <div class="stat-card">
      <p class="stat-label">Total Members</p>
      <p class="stat-value"><%= @total_members %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Male</p>
      <p class="stat-value"><%= @male_count %></p>
    </div>
    <div class="stat-card">
      <p class="stat-label">Female</p>
      <p class="stat-value"><%= @female_count %></p>
    </div>
  </div>

  <div class="table-container">
    <div class="overflow-x-auto">
      <table class="table">
        <thead>
          <tr>
            <th>Name</th>
            <th>Gender</th>
            <th>Mobile</th>
            <th>Email</th>
            <th>Member Since</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody id="members-tbody" data-members-search-target="tbody">
          <%= render "table_body", members: @members, query: params[:q] %>
        </tbody>
      </table>
    </div>
    <% if @pagy && @pagy.pages > 1 %>
      <div class="flex items-center justify-between border-t border-border px-4 py-3">
        <p class="text-xs text-text-tertiary">Showing <%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %> members</p>
        <div class="flex items-center gap-1">
          <% if @pagy.prev %>
            <%= link_to pagy_url_for(@pagy, @pagy.prev), class: "rounded-md px-2.5 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
            <% end %>
          <% end %>
          <% @pagy.series.each do |item| %>
            <% if item.is_a?(Integer) %>
              <%= link_to pagy_url_for(@pagy, item), class: "rounded-md px-2.5 py-1.5 text-xs font-medium #{item == @pagy.page ? 'bg-primary text-white' : 'text-text-secondary hover:bg-surface-alt'} transition-colors" do %>
                <%= item %>
              <% end %>
            <% elsif item.is_a?(String) %>
              <span class="px-2 text-xs text-text-tertiary"><%= item %></span>
            <% end %>
          <% end %>
          <% if @pagy.next %>
            <%= link_to pagy_url_for(@pagy, @pagy.next), class: "rounded-md px-2.5 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors" do %>
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
            <% end %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>