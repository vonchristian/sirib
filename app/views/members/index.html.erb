<% content_for :page_title,"Members" %> <% content_for :page_subtitle,"Manage cooperative member profiles" %> 
<div class="animate-fade-in" data-controller="members-search" data-members-search-url-value="<%= members_path %>"> 
  <div class="mb-4 flex items-center justify-between gap-4"> 
    <div class="flex-1 max-w-md"> <input type="text" placeholder="Search by name, email, mobile, address..." class="input w-full" data-members-search-target="input" data-action="input->members-search#search"> 
      <p id="members-count" class="mt-1 text-xs text-text-tertiary"> <%= pluralize(@members.count,"member") %> shown </p>
 </div>
 <%= link_to"Register Member", new_member_path, class:"btn-primary text-sm flex-shrink-0" %> </div>
 
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-3 mb-6"> 
    <div class="stat-card"> 
      <p class="stat-label">Total Members</p>
 
      <p class="stat-value"><%= @total_members %></p>
 </div>
 
    <div class="stat-card"> 
      <p class="stat-label">Male</p>
 
      <p class="stat-value"><%= @male_count %></p>
 </div>
 
    <div class="stat-card"> 
      <p class="stat-label">Female</p>
 
      <p class="stat-value"><%= @female_count %></p>
 </div>
 </div>
 
  <div class="table-container"> 
    <div class="overflow-x-auto"> 
      <table class="table"> 
        <thead> 
          <tr> 
            <th>Name</th>
 
            <th>Gender</th>
 
            <th>Mobile</th>
 
            <th>Email</th>
 
            <th>Member Since</th>
 
            <th class="text-right">Actions</th>
 </tr>
 </thead>
 
        <tbody id="members-tbody" data-members-search-target="tbody"> <%= render"table_body", members: @members, query: params[:q] %> </tbody>
 </table>
 </div>
 <% if @pagy && @pagy.pages > 1 %> 
      <div class="flex items-center justify-between border-t border-border px-4 py-3"> 
        <p class="text-xs text-text-tertiary">Showing <%= @pagy.from %>–<%= @pagy.to %> of <%= @pagy.count %> members</p>
 <%= render "shared/pagination", pagy: @pagy %> <% end %> </div>
 </div>
