<% if members.any? %>
  <% members.each do |member| %>
    <tr data-href="<%= member_path(member) %>"
        class="cursor-pointer hover:bg-surface-alt transition-colors"
        data-action="click->members-search#navigate"
        role="link"
        tabindex="0">
      <td class="px-4 py-3">
        <div class="flex items-center gap-3">
          <div class="flex h-8 w-8 items-center justify-center rounded-full bg-primary-50 text-xs font-semibold text-primary">
            <%= member.first_name.first.upcase %><%= member.last_name.first.upcase %>
          </div>
          <div>
            <p class="font-medium text-text-primary"><%= member.name %></p>
            <p class="text-xs text-text-tertiary"><%= member.address&.city&.titleize %></p>
          </div>
        </div>
      </td>
      <td class="px-4 py-3 text-sm text-text-secondary capitalize"><%= member.gender %></td>
      <td class="px-4 py-3 text-sm text-text-secondary"><%= member.mobile_number %></td>
      <td class="px-4 py-3 text-sm text-text-secondary"><%= member.email_address || "—" %></td>
      <td class="px-4 py-3 text-sm text-text-secondary"><%= member.created_at.strftime("%b %d, %Y") %></td>
      <td class="px-4 py-3 text-right">
        <%= link_to "View", member, class: "text-sm font-medium text-primary hover:text-primary-700 transition-colors" %>
      </td>
    </tr>
  <% end %>
<% else %>
  <tr>
    <td colspan="6" class="px-4 py-12 text-center text-sm text-text-tertiary">
      <% if local_assigns[:query].present? && query.present? %>
        No members matching "<%= query %>".
      <% else %>
        No members registered yet.
        <%= link_to "Register the first member", new_member_path, class: "font-medium text-primary hover:text-primary-700" %>.
      <% end %>
    </td>
  </tr>
<% end %>