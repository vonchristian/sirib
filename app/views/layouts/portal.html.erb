<!DOCTYPE html> <html> <head> <title><%= content_for(:title) ||"Member Portal — Sirib" %></title> <meta name="viewport" content="width=device-width,initial-scale=1"> <meta name="apple-mobile-web-app-capable" content="yes"> <meta name="mobile-web-app-capable" content="yes"> <%= csrf_meta_tags %> <%= csp_meta_tag %> <%= yield :head %> <link rel="preconnect" href="https://fonts.googleapis.com"> <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin> <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet"> <link rel="icon" href="/icon.png" type="image/png"> <link rel="icon" href="/icon.svg" type="image/svg+xml"> <link rel="apple-touch-icon" href="/icon.png"> <%= stylesheet_link_tag :app,"data-turbo-track":"reload" %> <%= javascript_importmap_tags %> </head> <body class="bg-surface-alt text-text-primary antialiased" style="font-family: 'Inter', system-ui, sans-serif;"> <% if Current.member %> <header class="sticky top-0 z-40 bg-surface border-b border-border"> <div class="max-w-4xl mx-auto px-4 h-14 flex items-center justify-between"> <div class="flex items-center gap-3"> <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary"> <svg class="h-4 w-4 text-white" viewBox="0 0 40 40" fill="none"> <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2.5"/> <circle cx="20" cy="20" r="9" fill="currentColor" opacity="0.85"/> <circle cx="20" cy="20" r="3.5" fill="white"/> </svg> </div> <span class="text-sm font-semibold">Member Portal</span> </div> <div class="flex items-center gap-3"> <span class="text-xs text-text-tertiary hidden sm:inline"><%= Current.member.name %></span> <%= button_to portal_session_path, method: :delete, class:"text-xs text-text-tertiary hover:text-text-secondary font-medium", data: { turbo: false } do %> Sign Out <% end %> </div> </div> </header> <nav class="bg-surface border-b border-border overflow-x-auto"> <div class="max-w-4xl mx-auto px-4 flex gap-1 py-1"> <%= link_to"Dashboard", portal_dashboard_path, class:"px-3 py-2 text-xs font-medium rounded-md #{current_page?(portal_dashboard_path) ? 'bg-primary-50 dark:bg-primary-900/30 text-primary dark:text-primary-400' : 'text-text-secondary hover:text-text-primary hover:bg-surface-alt '}" %> <%= link_to"Announcements", portal_announcements_path, class:"px-3 py-2 text-xs font-medium rounded-md #{controller_name == 'announcements' ? 'bg-primary-50 dark:bg-primary-900/30 text-primary dark:text-primary-400' : 'text-text-secondary hover:text-text-primary hover:bg-surface-alt '}" %> </div> </nav> <main class="max-w-4xl mx-auto px-4 py-6"> <% if flash[:notice] %> <div class="mb-4 rounded-lg bg-primary-50 dark:bg-primary-900/30 border border-primary-200 dark:border-primary-800 px-4 py-3 text-sm text-primary-700 dark:text-primary-300"><%= flash[:notice] %></div> <% end %> <% if flash[:alert] %> <div class="mb-4 rounded-lg bg-red-50 dark:bg-red-900/30 border border-red-200 dark:border-red-800 px-4 py-3 text-sm text-red-700 dark:text-red-300"><%= flash[:alert] %></div> <% end %> <%= yield %> </main> <% else %> <main> <%= yield %> </main> <% end %> </body> </html> 