<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Sirib" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;450;500;550;600;650;700&display=swap" rel="stylesheet">

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">
    <script>
      (function() {
        var theme = localStorage.getItem("theme");
        if (theme === "dark" || (!theme && window.matchMedia("(prefers-color-scheme: dark)").matches)) {
          document.documentElement.classList.add("dark");
        }
      })();
    </script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-surface-alt text-text-primary antialiased dark:bg-gray-950 dark:text-gray-100" data-controller="sidebar" data-action="keydown@window->sidebar#closeKeydown click@window->sidebar#hideUserMenu">
    <%= render "shared/sidebar" %>
    <%= render "shared/mobile_header" %>

    <div class="lg:pl-64">
      <%= render "shared/top_header" %>
      <main class="px-6 py-6 sm:px-8 lg:px-10">
        <%= render "shared/breadcrumbs" if content_for?(:breadcrumbs) %>

        <% if flash.any? %>
          <div class="mb-6 space-y-2 animate-fade-in">
            <% flash.each do |type, msg| %>
              <div class="flex items-center gap-3 rounded-md border p-3 text-sm leading-5 <%= type == 'notice' ? 'border-positive bg-positive-50 text-positive-700' : 'border-danger bg-danger-50 text-danger' %>" data-flash-message>
                <% if type == 'notice' %>
                  <svg class="flex-shrink-0 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                <% else %>
                  <svg class="flex-shrink-0 w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg>
                <% end %>
                <span class="flex-1"><%= msg %></span>
                <button type="button" class="ml-auto opacity-40 hover:opacity-100 transition-opacity flex-shrink-0" onclick="this.parentElement.remove()">&times;</button>
              </div>
            <% end %>
          </div>
        <% end %>

        <%= yield %>
      </main>
    </div>
  </body>
</html>
