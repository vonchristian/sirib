<% content_for :title,"Set Up Your Account" %> 
<div class="min-h-screen flex items-center justify-center px-4 py-12 bg-surface-alt"> 
  <div class="w-full max-w-md"> 
    <div class="text-center mb-8"> 
      <div class="flex justify-center mb-4"> 
        <div class="flex h-12 w-12 items-center justify-center rounded-xl bg-primary shadow-lg"> <svg class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"> <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 5.25a3 3 0 0 1 3 3m3 0a6 6 0 0 1-7.029 5.912c-.563-.097-1.159.026-1.563.43L10.5 17.25H8.25v2.25H6v2.25H2.25v-2.818c0-.597.237-1.17.659-1.591l6.499-6.499c.404-.404.527-1 .43-1.563A6 6 0 1 1 21.75 8.25Z"/> </svg> </div>
 </div>
 
      <h1 class="text-xl font-semibold text-text-primary">Welcome, <%= @member.first_name %>!</h1>
 
      <p class="text-sm text-text-tertiary mt-1">Set up your account to get started.</p>
 </div>
 
    <div class="bg-surface rounded-xl border border-border p-6 space-y-6"> 
      <div class="space-y-2"> 
        <h2 class="text-sm font-semibold text-text-primary">Step 1: Scan QR Code</h2>
 
        <p class="text-xs text-text-tertiary">Open your authenticator app (Google Authenticator, Authy, or Microsoft Authenticator) and scan this QR code.</p>
 </div>
 
      <div class="flex justify-center py-4 bg-surface rounded-lg"> <%= raw RQRCode::QRCode.new(@provisioning_uri).as_svg(module_size: 4, standalone: true) %> </div>
 
      <div class="rounded-lg bg-surface-alt border border-border p-3"> 
        <p class="text-xs font-medium text-text-tertiary mb-1">Or enter this key manually:</p>
 
        <p class="text-sm font-mono text-text-primary select-all break-all"><%= @secret.scan(/.{4}/).join("") %></p>
 </div>
 
      <div class="border-t border-border pt-6"> 
        <h2 class="text-sm font-semibold text-text-primary mb-4">Step 2: Verify & Set Password</h2>
 <%= form_tag portal_enrollment_path, class:"space-y-4", data: { turbo: false } do %> 
          <div> <%= label_tag :code,"Authentication Code", class:"block text-xs font-medium text-text-secondary mb-1.5" %> <%= text_field_tag :code, nil, class:"block w-full rounded-lg border border-border bg-surface px-3.5 py-2.5 text-sm text-center font-mono text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", placeholder:"000000", inputmode:"numeric", autocomplete:"off", required: true, pattern:"[0-9]*", maxlength: 6 %> </div>
 
          <div> <%= label_tag :password,"Create Password", class:"block text-xs font-medium text-text-secondary mb-1.5" %> <%= password_field_tag :password, nil, class:"block w-full rounded-lg border border-border bg-surface px-3.5 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary", placeholder:"Minimum 8 characters", required: true, minlength: 8, autocomplete:"new-password" %> </div>
 <%= submit_tag"Activate My Account", class:"flex w-full justify-center rounded-lg bg-primary px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-colors" %> <% end %> </div>
 </div>
 </div>
 </div>
 
