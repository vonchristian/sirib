<% content_for :title,"Member Sign In" %> 
<div class="min-h-screen flex items-center justify-center px-4 bg-surface-alt"> 
  <div class="w-full max-w-sm"> 
    <div class="text-center mb-8"> 
<div class="flex justify-center mb-4">
        <%= render "shared/logo", size: "lg", class: "text-primary" %>
      </div>
 
      <h1 class="text-xl font-semibold text-text-primary">Member Portal</h1>
 
      <p class="text-sm text-text-tertiary mt-1">Sign in to view your account</p>
 </div>
 <% if flash[:alert] %> 
      <div class="mb-4 rounded-lg bg-danger-50 dark:bg-danger/20 border border-danger/20 dark:border-danger/40 px-4 py-3 text-sm text-danger dark:text-danger/80"><%= flash[:alert] %></div>
 <% end %> 
    <div class="bg-surface rounded-xl border border-border p-6"> <%= form_with url: portal_session_path, class:"space-y-4", data: { turbo: false } do |form| %> 
        <div> <%= form.label :member_identifier,"Member ID or Email", class:"block text-xs font-medium text-text-secondary mb-1.5" %> <%= form.text_field :member_identifier, required: true, autofocus: true, autocomplete:"username", placeholder:"MBR-... or email address", class:"block w-full rounded-lg border border-border bg-surface px-3.5 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary dark:placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %> </div>
 
        <div> <%= form.label :password, class:"block text-xs font-medium text-text-secondary mb-1.5" %> <%= form.password_field :password, required: true, autocomplete:"current-password", placeholder:"Enter your password", maxlength: 72, class:"block w-full rounded-lg border border-border bg-surface px-3.5 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary dark:placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %> </div>
 <%= form.submit"Sign In", class:"flex w-full justify-center rounded-lg bg-primary px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-colors" %> <% end %> </div>
 
    <p class="mt-6 text-center text-xs text-text-tertiary"> Sirib — Cooperative Banking Platform </p>
 </div>
 </div>
 
