<% content_for :title, @announcement.title %>

<div class="max-w-2xl">
  <%= link_to "← Back to announcements", portal_announcements_path, class: "text-xs font-medium text-blue-600 dark:text-blue-400 hover:underline mb-4 inline-block" %>

  <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-6">
    <h1 class="text-lg font-semibold text-gray-900 dark:text-gray-100"><%= @announcement.title %></h1>
    <p class="text-xs text-gray-400 dark:text-gray-500 mt-1"><%= l(@announcement.published_at, format: :long) %></p>
    <div class="mt-4 text-sm text-gray-700 dark:text-gray-300 leading-relaxed whitespace-pre-wrap"><%= @announcement.body %></div>
  </div>
</div>
