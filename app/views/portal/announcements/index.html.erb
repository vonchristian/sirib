<% content_for :title, "Announcements" %>

<div class="space-y-6">
  <h1 class="text-lg font-semibold text-gray-900 dark:text-gray-100">Announcements</h1>

  <% if @announcements.any? %>
    <div class="space-y-4">
      <% @announcements.each do |announcement| %>
        <div class="rounded-xl bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 p-4">
          <h2 class="text-sm font-semibold text-gray-900 dark:text-gray-100"><%= link_to announcement.title, portal_announcement_path(announcement), class: "hover:text-blue-600 dark:hover:text-blue-400 transition-colors" %></h2>
          <p class="text-xs text-gray-500 dark:text-gray-400 mt-1"><%= truncate(announcement.body, length: 200) %></p>
          <p class="text-[10px] text-gray-400 dark:text-gray-500 mt-2"><%= l(announcement.published_at, format: :long) %></p>
        </div>
      <% end %>
    </div>
    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  <% else %>
    <div class="text-center py-12">
      <svg class="mx-auto h-12 w-12 text-gray-300 dark:text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.34 15.84c-.688-.06-1.386-.09-2.09-.09H7.5a4.5 4.5 0 1 1 0-9h.75c.704 0 1.402-.03 2.09-.09m0 9.18c.253.962.584 1.892.985 2.783.247.55.06 1.21-.463 1.511l-.657.38a2.293 2.293 0 0 1-2.067-.03M10.34 15.84A8.06 8.06 0 0 0 12 12a8.06 8.06 0 0 0-1.66-3.84m0 0a8.06 8.06 0 0 0-2.09-.09H7.5m5.16 0a8.041 8.041 0 0 1 .985-2.783.852.852 0 0 0-.463-1.511l-.657-.38a2.293 2.293 0 0 0-2.067.03m2.165 15.098A8.072 8.072 0 0 0 16.5 12a8.072 8.072 0 0 0-1.835-5.098m0 0A8.072 8.072 0 0 0 12 6.75a8.04 8.04 0 0 0-2.335.402M15.75 12a.75.75 0 1 1 0 1.5.75.75 0 0 1 0-1.5Z"/>
      </svg>
      <h3 class="mt-4 text-sm font-medium text-gray-900 dark:text-gray-100">No announcements yet</h3>
      <p class="mt-1 text-xs text-gray-500 dark:text-gray-400">Check back later for updates from your cooperative.</p>
    </div>
  <% end %>
</div>
