<% if pagy.pages > 1 %>
  <nav class="inline-flex items-center gap-1" aria-label="pagination">
    <% if pagy.prev %>
      <a href="<%= pagy_url_for(pagy, pagy.prev) %>" class="inline-flex items-center justify-center rounded-lg border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400">
        <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
        Prev
      </a>
    <% else %>
      <span class="inline-flex items-center justify-center rounded-lg border border-border/50 px-3 py-1.5 text-xs font-medium text-text-tertiary cursor-not-allowed dark:border-gray-700 dark:text-gray-600">
        <svg class="h-4 w-4 mr-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg>
        Prev
      </span>
    <% end %>

    <% pagy.series.each do |item| %>
      <% if item.is_a?(Integer) %>
        <% if item == pagy.page %>
          <span class="inline-flex items-center justify-center rounded-lg bg-primary px-3 py-1.5 text-xs font-semibold text-white min-w-[2rem]"><%= item %></span>
        <% else %>
          <a href="<%= pagy_url_for(pagy, item) %>" class="inline-flex items-center justify-center rounded-lg border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors min-w-[2rem] dark:border-gray-600 dark:text-gray-400"><%= item %></a>
        <% end %>
      <% elsif item.is_a?(String) %>
        <span class="inline-flex items-center justify-center px-2 py-1.5 text-xs text-text-tertiary dark:text-gray-500"><%= item %></span>
      <% end %>
    <% end %>

    <% if pagy.next %>
      <a href="<%= pagy_url_for(pagy, pagy.next) %>" class="inline-flex items-center justify-center rounded-lg border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400">
        Next
        <svg class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
      </a>
    <% else %>
      <span class="inline-flex items-center justify-center rounded-lg border border-border/50 px-3 py-1.5 text-xs font-medium text-text-tertiary cursor-not-allowed dark:border-gray-700 dark:text-gray-600">
        Next
        <svg class="h-4 w-4 ml-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg>
      </span>
    <% end %>
  </nav>
<% end %>
