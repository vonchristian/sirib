<% if pagy.pages > 1 %> <nav class="flex items-center gap-1" aria-label="pagination"> <% if pagy.prev %> <a href="<%= pagy_url_for(pagy, pagy.prev) %>" class="inline-flex items-center justify-center gap-2 rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors"> <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg> Prev </a> <% else %> <span class="inline-flex items-center justify-center gap-2 rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-medium text-text-secondary opacity-40 cursor-not-allowed"> <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5"/></svg> Prev </span> <% end %> <% pagy.series.each do |item| %> <% if item.is_a?(Integer) %> <% if item == pagy.page %> <span class="inline-flex items-center justify-center rounded-sm bg-primary px-3 py-1.5 text-xs font-semibold text-white min-w-[2rem]"><%= item %></span> <% else %> <a href="<%= pagy_url_for(pagy, item) %>" class="inline-flex items-center justify-center rounded-sm px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors min-w-[2rem]"><%= item %></a> <% end %> <% elsif item.is_a?(String) %> <span class="inline-flex items-center justify-center px-2 py-1.5 text-xs text-text-tertiary"><%= item %></span> <% end %> <% end %> <% if pagy.next %> <a href="<%= pagy_url_for(pagy, pagy.next) %>" class="inline-flex items-center justify-center gap-2 rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors"> Next <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg> </a> <% else %> <span class="inline-flex items-center justify-center gap-2 rounded-md border border-border bg-surface px-3 py-1.5 text-xs font-medium text-text-secondary opacity-40 cursor-not-allowed"> Next <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5"/></svg> </span> <% end %> </nav> <% end %> 