<div class="hidden h-14 items-center justify-between border-b border-border bg-surface px-6 lg:flex">
  <div class="flex items-center gap-4 flex-1">
    <div>
      <h1 class="text-base font-semibold text-text-primary"><%= content_for?(:page_title) ? yield(:page_title) : "Dashboard" %></h1>
      <p class="text-xs text-text-tertiary"><%= content_for?(:page_subtitle) ? yield(:page_subtitle) : "Overview of your cooperative" %></p>
    </div>
  </div>

  <div class="flex items-center gap-1">
    <div class="relative hidden xl:block">
      <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-tertiary pointer-events-none" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/>
      </svg>
      <input type="search" placeholder="Search accounts, members, transactions..." class="input w-60 pl-10 py-2 text-xs">
    </div>

    <button class="relative rounded-md p-2 text-text-tertiary hover:bg-surface-alt hover:text-text-secondary transition-colors" title="Notifications">
      <svg class="h-4.5 w-4.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M14.857 17.082a23.848 23.848 0 0 0 5.454-1.31A8.967 8.967 0 0 1 18 9.75V9A6 6 0 0 0 6 9v.75a8.967 8.967 0 0 1-2.312 6.022c1.733.64 3.56 1.085 5.455 1.31m5.714 0a24.255 24.255 0 0 1-5.714 0m5.714 0a3 3 0 1 1-5.714 0"/>
      </svg>
      <span class="absolute right-0.5 top-0.5 flex h-3.5 w-3.5 items-center justify-center rounded-full bg-danger text-[9px] font-bold text-white">3</span>
    </button>

    <button data-action="click->sidebar#toggleDarkMode" class="rounded-md p-2 text-text-tertiary hover:bg-surface-alt hover:text-text-secondary transition-colors" title="Toggle dark mode">
      <svg class="hidden h-4.5 w-4.5 dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z"/>
      </svg>
      <svg class="block h-4.5 w-4.5 dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.72 9.72 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z"/>
      </svg>
    </button>

    <div class="relative" data-user-menu-container>
      <button data-action="click->sidebar#toggleUserMenu" class="flex items-center gap-2 rounded-md pl-0.5 pr-2 py-0.5 text-sm text-text-secondary hover:bg-surface-alt transition-colors">
        <span class="flex h-6 w-6 items-center justify-center rounded bg-primary text-[11px] font-semibold text-white"><%= Current.user.email_address.first.upcase %></span>
        <span class="hidden xl:block max-w-[120px] truncate text-xs"><%= Current.user.email_address %></span>
        <svg class="h-3 w-3 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5"/>
        </svg>
      </button>

      <div data-sidebar-target="userMenu" class="absolute right-0 top-full mt-2 hidden w-56 rounded-md border border-border bg-surface py-1 shadow-sm animate-fade-in">
        <div class="border-b border-border px-4 pb-2 mb-1">
          <p class="text-sm font-medium text-text-primary"><%= Current.user.email_address %></p>
          <p class="text-xs text-text-tertiary">Signed in</p>
        </div>

        <%= link_to "#", class: "flex items-center gap-3 px-4 py-2 text-sm text-text-secondary hover:bg-surface-alt transition-colors" do %>
          <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0ZM4.501 20.118a7.5 7.5 0 0 1 14.998 0A17.933 17.933 0 0 1 12 21.75c-2.676 0-5.216-.584-7.499-1.632Z"/>
          </svg>
          Profile
        <% end %>

        <%= link_to "#", class: "flex items-center gap-3 px-4 py-2 text-sm text-text-secondary hover:bg-surface-alt transition-colors" do %>
          <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.582.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z"/>
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z"/>
          </svg>
          Settings
        <% end %>

        <div class="border-t border-border mt-1 pt-1">
          <%= button_to session_path, method: :delete, class: "flex w-full items-center gap-3 px-4 py-2 text-sm text-text-secondary hover:bg-surface-alt transition-colors" do %>
            <svg class="h-4 w-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
            </svg>
            Sign out
          <% end %>
        </div>
      </div>
    </div>
  </div>
</div>