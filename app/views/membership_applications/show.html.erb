iv> <% end %> </div> <% else %> <p class="text-sm text-text-tertiary italic">None provided</p> <% end %> </div> <hr class="border-border"> <div class="print-break-inside" data-controller="image-modal"> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Signature Specimens</h4> <% if @application.signature_specimens.any? %> <div class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-3"> <% @application.signature_specimens.each_with_index do |data_url, index| %> <div class="text-center"> <div class="group relative"> <%= image_tag data_url, class:"h-16 w-full rounded-md border border-border bg-surface object-contain" %> <button type="button" data-action="click->image-modal#open" data-image-modal-group="signature" class="absolute bottom-1 right-1 flex items-center gap-1 rounded-md bg-black/60 px-1.5 py-0.5 text-[10px] text-white opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/75"> <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM13.5 10.5h-6m0 0h-3m3 0v-3m0 3v3" /></svg> View Larger </button> </div> <p class="mt-1 text-[10px] text-text-tertiary">Specimen #<%= index + 1 %></p> </div> <% end %> </div> <% else %> <p class="text-sm text-text-tertiary italic">Not yet provided</p> <% end %> <dialog data-image-modal-target="dialog" class="id-modal" data-action="keydown.self->image-modal#navigate click->image-modal#closeOnBackdrop"> <div class="relative p-6"> <button type="button" data-action="image-modal#close" class="absolute -top-4 -right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-surface shadow-md border border-border text-text-secondary hover:text-text-primary transition-colors"> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M