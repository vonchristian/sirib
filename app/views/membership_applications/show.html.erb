<% content_for :page_title, "Membership Application" %>
<% content_for :page_subtitle, "Application ##{@application.uuid.first(8).upcase}" %>

<div class="animate-fade-in space-y-6">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
    <div class="flex items-center justify-between">
      <div>
        <h3 class="text-sm font-semibold text-text-primary dark:text-white">Application Status</h3>
        <p class="mt-1 text-sm text-text-secondary dark:text-gray-400">UUID: <code class="rounded bg-gray-100 px-1.5 py-0.5 text-xs dark:bg-gray-800"><%= @application.uuid %></code></p>
      </div>
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center rounded-full px-3 py-1 text-xs font-medium ring-1 ring-inset capitalize
          <%= case @application.status
          when 'draft' then 'bg-warning-50 text-warning ring-warning/20 dark:bg-amber-900/30 dark:text-amber-400'
          when 'completed' then 'bg-primary-50 text-primary ring-primary/20 dark:bg-primary-900/30 dark:text-primary-300'
          when 'approved' then 'bg-positive-50 text-positive ring-positive/20 dark:bg-emerald-900/30 dark:text-emerald-400'
          when 'rejected' then 'bg-danger-50 text-danger ring-danger/20 dark:bg-red-900/30 dark:text-red-400'
          end %>">
          <%= @application.status %>
        </span>
        <% if @application.complete? && @application.status != "approved" %>
          <%= button_to "Approve Membership",
                approve_membership_application_path(@application.uuid),
                method: :post,
                class: "inline-flex items-center gap-2 rounded-md bg-positive px-4 py-2 text-sm font-medium text-white hover:bg-positive-700 transition-colors",
                data: { turbo_confirm: "Approve this membership? This will create a permanent member record." } %>
        <% end %>
        <% if @application.status == "draft" %>
          <%= link_to "Resume Application",
                edit_membership_application_path(@application.uuid),
                class: "inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 transition-colors" %>
        <% end %>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-2">
    <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
      <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Personal Details</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Name</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= [@application.first_name, @application.middle_name, @application.last_name].compact.join(" ") %><%= " #{@application.suffix}" if @application.suffix.present? %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Birth Date</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.birth_date %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Gender</dt>
          <dd class="text-sm text-text-primary dark:text-white capitalize"><%= @application.gender %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Civil Status</dt>
          <dd class="text-sm text-text-primary dark:text-white capitalize"><%= @application.civil_status %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Mobile</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.mobile_number %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Email</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.email_address || "—" %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
      <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Address</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Street</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.house_street %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Barangay</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.barangay %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">City</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.city %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Province</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.province %></dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Region</dt>
          <dd class="text-sm text-text-primary dark:text-white"><%= @application.region %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
      <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Identifications</h3>
      <% if @application.identifications.any? %>
        <div class="space-y-2">
          <% @application.identifications.each do |id| %>
            <div class="flex items-center justify-between rounded-lg border border-border bg-surface-alt px-4 py-3 dark:border-gray-700 dark:bg-gray-800/50">
              <div>
                <p class="text-sm font-medium text-text-primary dark:text-white"><%= id["id_type"].titleize %></p>
                <p class="text-xs text-text-tertiary dark:text-gray-500"><%= id["id_number"] %></p>
              </div>
            </div>
          <% end %>
        </div>
      <% else %>
        <p class="text-sm text-text-tertiary dark:text-gray-500">No identifications provided.</p>
      <% end %>
    </div>

    <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-6">
      <h3 class="text-sm font-semibold text-text-primary dark:text-white mb-4">Files</h3>
      <dl class="space-y-3">
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Signature</dt>
          <dd class="text-sm text-text-primary dark:text-white">
            <% if @application.signature_data.present? %>
              <span class="inline-flex items-center rounded-full bg-positive-50 px-2 py-0.5 text-xs font-medium text-positive dark:bg-emerald-900/30 dark:text-emerald-400">Provided</span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500 dark:bg-gray-800">Missing</span>
            <% end %>
          </dd>
        </div>
        <div class="flex justify-between">
          <dt class="text-xs font-medium text-text-tertiary dark:text-gray-500 uppercase">Profile Photo</dt>
          <dd class="text-sm text-text-primary dark:text-white">
            <% if @application.profile_image_data.present? %>
              <span class="inline-flex items-center rounded-full bg-positive-50 px-2 py-0.5 text-xs font-medium text-positive dark:bg-emerald-900/30 dark:text-emerald-400">Captured</span>
            <% else %>
              <span class="inline-flex items-center rounded-full bg-gray-100 px-2 py-0.5 text-xs font-medium text-gray-500 dark:bg-gray-800">Missing</span>
            <% end %>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</div>
