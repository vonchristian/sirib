<% content_for :page_title,"Membership Application" %> <% content_for :page_subtitle,"Application ##{@application.uuid.first(8).upcase}" %> <% content_for :head do %> <style> @media print { .no-print { display: none !important; } } </style> <% end %> <% cooperative = @application.cooperative %> <div class="animate-fade-in max-w-4xl mx-auto space-y-4 no-print screen-only"> <div class="flex items-center justify-between"> <div> <h2 class="text-lg font-semibold text-text-primary">Membership Application</h2> <p class="text-sm text-text-tertiary">Application #<%= @application.uuid.first(8).upcase %></p> </div> <div class="flex items-center gap-2"> <%= link_to download_pdf_membership_application_path(@application.uuid), class:"inline-flex items-center gap-2 rounded-md border border-border bg-surface px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-alt transition-colors" do %> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z" /> </svg> Download PDF <% end %> <% if @application.status =="draft" %> <%= link_to"Resume", edit_membership_application_path(@application.uuid), class:"inline-flex items-center gap-2 rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-700 transition-colors" %> <% end %> <% if @application.complete? && @application.status !="approved" %> <%= button_to"Approve Membership", approve_membership_application_path(@application.uuid), method: :post, class:"inline-flex items-center gap-2 rounded-md bg-positive px-4 py-2 text-sm font-medium text-white hover:bg-positive-700 transition-colors", data: { turbo_confirm:"Approve this membership? This will create a permanent member record." } %> <% end %> </div> </div> </div> <div id="print-area" class="animate-fade-in max-w-4xl mx-auto screen-only"> <div class="rounded-lg border border-border bg-surface overflow-hidden"> <div class="p-6 space-y-6"> <div class="flex items-center gap-4"> <% if @application.profile_images.any? %> <div class="flex-shrink-0"> <%= image_tag @application.profile_images.first, class:"h-20 w-20 rounded-full object-cover border-2 border-border" %> </div> <% end %> <div> <h3 class="text-xl font-bold text-text-primary"> <%= [@application.first_name, @application.middle_name, @application.last_name].compact.join("") %> <%=" #{@application.suffix}" if @application.suffix.present? %> </h3> <div class="mt-1 flex items-center gap-2"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium ring-1 ring-inset capitalize <%= case @application.status when 'draft' then 'bg-warning-50 text-warning ring-warning/20 dark:bg-amber-900/30 dark:text-amber-400' when 'completed' then 'bg-primary-50 text-primary ring-primary/20 dark:bg-primary-900/30 dark:text-primary-300' when 'approved' then 'bg-positive-50 text-positive ring-positive/20 dark:bg-emerald-900/30 dark:text-emerald-400' when 'rejected' then 'bg-danger-50 text-danger ring-danger/20 dark:bg-red-900/30 dark:text-red-400' end %>"> <%= @application.status %> </span> <span class="text-xs text-text-tertiary">UUID: <%= @application.uuid %></span> </div> </div> </div> <hr class="border-border"> <div class="print-break-inside"> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Personal Details</h4> <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3"> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Birth Date</dt> <dd class="text-sm text-text-primary"><%= @application.birth_date %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Gender</dt> <dd class="text-sm text-text-primary capitalize"><%= @application.gender %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Civil Status</dt> <dd class="text-sm text-text-primary capitalize"><%= @application.civil_status %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Mobile</dt> <dd class="text-sm text-text-primary"><%= @application.mobile_number %></dd> </div> <div class="flex justify-between sm:flex-col sm:col-span-2"> <dt class="text-xs font-medium text-text-tertiary">Email</dt> <dd class="text-sm text-text-primary"><%= @application.email_address ||"—" %></dd> </div> </dl> </div> <hr class="border-border"> <div class="print-break-inside"> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Address</h4> <dl class="grid grid-cols-1 sm:grid-cols-2 gap-x-8 gap-y-3"> <div class="flex justify-between sm:flex-col sm:col-span-2"> <dt class="text-xs font-medium text-text-tertiary">Street</dt> <dd class="text-sm text-text-primary"><%= @application.house_street %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Barangay</dt> <dd class="text-sm text-text-primary"><%= @application.barangay %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">City</dt> <dd class="text-sm text-text-primary"><%= @application.city %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Province</dt> <dd class="text-sm text-text-primary"><%= @application.province %></dd> </div> <div class="flex justify-between sm:flex-col"> <dt class="text-xs font-medium text-text-tertiary">Region</dt> <dd class="text-sm text-text-primary"><%= @application.region %></dd> </div> </dl> </div> <hr class="border-border"> <div class="print-break-inside" data-controller="image-modal"> <h4 class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-3">Identifications</h4> <% if @application.identifications.any? %> <div class="space-y-2"> <% @application.identifications.each do |id| %> <div class="rounded-lg border border-border bg-surface-alt px-4 py-3"> <div class="flex items-center justify-between"> <div> <p class="text-sm font-medium text-text-primary"><%= id["id_type"].titleize %></p> <p class="text-xs text-text-tertiary"><%= id["id_number"] %></p> </div> </div> <% if id["front_image"].present? || id["back_image"].present? %> <div class="mt-3 flex gap-3"> <% if id["front_image"].present? %> <div> <p class="text-[10px] text-text-tertiary mb-1">Front</p> <div class="group relative w-32"> <%= image_tag id["front_image"], class:"h-20 w-full rounded-md border border-border object-cover" %> <button type="button" data-action="click->image-modal#open" data-image-modal-group="id" class="absolute bottom-1 right-1 flex items-center gap-1 rounded-md bg-black/60 px-1.5 py-0.5 text-[10px] text-white opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/75"> <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM13.5 10.5h-6m0 0h-3m3 0v-3m0 3v3" /></svg> View Larger </button> </div> </div> <% end %> <% if id["back_image"].present? %> <div> <p class="text-[10px] text-text-tertiary mb-1">Back</p> <div class="group relative w-32"> <%= image_tag id["back_image"], class:"h-20 w-full rounded-md border border-border object-cover" %> <button type="button" data-action="click->image-modal#open" data-image-modal-group="id" class="absolute bottom-1 right-1 flex items-center gap-1 rounded-md bg-black/60 px-1.5 py-0.5 text-[10px] text-white opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/75"> <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM13.5 10.5h-6m0 0h-3m3 0v-3m0 3v3" /></svg> View Larger </button> </div> </div> <% end %> </div> <% end %> </div> <% end %> </div> <% else %> <p class="text-sm text-text-tertiary italic">None provided</p> <% end %> <style> .id-modal::backdrop { background: rgba(0, 0, 0, 0.6); backdrop-filter: blur(6px); -webkit-backdrop-filter: blur(6px); animation: modalBackdropIn 0.2s ease-out; } .id-modal { position: fixed; inset: 0px; margin: auto; width: fit-content; height: fit-content; border-radius: 0.75rem; border: 1px solid rgb(229 231 235); background: rgb(255 255 255); padding: 0; box-shadow: 0 25px 50px -12px rgb(0 0 0 / 0.25); max-width: 90vw; max-height: 90vh; animation: modalIn 0.2s ease-out; } .dark .id-modal { border-color: rgb(55 65 81); background: rgb(17 24 39); } @keyframes modalBackdropIn { from { opacity: 0; } to { opacity: 1; } } @keyframes modalIn { from { opacity: 0; transform: scale(0.95); } to { opacity: 1; transform: scale(1); } } </style> <dialog data-image-modal-target="dialog" class="id-modal" data-action="keydown.self->image-modal#navigate click->image-modal#closeOnBackdrop"> <div class="relative p-6"> <button type="button" data-action="image-modal#close" class="absolute -top-4 -right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-surface shadow-md border border-border text-text-secondary hover:text-text-primary transition-colors"> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"> <path stroke-linec