<% content_for :page_title,"Membership Application" %> <% content_for :page_subtitle,"Application ##{@application.uuid.first(8).upcase}" %> 
<div class="mb-4 rounded-lg border border-primary/20 bg-primary-50 px-4 py-3 text-sm text-primary dark:border-primary-900/30 dark:bg-primary-900/20 dark:text-primary-300"> <span class="font-medium">Application ID:</span> <%= @application.uuid %> <span class="ml-4 font-medium">Status:</span> <span class="inline-flex items-center rounded-full bg-warning-50 px-2 py-0.5 text-xs font-medium text-warning ring-1 ring-inset ring-warning/20 dark:bg-warning-900/30 dark:text-warning-400 capitalize"><%= @application.status %></span> 
  <p class="mt-1 text-xs opacity-75">Share this ID so the applicant can resume their application later.</p>
 </div>
 
<div class="animate-fade-in max-w-5xl mx-auto" data-controller="wizard" data-current-step="<%= @initial_step %>"> <%= form_with model: @application, url: membership_application_path(@application.uuid), method: :patch, html: { class:"space-y-6" } do |f| %> <% if @application.errors.any? %> 
      <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger dark:border-danger-900/30 dark:bg-danger-900/20 dark:text-danger-400"> 
        <ul class="list-inside list-disc"> <% @application.errors.each do |error| %> 
            <li><%= error.full_message %></li>
 <% end %> </ul>
 </div>
 <% end %> <%= f.hidden_field :current_step, value: @initial_step, data: { wizard_target:"currentStep" } %> 
    <div data-wizard-target="stepper" class="hidden sm:block"> 
      <div class="flex items-center justify-between"> <% step_labels = ["Personal Details","Address & Contact","Identifications","Sources of Income","Signatures","Profile Photos"] %> <% step_labels.each_with_index do |label, i| %> 
          <div class="flex flex-col items-center flex-1 min-w-0" data-step-index="<%= i %>"> 
            <div class="flex items-center w-full"> 
              <div class="flex-1 h-px <%= i.zero? ? 'invisible' : '' %>" data-step-connector data-step-index="<%= i %>"></div>
 
              <div class="relative flex h-8 w-8 flex-shrink-0 items-center justify-center rounded-full border-2 text-xs font-semibold transition-all duration-300" data-step-circle data-step-index="<%= i %>"> <span data-step-number><%= i + 1 %></span> <svg data-step-check class="hidden h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg> </div>
 
              <div class="flex-1 h-px <%= i == step_labels.length - 1 ? 'invisible' : '' %>" data-step-connector data-step-index="<%= i %>"></div>
 </div>
 <span class="mt-1.5 text-[11px] font-medium leading-tight text-center truncate max-w-[7rem] transition-colors duration-200" data-step-label data-step-index="<%= i %>"><%= label %></span> </div>
 <% end %> </div>
 </div>
 
    <div class="sm:hidden flex items-center justify-between"> 
      <div class="flex items-center gap-1.5"> <% 6.times do |i| %> 
          <div class="flex-1 h-1.5 rounded-full transition-colors duration-300" data-wizard-target="dotMobile"></div>
 <% end %> </div>
 <span class="text-xs text-text-tertiary ml-3" data-wizard-target="counter">Personal Details</span> </div>
 
    <div class="rounded-xl border border-border bg-surface p-6 sm:p-8"> 
      <div data-wizard-target="step"> 
        <h2 class="text-lg font-semibold text-text-primary mb-4">Step 1: Personal Details</h2>
 
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"> 
          <div class="field-group sm:col-span-2 lg:col-span-3"> <%= f.label :first_name, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :first_name, required: true, placeholder:"First name", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :middle_name, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :middle_name, placeholder:"Middle name", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :last_name, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :last_name, required: true, placeholder:"Last name", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :suffix, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.select :suffix, options_for_select([["None",""],"Jr.","Sr.","II","III","IV"], @application.suffix), {}, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :birth_date, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.date_field :birth_date, required: true, max: Date.current.to_s, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :gender, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.select :gender, options_for_select([["Select gender",""],"male","female"], @application.gender), {}, required: true, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :civil_status, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.select :civil_status, options_for_select([["Select civil status",""],"single","married","divorced","widowed"], @application.civil_status), {}, required: true, class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 </div>
 
      <div data-wizard-target="step" class="hidden"> 
        <h2 class="text-lg font-semibold text-text-primary mb-4">Step 2: Address & Contact</h2>
 
        <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3"> 
          <div class="field-group sm:col-span-2 lg:col-span-3"> <%= f.label :house_street,"House / Street", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :house_street, required: true, placeholder:"House number and street name", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :barangay, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :barangay, required: true, placeholder:"Barangay", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :city, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :city, required: true, placeholder:"City / Municipality", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :province, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :province, required: true, placeholder:"Province", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :region, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :region, required: true, placeholder:"Region (e.g. NCR)", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group"> <%= f.label :zip_code, class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :zip_code, placeholder:"ZIP code", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group sm:col-span-2 lg:col-span-3"> <%= f.label :mobile_number,"Mobile Number", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.text_field :mobile_number, required: true, placeholder:"09171234567", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 
          <div class="field-group sm:col-span-2 lg:col-span-3"> <%= f.label :email_address,"Email Address", class:"block mb-1.5 text-xs font-medium text-text-primary" %> <%= f.email_field :email_address, placeholder:"email@example.com", class:"block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none" %> </div>
 </div>
 </div>
 
      <div data-wizard-target="step" class="hidden"> 
        <div data-controller="image-modal"> 
          <h2 class="text-lg font-semibold text-text-primary mb-4">Step 3: Identifications</h2>
 
          <p class="mb-4 text-sm text-text-secondary">At least one BIR identification is required.</p>
 
          <div id="identifications" class="space-y-4"> <% entries = @application.identifications.presence || [{}] %> <% entries.each_with_index do |id, idx| %> 
              <div class="rounded-lg border border-border bg-surface-alt p-4 identification-entry"> 
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2"> 
                  <div class="field-group"> <label class="block mb-1.5 text-xs font-medium text-text-primary">ID Type</label> <select name="membership_application[identifications][][id_type]" required class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"> <option value="">Select ID type</option> <% Membership::Identification::ID_TYPES.each do |type| %> <option value="<%= type %>" <%= type == id["id_type"] ? "selected" :"" %>><%= type.titleize %></option> <% end %> </select> </div>
 
                    <div class="field-group"> <label class="block mb-1.5 text-xs font-medium text-text-primary">ID Number</label> <input type="text" name="membership_application[identifications][][id_number]" value="<%= id["id_number"] %>" required placeholder="ID number" class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"> </div>
 </div>
 
                  <div class="mt-4 grid grid-cols-1 gap-4 sm:grid-cols-2"> 
                    <div class="field-group"> <label class="block mb-1.5 text-xs font-medium text-text-primary">Front of ID *</label> <input type="hidden" name="membership_application[identifications][][front_image]" value="<%= id["front_image"] %>" class="id-image-input"> <input type="file" accept="image/*" data-action="change->wizard#handleIdImage" class="file-input-highlight block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-1 file:text-xs file:font-medium file:text-white hover:file:bg-primary-700"> <% if id["front_image"].present? %> 
                        <div class="group relative"> <img src="<%= id["front_image"] %>" class="id-image-preview mt-2 h-24 w-full rounded-md border border-border object-cover"> <button type="button" data-action="click->image-modal#open" data-image-modal-group="id" class="id-image-enlarge absolute bottom-1 right-1 flex items-center gap-1 rounded-md bg-black/60 px-1.5 py-0.5 text-[10px] text-white opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/75"> <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM13.5 10.5h-6m0 0h-3m3 0v-3m0 3v3" /></svg> View Larger </button> </div>
 <% else %> <img class="id-image-preview mt-2 h-24 w-full rounded-md border border-border object-cover hidden"> <% end %> </div>
 
                    <div class="field-group"> <label class="block mb-1.5 text-xs font-medium text-text-primary">Back of ID *</label> <input type="hidden" name="membership_application[identifications][][back_image]" value="<%= id["back_image"] %>" class="id-image-input"> <input type="file" accept="image/*" data-action="change->wizard#handleIdImage" class="file-input-highlight block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary file:mr-3 file:rounded-md file:border-0 file:bg-primary file:px-3 file:py-1 file:text-xs file:font-medium file:text-white hover:file:bg-primary-700"> <% if id["back_image"].present? %> 
                        <div class="group relative"> <img src="<%= id["back_image"] %>" class="id-image-preview mt-2 h-24 w-full rounded-md border border-border object-cover"> <button type="button" data-action="click->image-modal#open" data-image-modal-group="id" class="id-image-enlarge absolute bottom-1 right-1 flex items-center gap-1 rounded-md bg-black/60 px-1.5 py-0.5 text-[10px] text-white opacity-0 group-hover:opacity-100 transition-opacity hover:bg-black/75"> <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607zM13.5 10.5h-6m0 0h-3m3 0v-3m0 3v3" /></svg> View Larger </button> </div>
 <% else %> <img class="id-image-preview mt-2 h-24 w-full rounded-md border border-border object-cover hidden"> <% end %> </div>
 </div>
 </div>
 <% end %> </div>
 <button type="button" data-action="wizard#addIdentification" class="inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors mt-3"> <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3" /> </svg> Add Another ID </button> <dialog data-image-modal-target="dialog" class="id-modal" data-action="keydown.self->image-modal#navigate click->image-modal#closeOnBackdrop"> 
              <div class="relative p-6"> <button type="button" data-action="image-modal#close" class="absolute -top-4 -right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-surface shadow-md border border-border text-text-secondary hover:text-text-primary transition-colors"> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /> </svg> </button> 
                <p data-image-modal-target="title" class="text-sm font-medium text-text-primary text-center mb-3"></p>
 
                <div class="flex items-center justify-center gap-4 mb-4"> <button type="button" data-image-modal-target="prevNav" data-action="image-modal#prev" class="flex h-10 w-10 items-center justify-center rounded-full bg-surface border border-border text-text-secondary hover:bg-surface-alt transition-colors flex-shrink-0"> <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg> </button> <span class="text-xs text-text-tertiary select-none flex-shrink-0" data-image-modal-target="counter">1 / 1</span> <button type="button" data-image-modal-target="nextNav" data-action="image-modal#next" class="flex h-10 w-10 items-center justify-center rounded-full bg-surface border border-border text-text-secondary hover:bg-surface-alt transition-colors flex-shrink-0"> <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg> </button> </div>
 <img data-image-modal-target="image" class="max-h-[75vh] max-w-[85vw] rounded-lg object-contain"> </div>
 </dialog> </div>
 </div>
 
        <div data-wizard-target="step" class="hidden"> 
          <h2 class="text-lg font-semibold text-text-primary mb-4">Step 4: Sources of Income</h2>
 
          <p class="mb-4 text-sm text-text-secondary">Specify your source(s) of income. You can add multiple sources.</p>
 
          <div id="sources-of-income" class="space-y-4"> <% entries = @application.sources_of_income.presence || [{}] %> <% entries.each_with_index do |src, idx| %> 
              <div class="rounded-lg border border-border bg-surface-alt p-4 income-entry"> 
                <div class="grid grid-cols-1 gap-4 sm:grid-cols-2"> 
                  <div class="field-group"> <label class="block mb-1.5 text-xs font-medium text-text-primary">Source of Income</label> <select name="membership_application[sources_of_income][][source_type]" required class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"> <option value="">Select source</option> <option value="Employment" <%="selected" if src["source_type"] =="Employment" %>>Employment</option> <option value="Self-Employed" <%="selected" if src["source_type"] =="Self-Employed" %>>Self-Employed</option> <option value="Business" <%="selected" if src["source_type"] =="Business" %>>Business</option> <option value="Remittances" <%="selected" if src["source_type"] =="Remittances" %>>Remittances</option> <option value="Pension" <%="selected" if src["source_type"] =="Pension" %>>Pension</option> <option value="Investment" <%="selected" if src["source_type"] =="Investment" %>>Investment</option> <option value="Others" <%="selected" if src["source_type"] =="Others" %>>Others</option> </select> </div> <div class="field-group"> <label class="block mb-1.5 text-xs font-medium text-text-primary">Monthly Income (PHP)</label> <input type="number" name="membership_application[sources_of_income][][monthly_income]" value="<%= src["monthly_income"] %>" required min="0" step="0.01" placeholder="0.00" class="block w-full rounded-md border border-border bg-surface px-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"> </div>
 </div>
 </div>
 <% end %> </div>
 <button type="button" data-action="wizard#addIncome" class="inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors mt-3"> <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3" /> </svg> Add Another Source </button> </div>
 
            <div data-wizard-target="step" class="hidden"> 
              <h2 class="text-lg font-semibold text-text-primary mb-4">Step 5: Signature Specimens</h2>
 
              <p class="mb-4 text-sm text-text-secondary">Draw your signature below and capture at least 3 specimens.</p>
 
              <div data-controller="signature-pad" class="space-y-4"> 
                <div class="relative overflow-hidden rounded-lg border border-border bg-surface" style="touch-action: none;"> 
                  <canvas data-signature-pad-target="canvas" class="h-48 w-full cursor-crosshair" width="800" height="192"></canvas>
 
                  <div class="pointer-events-none absolute inset-0 flex items-center justify-center"> <span class="text-sm text-text-tertiary select-none">Draw signature here</span> </div>
 </div>
 <%= f.hidden_field :signature_specimens, value: @application.signature_specimens.to_json, data: { signature_pad_target:"hidden" } %> 
                <div class="flex items-center gap-2"> <button type="button" data-signature-pad-target="clearBtn" data-action="signature-pad#clear" class="hidden inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors"> Clear </button> <button type="button" data-action="signature-pad#capture" class="inline-flex items-center justify-center gap-2 rounded-md bg-primary px-3 py-1.5 text-xs font-medium text-white hover:bg-primary-700 transition-colors"> <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /> </svg> Capture Specimen </button> </div>
 
                <div data-signature-pad-target="counter" class="text-xs text-text-tertiary"> 0 of at least 3 captured </div>
 
                <div data-controller="image-modal"> 
                  <div data-signature-pad-target="gallery" class="grid grid-cols-3 sm:grid-cols-4 md:grid-cols-5 gap-2"> </div>
 <dialog data-image-modal-target="dialog" class="id-modal" data-action="keydown.self->image-modal#navigate click->image-modal#closeOnBackdrop"> 
                    <div class="relative p-6"> <button type="button" data-action="image-modal#close" class="absolute -top-4 -right-4 z-10 flex h-8 w-8 items-center justify-center rounded-full bg-surface shadow-md border border-border text-text-secondary hover:text-text-primary transition-colors"> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /> </svg> </button> 
                      <p data-image-modal-target="title" class="text-sm font-medium text-text-primary text-center mb-3"></p>
 
                      <div class="flex items-center justify-center gap-4 mb-4"> <button type="button" data-image-modal-target="prevNav" data-action="image-modal#prev" class="flex h-10 w-10 items-center justify-center rounded-full bg-surface border border-border text-text-secondary hover:bg-surface-alt transition-colors flex-shrink-0"> <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 19.5 8.25 12l7.5-7.5" /></svg> </button> <span class="text-xs text-text-tertiary select-none flex-shrink-0" data-image-modal-target="counter">1 / 1</span> <button type="button" data-image-modal-target="nextNav" data-action="image-modal#next" class="flex h-10 w-10 items-center justify-center rounded-full bg-surface border border-border text-text-secondary hover:bg-surface-alt transition-colors flex-shrink-0"> <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="m8.25 4.5 7.5 7.5-7.5 7.5" /></svg> </button> </div>
 <img data-image-modal-target="image" class="max-h-[75vh] max-w-[85vw] rounded-lg object-contain"> </div>
 </dialog> </div>
 </div>
 </div>
 
            <div data-wizard-target="step" class="hidden"> 
              <h2 class="text-lg font-semibold text-text-primary mb-4">Step 6: Profile Photos</h2>
 
              <p class="mb-4 text-sm text-text-secondary">Capture at least 1 photo using your webcam.</p>
 
              <div class="space-y-4"> 
                <div data-wizard-target="webcamError" class="hidden rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger dark:border-danger-900/30 dark:bg-danger-900/20 dark:text-danger-400"> Could not access camera. Please ensure camera permissions are granted. </div>
 
                <div class="flex flex-col items-center gap-4"> 
