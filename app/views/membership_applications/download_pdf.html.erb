<% cooperative = @application.cooperative %> <div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #1a1a1a; font-size: 9pt; line-height: 1.4;"> <div style="border-bottom: 2pt solid #1a1a1a; padding-bottom: 10pt; margin-bottom: 14pt;"> <div style="display: flex; justify-content: space-between; align-items: flex-end;"> <div> <div style="font-size: 13pt; font-weight: 700; letter-spacing: 0.3pt; text-transform: uppercase;"><%= cooperative.name %></div> <div style="font-size: 8pt; color: #555; margin-top: 3pt;"><%= cooperative.address.presence %></div> </div> <div style="text-align: right; font-size: 8pt; color: #555; line-height: 1.6;"> <% if cooperative.contact_number.present? %><div>Tel: <%= cooperative.contact_number %></div><% end %> <% if cooperative.registration_number.present? %><div>Reg: <%= cooperative.registration_number %></div><% end %> </div> </div> </div> <div style="text-align: center; font-size: 10pt; font-weight: 600; letter-spacing: 1pt; text-transform: uppercase; margin-bottom: 14pt;">Membership Application</div> <div style="display: flex; gap: 20pt; margin-bottom: 14pt;"> <div style="flex: 1;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Applicant</div> <div style="font-size: 10pt; font-weight: 600; margin-bottom: 4pt;"><%= [@application.first_name, @application.middle_name, @application.last_name].compact.join("") %><%=" #{@application.suffix}" if @application.suffix.present? %></div> <div style="font-size: 8pt; color: #555;"><%= @application.gender&.titleize %> &middot; <%= @application.civil_status&.titleize %></div> <div style="font-size: 8pt; color: #555;">Born <%= @application.birth_date %></div> </div> <div style="flex: 1;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Contact</div> <div style="font-size: 8pt; line-height: 1.7;"><%= @application.mobile_number %></div> <div style="font-size: 8pt; line-height: 1.7;"><%= @application.email_address.presence ||"—" %></div> </div> </div> <hr style="border: none; border-top: 0.5pt solid #ccc; margin: 0 0 10pt 0;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Address</div> <div style="font-size: 8pt; line-height: 1.7; margin-bottom: 14pt;"> <%= @application.house_street %><% if @application.barangay.present? %>, <%= @application.barangay %><% end %><br> <%= @application.city %>, <%= @application.province %><% if @application.region.present? %>, <%= @application.region %><% end %> </div> <hr style="border: none; border-top: 0.5pt solid #ccc; margin: 0 0 10pt 0;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Identifications</div> <% if @application.identifications.any? %> <div style="margin-bottom: 14pt;"> <% @application.identifications.each do |id| %> <div style="margin-bottom: 6pt;"> <div style="display: inline-block; padding: 3pt 8pt; border: 0.5pt solid #ccc; border-radius: 3pt; font-size: 8pt;"> <strong><%= id["id_type"].titleize %></strong>: <%= id["id_number"] %> </div> <% if id["front_image"].present? || id["back_image"].present? %> <div style="display: flex; gap: 8pt; margin-top: 4pt;"> <% if id["front_image"].present? %> <div style="text-align: center;"> <%= image_tag id["front_image"], style:"height: 48pt; width: 72pt; object-fit: cover; border: 0.5pt solid #ccc; border-radius: 2pt;" %> <div style="font-size: 6pt; color: #999; margin-top: 1pt;">Front</div> </div> <% end %> <% if id["back_image"].present? %> <div style="text-align: center;"> <%= image_tag id["back_image"], style:"height: 48pt; width: 72pt; object-fit: cover; border: 0.5pt solid #ccc; border-radius: 2pt;" %> <div style="font-size: 6pt; color: #999; margin-top: 1pt;">Back</div> </div> <% end %> </div> <% end %> </div> <% end %> </div> <% else %> <div style="font-size: 8pt; color: #999; font-style: italic; margin-bottom: 14pt;">None provided</div> <% end %> <hr style="border: none; border-top: 0.5pt solid #ccc; margin: 0 0 10pt 0;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Sources of Income</div> <% if @application.sources_of_income.any? %> <div style="margin-bottom: 14pt;"> <table style="width: 100%; border-collapse: collapse; font-size: 8pt;"> <thead> <tr style="border-bottom: 0.5pt solid #ccc;"> <th style="text-align: left; padding: 3pt 6pt; font-weight: 600; color: #555;">Source</th> <th style="text-align: right; padding: 3pt 6pt; font-weight: 600; color: #555;">Monthly Income (PHP)</th> </tr> </thead> <tbody> <% @application.sources_of_income.each do |src| %> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 3pt 6pt;"><%= src["source_type"] %></td> <td style="padding: 3pt 6pt; text-align: right;"><%= number_with_delimiter(src["monthly_income"].to_f, delimiter:",") %></td> </tr> <% end %> </tbody> </table> </div> <% else %> <div style="font-size: 8pt; color: #999; font-style: italic; margin-bottom: 14pt;">None provided</div> <% end %> <% if @application.signature_specimens.any? %> <hr style="border: none; border-top: 0.5pt solid #ccc; margin: 0 0 10pt 0;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Signature Specimens</div> <div style="display: flex; gap: 12pt; margin-bottom: 14pt;"> <% @application.signature_specimens.each_with_index do |data_url, index| %> <div style="text-align: center;"> <div style="border: 0.5pt solid #ccc; border-radius: 3pt; padding: 4pt; background: #fafafa;"> <%= image_tag data_url, style:"height: 32pt; width: 96pt; object-fit: contain;" %> </div> <div style="font-size: 7pt; color: #888; margin-top: 2pt;">#<%= index + 1 %></div> </div> <% end %> </div> <% end %> <% if @application.profile_images.any? %> <hr style="border: none; border-top: 0.5pt solid #ccc; margin: 0 0 10pt 0;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 6pt;">Profile Photos</div> <div style="display: flex; gap: 10pt; margin-bottom: 14pt;"> <% @application.profile_images.each_with_index do |data_url, index| %> <div style="text-align: center;"> <%= image_tag data_url, style:"height: 48pt; width: 48pt; border-radius: 50%; border: 0.5pt solid #ccc; object-fit: cover;" %> <div style="font-size: 7pt; color: #888; margin-top: 2pt;">#<%= index + 1 %></div> </div> <% end %> </div> <% end %> <div style="margin-top: 20pt; border-top: 0.5pt solid #ccc; padding-top: 6pt; font-size: 6.5pt; color: #999;"> <div style="display: flex; justify-content: space-between;"> <span>UUID: <%= @application.uuid %></span> <span>Status: <%= @application.status.titleize %></span> <span>Filed: <%= @application.created_at.strftime("%b %d, %Y") %></span> <span>Printed: <%= Time.current.strftime("%b %d, %Y") %></span> </div> </div> </div> 