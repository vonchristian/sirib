<%= turbo_frame_tag"branch_performance" do %> <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; padding: 20px;"> <h3 style="font-size: 13px; font-weight: 600; color: var(--text-primary); margin: 0 0 12px;">Branch Performance</h3> <div style="overflow-x: auto;"> <table style="width: 100%; font-size: 13px; border-collapse: collapse;"> <thead> <tr> <th style="text-align: left; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border-color);">Branch</th> <th style="text-align: right; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border-color);">Portfolio</th> <th style="text-align: right; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border-color);">Delinquent</th> <th style="text-align: right; padding: 8px 12px; font-size: 11px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; color: var(--text-muted); border-bottom: 1px solid var(--border-color);">PAR30</th> </tr> </thead> <tbody> <% if @branch_performance.any? %> <% @branch_performance.each do |branch| %> <tr style="transition: background 0.1s;"> <td style="padding: 10px 12px; font-weight: 500; color: var(--text-primary); border-bottom: 1px solid var(--border-color);"><%= branch[:branch_name] %></td> <td style="padding: 10px 12px; text-align: right; color: var(--text-secondary); border-bottom: 1px solid var(--border-color);"><%= number_to_currency(branch[:portfolio_cents].to_f / 100, unit:"PHP") %></td> <td style="padding: 10px 12px; text-align: right; color: <%= branch[:delinquent_cents] > 0 ? '#ef4444' : 'var(--text-secondary)' %>; border-bottom: 1px solid var(--border-color);"> <%= number_to_currency(branch[:delinquent_cents].to_f / 100, unit:"PHP") %> </td> <td style="padding: 10px 12px; text-align: right; color: <%= branch[:par30_ratio] > 5 ? '#ef4444' : 'var(--text-secondary)' %>; font-weight: <%= branch[:par30_ratio] > 5 ? '600' : '400' %>; border-bottom: 1px solid var(--border-color);"> <%= branch[:par30_ratio] %>% </td> </tr> <% end %> <% else %> <tr> <td colspan="4" style="padding: 32px 12px; text-align: center; font-size: 13px; color: var(--text-muted);">No branch data available.</td> </tr> <% end %> </tbody> </table> </div> </div> <% end %> 