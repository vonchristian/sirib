<%= turbo_frame_tag"filters" do %> 
  <div style="background: var(--bg-secondary); border: 1px solid var(--border-color); border-radius: 8px; padding: 16px; margin-bottom: 24px;"> <%= form_tag lending_loan_aging_path, method: :get, data: { turbo_frame:"filters", controller:"filters", action:"change->filters#submit" } do %> 
      <div class="flex flex-wrap gap-4 items-end"> 
        <div> <%= label_tag :branch_id,"Branch", style:"display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;" %> <%= select_tag :branch_id, options_from_collection_for_select(Management::Branch.active.by_name, :id, :name, params[:branch_id]), prompt:"All Branches", style:"background: var(--bg-tertiary); border: 1px solid var(--border-color); color: var(--text-primary); font-size: 13px; padding: 6px 10px; border-radius: 4px; outline: none;" %> </div>
 
        <div> <%= label_tag :loan_product_id,"Product", style:"display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;" %> <%= select_tag :loan_product_id, options_from_collection_for_select(Lending::LoanProduct.active.order(:name), :id, :name, params[:loan_product_id]), prompt:"All Products", style:"background: var(--bg-tertiary); border: 1px solid var(--border-color); color: var(--text-primary); font-size: 13px; padding: 6px 10px; border-radius: 4px; outline: none;" %> </div>
 
        <div> <%= label_tag :loan_aging_group_id,"Aging Group", style:"display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;" %> <%= select_tag :loan_aging_group_id, options_from_collection_for_select(Lending::LoanAgingGroup.active.ordered, :id, :name, params[:loan_aging_group_id]), prompt:"All Groups", style:"background: var(--bg-tertiary); border: 1px solid var(--border-color); color: var(--text-primary); font-size: 13px; padding: 6px 10px; border-radius: 4px; outline: none;" %> </div>
 
        <div> <%= label_tag :min_dpd,"Min DPD", style:"display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;" %> <%= number_field_tag :min_dpd, params[:min_dpd], placeholder:"0", style:"background: var(--bg-tertiary); border: 1px solid var(--border-color); color: var(--text-primary); font-size: 13px; padding: 6px 10px; width: 80px; border-radius: 4px; outline: none;" %> </div>
 
        <div> <%= label_tag :max_dpd,"Max DPD", style:"display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;" %> <%= number_field_tag :max_dpd, params[:max_dpd], placeholder:"999", style:"background: var(--bg-tertiary); border: 1px solid var(--border-color); color: var(--text-primary); font-size: 13px; padding: 6px 10px; width: 80px; border-radius: 4px; outline: none;" %> </div>
 
        <div> <%= label_tag :as_of_date,"As Of", style:"display: block; font-size: 11px; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 4px;" %> <%= date_field_tag :as_of_date, params[:as_of_date] || Date.current, style:"background: var(--bg-tertiary); border: 1px solid var(--border-color); color: var(--text-primary); font-size: 13px; padding: 6px 10px; border-radius: 4px; outline: none;" %> </div>
 
        <div class="flex gap-2"> <%= submit_tag"Apply", style:"background: var(--accent); color: white; font-size: 13px; font-weight: 500; padding: 6px 16px; border: none; border-radius: 4px; cursor: pointer; opacity: 0.9; transition: opacity 0.15s;" %> <%= link_to"Clear", lending_loan_aging_path, style:"background: transparent; border: 1px solid var(--border-color); color: var(--text-secondary); font-size: 13px; font-weight: 500; padding: 6px 16px; border-radius: 4px; text-decoration: none; transition: background 0.15s;" %> </div>
 </div>
 <% end %> </div>
 <% end %> 
