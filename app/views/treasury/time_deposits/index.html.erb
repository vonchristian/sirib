<h1>Time Deposits</h1> <% if @deposits.any? %> <div class="rounded-md border border-border bg-surface overflow-hidden"> <table class="min-w-full divide-y divide-border"> <thead class="bg-surface-alt"> <tr> <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Product</th> <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Amount</th> <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Rate</th> <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Maturity</th> <th class="px-6 py-3 text-left text-xs font-medium text-text-secondary uppercase tracking-wider">Status</th> <th class="px-6 py-3 text-right text-xs font-medium text-text-secondary uppercase tracking-wider"></th> </tr> </thead> <tbody class="divide-y divide-border"> <% @deposits.each do |deposit| %> <tr class="hover:bg-surface-alt -alt transition-colors"> <td class="px-6 py-4 text-sm font-medium text-text-primary"><%= deposit.time_deposit_product.name %></td> <td class="px-6 py-4 text-sm text-text-primary"><%= deposit.amount.format %></td> <td class="px-6 py-4 text-sm text-text-secondary"><%= number_to_percentage(deposit.interest_rate * 100, precision: 2) %></td> <td class="px-6 py-4 text-sm text-text-secondary"><%= l deposit.matured_on, format: :short if deposit.matured_on %></td> <td class="px-6 py-4"><span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= deposit.status =="active" ? "bg-positive-50 text-positive" : deposit.status =="matured" ? "bg-blue-100 text-primary" :"bg-surface-alt text-text-secondary" %>"><%= deposit.status.titleize %></span></td> <td class="px-6 py-4 text-right"><%= link_to"View", treasury_time_deposit_path(deposit), class:"text-sm font-medium text-primary hover:text-primary/80" %></td> </tr> <% end %> </tbody> </table> </div> <% else %> <div class="rounded-md border border-border bg-surface px-6 py-12 text-center"> <p class="text-sm text-text-secondary">No time deposits yet.</p> <%= link_to"Open a Time Deposit", new_treasury_time_deposit_path, class:"mt-4 inline-flex items-center rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary/90 transition-colors" %> </div> <% end %> 