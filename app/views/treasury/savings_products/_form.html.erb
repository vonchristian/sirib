<% content_for :page_title, @product.persisted? ? "Edit #{@product.name}" :"New Savings Product" %> <div class="card p-6 sm:p-8"> <%= form_with model: @product, url: @product.persisted? ? treasury_savings_product_path(@product) : treasury_savings_products_path, class:"space-y-6" do |f| %> <% if @product.errors.any? %> <div class="rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 text-sm text-danger"> <ul class="list-inside list-disc"> <% @product.errors.each do |error| %> <li><%= error.full_message %></li> <% end %> </ul> </div> <% end %> <div> <%= f.label :name, class:"input-label" %> <%= f.text_field :name, required: true, placeholder:"e.g. Regular Savings", class:"input" %> </div> <div> <%= f.label :description, class:"input-label" %> <%= f.text_area :description, rows: 2, placeholder:"Optional description...", class:"input" %> </div> <div> <%= f.label :status, class:"input-label" %> <%= f.select :status, options_for_select([["Active","active"], ["Inactive","inactive"]], @product.status), {}, class:"input" %> </div> <div class="rounded-lg bg-surface-alt p-4 text-xs text-text-tertiary"> <p>A liability ledger and an interest expense ledger will be automatically created for this product with the correct account types.</p> </div> <div> <h3 class="text-sm font-semibold text-text-primary mb-3">Interest Rates</h3> <div data-controller="nested-form" class="space-y-3"> <%= f.fields_for :interest_rates do |irf| %> <div class="nested-fields rounded-lg border border-border bg-surface-alt p-4" data-nested-form-target="fields"> <div class="grid grid-cols-1 sm:grid-cols-3 gap-3"> <div> <%= irf.label :rate,"Rate (decimal)", class:"input-label" %> <%= irf.number_field :rate, step: 0.0001, min: 0, placeholder:"e.g. 0.025", class:"input" %> </div> <div class="flex items-end pb-2"> <label class="flex items-center gap-2 text-sm text-text-primary"> <%= irf.check_box :current, class:"h-4 w-4 rounded border-border text-primary focus:ring-primary" %> Current rate </label> </div> <div class="flex items-end pb-2 justify-end"> <%= irf.hidden_field :_destroy %> <button type="button" data-action="nested-form#remove" class="btn-ghost text-xs text-danger"> Remove </button> </div> </div> </div> <% end %> <template data-nested-form-target="template"> <div class="nested-fields rounded-lg border border-border bg-surface-alt p-4"> <div class="grid grid-cols-1 sm:grid-cols-3 gap-3"> <div> <label class="input-label">Rate (decimal)</label> <input type="number" name="savings_product[interest_rates_attributes][NEW_RECORD][rate]" step="0.0001" min="0" placeholder="e.g. 0.025" class="input"> </div> <div class="flex items-end pb-2"> <label class="flex items-center gap-2 text-sm text-text-primary"> <input type="checkbox" name="savings_product[interest_rates_attributes][NEW_RECORD][current]" value="1" class="h-4 w-4 rounded border-border text-primary focus:ring-primary"> Current rate </label> </div> <div class="flex items-end pb-2 justify-end"> <input type="hidden" name="savings_product[interest_rates_attributes][NEW_RECORD][_destroy]" value="false"> <button type="button" data-action="nested-form#remove" class="btn-ghost text-xs text-danger"> Remove </button> </div> </div> </div> </template> <button type="button" data-action="nested-form#add" class="btn-ghost text-xs"> + Add Interest Rate </button> </div> </div> <div class="flex items-center justify-between pt-4 border-t border-border"> <%= link_to"Cancel", @product.persisted? ? treasury_savings_product_path(@product) : treasury_savings_products_path, class:"btn-ghost text-xs" %> <%= f.submit @product.persisted? ? "Update Product" :"Create Product", class:"btn-primary text-xs" %> </div> <% end %> </div> <script> document.addEventListener("DOMContentLoaded", function() { document.querySelectorAll("[data-controller='nested-form']").forEach((container) => { const template = container.querySelector("[data-nested-form-target='template']") const addBtn = container.querySelector("[data-action*='nested-form#add']") addBtn?.addEventListener("click", () => { const content = template.content.cloneNode(true) const index = container.querySelectorAll(".nested-fields").length content.querySelectorAll("[name*='NEW_RECORD']").forEach((el) => { el.name = el.name.replace("NEW_RECORD", index.toString()) }) template.parentNode.insertBefore(content, template) }) container.querySelectorAll("[data-action*='nested-form#remove']").forEach((btn) => { btn.addEventListener("click", () => { const fields = btn.closest(".nested-fields") const destroyInput = fields?.querySelector("input[name*='_destroy']") if (destroyInput) { destroyInput.value ="1" fields.style.display ="none" } else { fields?.remove() } }) }) }) }) </script> 