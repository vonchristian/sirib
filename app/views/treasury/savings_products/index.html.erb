<% content_for :page_title,"Savings Products" %> 
<div class="animate-fade-in"> 
  <div class="flex items-center justify-between mb-6"> 
    <div> 
      <h1 class="text-xl font-semibold text-text-primary">Savings Products</h1>
 
      <p class="text-sm text-text-tertiary mt-0.5">Manage savings account product offerings</p>
 </div>
 <%= link_to"New Product", new_treasury_savings_product_path, class:"btn-primary" %> </div>
 <% if @products.any? %> 
    <div class="table-container"> 
      <table class="table"> 
        <thead> 
          <tr> 
            <th>Name</th>
 
            <th>Current Rate</th>
 
            <th>Status</th>
 
            <th class="text-right">Accounts</th>
 
            <th class="text-right">Actions</th>
 </tr>
 </thead>
 
        <tbody> <% @products.each do |product| %> 
            <tr> 
              <td> <%= link_to treasury_savings_product_path(product), class:"font-medium text-text-primary hover:text-primary" do %> <%= product.name %> <% end %> <% if product.description.present? %> 
                  <p class="text-xs text-text-tertiary mt-0.5 truncate max-w-xs"><%= product.description %></p>
 <% end %> </td>
 
              <td> <% if (rate = product.current_interest_rate) %> <%= number_to_percentage(rate.rate * 100, precision: 2) %> <% else %> <span class="text-text-tertiary">—</span> <% end %> </td>
 
              <td> <span class="badge <%= product.status == 'active' ? 'badge-success' : 'badge-warning' %> capitalize"> <%= product.status %> </span> </td>
 
              <td class="text-right"><%= product.savings_accounts.count %></td>
 
              <td class="text-right"> 
                <div class="flex items-center justify-end gap-2"> <%= link_to"Edit", edit_treasury_savings_product_path(product), class:"btn-ghost text-xs" %> <%= button_to"Delete", treasury_savings_product_path(product), method: :delete, class:"btn-ghost text-xs text-danger", data: { turbo_confirm:"Remove #{product.name}?" } %> </div>
 </td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 <% else %> 
    <div class="rounded-lg border-2 border-dashed border-border bg-surface-alt px-6 py-16 text-center"> <svg class="mx-auto h-10 w-10 text-text-tertiary mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/> </svg> 
      <p class="text-sm text-text-tertiary mb-1">No savings products yet</p>
 
      <p class="text-xs text-text-tertiary mb-4">Create your first savings product to offer savings accounts.</p>
 <%= link_to"Create Product", new_treasury_savings_product_path, class:"btn-primary" %> </div>
 <% end %> </div>
