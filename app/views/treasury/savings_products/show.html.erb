<% content_for :page_title, @product.name %> 
<div class="animate-fade-in max-w-2xl mx-auto"> 
  <div class="rounded-xl border border-border bg-surface p-6 sm:p-8"> 
    <div class="flex items-start justify-between mb-6"> 
      <div> 
        <h1 class="text-xl font-semibold text-text-primary"><%= @product.name %></h1>
 <% if @product.description.present? %> 
          <p class="text-sm text-text-tertiary mt-1"><%= @product.description %></p>
 <% end %> </div>
 <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium capitalize <%= @product.status == 'active' ? 'bg-positive-50 text-positive' : 'bg-warning-50 text-warning' %>"> <%= @product.status %> </span> </div>
 
    <div class="space-y-6"> 
      <div> 
        <h2 class="text-sm font-semibold text-text-primary mb-3">Interest Rates</h2>
 <% if @product.interest_rates.any? %> 
          <div class="rounded-lg border border-border overflow-hidden"> 
            <table class="min-w-full text-sm"> 
              <thead> 
                <tr class="bg-surface-alt border-b border-border"> 
                  <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Rate</th>
 
                  <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Current</th>
 
                  <th class="px-4 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Created</th>
 </tr>
 </thead>
 
              <tbody class="divide-y divide-border"> <% @product.interest_rates.order(current: :desc, created_at: :desc).each do |ir| %> 
                  <tr> 
                    <td class="px-4 py-2 text-text-primary"><%= number_to_percentage(ir.rate * 100, precision: 2) %></td>
 
                    <td class="px-4 py-2"> <% if ir.current %> <span class="inline-flex items-center rounded-full bg-positive-50 px-2 py-0.5 text-xs font-medium text-positive">Active</span> <% else %> <span class="text-text-tertiary text-xs">Inactive</span> <% end %> </td>
 
                    <td class="px-4 py-2 text-text-secondary text-xs"><%= ir.created_at.strftime("%b %d, %Y") %></td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 <% else %> 
          <p class="text-sm text-text-tertiary">No interest rates configured.</p>
 <% end %> </div>
 
      <div class="border-t border-border pt-4"> 
        <h2 class="text-sm font-semibold text-text-primary mb-2">Accounts</h2>
 
        <p class="text-sm text-text-tertiary"><%= @product.savings_accounts.count %> savings account(s) using this product.</p>
 </div>
 </div>
 
    <div class="flex items-center justify-between mt-8 pt-6 border-t border-border"> <%= link_to"Back to Products", treasury_savings_products_path, class:"btn-ghost" %> 
      <div class="flex gap-2"> <%= link_to"Edit", edit_treasury_savings_product_path(@product), class:"btn-secondary" %> <%= button_to"Delete", treasury_savings_product_path(@product), method: :delete, class:"btn-ghost text-danger", data: { turbo_confirm:"Remove #{@product.name}?" } %> </div>
 </div>
 </div>
 </div>
 
