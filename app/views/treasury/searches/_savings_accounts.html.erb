<% if accounts.any? %> <% accounts.each do |account| %> <%= link_to treasury_savings_account_path(account), class:"w-full text-left px-3 py-2 flex items-center gap-3 hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors border-b border-border last:border-0 no-underline", data: { autocomplete_id: account.id, autocomplete_label: account.account_number } do %> <% if account.depositor.respond_to?(:profile_image) && account.depositor.profile_image.attached? %> <%= image_tag account.depositor.profile_image.variant(:thumb), class:"h-8 w-8 rounded-full object-cover flex-shrink-0" %> <% else %> <span class="h-8 w-8 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0"> <span class="text-xs font-semibold text-primary dark:text-primary-300"><%= account.depositor_name.split.map(&:first).first(2).join.upcase %></span> </span> <% end %> <div class="min-w-0 flex-1"> <div class="font-medium text-text-primary truncate"><%= account.account_number %></div> <div class="text-xs text-text-tertiary truncate"><%= account.depositor_name %></div> </div> <% end %> <% end %> <% else %> <div class="px-3 py-4 text-center text-sm text-text-tertiary">No accounts found</div> <% end %> 