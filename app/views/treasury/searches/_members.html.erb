<% if members.any? %>
  <% members.each do |member| %>
    <button type="button"
            class="w-full text-left px-3 py-2 flex items-center gap-3 hover:bg-primary-50 dark:hover:bg-primary-900/20 transition-colors border-b border-border last:border-0"
            data-autocomplete-id="<%= member.id %>"
            data-autocomplete-label="<%= member.name %>"
            data-autocomplete-thumb="<%= member.profile_image.attached? ? url_for(member.profile_image) : '' %>"
            data-action="member-autocomplete#select">
      <% if member.profile_image.attached? %>
        <%= image_tag member.profile_image, class: "h-8 w-8 rounded-full object-cover shrink-0 ring-1 ring-border-strong" %>
      <% else %>
        <span class="h-8 w-8 rounded-full bg-surface text-text-secondary flex items-center justify-center shrink-0 ring-1 ring-border-strong text-xs font-semibold">
          <%= member.name.split.map(&:first).first(2).join.upcase %>
        </span>
      <% end %>
      <div class="min-w-0">
        <div class="text-sm font-medium text-text-primary truncate"><%= member.name %></div>
        <div class="text-xs text-text-tertiary truncate"><%= member.member_identifier %></div>
      </div>
    </button>
  <% end %>
<% else %>
  <div class="px-3 py-4 text-center text-sm text-text-tertiary">No members found</div>
<% end %>
