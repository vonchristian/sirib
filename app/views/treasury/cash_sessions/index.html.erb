<% content_for :page_title,"Cash Sessions" %> 
<div class="animate-fade-in"> 
  <div class="flex items-center justify-between mb-6"> 
    <div> 
      <h1 class="text-xl font-semibold text-text-primary">Cash Sessions</h1>
 
      <p class="text-sm text-text-tertiary mt-0.5">Daily cash session reports</p>
 </div>
 </div>
 <% if @sessions.any? %> 
    <div class="rounded-lg border border-border bg-surface overflow-hidden"> 
      <table class="min-w-full text-sm"> 
        <thead> 
          <tr class="bg-surface-alt border-b border-border"> 
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Date</th>
 
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Cash Account</th>
 
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Beginning</th>
 
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Receipts</th>
 
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Disbursements</th>
 
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Ending</th>
 
            <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Status</th>
 
            <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Actions</th>
 </tr>
 </thead>
 
        <tbody class="divide-y divide-border"> <% @sessions.each do |session| %> 
            <tr class="hover:bg-surface-alt/50 /30 transition-colors"> 
              <td class="px-4 py-3 font-medium text-text-primary"><%= session.date.strftime("%b %d, %Y") %></td>
 
              <td class="px-4 py-3 text-text-secondary"><%= session.cash_account.name %></td>
 
              <td class="px-4 py-3 text-right text-text-secondary"><%= session.beginning_balance_cents ? Money.from_cents(session.beginning_balance_cents,"PHP").format :"—" %></td>
 
              <td class="px-4 py-3 text-right text-positive font-medium"><%= Money.from_cents(session.total_receipts,"PHP").format %></td>
 
              <td class="px-4 py-3 text-right text-warning font-medium"><%= Money.from_cents(session.total_disbursements,"PHP").format %></td>
 
              <td class="px-4 py-3 text-right font-medium text-text-primary"><%= Money.from_cents(session.computed_ending_balance,"PHP").format %></td>
 
              <td class="px-4 py-3"> <span class="inline-flex items-center rounded-full px-2.5 py-0.5 text-xs font-medium <%= session.open? ? 'bg-green-50 text-green-700 dark:bg-green-900/20 dark:text-green-400' : 'bg-surface-alt text-text-secondary ' %>"> <%= session.status.titleize %> </span> </td>
 
              <td class="px-4 py-3 text-right"> <%= link_to"View", treasury_cash_session_path(session), class:"btn-ghost text-xs py-1.5 px-3" %> </td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 <% else %> 
    <div class="rounded-lg border border-dashed border-border bg-surface-alt p-12 text-center"> 
      <p class="text-sm text-text-tertiary">No cash sessions yet. Sessions are created automatically when you start a transaction.</p>
 </div>
 <% end %> </div>
 
