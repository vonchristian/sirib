<% cooperative = Cooperative.first %> <% session = @session %> <% cash_account = session.cash_account %> <% user = session.user %> <% variance = session.ending_balance_cents.to_i - session.computed_ending_balance %> <% counted_total = session.counts.sum { |c| c["subtotal"].to_i } %> <% approved_transfers = session.vault_transfers.approved %> <% vault_in = approved_transfers.where(direction: :to_teller).sum(:amount_cents) %> <% vault_out = approved_transfers.where(direction: :to_vault).sum(:amount_cents) %> <div style="font-family: 'Helvetica Neue', Helvetica, Arial, sans-serif; color: #1a1a1a; font-size: 9pt; line-height: 1.4;"> <!-- Header --> <div style="border-bottom: 2pt solid #1a1a1a; padding-bottom: 10pt; margin-bottom: 14pt;"> <div style="text-align: center; margin-bottom: 6pt;"> <div style="font-size: 14pt; font-weight: 700; letter-spacing: 0.5pt; text-transform: uppercase; margin-bottom: 2pt;"><%= cooperative&.name ||"SIRIB" %></div> <div style="font-size: 8pt; color: #555;"><%= cooperative&.address.presence %></div> </div> <div style="text-align: center; font-size: 11pt; font-weight: 700; letter-spacing: 1pt; text-transform: uppercase; padding: 4pt 0; border-top: 0.5pt solid #ccc; border-bottom: 0.5pt solid #ccc;"> Bank Teller End-of-Day Cash Report </div> </div> <!-- Teller & Session Info --> <table style="width: 100%; border-collapse: collapse; font-size: 9pt; margin-bottom: 14pt;"> <tr> <td style="padding: 2pt 6pt; width: 15%; font-weight: 600; color: #555;">Branch:</td> <td style="padding: 2pt 6pt; width: 35%;"><%= cooperative&.name.presence ||"—" %></td> <td style="padding: 2pt 6pt; width: 15%; font-weight: 600; color: #555;">Teller:</td> <td style="padding: 2pt 6pt; width: 35%;"><%= user.email_address %></td> </tr> <tr> <td style="padding: 2pt 6pt; font-weight: 600; color: #555;">Date:</td> <td style="padding: 2pt 6pt;"><%= session.date.strftime("%B %d, %Y") %></td> <td style="padding: 2pt 6pt; font-weight: 600; color: #555;">Shift:</td> <td style="padding: 2pt 6pt;"><%= session.opened_at.strftime("%I:%M %p") %> &mdash; <%= session.closed_at&.strftime("%I:%M %p") ||"open" %></td> </tr> </table> <!-- 1. Cash Reconciliation Summary --> <div style="font-size: 9pt; font-weight: 700; padding: 4pt 6pt; background: #1a1a1a; color: #fff; margin-bottom: 6pt;">1. Cash Reconciliation Summary</div> <table style="width: 100%; border-collapse: collapse; font-size: 9pt; margin-bottom: 14pt;"> <thead> <tr style="border-bottom: 0.5pt solid #ccc;"> <th style="text-align: left; padding: 4pt 6pt; font-weight: 600; color: #555;">Category</th> <th style="text-align: right; padding: 4pt 6pt; font-weight: 600; color: #555;">Amount (PHP)</th> </tr> </thead> <tbody> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt;">Opening Cash (Start of Day)</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 600;"><%= number_to_currency(session.beginning_balance_cents.to_f / 100, unit:"₱") %></td> </tr> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt; padding-left: 14pt;">(+) Total Cash Received / Deposits</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 600; color: #16a34a;"><%= number_to_currency(session.total_receipts.to_f / 100, unit:"₱") %></td> </tr> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt; padding-left: 14pt;">(-) Total Cash Paid Out / Withdrawals</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 600; color: #dc2626;">(<%= number_to_currency(session.total_disbursements.to_f / 100, unit:"₱") %>)</td> </tr> <% if vault_in > 0 %> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt; padding-left: 14pt;">(+) Cash Received from Vault</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 600; color: #16a34a;"><%= number_to_currency(vault_in.to_f / 100, unit:"₱") %></td> </tr> <% end %> <% if vault_out > 0 %> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt; padding-left: 14pt;">(-) Cash Returned to Vault</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 600; color: #dc2626;">(<%= number_to_currency(vault_out.to_f / 100, unit:"₱") %>)</td> </tr> <% end %> <tr style="border-bottom: 0.5pt solid #ccc;"> <td style="padding: 4pt 6pt; font-weight: 700;">Calculated Ending Cash Balance</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 700; border-bottom: 2pt solid #1a1a1a;"><%= number_to_currency(session.computed_ending_balance.to_f / 100, unit:"₱") %></td> </tr> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt;">Physical Counted Cash</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 700;"><%= number_to_currency(session.ending_balance_cents.to_f / 100, unit:"₱") %></td> </tr> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 4pt 6pt; font-weight: 700;">Over / (Short)</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 700; <%= variance >= 0 ? 'color: #16a34a;' : 'color: #dc2626;' %>"> <%= variance >= 0 ? "" :"(" %><%= number_to_currency(variance.abs.to_f / 100, unit:"₱") %><%= variance >= 0 ? "" :")" %> </td> </tr> </tbody> </table> <!-- 2. Physical Cash Breakdown --> <div style="font-size: 9pt; font-weight: 700; padding: 4pt 6pt; background: #1a1a1a; color: #fff; margin-bottom: 6pt;">2. Physical Cash Breakdown</div> <table style="width: 100%; border-collapse: collapse; font-size: 9pt; margin-bottom: 14pt;"> <thead> <tr style="border-bottom: 0.5pt solid #ccc;"> <th style="text-align: left; padding: 4pt 6pt; font-weight: 600; color: #555;">Denomination</th> <th style="text-align: center; padding: 4pt 6pt; font-weight: 600; color: #555;">Quantity</th> <th style="text-align: right; padding: 4pt 6pt; font-weight: 600; color: #555;">Amount (PHP)</th> </tr> </thead> <tbody> <% session.counts.each do |entry| %> <tr style="border-bottom: 0.5pt solid #eee;"> <td style="padding: 3pt 6pt;">₱ <%= entry["label"] %></td> <td style="padding: 3pt 6pt; text-align: center;"><%= entry["count"] %></td> <td style="padding: 3pt 6pt; text-align: right;"><%= number_to_currency(entry["subtotal"].to_f / 100, unit:"₱") %></td> </tr> <% end %> <tr style="border-top: 0.5pt solid #ccc;"> <td style="padding: 4pt 6pt; font-weight: 700;">Total Cash On Hand</td> <td style="padding: 4pt 6pt; text-align: center;">—</td> <td style="padding: 4pt 6pt; text-align: right; font-weight: 700; border-top: 2pt solid #1a1a1a;"><%= number_to_currency(session.ending_balance_cents.to_f / 100, unit:"₱") %></td> </tr> </tbody> </table> <!-- 3. Transaction Breakdown --> <div style="font-size: 9pt; font-weight: 700; padding: 4pt 6pt; background: #1a1a1a; color: #fff; margin-bottom: 6pt;">3. Transaction Breakdown</div> <!-- Receipts --> <% if @receipts.any? %> <div style="font-size: 8pt; font-weight: 600; padding: 3pt 6pt; background: #f0fdf4; border-bottom: 0.5pt solid #86efac; margin-bottom: 4pt;">Cash Inflow / Deposits</div> <div style="margin-bottom: 10pt;"> <% @grouped_receipts.each do |category, vouchers| %> <% group_total = vouchers.sum(&:amount_cents) %> <div style="margin-bottom: 4pt;"> <div style="display: flex; justify-content: space-between; padding: 2pt 6pt; font-size: 8pt; font-weight: 700; background: #f9fafb; border-bottom: 0.5pt solid #ddd;"> <span><%= category_label(category) %></span> <span style="color: #16a34a;"><%= number_to_currency(group_total.to_f / 100, unit:"₱") %></span> </div> <table style="width: 100%; border-collapse: collapse; font-size: 7.5pt;"> <thead> <tr style="border-bottom: 0.5pt solid #eee;"> <th style="text-align: left; padding: 2pt 6pt; font-weight: 600; color: #888;">Transaction ID</th> <th style="text-align: left; padding: 2pt 6pt; font-weight: 600; color: #888;">Type</th> <th style="text-align: left; padding: 2pt 6pt; font-weight: 600; color: #888;">Description</th> <th style="text-align: right; padding: 2pt 6pt; font-weight: 600; color: #888;">Amount (PHP)</th> </tr> </thead> <tbody> <% vouchers.each do |v| %> <tr style="border-bottom: 0.5pt solid #f0f0f0;"> <td style="padding: 2pt 6pt; font-family: monospace; font-size: 7pt; color: #555;"><%= v.voucher_number %></td> <td style="padding: 2pt 6pt; font-size: 7pt;"><%= v.category.titleize %></td> <td style="padding: 2pt 6pt; font-size: 7pt; color: #555;"><%= v.description ||"—" %></td> <td style="padding: 2pt 6pt; text-align: right; font-size: 7pt; font-weight: 600; color: #16a34a;"><%= number_to_currency(v.amount_cents.to_f / 100, unit:"₱") %></td> </tr> <% end %> </tbody> </table> </div> <% end %> </div> <% end %> <!-- Disbursements --> <% if @disbursements.any? %> <div style="font-size: 8pt; font-weight: 600; padding: 3pt 6pt; background: #fef2f2; border-bottom: 0.5pt solid #fca5a5; margin-bottom: 4pt;">Cash Outflow / Withdrawals</div> <div style="margin-bottom: 10pt;"> <% @grouped_disbursements.each do |category, vouchers| %> <% group_total = vouchers.sum(&:amount_cents) %> <div style="margin-bottom: 4pt;"> <div style="display: flex; justify-content: space-between; padding: 2pt 6pt; font-size: 8pt; font-weight: 700; background: #f9fafb; border-bottom: 0.5pt solid #ddd;"> <span><%= category_label(category) %></span> <span style="color: #dc2626;">(<%= number_to_currency(group_total.to_f / 100, unit:"₱") %>)</span> </div> <table style="width: 100%; border-collapse: collapse; font-size: 7.5pt;"> <thead> <tr style="border-bottom: 0.5pt solid #eee;"> <th style="text-align: left; padding: 2pt 6pt; font-weight: 600; color: #888;">Transaction ID</th> <th style="text-align: left; padding: 2pt 6pt; font-weight: 600; color: #888;">Type</th> <th style="text-align: left; padding: 2pt 6pt; font-weight: 600; color: #888;">Description</th> <th style="text-align: right; padding: 2pt 6pt; font-weight: 600; color: #888;">Amount (PHP)</th> </tr> </thead> <tbody> <% vouchers.each do |v| %> <tr style="border-bottom: 0.5pt solid #f0f0f0;"> <td style="padding: 2pt 6pt; font-family: monospace; font-size: 7pt; color: #555;"><%= v.voucher_number %></td> <td style="padding: 2pt 6pt; font-size: 7pt;"><%= v.category.titleize %></td> <td style="padding: 2pt 6pt; font-size: 7pt; color: #555;"><%= v.description ||"—" %></td> <td style="padding: 2pt 6pt; text-align: right; font-size: 7pt; font-weight: 600; color: #dc2626;"><%= number_to_currency(v.amount_cents.to_f / 100, unit:"₱") %></td> </tr> <% end %> </tbody> </table> </div> <% end %> </div> <% end %> <% if @receipts.empty? && @disbursements.empty? %> <div style="font-size: 8pt; color: #999; font-style: italic; margin-bottom: 14pt;">No transactions for this session.</div> <% end %> <!-- Vault Transfer Audit Trail --> <% if approved_transfers.any? %> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 4pt;">Vault Transfer Audit Trail</div> <table style="width: 100%; border-collapse: collapse; font-size: 8pt; margin-bottom: 12pt;"> <thead> <tr style="border-bottom: 0.5pt solid #ccc;"> <th style="text-align: left; padding: 3pt 6pt; font-weight: 600; color: #555;">Time</th> <th style="text-align: left; padding: 3pt 6pt; font-weight: 600; color: #555;">Direction</th> <th style="text-align: left; padding: 3pt 6pt; font-weight: 600; color: #555;">Notes</th> <th style="text-align: right; padding: 3pt 6pt; font-weight: 600; color: #555;">Amount (PHP)</th> </tr> </thead> <tbody> <% approved_transfers.order(created_at: :asc).each do |t| %> <tr style="border-bottom: 0.5pt solid #eee; font-size: 7.5pt;"> <td style="padding: 2pt 6pt; font-family: monospace; color: #555;"><%= t.created_at.strftime("%H:%M") %></td> <td style="padding: 2pt 6pt;"> <%= t.to_teller? ? "Vault \u2192 Teller" :"Teller \u2192 Vault" %> </td> <td style="padding: 2pt 6pt; color: #555;"><%= t.description.presence ||"\u2014" %></td> <td style="padding: 2pt 6pt; text-align: right; font-weight: 600; <%= t.to_teller? ? 'color: #16a34a;' : 'color: #dc2626;' %>"> <%= t.to_teller? ? "" :"(" %><%= number_to_currency(t.amount_cents.to_f / 100, unit:"\u20B1") %><%= t.to_teller? ? "" :")" %> </td> </tr> <% end %> </tbody> </table> <% end %> <!-- Notes --> <% if session.notes.present? %> <div style="margin-bottom: 14pt;"> <div style="font-size: 7pt; font-weight: 700; letter-spacing: 0.8pt; text-transform: uppercase; color: #888; margin-bottom: 4pt;">Notes</div> <div style="font-size: 8pt; color: #555; padding: 4pt 6pt; border: 0.5pt solid #ddd; background: #fafafa;"> <%= simple_format(session.notes) %> </div> </div> <% end %> <!-- Signatures --> <div style="margin-top: 24pt; border-top: 0.5pt solid #ccc; padding-top: 12pt;"> <table style="width: 100%; font-size: 8pt;"> <tr> <td style="width: 50%; padding: 0 6pt;"> <div style="margin-bottom: 36pt;">Teller Signature: ___________________________</div> <div>Time: ___________________________</div> </td> <td style="width: 50%; padding: 0 6pt;"> <div style="margin-bottom: 36pt;">Verified By (Supervisor): ___________________________</div> <div>Time: ___________________________</div> </td> </tr> </table> </div> <!-- Footer --> <div style="margin-top: 12pt; border-top: 0.5pt solid #ccc; padding-top: 4pt; font-size: 6.5pt; color: #999;"> <div style="display: flex; justify-content: space-between;"> <span>Cash Account: <%= cash_account.name %></span> <span>Session #<%= session.id %></span> <span>Printed: <%= Time.current.strftime("%b %d, %Y at %I:%M %p") %></span> </div> </div> </div> 