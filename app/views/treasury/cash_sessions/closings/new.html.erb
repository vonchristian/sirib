<% content_for :page_title, "Close Session ##{@session.id}" %>

<% content_for :head do %>
<style>
  .count-input::-webkit-inner-spin-button {
    opacity: 1;
  }
  .variance-positive { color: #16a34a; }
  .variance-negative { color: #dc2626; }
  .variance-zero { color: #6b7280; }
</style>
<% end %>

<%= form_with url: treasury_cash_session_closings_path(@session), method: :post, local: true do |f| %>

<div class="mx-auto max-w-3xl">
  <!-- Header Card -->
  <div class="rounded-xl border border-gray-200 bg-white shadow-sm"
       data-controller="cash-count"
       data-cash-count-expected-total-value="<%= @expected_total %>"
       data-cash-count-currency-value="PHP"
       data-cash-count-session-id-value="<%= @session.id %>">
    <div class="flex items-center justify-between px-6 py-4 border-b border-gray-100">
      <div>
        <h1 class="text-lg font-semibold text-gray-900">Close Session #<%= @session.id %></h1>
        <p class="text-sm text-gray-500 mt-0.5"><%= @session.user.email_address %></p>
      </div>
      <div class="text-right">
        <p class="text-xs font-medium text-gray-400 uppercase tracking-wider">Expected Total</p>
        <p class="text-2xl font-bold text-gray-900 tabular-nums"><%= number_to_currency(@expected_total / 100.0, unit: "₱") %></p>
      </div>
    </div>

    <!-- Denomination Table -->
    <div class="px-6 py-5">
      <div class="rounded-lg border border-gray-200 overflow-hidden">
        <table class="w-full">
          <thead>
            <tr class="bg-gray-50 border-b border-gray-200">
              <th class="px-4 py-2.5 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">Denomination</th>
              <th class="px-4 py-2.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Count</th>
              <th class="px-4 py-2.5 text-right text-xs font-semibold text-gray-500 uppercase tracking-wider">Subtotal</th>
            </tr>
          </thead>
          <tbody>
            <% @denominations.each_with_index do |denom, index| %>
              <tr class="border-b border-gray-100 last:border-0">
                <td class="px-4 py-2.5 text-sm font-medium text-gray-900">₱ <%= denom[:label] %></td>
                <td class="px-4 py-2.5">
                  <input type="number"
                    name="counts[<%= index %>]"
                    id="counts_<%= index %>"
                    min="0"
                    step="1"
                    value="0"
                    data-cash-count-target="count"
                    data-amount="<%= denom[:amount] %>"
                    data-action="input->cash-count#calculateTotals change->cash-count#calculateTotals"
                    class="count-input block w-28 ml-auto text-right rounded-md border-gray-300 text-sm text-gray-900 shadow-sm focus:border-blue-500 focus:ring-blue-500">
                </td>
                <td class="px-4 py-2.5 text-right">
                  <span class="text-sm font-mono tabular-nums text-gray-700" data-cash-count-target="subtotal">₱0.00</span>
                </td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>

    <!-- Summary -->
    <div class="mx-6 mb-5 rounded-lg bg-gradient-to-r from-gray-50 to-gray-100/50 border border-gray-200 px-5 py-4">
      <div class="flex items-center justify-between">
        <span class="text-sm font-medium text-gray-700">Total Counted</span>
        <span class="text-xl font-bold text-gray-900 tabular-nums" data-cash-count-target="total">₱0.00</span>
      </div>
      <div class="flex items-center justify-between mt-2 pt-2 border-t border-gray-200">
        <span class="text-sm font-medium text-gray-700">Variance</span>
        <span class="text-xl font-bold tabular-nums" data-cash-count-target="variance">₱0.00</span>
      </div>
    </div>

    <!-- Notes -->
    <div class="px-6 pb-4">
      <%= f.label :notes, class: "block text-sm font-medium text-gray-700 mb-1.5" do %>
        Notes <span class="text-gray-400 font-normal">(optional)</span>
      <% end %>
      <%= f.text_area :notes, rows: 2,
        class: "block w-full rounded-md border-gray-300 text-sm text-gray-900 shadow-sm placeholder:text-gray-400 focus:border-blue-500 focus:ring-blue-500",
        placeholder: "Add any remarks about this closing..." %>
    </div>

    <!-- Actions -->
    <div class="flex items-center justify-end gap-3 px-6 py-4 bg-gray-50/50 border-t border-gray-100 rounded-b-xl">
      <%= link_to "Cancel", treasury_cash_session_path(@session),
        class: "rounded-md px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900 hover:bg-gray-100 transition-colors" %>
      <button type="submit"
        data-action="click->cash-count#validateAndSubmit"
        class="rounded-md bg-blue-600 px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-blue-600 transition-colors">
        Close Session
      </button>
    </div>
  </div>
</div>
<% end %>
