<% content_for :page_title,"Close Session ##{@session.id}" %> <% content_for :head do %> <style>
    .count-input::-webkit-inner-spin-button { opacity: 1; } .variance-positive { color: #16a34a; } .variance-negative { color: #dc2626; } .variance-zero { color: #6b7280; }
  </style> <% end %> <%= form_with url: treasury_cash_session_closings_path(@session), method: :post, local: true do |f| %> 
  <div class="mx-auto max-w-3xl"> <!-- Header Card --> 
    <div class="rounded-xl border border-border bg-surface shadow-sm" data-controller="cash-count" data-cash-count-expected-total-value="<%= @expected_total %>" data-cash-count-currency-value="PHP" data-cash-count-session-id-value="<%= @session.id %>"> 
      <div class="flex items-center justify-between px-6 py-4 border-b border-border/50"> 
        <div> 
          <h1 class="text-lg font-semibold text-text-primary">Close Session #<%= @session.id %></h1>
 
          <p class="text-sm text-text-tertiary mt-0.5"><%= @session.user.email_address %></p>
 </div>
 
        <div class="text-right"> 
          <p class="text-xs font-medium text-text-tertiary uppercase tracking-wider">Expected Total</p>
 
          <p class="text-2xl font-bold text-text-primary tabular-nums"><%= number_to_currency(@expected_total / 100.0, unit:"₱") %></p>
 </div>
 </div>
 <!-- Denomination Table --> 
      <div class="px-6 py-5"> 
        <div class="rounded-lg border border-border overflow-hidden"> 
          <table class="w-full"> 
            <thead> 
              <tr class="bg-surface-alt border-b border-border"> 
                <th class="px-4 py-2.5 text-left text-xs font-semibold text-text-tertiary uppercase tracking-wider">Denomination</th>
 
                <th class="px-4 py-2.5 text-right text-xs font-semibold text-text-tertiary uppercase tracking-wider">Count</th>
 
                <th class="px-4 py-2.5 text-right text-xs font-semibold text-text-tertiary uppercase tracking-wider">Subtotal</th>
 </tr>
 </thead>
 
            <tbody> <% @denominations.each_with_index do |denom, index| %> 
                <tr class="border-b border-border/50 last:border-0"> 
                  <td class="px-4 py-2.5 text-sm font-medium text-text-primary">₱ <%= denom[:label] %></td>
 
                  <td class="px-4 py-2.5"> <input type="number" name="counts[<%= index %>]" id="counts_<%= index %>" min="0" step="1" value="0" data-cash-count-target="count" data-amount="<%= denom[:amount] %>" data-action="input->cash-count#calculateTotals change->cash-count#calculateTotals" class="count-input block w-28 ml-auto text-right rounded-md border-border text-sm text-text-primary shadow-sm focus:border-primary focus:ring-primary"> </td>
 
                  <td class="px-4 py-2.5 text-right"> <span class="text-sm font-mono tabular-nums text-text-secondary" data-cash-count-target="subtotal">₱0.00</span> </td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 </div>
 <!-- Summary --> 
      <div class="mx-6 mb-5 rounded-lg bg-gradient-to-r from-surface-alt to-surface-alt/50 border border-border px-5 py-4"> 
        <div class="flex items-center justify-between"> <span class="text-sm font-medium text-text-secondary">Total Counted</span> <span class="text-xl font-bold text-text-primary tabular-nums" data-cash-count-target="total">₱0.00</span> </div>
 
        <div class="flex items-center justify-between mt-2 pt-2 border-t border-border"> <span class="text-sm font-medium text-text-secondary">Variance</span> <span class="text-xl font-bold tabular-nums" data-cash-count-target="variance">₱0.00</span> </div>
 </div>
 <!-- Notes --> 
      <div class="px-6 pb-4"> <%= f.label :notes, class:"block text-sm font-medium text-text-secondary mb-1.5" do %> Notes <span class="text-text-tertiary font-normal">(optional)</span> <% end %> <%= f.text_area :notes, rows: 2, class:"block w-full rounded-md border-border text-sm text-text-primary shadow-sm placeholder:text-text-tertiary focus:border-primary focus:ring-primary", placeholder:"Add any remarks about this closing..." %> </div>
 <!-- Actions --> 
      <div class="flex items-center justify-end gap-3 px-6 py-4 bg-surface-alt/50 border-t border-border/50 rounded-b-xl"> <%= link_to"Cancel", treasury_cash_session_path(@session), class:"rounded-md px-4 py-2 text-sm font-medium text-text-secondary hover:text-text-primary hover:bg-surface-alt transition-colors" %> <button type="submit" data-action="click->cash-count#validateAndSubmit" class="rounded-md bg-primary px-5 py-2 text-sm font-semibold text-white shadow-sm hover:bg-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-colors"> Close Session </button> </div>
 </div>
 </div>
 <% end %> 
