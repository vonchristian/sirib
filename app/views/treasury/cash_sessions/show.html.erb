<% content_for :page_title, "Cash Session — #{@session.date.strftime('%b %d, %Y')}" %>

<% content_for :head do %>
<style>
  @keyframes pulse-dot {
    0%, 100% { opacity: 1; box-shadow: 0 0 0 0 rgba(var(--pulse-color), 0.6); }
    50% { opacity: 0.7; box-shadow: 0 0 0 6px rgba(var(--pulse-color), 0); }
  }
  .category-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.125rem 0.5rem;
    border-radius: 9999px;
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }
  .category-badge::before {
    content: '';
    width: 0.375rem;
    height: 0.375rem;
    border-radius: 9999px;
    background: currentColor;
    opacity: 0.6;
  }
  .is-expanded {
    background: rgba(251,191,36,0.04);
  }
</style>
<% end %>

<div class="animate-fade-in space-y-5 max-w-7xl mx-auto">
  <!-- Header -->
  <div class="rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900">
    <div class="flex items-center justify-between px-5 py-3.5">
      <div class="flex items-center gap-4">
        <div class="flex items-center gap-2.5">
          <span class="relative flex h-2.5 w-2.5">
            <span class="animate-ping absolute inline-flex h-full w-full rounded-full opacity-75"
                  style="background: <%= @session.open? ? '#10b981' : '#ef4444' %>;
                         --pulse-color: <%= @session.open? ? '16,185,129' : '239,68,68' %>;
                         animation: pulse-dot 2s ease-in-out infinite;"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5"
                  style="background: <%= @session.open? ? '#10b981' : '#ef4444' %>;"></span>
          </span>
          <span class="text-xs font-semibold tracking-[0.15em] uppercase"
                style="color: <%= @session.open? ? '#10b981' : '#ef4444' %>;">
            <%= @session.status %>
          </span>
        </div>
        <div class="h-4 w-px bg-border dark:bg-gray-700"></div>
        <div class="text-sm font-medium text-text-primary dark:text-gray-100">
          <%= @session.date.strftime("%B %d, %Y") %>
        </div>
        <div class="h-4 w-px bg-border dark:bg-gray-700"></div>
        <div class="text-xs text-text-tertiary dark:text-gray-500 font-mono">
          SESSION-<%= @session.id.to_s.rjust(4, '0') %>
        </div>
      </div>
      <div class="flex items-center gap-2.5">
        <%= link_to treasury_cash_sessions_path, class: "inline-flex items-center gap-1.5 rounded-lg border border-border bg-surface px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt hover:text-text-primary dark:border-gray-700 dark:bg-gray-800 dark:text-gray-400 dark:hover:bg-gray-700 dark:hover:text-gray-200 transition-all duration-150" do %>
          <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/></svg>
          All Sessions
        <% end %>
        <% if @session.open? %>
          <%= link_to new_treasury_cash_session_closing_path(@session),
                class: "inline-flex items-center gap-1.5 rounded-lg border border-warning/30 bg-warning-50 px-3 py-1.5 text-xs font-medium text-warning hover:bg-warning-50 dark:border-warning/40 dark:bg-warning-900/20 dark:text-warning dark:hover:bg-warning-900/30 transition-all duration-150" do %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
            Close Session
          <% end %>
        <% else %>
          <%= link_to download_pdf_treasury_cash_session_path(@session),
                class: "inline-flex items-center gap-1.5 rounded-lg border border-blue-600/30 bg-blue-50 px-3 py-1.5 text-xs font-medium text-blue-700 hover:bg-blue-100 dark:border-blue-600/40 dark:bg-blue-900/20 dark:text-blue-400 dark:hover:bg-blue-900/30 transition-all duration-150" do %>
            <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 10v6m0 0l-3-3m3 3l3-3m2 8H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
            Download PDF
          <% end %>
        <% end %>
      </div>
    </div>
    <% if @session.opened_at %>
      <div class="flex items-center gap-4 px-5 pb-3.5">
        <div class="flex items-center gap-1.5 text-[0.65rem] text-text-tertiary dark:text-gray-500 font-mono tracking-wider">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/></svg>
          Opened: <%= @session.opened_at.strftime("%H:%M:%S") %>
        </div>
        <% if @session.closed_at %>
          <div class="flex items-center gap-1.5 text-[0.65rem] text-text-tertiary dark:text-gray-500 font-mono tracking-wider">
            <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/></svg>
            Closed: <%= @session.closed_at.strftime("%H:%M:%S") %>
          </div>
        <% end %>
        <div class="flex items-center gap-1.5 text-[0.65rem] text-text-tertiary dark:text-gray-500 font-mono tracking-wider">
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2"/></svg>
          Account: <%= @session.cash_account.name %>
        </div>
      </div>
    <% end %>
  </div>

<% vault_account = Cooperative.first&.vault_account %>

  <!-- Metrics Dashboard -->
  <div class="grid grid-cols-2 lg:grid-cols-5 gap-3">
    <% metrics = [
      { label: "Beginning Balance", value: Money.from_cents(@session.beginning_balance_cents.to_i, "PHP").format, icon: "M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z" },
      { label: "Total Receipts", value: Money.from_cents(@session.total_receipts, "PHP").format, icon: "M13 7h8m0 0v8m0-8l-8 8-4-4-6 6" },
      { label: "Total Disbursements", value: Money.from_cents(@session.total_disbursements, "PHP").format, icon: "M13 17h8m0 0V9m0 8l-8-8-4 4-6-6" },
      { label: "Ending Balance", value: Money.from_cents(@session.computed_ending_balance, "PHP").format, icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" },
      { label: "Vault Flow", value: Money.from_cents(@session.net_vault_flow, "PHP").format, icon: "M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4" },
    ].each_with_index do |m, i| %>
      <div class="rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900 p-4 animate-fade-in-up-<%= i + 1 %>">
        <div class="flex items-center justify-between mb-2">
          <span class="text-xs font-semibold tracking-wider uppercase text-text-tertiary"><%= m[:label] %></span>
          <svg class="w-4 h-4 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="<%= m[:icon] %>"/></svg>
        </div>
        <p class="text-xl sm:text-2xl font-bold font-mono tracking-tight text-text-primary"><%= m[:value] %></p>
      </div>
    <% end %>
  </div>

  <!-- Cash Health: Composition & Category Breakdown -->
  <div class="grid grid-cols-1 lg:grid-cols-5 gap-3 animate-fade-in-up-3">
    <!-- Composition Stacked Bar -->
    <div class="lg:col-span-2 rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900 p-4">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-semibold tracking-wider uppercase text-text-tertiary">Cash Composition</span>
        <span class="text-sm font-mono text-text-tertiary"><%= Money.from_cents(@session.computed_ending_balance, "PHP").format %></span>
      </div>
      <% comp_bars = [
        { label: "Beginning", cents: @session.beginning_balance_cents.to_i, color: "bg-primary" },
        { label: "Receipts",  cents: @session.total_receipts, color: "bg-positive" },
        { label: "Disbursements", cents: -@session.total_disbursements.abs, color: "bg-warning" },
        { label: "Vault Flow", cents: @session.net_vault_flow, color: "bg-text-tertiary" },
      ] %>
      <% pos_total = comp_bars.sum { |b| [b[:cents], 0].max } %>
      <div class="flex h-6 rounded-md overflow-hidden mb-3 bg-surface-alt">
        <% comp_bars.each do |b| %>
          <% if b[:cents] > 0 %>
            <div class="<%= b[:color] %> h-full flex-shrink-0 transition-all" style="width: <%= (b[:cents].to_f / pos_total * 100).clamp(0, 100) %>%"></div>
          <% end %>
        <% end %>
      </div>
      <div class="space-y-2">
        <% comp_bars.each do |b| %>
          <div class="flex items-center justify-between text-sm">
            <div class="flex items-center gap-2">
              <span class="w-2.5 h-2.5 rounded-sm <%= b[:color] %>"></span>
              <span class="text-text-secondary"><%= b[:label] %></span>
            </div>
            <span class="font-mono font-semibold tabular-nums text-text-primary">
              <%= b[:cents] >= 0 ? '' : '−' %><%= Money.from_cents(b[:cents].abs, "PHP").format %>
            </span>
          </div>
        <% end %>
      </div>
    </div>

    <!-- Receipts by Category -->
    <div class="lg:col-span-1 rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900 p-4">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-semibold tracking-wider uppercase text-text-tertiary">Receipts by Category</span>
        <span class="text-sm font-mono font-semibold text-positive"><%= Money.from_cents(@session.total_receipts, "PHP").format %></span>
      </div>
      <div class="space-y-3">
        <% if @grouped_receipts.any? %>
          <% max_receipt = @grouped_receipts.map { |_, v| v.sum(&:amount_cents) }.max.to_f %>
          <% @grouped_receipts.each do |cat, vouchers| %>
            <% cat_total = vouchers.sum(&:amount_cents) %>
            <% pct = @session.total_receipts > 0 ? (cat_total.to_f / @session.total_receipts * 100).round(1) : 0 %>
            <div>
              <div class="flex items-center justify-between text-sm mb-1">
                <span class="text-text-secondary truncate pr-2"><%= category_label(cat) %></span>
                <span class="font-mono font-semibold text-text-primary tabular-nums"><%= Money.from_cents(cat_total, "PHP").format %></span>
              </div>
              <div class="flex items-center gap-2">
                <div class="flex-1 h-2.5 bg-surface-alt rounded-full overflow-hidden">
                  <div class="h-full rounded-full bg-positive transition-all" style="width: <%= max_receipt > 0 ? (cat_total / max_receipt * 100).round : 0 %>%"></div>
                </div>
                <span class="text-xs font-mono text-text-tertiary w-8 text-right tabular-nums"><%= pct %>%</span>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-text-tertiary text-center py-6">No receipts yet.</p>
        <% end %>
      </div>
    </div>

    <!-- Disbursements by Category -->
    <div class="lg:col-span-1 rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900 p-4">
      <div class="flex items-center justify-between mb-4">
        <span class="text-xs font-semibold tracking-wider uppercase text-text-tertiary">Disbursements by Category</span>
        <span class="text-sm font-mono font-semibold text-warning"><%= Money.from_cents(@session.total_disbursements, "PHP").format %></span>
      </div>
      <div class="space-y-3">
        <% if @grouped_disbursements.any? %>
          <% max_disburse = @grouped_disbursements.map { |_, v| v.sum(&:amount_cents) }.max.to_f %>
          <% @grouped_disbursements.each do |cat, vouchers| %>
            <% cat_total = vouchers.sum(&:amount_cents) %>
            <% pct = @session.total_disbursements > 0 ? (cat_total.to_f / @session.total_disbursements * 100).round(1) : 0 %>
            <div>
              <div class="flex items-center justify-between text-sm mb-1">
                <span class="text-text-secondary truncate pr-2"><%= category_label(cat) %></span>
                <span class="font-mono font-semibold text-text-primary tabular-nums"><%= Money.from_cents(cat_total, "PHP").format %></span>
              </div>
              <div class="flex items-center gap-2">
                <div class="flex-1 h-2.5 bg-surface-alt rounded-full overflow-hidden">
                  <div class="h-full rounded-full bg-warning transition-all" style="width: <%= max_disburse > 0 ? (cat_total / max_disburse * 100).round : 0 %>%"></div>
                </div>
                <span class="text-xs font-mono text-text-tertiary w-8 text-right tabular-nums"><%= pct %>%</span>
              </div>
            </div>
          <% end %>
        <% else %>
          <p class="text-sm text-text-tertiary text-center py-6">No disbursements yet.</p>
        <% end %>
      </div>
    </div>

    <!-- Cash Health Summary -->
    <div class="lg:col-span-1 rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900 p-4">
      <span class="text-xs font-semibold tracking-wider uppercase text-text-tertiary">Cash Health</span>
      <div class="mt-4 space-y-3">
        <% if @session.net_cash_flow >= 0 %>
          <div class="rounded-lg border border-positive/20 bg-positive-50 p-3">
            <div class="text-xs font-semibold uppercase tracking-wider text-text-tertiary mb-1">Net Cash Flow</div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-positive" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
              <span class="font-mono text-base font-bold tabular-nums text-positive"><%= Money.from_cents(@session.net_cash_flow.abs, "PHP").format %></span>
              <span class="text-xs font-semibold uppercase text-positive">inflow</span>
            </div>
          </div>
        <% else %>
          <div class="rounded-lg border border-danger/20 bg-danger-50 p-3">
            <div class="text-xs font-semibold uppercase tracking-wider text-text-tertiary mb-1">Net Cash Flow</div>
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-danger" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M13 17h8m0 0V9m0 8l-8-8-4 4-6-6"/></svg>
              <span class="font-mono text-base font-bold tabular-nums text-danger"><%= Money.from_cents(@session.net_cash_flow.abs, "PHP").format %></span>
              <span class="text-xs font-semibold uppercase text-danger">outflow</span>
            </div>
          </div>
        <% end %>
        <% total_vol = @session.total_receipts + @session.total_disbursements %>
        <% rec_ratio = total_vol > 0 ? (@session.total_receipts.to_f / total_vol * 100).round(0) : 50 %>
        <% dis_ratio = 100 - rec_ratio %>
        <div class="rounded-lg border border-border p-3">
          <div class="text-xs font-semibold uppercase tracking-wider text-text-tertiary mb-2">Receipt vs Disbursement</div>
          <div class="flex h-2 rounded-full overflow-hidden bg-surface-alt mb-2">
            <div class="bg-positive h-full transition-all" style="width: <%= rec_ratio %>%"></div>
            <div class="bg-warning h-full transition-all" style="width: <%= dis_ratio %>%"></div>
          </div>
          <div class="flex justify-between text-xs font-mono text-text-tertiary">
            <span><%= rec_ratio %>% Receipts</span>
            <span><%= dis_ratio %>% Disbursements</span>
          </div>
        </div>
        <% if @session.open? %>
          <div class="rounded-lg border border-primary/20 bg-primary-50 p-3">
            <div class="flex items-center gap-2">
              <span class="relative flex h-2.5 w-2.5">
                <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-primary opacity-75"></span>
                <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-primary"></span>
              </span>
              <span class="text-xs font-semibold uppercase tracking-wider text-primary">Session Active</span>
            </div>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <!-- Tabs: Receipts / Disbursements / Vault Transfers -->
  <div data-controller="tabs cash-session" class="rounded-xl border border-border bg-surface shadow-sm dark:border-gray-800 dark:bg-gray-900 overflow-hidden animate-fade-in-up-4">
    <!-- Tab Bar -->
    <div class="flex border-b border-border dark:border-gray-800 px-4">
      <button type="button" data-tabs-target="tab" data-tab="receipts" data-action="tabs#activate"
              class="border-b-2 border-primary text-primary px-3 py-3 text-xs font-semibold uppercase tracking-[0.08em] transition-colors">
        Receipts
        <span class="ml-1.5 text-[0.6rem] font-mono opacity-60"><%= @receipts.size %></span>
      </button>
      <button type="button" data-tabs-target="tab" data-tab="disbursements" data-action="tabs#activate"
              class="border-b-2 border-transparent text-text-tertiary hover:text-text-secondary dark:hover:text-gray-300 px-3 py-3 text-xs font-semibold uppercase tracking-[0.08em] transition-colors">
        Disbursements
        <span class="ml-1.5 text-[0.6rem] font-mono opacity-60"><%= @disbursements.size %></span>
      </button>
      <% if vault_account %>
        <button type="button" data-tabs-target="tab" data-tab="vault_transfers" data-action="tabs#activate"
                class="border-b-2 border-transparent text-text-tertiary hover:text-text-secondary dark:hover:text-gray-300 px-3 py-3 text-xs font-semibold uppercase tracking-[0.08em] transition-colors">
          Vault Transfers
          <% pending_count = @vault_transfers.count(&:pending?) %>
          <% if pending_count > 0 %>
            <span class="ml-1.5 inline-flex items-center justify-center w-4 h-4 rounded-full bg-warning text-[0.55rem] font-bold text-white"><%= pending_count %></span>
          <% else %>
            <span class="ml-1.5 text-[0.6rem] font-mono opacity-60"><%= @vault_transfers.size %></span>
          <% end %>
        </button>
      <% end %>
    </div>

    <!-- Receipts Panel -->
    <div id="tab-receipts" data-tabs-target="panel">
      <% if @receipts.any? %>
        <div class="overflow-x-auto scrollbar-thin max-h-[32rem] overflow-y-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-border dark:border-gray-800 bg-surface-alt/50 dark:bg-gray-800/50">
                <th class="px-4 py-2.5 text-left w-36 text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Voucher</th>
                <th class="px-4 py-2.5 text-left w-28 text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Date</th>
                <th class="px-4 py-2.5 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Category</th>
                <th class="px-4 py-2.5 text-left hidden lg:table-cell text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Description</th>
                <th class="px-4 py-2.5 text-left hidden md:table-cell text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Counterparty</th>
                <th class="px-4 py-2.5 text-right w-28 text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Amount</th>
              </tr>
            </thead>
            <tbody>
              <% @receipts.each do |v| %>
                <tr data-action="click->cash-session#toggle" data-id="<%= v.id %>"
                    class="border-b border-border/50 dark:border-gray-800/40 hover:bg-positive-50/30 dark:hover:bg-positive-900/5 transition-colors cursor-pointer">
                  <td class="px-4 py-2.5 font-mono text-sm text-text-tertiary dark:text-gray-400"><%= v.voucher_number %></td>
                  <td class="px-4 py-2.5 text-xs text-text-secondary dark:text-gray-400"><%= v.posted_at&.strftime("%b %d") || "—" %></td>
                  <td class="px-4 py-2.5">
                    <span class="category-badge text-positive bg-positive-50 border border-positive/30"><%= v.category.titleize %></span>
                  </td>
                  <td class="px-4 py-2.5 text-xs text-text-secondary dark:text-gray-400 hidden lg:table-cell max-w-[14rem] truncate"><%= v.description || "—" %></td>
                  <td class="px-4 py-2.5 text-xs text-text-secondary dark:text-gray-400 hidden md:table-cell"><%= v.counterparty&.respond_to?(:name) ? v.counterparty.name : "—" %></td>
                  <td class="px-4 py-2.5 text-right font-mono text-sm font-semibold text-positive tabular-nums"><%= Money.from_cents(v.amount_cents, "PHP").format %></td>
                </tr>
                <tr id="voucher-detail-<%= v.id %>" class="hidden">
                  <td colspan="6" class="p-0">
                    <div class="bg-surface-alt/70 dark:bg-gray-800/30 border-b border-border/50 dark:border-gray-800/40">
                      <table class="w-full">
                        <thead>
                          <tr class="text-[0.55rem] font-semibold uppercase tracking-[0.1em] text-text-tertiary dark:text-gray-500">
                            <th class="px-4 py-1.5 text-left w-24">Account</th>
                            <th class="px-4 py-1.5 text-left">Type</th>
                            <th class="px-4 py-1.5 text-right w-28">Debit</th>
                            <th class="px-4 py-1.5 text-right w-28">Credit</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% if v.entry&.amount_lines&.any? %>
                            <% v.entry.amount_lines.each do |line| %>
                              <tr class="font-mono text-xs">
                                <td class="px-4 py-1 text-text-secondary dark:text-gray-400"><%= line.account.account_code %></td>
                                <td class="px-4 py-1 text-text-tertiary dark:text-gray-500"><%= line.account.name %></td>
                                <td class="px-4 py-1 text-right tabular-nums <%= line.debit? ? 'text-positive font-semibold' : 'text-text-tertiary dark:text-gray-600' %>">
                                  <%= line.debit? ? line.amount.format : "—" %>
                                </td>
                                <td class="px-4 py-1 text-right tabular-nums <%= line.credit? ? 'text-warning font-semibold' : 'text-text-tertiary dark:text-gray-600' %>">
                                  <%= line.credit? ? line.amount.format : "—" %>
                                </td>
                              </tr>
                            <% end %>
                          <% else %>
                            <tr>
                              <td colspan="4" class="px-4 py-2 text-center text-xs text-text-tertiary dark:text-gray-500 italic">No accounting entry posted yet.</td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                      <div class="flex items-center justify-end gap-2 px-4 py-1.5 border-t border-border/30 dark:border-gray-800/30">
                        <span class="text-[0.55rem] font-mono text-text-tertiary dark:text-gray-600">
                          JE: <%= v.entry&.reference_number || "—" %>
                        </span>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-14 text-center">
          <svg class="w-10 h-10 text-text-tertiary/40 dark:text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
          <p class="text-xs text-text-tertiary dark:text-gray-500">No receipts yet.</p>
        </div>
      <% end %>
    </div>

    <!-- Disbursements Panel -->
    <div id="tab-disbursements" data-tabs-target="panel" class="hidden">
      <% if @disbursements.any? %>
        <div class="overflow-x-auto scrollbar-thin max-h-[32rem] overflow-y-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-border dark:border-gray-800 bg-surface-alt/50 dark:bg-gray-800/50">
                <th class="px-4 py-2.5 text-left w-36 text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Voucher</th>
                <th class="px-4 py-2.5 text-left w-28 text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Date</th>
                <th class="px-4 py-2.5 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Category</th>
                <th class="px-4 py-2.5 text-left hidden lg:table-cell text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Description</th>
                <th class="px-4 py-2.5 text-left hidden md:table-cell text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Counterparty</th>
                <th class="px-4 py-2.5 text-right w-28 text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary dark:text-gray-500">Amount</th>
              </tr>
            </thead>
            <tbody>
              <% @disbursements.each do |v| %>
                <tr data-action="click->cash-session#toggle" data-id="<%= v.id %>"
                    class="border-b border-border/50 dark:border-gray-800/40 hover:bg-warning-50/30 dark:hover:bg-warning-900/5 transition-colors cursor-pointer">
                  <td class="px-4 py-2.5 font-mono text-sm text-text-tertiary dark:text-gray-400"><%= v.voucher_number %></td>
                  <td class="px-4 py-2.5 text-sm text-text-secondary dark:text-gray-400"><%= v.posted_at&.strftime("%b %d") || "—" %></td>
                  <td class="px-4 py-2.5">
                    <span class="category-badge text-warning bg-warning-50 border border-warning/30"><%= v.category.titleize %></span>
                  </td>
                  <td class="px-4 py-2.5 text-xs text-text-secondary dark:text-gray-400 hidden lg:table-cell max-w-[14rem] truncate"><%= v.description || "—" %></td>
                  <td class="px-4 py-2.5 text-xs text-text-secondary dark:text-gray-400 hidden md:table-cell"><%= v.counterparty&.respond_to?(:name) ? v.counterparty.name : "—" %></td>
                  <td class="px-4 py-2.5 text-right font-mono text-sm font-semibold text-warning tabular-nums"><%= Money.from_cents(v.amount_cents, "PHP").format %></td>
                </tr>
                <tr id="voucher-detail-<%= v.id %>" class="hidden">
                  <td colspan="6" class="p-0">
                    <div class="bg-surface-alt/70 dark:bg-gray-800/30 border-b border-border/50 dark:border-gray-800/40">
                      <table class="w-full">
                        <thead>
                          <tr class="text-[0.55rem] font-semibold uppercase tracking-[0.1em] text-text-tertiary dark:text-gray-500">
                            <th class="px-4 py-1.5 text-left w-24">Account</th>
                            <th class="px-4 py-1.5 text-left">Type</th>
                            <th class="px-4 py-1.5 text-right w-28">Debit</th>
                            <th class="px-4 py-1.5 text-right w-28">Credit</th>
                          </tr>
                        </thead>
                        <tbody>
                          <% if v.entry&.amount_lines&.any? %>
                            <% v.entry.amount_lines.each do |line| %>
                              <tr class="font-mono text-xs">
                                <td class="px-4 py-1 text-text-secondary dark:text-gray-400"><%= line.account.account_code %></td>
                                <td class="px-4 py-1 text-text-tertiary dark:text-gray-500"><%= line.account.name %></td>
                                <td class="px-4 py-1 text-right tabular-nums <%= line.debit? ? 'text-positive font-semibold' : 'text-text-tertiary dark:text-gray-600' %>">
                                  <%= line.debit? ? line.amount.format : "—" %>
                                </td>
                                <td class="px-4 py-1 text-right tabular-nums <%= line.credit? ? 'text-warning font-semibold' : 'text-text-tertiary dark:text-gray-600' %>">
                                  <%= line.credit? ? line.amount.format : "—" %>
                                </td>
                              </tr>
                            <% end %>
                          <% else %>
                            <tr>
                              <td colspan="4" class="px-4 py-2 text-center text-xs text-text-tertiary dark:text-gray-500 italic">No accounting entry posted yet.</td>
                            </tr>
                          <% end %>
                        </tbody>
                      </table>
                      <div class="flex items-center justify-end gap-2 px-4 py-1.5 border-t border-border/30 dark:border-gray-800/30">
                        <span class="text-[0.55rem] font-mono text-text-tertiary dark:text-gray-600">
                          JE: <%= v.entry&.reference_number || "—" %>
                        </span>
                      </div>
                    </div>
                  </td>
                </tr>
              <% end %>
            </tbody>
          </table>
        </div>
      <% else %>
        <div class="flex flex-col items-center justify-center py-14 text-center">
          <svg class="w-10 h-10 text-text-tertiary/40 dark:text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
          <p class="text-xs text-text-tertiary dark:text-gray-500">No disbursements yet.</p>
        </div>
      <% end %>
    </div>

    <!-- Vault Transfers Panel -->
    <div id="tab-vault_transfers" data-tabs-target="panel" class="hidden">
      <% if vault_account %>
        <% if @session.open? %>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-px bg-border dark:bg-gray-800 border-b border-border dark:border-gray-800">
            <div class="bg-surface dark:bg-gray-900 p-4">
              <%= form_tag receive_from_vault_treasury_cash_session_path(@session), method: :post, class: "space-y-3" do %>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-positive"></span>
                  <span class="text-xs font-semibold tracking-wider uppercase text-positive">Buy Cash from Vault</span>
                </div>
                <div>
                  <%= label_tag :amount, "Amount (PHP)", class: "block text-[0.65rem] font-semibold tracking-[0.08em] uppercase text-text-tertiary dark:text-gray-500 mb-1" %>
                  <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-xs font-mono text-text-tertiary dark:text-gray-500">₱</span>
                    <%= number_field_tag :amount, nil, step: 0.01, min: 0.01, class: "w-full rounded-lg border border-border bg-surface-alt pl-7 pr-3 py-2 text-sm font-mono text-text-primary placeholder-text-tertiary/50                     focus:outline-none focus:ring-2 focus:ring-positive/20 focus:border-positive dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:placeholder-gray-600", placeholder: "0.00", required: true %>
                  </div>
                </div>
                <%= submit_tag "Request Cash from Vault", class: "w-full rounded-lg bg-positive px-3 py-2 text-xs font-semibold tracking-wider uppercase text-white hover:bg-positive-700 transition-colors cursor-pointer" %>
              <% end %>
            </div>
            <div class="bg-surface dark:bg-gray-900 p-4">
              <%= form_tag return_to_vault_treasury_cash_session_path(@session), method: :post, class: "space-y-3" do %>
                <div class="flex items-center gap-2 mb-2">
                  <span class="w-1.5 h-1.5 rounded-full bg-warning"></span>
                  <span class="text-xs font-semibold tracking-wider uppercase text-warning">Return Cash to Vault</span>
                </div>
                <div>
                  <%= label_tag :amount, "Amount (PHP)", class: "block text-[0.65rem] font-semibold tracking-[0.08em] uppercase text-text-tertiary dark:text-gray-500 mb-1" %>
                  <div class="relative">
                    <span class="absolute inset-y-0 left-0 flex items-center pl-3 text-xs font-mono text-text-tertiary dark:text-gray-500">₱</span>
                    <%= number_field_tag :amount, nil, step: 0.01, min: 0.01, class: "w-full rounded-lg border border-border bg-surface-alt pl-7 pr-3 py-2 text-sm font-mono text-text-primary placeholder-text-tertiary/50                     focus:outline-none focus:ring-2 focus:ring-warning/20 focus:border-warning dark:border-gray-700 dark:bg-gray-800 dark:text-gray-100 dark:placeholder-gray-600", placeholder: "0.00", required: true %>
                  </div>
                </div>
                <%= submit_tag "Return to Vault", class: "w-full rounded-lg bg-warning px-3 py-2 text-xs font-semibold tracking-wider uppercase text-white hover:bg-warning-700 transition-colors cursor-pointer" %>
              <% end %>
            </div>
          </div>
        <% end %>
        <% if @vault_transfers.any? %>
          <div class="overflow-x-auto scrollbar-thin max-h-56 overflow-y-auto">
            <table class="w-full">
              <thead>
                <tr class="border-b border-border dark:border-gray-800 bg-surface-alt/50 dark:bg-gray-800/50">
                  <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary">Time</th>
                  <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary">Direction</th>
                  <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary">Status</th>
                  <th class="px-4 py-2 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary">Notes</th>
                  <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-text-tertiary">Amount</th>
                  <th class="px-4 py-2 text-right text-xs font-semibold uppercase tracking-wider text-text-tertiary">Actions</th>
                </tr>
              </thead>
              <tbody>
                <% @vault_transfers.each do |t| %>
                  <tr class="border-b border-border/50 dark:border-gray-800/40 <%= 'bg-warning-50/40 dark:bg-warning-900/10' if t.pending? %>">
                    <td class="px-4 py-2 font-mono text-xs text-text-tertiary dark:text-gray-500"><%= t.created_at.strftime("%H:%M:%S") %></td>
                    <td class="px-4 py-2">
                      <% if t.to_teller? %>
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-positive">
                          <span class="w-1 h-1 rounded-full bg-positive"></span> Vault &rarr; Teller
                        </span>
                      <% else %>
                        <span class="inline-flex items-center gap-1 text-xs font-medium text-warning">
                          <span class="w-1 h-1 rounded-full bg-warning"></span> Teller &rarr; Vault
                        </span>
                      <% end %>
                    </td>
                    <td class="px-4 py-2">
                      <% if t.pending? %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-warning">
                          <span class="relative flex h-1.5 w-1.5">
                            <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-warning opacity-75"></span>
                            <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-warning"></span>
                          </span>
                          Pending
                        </span>
                      <% elsif t.approved? %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-positive">
                          <span class="w-1.5 h-1.5 rounded-full bg-positive"></span>
                          Approved
                        </span>
                      <% else %>
                        <span class="inline-flex items-center gap-1 text-xs font-semibold text-danger">
                          <span class="w-1.5 h-1.5 rounded-full bg-danger"></span>
                          Rejected
                        </span>
                      <% end %>
                    </td>
                    <td class="px-4 py-2 text-xs text-text-tertiary dark:text-gray-500 max-w-[8rem] truncate"><%= t.description.presence || "—" %></td>
                    <td class="px-4 py-2 text-right font-mono text-xs font-semibold tabular-nums <%= t.to_teller? ? 'text-positive' : 'text-warning' %>">
                      <%= Money.from_cents(t.amount_cents, "PHP").format %>
                    </td>
                    <% if t.pending? %>
                    <td class="px-4 py-2 text-right">
                      <div class="flex items-center justify-end gap-1.5">
                        <%= button_to approve_treasury_vault_transfer_path(t), method: :post,
                              class: "rounded-md bg-positive px-2 py-1 text-[0.6rem] font-semibold text-white hover:bg-positive-700 transition-colors cursor-pointer",
                              data: { turbo_confirm: "Approve this transfer?" } do %>
                          Approve
                        <% end %>
                        <%= button_to reject_treasury_vault_transfer_path(t), method: :post,
                              class: "rounded-md border border-border bg-surface px-2 py-1 text-[0.6rem] font-semibold text-text-secondary hover:bg-surface-alt transition-colors cursor-pointer",
                              data: { turbo_confirm: "Reject this transfer?" } do %>
                          Reject
                        <% end %>
                      </div>
                    </td>
                    <% end %>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% else %>
          <div class="flex flex-col items-center justify-center py-14 text-center">
            <svg class="w-10 h-10 text-text-tertiary/40 dark:text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M21 12a2.25 2.25 0 00-2.25-2.25H15a3 3 0 11-6 0H5.25A2.25 2.25 0 003 12m18 0v6a2.25 2.25 0 01-2.25 2.25H5.25A2.25 2.25 0 013 18v-6m18 0V9M3 12V9m18 0a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 9m18 0V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v3"/></svg>
            <p class="text-xs text-text-tertiary dark:text-gray-500">No vault transfers yet.</p>
          </div>
        <% end %>
      <% else %>
        <div class="flex flex-col items-center justify-center py-14 text-center">
          <svg class="w-10 h-10 text-text-tertiary/40 dark:text-gray-600 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          <p class="text-xs text-text-tertiary dark:text-gray-500">Vault account not configured.</p>
        </div>
      <% end %>
    </div>
  </div>

  <!-- Footer Summary -->
  <div class="flex items-center justify-end gap-4 px-4 py-2.5 animate-fade-in">
    <div class="flex items-center gap-2 text-xs text-text-tertiary dark:text-gray-500">
      <span class="font-semibold tracking-wider uppercase">Net Cash Flow</span>
      <span class="w-px h-3 bg-border dark:bg-gray-700"></span>
      <span class="font-mono text-sm font-bold <%= @session.net_cash_flow >= 0 ? 'text-positive' : 'text-warning' %>">
        <%= Money.from_cents(@session.net_cash_flow.abs, "PHP").format %>
        <span class="text-[0.6rem] ml-0.5"><%= @session.net_cash_flow >= 0 ? 'IN' : 'OUT' %></span>
      </span>
    </div>
  </div>
</div>
