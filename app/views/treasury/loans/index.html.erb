<% content_for :page_title,"Disburse Loans" %> <% content_for :page_subtitle,"Approve and disburse loan proceeds" %> <div class="animate-fade-in"> <div class="rounded-lg border border-border bg-surface overflow-hidden"> <table class="min-w-full text-sm"> <thead> <tr class="border-b border-border bg-surface-alt"> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Reference</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Member</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Product</th> <th class="px-4 py-3 text-right text-xs font-semibold uppercase tracking-wide text-text-tertiary">Principal</th> <th class="px-4 py-3 text-left text-xs font-semibold uppercase tracking-wide text-text-tertiary">Status</th> <th class="px-4 py-3 text-center text-xs font-semibold uppercase tracking-wide text-text-tertiary">Actions</th> </tr> </thead> <tbody class="divide-y divide-border"> <% if @loans.any? %> <% @loans.each do |loan| %> <tr class="hover:bg-surface-alt /30 transition-colors"> <td class="px-4 py-3"><code class="rounded bg-surface-alt px-1.5 py-0.5 text-xs font-mono"><%= loan.reference_number %></code></td> <td class="px-4 py-3 font-medium text-text-primary"><%= loan.member.name %></td> <td class="px-4 py-3 text-text-secondary"><%= loan.loan_product.name %></td> <td class="px-4 py-3 text-right font-medium text-text-primary"><%= number_to_currency(loan.principal_cents.to_f / 100, unit:"PHP") %></td> <td class="px-4 py-3"> <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize <%= loan.disbursed? ? 'bg-positive-50 text-positive' : 'bg-warning-50 text-warning' %>"> <%= loan.disbursed? ? "Disbursed" :"Pending" %> </span> </td> <td class="px-4 py-3 text-center"> <div class="flex items-center justify-center gap-2"> <% unless loan.disbursed? %> <%= button_to"Disburse", disburse_treasury_loan_path(loan), method: :post, class:"btn-primary btn-sm", data: { turbo_confirm:"Disburse #{number_to_currency(loan.principal_cents.to_f / 100, unit: 'PHP ')} to #{loan.member.name}?" } %> <% end %> <%= link_to"Voucher", voucher_treasury_loan_path(loan), class:"btn-ghost" %> </div> </td> </tr> <% end %> <% else %> <tr> <td colspan="6" class="px-4 py-12 text-center text-sm text-text-tertiary"> No loans pending disbursement. </td> </tr> <% end %> </tbody> </table> </div> </div> 