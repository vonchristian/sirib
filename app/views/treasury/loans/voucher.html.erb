<% content_for :page_title, "Disbursement Voucher" %>
<% content_for :page_subtitle, "##{@loan.reference_number}" %>

<div class="animate-fade-in max-w-3xl mx-auto">
  <div class="rounded-xl border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 p-8 print:p-0 print:border-0">
    <div class="text-center mb-8">
      <h1 class="text-xl font-bold text-text-primary dark:text-white">DISBURSEMENT VOUCHER</h1>
      <p class="text-sm text-text-tertiary">Reference: <%= @loan.reference_number %></p>
    </div>

    <div class="border-2 border-border dark:border-gray-700 rounded-lg p-6 space-y-6">
      <div class="grid grid-cols-2 gap-6">
        <div>
          <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wider">Payee</p>
          <p class="mt-1 text-base font-medium text-text-primary"><%= @loan.member.name %></p>
          <p class="text-sm text-text-tertiary"><%= @loan.loan_application.notes %></p>
        </div>
        <div class="text-right">
          <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wider">Date</p>
          <p class="mt-1 text-sm text-text-primary"><%= @loan.disbursed_at&.strftime("%B %d, %Y") || Date.current.strftime("%B %d, %Y") %></p>
          <p class="text-xs text-text-tertiary mt-1">Voucher #: DV-<%= @loan.reference_number %></p>
        </div>
      </div>

      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b-2 border-border dark:border-gray-700">
            <th class="py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Particulars</th>
            <th class="py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Amount</th>
          </tr>
        </thead>
        <tbody>
          <tr class="border-b border-border dark:border-gray-700">
            <td class="py-3 text-text-primary">Loan Proceeds - <%= @loan.loan_product.name %></td>
            <td class="py-3 text-right font-medium text-text-primary"><%= number_to_currency(@loan.principal_cents.to_f / 100, unit: "PHP ") %></td>
          </tr>
          <tr class="border-b border-border dark:border-gray-700">
            <td class="py-3 text-text-primary">Less: Interest (<%= @loan.interest_rate %>% <%= @loan.interest_calculation.titleize %>)</td>
            <td class="py-3 text-right text-text-secondary">—</td>
          </tr>
        </tbody>
        <tfoot>
          <tr>
            <th class="pt-3 text-left text-sm font-semibold text-text-primary">Net Proceeds</th>
            <th class="pt-3 text-right text-lg font-bold text-text-primary"><%= number_to_currency(@loan.principal_cents.to_f / 100, unit: "PHP ") %></th>
          </tr>
        </tfoot>
      </table>
    </div>

    <div class="mt-8 grid grid-cols-3 gap-6">
      <div class="text-center">
        <div class="border-b-2 border-border dark:border-gray-700 pb-1 mb-2"></div>
        <p class="text-xs text-text-tertiary">Prepared by</p>
      </div>
      <div class="text-center">
        <div class="border-b-2 border-border dark:border-gray-700 pb-1 mb-2"></div>
        <p class="text-xs text-text-tertiary">Approved by</p>
      </div>
      <div class="text-center">
        <div class="border-b-2 border-border dark:border-gray-700 pb-1 mb-2"></div>
        <p class="text-xs text-text-tertiary">Received by</p>
      </div>
    </div>

    <div class="mt-8 flex items-center justify-between no-print">
      <%= link_to "Back to Disbursements", treasury_loans_path, class: "btn-ghost" %>
      <button onclick="window.print()" class="btn-primary">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z"/>
        </svg>
        Print
      </button>
    </div>
  </div>
</div>
