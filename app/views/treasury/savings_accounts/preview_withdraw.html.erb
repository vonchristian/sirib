<% content_for :page_title,"Confirm Withdrawal" %> <% content_for :page_subtitle, @account.account_number %> <div class="animate-fade-in-up max-w-2xl"> <div class="rounded-lg border border-border bg-surface overflow-hidden"> <div class="flex items-center justify-between border-b border-border px-5 py-4"> <div class="flex items-center gap-3"> <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-warning-50 text-warning">Step 2 of 2</span> <span class="text-xs text-text-tertiary">Review and confirm</span> </div> </div> <div class="p-5"> <table class="w-full"> <tbody> <tr> <td class="pb-3 pr-4 text-xs text-text-tertiary align-top">Account</td> <td class="pb-3 text-sm font-medium text-text-primary"><%= @account.account_number %></td> </tr> <tr> <td class="pb-3 pr-4 text-xs text-text-tertiary align-top">Depositor</td> <td class="pb-3 text-sm font-medium text-text-primary"><%= @account.depositor_name %></td> </tr> <tr> <td class="pb-3 pr-4 text-xs text-text-tertiary align-top">Amount to Withdraw</td> <td class="pb-3 text-sm font-semibold text-warning"><%= @amount.format %></td> </tr> <tr> <td class="pb-3 pr-4 text-xs text-text-tertiary align-top">Cash Account</td> <td class="pb-3 text-sm font-medium text-text-primary"><%= @cash_account.name %></td> </tr> <% if @notes.present? %> <tr> <td class="pb-3 pr-4 text-xs text-text-tertiary align-top">Notes</td> <td class="pb-3 text-sm text-text-secondary"><%= @notes %></td> </tr> <% end %> <tr class="border-t border-border"> <td class="pt-4 pr-4 text-xs font-medium text-text-primary align-top">Balance After Withdrawal</td> <td class="pt-4 text-sm font-semibold text-text-primary"><%= (@account.balance - @amount).format %></td> </tr> </tbody> </table> <div class="mt-6 border-t border-border pt-4"> <p class="text-xs font-semibold uppercase tracking-wider text-text-tertiary mb-3">Accounting Entry — Debits &amp; Credits</p> <table class="w-full text-xs"> <thead> <tr class="border-b border-border"> <th class="pb-2 pr-4 text-left font-medium text-text-tertiary">Account</th> <th class="pb-2 pr-4 text-left font-medium text-text-tertiary">Type</th> <th class="pb-2 text-right font-medium text-text-tertiary w-36">Debit</th> <th class="pb-2 text-right font-medium text-text-tertiary w-36">Credit</th> </tr> </thead> <tbody> <% @debits.each do |debit| %> <tr class="border-b border-border last:border-0"> <td class="py-2 pr-4 text-text-primary"><%= debit[:account].name %></td> <td class="py-2 pr-4 text-text-tertiary capitalize"><%= debit[:account].account_type %></td> <td class="py-2 text-right font-medium tabular-nums text-positive"><%= debit[:amount].format %></td> <td class="py-2 text-right font-medium tabular-nums text-text-tertiary">—</td> </tr> <% end %> <% @credits.each do |credit| %> <tr class="border-b border-border last:border-0"> <td class="py-2 pr-4 text-text-primary"><%= credit[:account].name %></td> <td class="py-2 pr-4 text-text-tertiary capitalize"><%= credit[:account].account_type %></td> <td class="py-2 text-right font-medium tabular-nums text-text-tertiary">—</td> <td class="py-2 text-right font-medium tabular-nums text-negative"><%= credit[:amount].format %></td> </tr> <% end %> </tbody> </table> </div> </div> <div class="flex items-center justify-between gap-2 border-t border-border bg-surface-alt px-5 py-3"> <%= link_to"Edit", withdraw_treasury_savings_account_path(@account, amount_cents: params[:amount_cents], cash_account_id: params[:cash_account_id], notes: params[:notes]), class:"inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors" %> <div class="flex gap-3"> <%= link_to"Cancel", treasury_savings_account_path(@account), class:"inline-flex items-center justify-center gap-1.5 rounded-md px-4 py-2 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors" %> <%= button_to"Confirm Withdrawal", confirm_withdraw_treasury_savings_account_path(@account), method: :post, data: { turbo: false }, class:"inline-flex items-center justify-center gap-2 rounded-md bg-primary px-5 py-2 text-xs font-medium text-white hover:bg-primary-700 transition-colors", params: { amount_cents: params[:amount_cents], cash_account_id: @cash_account.id, notes: @notes } %> </div> </div> </div> </div> 