<% content_for :page_title,"Savings Account" %> <% content_for :page_subtitle, @account.account_number %> <div class="animate-fade-in"> <div class="grid grid-cols-1 lg:grid-cols-3 gap-6"> <div class="lg:col-span-2 space-y-6"> <div class="rounded-xl border border-border bg-surface p-6"> <div class="flex items-center justify-between mb-4"> <h2 class="text-sm font-semibold text-text-primary">Account Details</h2> <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium capitalize <%= @account.status == 'active' ? 'bg-positive-50 text-positive' : 'bg-text-tertiary/10 text-text-tertiary' %>"> <%= @account.status %> </span> </div> <dl class="grid grid-cols-2 gap-4 text-sm"> <div> <dt class="text-text-tertiary text-xs">Account Number</dt> <dd class="text-text-primary font-medium"><%= @account.account_number %></dd> </div> <div> <dt class="text-text-tertiary text-xs">Depositor</dt> <dd class="text-text-primary"><%= @account.depositor_name %></dd> </div> <div> <dt class="text-text-tertiary text-xs">Product</dt> <dd class="text-text-primary"><%= @account.savings_product.name %></dd> </div> <div> <dt class="text-text-tertiary text-xs">Account Type</dt> <dd class="text-text-primary capitalize"><%= @account.account_type %></dd> </div> <div> <dt class="text-text-tertiary text-xs">Current Balance</dt> <dd class="text-text-primary font-semibold text-lg"> <%= @account.balance.format %> </dd> </div> <div> <dt class="text-text-tertiary text-xs">Opened</dt> <dd class="text-text-primary"><%= @account.opened_at&.strftime("%b %d, %Y %H:%M") %></dd> </div> </dl> </div> <div class="rounded-xl border border-border bg-surface p-6"> <h2 class="text-sm font-semibold text-text-primary mb-4">Transaction History</h2> <div class="grid grid-cols-3 gap-4 mb-5 pb-5 border-b border-border"> <div> <p class="text-[11px] uppercase tracking-wider text-text-tertiary">This Month</p> <p class="text-lg font-semibold text-text-primary tabular-nums mt-0.5"><%= @month_transactions.size %></p> </div> <div> <p class="text-[11px] uppercase tracking-wider text-text-tertiary">Deposits</p> <p class="text-lg font-semibold text-positive tabular-nums mt-0.5"><%= Money.new(@month_deposits,"PHP").format %></p> </div> <div> <p class="text-[11px] uppercase tracking-wider text-text-tertiary">Withdrawals</p> <p class="text-lg font-semibold text-warning tabular-nums mt-0.5"><%= Money.new(@month_withdrawals,"PHP").format %></p> </div> </div> <% if @transactions.any? %> <div class="overflow-hidden"> <table class="min-w-full text-sm"> <thead> <tr class="bg-surface-alt border-b border-border"> <th class="px-3 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Reference</th> <th class="px-3 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Type</th> <th class="px-3 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Amount</th> <th class="px-3 py-2 text-right text-xs font-semibold text-text-tertiary uppercase">Balance</th> <th class="px-3 py-2 text-left text-xs font-semibold text-text-tertiary uppercase">Date</th> </tr> </thead> <tbody class="divide-y divide-border"> <% @transactions.each do |txn| %> <tr> <td class="px-3 py-2 text-xs text-text-primary"><%= txn.reference_number %></td> <td class="px-3 py-2"> <span class="inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium <%= txn.deposit? ? 'bg-positive-50 text-positive' : 'bg-warning-50 text-warning' %>"> <%= txn.transaction_type.capitalize %> </span> </td> <td class="px-3 py-2 text-right font-medium <%= txn.deposit? ? 'text-positive' : 'text-warning' %>"> <%= txn.deposit? ? '+' : '-' %><%= number_to_currency(txn.amount_cents / 100.0, unit:"PHP") %> </td> <td class="px-3 py-2 text-right text-text-primary"> <% rb = @account.liability_account&.running_balances&.find_by(as_of_date: txn.posted_at.to_date) %> <%= rb ? rb.balance.format : @account.balance.format %> </td> <td class="px-3 py-2 text-text-secondary text-xs"><%= txn.posted_at.strftime("%b %d, %Y %H:%M") %></td> </tr> <% end %> </tbody> </table> </div> <% else %> <div class="py-8 text-center"> <p class="text-sm text-text-tertiary">No transactions yet.</p> </div> <% end %> </div> </div> <div class="space-y-4"> <%= link_to deposit_treasury_savings_account_path(@account), class:"block w-full rounded-lg border border-border bg-surface p-5 text-center hover:bg-surface-alt transition-colors" do %> <svg class="mx-auto h-8 w-8 text-positive mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3"/> </svg> <span class="text-sm font-medium text-text-primary">Deposit</span> <p class="text-xs text-text-tertiary mt-0.5">Add funds to this account</p> <% end %> <%= link_to withdraw_treasury_savings_account_path(@account), class:"block w-full rounded-lg border border-border bg-surface p-5 text-center hover:bg-surface-alt transition-colors" do %> <svg class="mx-auto h-8 w-8 text-warning mb-2" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 19.5v-15m0 0-3 3m3-3 3 3"/> </svg> <span class="text-sm font-medium text-text-primary">Withdraw</span> <p class="text-xs text-text-tertiary mt-0.5">Withdraw funds from this account</p> <% end %> <div class="rounded-lg border border-border bg-surface p-4 text-xs text-text-tertiary"> <h3 class="font-semibold text-text-primary mb-2">Account Info</h3> <dl class="space-y-1"> <dt class="text-text-tertiary">Liability Account</dt> <dd class="text-text-primary"><%= @account.liability_account&.name ||"—" %></dd> <dt class="text-text-tertiary mt-1">Interest Expense Account</dt> <dd class="text-text-primary"><%= @account.interest_expense_account&.name ||"—" %></dd> </dl> </div> </div> </div> </div> 