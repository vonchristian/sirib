<% content_for :page_title,"Open Savings Account" %> <div class="animate-fade-in max-w-2xl mx-auto"> <div class="rounded-xl border border-border bg-surface shadow-sm"> <%# Header %> <div class="px-6 py-5 border-b border-border"> <div class="flex items-center gap-3"> <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-surface-alt text-primary ring-1 ring-border-strong"> <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.078.879 4.249 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /> </svg> </div> <div> <h1 class="text-lg font-semibold text-text-primary">Open Savings Account</h1> <% if @account.depositor_id.present? %> <% member = Membership::Member.find_by(id: @account.depositor_id) %> <% if member %> <p class="text-sm text-text-secondary mt-0.5">for <%= member.name %></p> <% end %> <% else %> <p class="text-sm text-text-secondary mt-0.5">Select a member to open a savings account</p> <% end %> </div> </div> </div> <%# Form %> <%= form_with model: @account, url: treasury_savings_accounts_path, class:"space-y-0" do |f| %> <% if @account.errors.any? %> <div class="mx-6 mt-5 rounded-lg border border-danger/20 bg-danger-50 px-4 py-3 dark:bg-danger/10"> <div class="flex items-start gap-2"> <svg class="mt-0.5 h-4 w-4 flex-shrink-0 text-danger" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" /> </svg> <div> <p class="text-sm font-medium text-danger"><%= pluralize(@account.errors.count,"error") %> prevented this account from being opened</p> <ul class="mt-1.5 list-inside list-disc text-sm text-danger/80"> <% @account.errors.each do |error| %> <li><%= error.full_message %></li> <% end %> </ul> </div> </div> </div> <% end %> <div class="px-6 py-5 space-y-6"> <%# Member %> <% if @account.depositor_id.present? %> <% member = Membership::Member.find_by(id: @account.depositor_id) %> <div class="animate-fade-in-up-1"> <label class="block text-xs font-medium text-text-secondary mb-1.5">Member</label> <div class="flex items-center gap-3 rounded-lg border border-border bg-surface-alt px-3.5 py-2.5"> <div class="flex h-8 w-8 items-center justify-center rounded-full bg-surface text-text-secondary text-xs font-semibold ring-1 ring-border-strong"> <%= member.name.first(2).upcase %> </div> <div class="flex-1 min-w-0"> <p class="text-sm font-medium text-text-primary"><%= member.name %></p> <p class="text-xs text-text-tertiary"><%= member.member_identifier %> &middot; <%= member.mobile_number %></p> </div> <span class="badge badge-success">Selected</span> </div> <%= f.hidden_field :depositor_id %> </div> <% else %> <div data-controller="member-autocomplete" data-member-autocomplete-url-value="/treasury/searches/members"> <label class="block text-xs font-medium text-text-secondary mb-1.5">Member</label> <div class="relative"> <%= f.hidden_field :depositor_id, data: { member_autocomplete_target:"hidden" } %> <div class="pointer-events-none absolute inset-y-0 left-0 z-10 flex items-center pl-3"> <svg class="h-4 w-4 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z" /> </svg> </div> <input type="text" data-member-autocomplete-target="input" data-action="input->member-autocomplete#search keydown->member-autocomplete#keyboard" placeholder="Search member by name or ID..." autocomplete="off" class="block w-full rounded-lg border border-border bg-surface pl-10 pr-3 py-2 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent" role="combobox" aria-expanded="false" aria-autocomplete="list"> <div data-member-autocomplete-target="results" class="hidden absolute left-0 right-0 z-50 mt-1 rounded-lg border border-border bg-surface shadow-lg overflow-y-auto max-h-60"></div> </div> <div data-member-autocomplete-target="selected" class="hidden mt-2"> <div class="flex items-center gap-3 rounded-lg border border-border bg-surface-alt px-3.5 py-2.5"> <img data-member-image src="" alt="" class="hidden h-8 w-8 rounded-full object-cover ring-1 ring-border-strong"> <div data-member-initial class="flex h-8 w-8 items-center justify-center rounded-full bg-surface text-text-secondary text-xs font-semibold ring-1 ring-border-strong"></div> <div class="flex-1 min-w-0"> <p data-member-name class="text-sm font-medium text-text-primary"></p> </div> <button type="button" data-action="member-autocomplete#clear" class="flex h-6 w-6 items-center justify-center rounded-full text-text-tertiary hover:text-danger hover:bg-danger-50 transition-colors" title="Change member"> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" /> </svg> </button> </div> </div> </div> <% end %> <%# Savings Product %> <div class="animate-fade-in-up-2"> <label class="block text-xs font-medium text-text-secondary mb-1.5">Savings Product</label> <div class="grid grid-cols-1 gap-3"> <% @products.each do |product| %> <% rate = product.current_interest_rate %> <% selected = @account.savings_product_id == product.id %> <label data-product-id="<%= product.id %>" class="relative flex cursor-pointer rounded-lg border <%= selected ? 'border-primary ring-2 ring-primary/20 bg-surface' : 'border-border bg-surface hover:border-border-strong' %> p-4 transition-all"> <div class="flex items-start gap-3 w-full"> <div class="flex h-5 w-5 items-center justify-center mt-0.5"> <%= f.radio_button :savings_product_id, product.id, class:"h-4 w-4 text-primary border-border focus:ring-primary" %> </div> <div class="flex-1 min-w-0"> <p class="text-sm font-medium text-text-primary"><%= product.name %></p> <div class="flex items-center gap-3 mt-1"> <% if rate %> <span class="text-xs font-medium text-positive"><%= number_to_percentage(rate.rate * 100, precision: 2) %> interest</span> <% end %> <% if product.description.present? %> <span class="text-xs text-text-tertiary truncate"><%= product.description %></span> <% end %> </div> </div> <% if selected %> <svg class="h-5 w-5 flex-shrink-0 text-primary" fill="currentColor" viewBox="0 0 20 20"> <path fill-rule="evenodd" d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16Zm3.857-9.809a.75.75 0 0 0-1.214-.882l-3.483 4.79-1.88-1.88a.75.75 0 1 0-1.06 1.061l2.5 2.5a.75.75 0 0 0 1.137-.089l4-5.5Z" clip-rule="evenodd" /> </svg> <% end %> </div> </label> <% end %> </div> </div> <%# Account Type %> <div class="animate-fade-in-up-3"> <label class="block text-xs font-medium text-text-secondary mb-1.5">Account Type</label> <div class="grid grid-cols-2 gap-3"> <% [["personal","Personal Savings","Standard individual savings account for everyday use"], ["business","Business Savings","Business account with higher transaction limits"]].each do |value, label, desc| %> <% selected = @account.account_type == value %> <label class="relative flex cursor-pointer rounded-lg border <%= selected ? 'border-primary ring-2 ring-primary/20 bg-surface' : 'border-border bg-surface hover:border-border-strong' %> p-3.5 transition-all"> <div class="flex items-start gap-3"> <div class="flex h-5 w-5 items-center justify-center"> <%= f.radio_button :account_type, value, class:"h-4 w-4 text-primary border-border focus:ring-primary" %> </div> <div> <p class="text-sm font-medium text-text-primary"><%= label %></p> <p class="text-xs text-text-tertiary mt-0.5"><%= desc %></p> </div> </div> </label> <% end %> </div> </div> </div> <%# Footer %> <div class="px-6 py-4 flex items-center justify-between border-t border-border bg-surface-alt rounded-b-xl"> <%= link_to treasury_savings_accounts_path, class:"btn btn-ghost" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5 3 12m0 0 7.5-7.5M3 12h18" /> </svg> Cancel <% end %> <%= f.button class:"btn btn-primary" do %> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" /> </svg> Open Account <% end %> </div> <% end %> </div> </div> 