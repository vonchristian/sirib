<% content_for :page_title,"Savings Accounts" %> 
<div class="animate-fade-in-up"> 
  <div class="flex items-center justify-between mb-6"> 
    <div> 
      <p class="text-xl font-semibold text-text-primary">Savings Accounts</p>
 </div>
 
    <div class="flex items-center gap-3"> 
      <div class="relative" data-controller="autocomplete" data-autocomplete-url-value="<%= treasury_searches_savings_accounts_path %>"> <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-text-tertiary pointer-events-none z-10" width="16" height="16" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"> <path stroke-linecap="round" stroke-linejoin="round" d="m21 21-5.197-5.197m0 0A7.5 7.5 0 1 0 5.196 5.196a7.5 7.5 0 0 0 10.607 10.607Z"/> </svg> <input type="search" placeholder="Account #, depositor, product..." data-autocomplete-target="input" data-action="input->autocomplete#search keydown->autocomplete#keyboard" class="w-72 rounded-md border border-border bg-surface py-2 pl-10 pr-3 text-xs text-text-primary placeholder:text-text-tertiary transition-colors focus:border-primary focus:ring-1 focus:ring-primary outline-none"> <input type="hidden" data-autocomplete-target="hidden"> 
        <div data-autocomplete-target="results" class="absolute top-full left-0 right-0 z-50 mt-1 rounded-lg border border-border bg-surface shadow-lg hidden max-h-60 overflow-y-auto"></div>
 </div>
 <%= link_to"Open Account", new_treasury_savings_account_path, class:"inline-flex items-center justify-center gap-2 rounded-md bg-primary px-5 py-2 text-xs font-medium text-white hover:bg-primary-700 transition-colors" %> </div>
 </div>
 <% if @accounts.any? %> 
    <div class="rounded-lg border border-border bg-surface overflow-x-auto"> 
      <table class="w-full min-w-[48rem] border-collapse text-xs"> 
        <thead> 
          <tr> 
            <th class="bg-surface-alt px-4 py-2.5 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary border-b border-border whitespace-nowrap cursor-pointer hover:text-text-secondary select-none">Account #</th>
 
            <th class="bg-surface-alt px-4 py-2.5 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary border-b border-border whitespace-nowrap cursor-pointer hover:text-text-secondary select-none">Depositor</th>
 
            <th class="bg-surface-alt px-4 py-2.5 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary border-b border-border whitespace-nowrap cursor-pointer hover:text-text-secondary select-none">Product</th>
 
            <th class="bg-surface-alt px-4 py-2.5 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary border-b border-border whitespace-nowrap cursor-pointer hover:text-text-secondary select-none">Type</th>
 
            <th class="bg-surface-alt px-4 py-2.5 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary border-b border-border whitespace-nowrap select-none">Status</th>
 
            <th class="bg-surface-alt px-4 py-2.5 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary border-b border-border whitespace-nowrap select-none">Actions</th>
 </tr>
 </thead>
 
        <tbody> <% @accounts.each do |account| %> 
            <tr class="hover:bg-surface-alt transition-colors"> 
              <td class="px-4 py-3 text-sm font-medium text-text-primary border-b border-border align-middle"><%= account.account_number %></td>
 
              <td class="px-4 py-3 text-sm text-text-secondary border-b border-border align-middle"> 
                <div class="flex items-center gap-2.5"> <% if account.depositor.respond_to?(:profile_image) && account.depositor.profile_image.attached? %> <%= image_tag account.depositor.profile_image.variant(:thumb), class:"h-7 w-7 rounded-full object-cover flex-shrink-0" %> <% else %> <span class="h-7 w-7 rounded-full bg-primary-100 dark:bg-primary-900/30 flex items-center justify-center flex-shrink-0"> <span class="text-[10px] font-semibold text-primary dark:text-primary-300"><%= account.depositor_name.split.map(&:first).first(2).join.upcase %></span> </span> <% end %> <span><%= account.depositor_name %></span> </div>
 </td>
 
              <td class="px-4 py-3 text-sm text-text-secondary border-b border-border align-middle"><%= account.savings_product.name %></td>
 
              <td class="px-4 py-3 text-sm text-text-secondary border-b border-border align-middle capitalize"><%= account.account_type %></td>
 
              <td class="px-4 py-3 text-sm border-b border-border align-middle"> <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap <%= account.status == 'active' ? 'bg-positive-50 text-positive' : 'bg-surface-alt text-text-tertiary' %>"> <%= account.status %> </span> </td>
 
              <td class="px-4 py-3 border-b border-border align-middle text-right"> <%= link_to"View", treasury_savings_account_path(account), class:"inline-flex items-center gap-1 rounded px-2 py-1 text-xs font-medium text-text-tertiary hover:text-primary hover:bg-primary-50 transition-colors no-underline" %> </td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 
    <div class="mt-4 flex items-center justify-between"> 
      <p class="text-xs text-text-tertiary">Showing <%= @accounts.count %> of <%= @accounts.count %> accounts</p>
 </div>
 <% else %> 
    <div class="flex flex-col items-center justify-center px-6 py-12 text-center rounded-lg border border-dashed border-border bg-surface-alt"> <svg class="w-10 h-10 text-text-tertiary mb-3" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"> <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 0 0 2.25-2.25V6.75A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25v10.5A2.25 2.25 0 0 0 4.5 19.5Z"/> </svg> 
      <p class="text-xs text-text-tertiary max-w-80">No savings accounts yet</p>
 
      <p class="text-xs text-text-tertiary mt-1">Open the first savings account for a member.</p>
 <%= link_to"Open Account", new_treasury_savings_account_path, class:"inline-flex items-center justify-center gap-2 rounded-md bg-primary px-5 py-2 text-xs font-medium text-white hover:bg-primary-700 transition-colors mt-4" %> </div>
 <% end %> </div>
 
