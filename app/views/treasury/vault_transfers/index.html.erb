<% content_for :page_title,"Pending Vault Transfers" %> 
<div class="animate-fade-in space-y-5 max-w-5xl mx-auto"> 
  <div class="flex items-center justify-between"> 
    <div> 
      <h1 class="text-xl font-bold text-text-primary tracking-tight">Vault Transfers</h1>
 
      <p class="text-sm text-text-tertiary mt-0.5">Pending requests from tellers</p>
 </div>
 </div>
 <% if @transfers.any? %> 
    <div class="rounded-xl border border-border bg-surface shadow-sm overflow-hidden"> 
      <div class="overflow-x-auto"> 
        <table class="w-full"> 
          <thead> 
            <tr class="border-b border-border bg-surface-alt/50"> 
              <th class="px-4 py-3 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Requested</th>
 
              <th class="px-4 py-3 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Teller</th>
 
              <th class="px-4 py-3 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Session</th>
 
              <th class="px-4 py-3 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Direction</th>
 
              <th class="px-4 py-3 text-left text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Notes</th>
 
              <th class="px-4 py-3 text-right text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Amount</th>
 
              <th class="px-4 py-3 text-right text-[0.65rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Actions</th>
 </tr>
 </thead>
 
          <tbody> <% @transfers.each do |t| %> 
              <tr class="border-b border-border/50 hover:bg-warning-50/30 dark:hover:bg-warning-900/5 transition-colors"> 
                <td class="px-4 py-3 font-mono text-sm text-text-tertiary"> <%= t.created_at.strftime("%b %d, %H:%M") %> </td>
 
                <td class="px-4 py-3 text-sm font-medium text-text-primary"> <%= t.cash_session.user.email_address %> </td>
 
                <td class="px-4 py-3 text-sm font-mono text-text-tertiary"> SESSION-<%= t.cash_session_id.to_s.rjust(4, '0') %> </td>
 
                <td class="px-4 py-3"> <% if t.to_teller? %> <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-positive"> <span class="w-2 h-2 rounded-full bg-positive"></span> Vault &rarr; Teller </span> <% else %> <span class="inline-flex items-center gap-1.5 text-sm font-semibold text-warning"> <span class="w-2 h-2 rounded-full bg-warning"></span> Teller &rarr; Vault </span> <% end %> </td>
 
                <td class="px-4 py-3 text-sm text-text-tertiary max-w-[10rem] truncate"> <%= t.description.presence ||"—" %> </td>
 
                <td class="px-4 py-3 text-right font-mono text-sm font-semibold tabular-nums <%= t.to_teller? ? 'text-positive' : 'text-warning' %>"> <%= Money.from_cents(t.amount_cents,"PHP").format %> </td>
 
                <td class="px-4 py-3 text-right"> 
                  <div class="flex items-center justify-end gap-2"> <%= button_to approve_treasury_vault_transfer_path(t), method: :post, class:"rounded-lg bg-positive px-3 py-1.5 text-xs font-semibold text-white hover:bg-positive-700 transition-colors cursor-pointer", data: { turbo_confirm:"Approve this transfer?" } do %> Approve <% end %> <%= button_to reject_treasury_vault_transfer_path(t), method: :post, class:"rounded-lg border border-border bg-surface px-3 py-1.5 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors cursor-pointer", data: { turbo_confirm:"Reject this transfer?" } do %> Reject <% end %> </div>
 </td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 </div>
 <% else %> 
    <div class="rounded-xl border border-border bg-surface shadow-sm"> 
      <div class="flex flex-col items-center justify-center py-16 text-center"> <svg class="w-12 h-12 text-text-tertiary/30 mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg> 
        <p class="text-sm font-medium text-text-tertiary">No pending vault transfer requests.</p>
 
        <p class="text-xs text-text-tertiary/60 mt-1">All requests have been processed.</p>
 </div>
 </div>
 <% end %> <!-- Approval History --> <% recent = Treasury::VaultTransfer.where.not(status: :pending).order(approved_at: :desc).limit(10) %> <% if recent.any? %> 
    <div class="mt-6"> 
      <h2 class="text-xs font-semibold tracking-[0.12em] uppercase text-text-tertiary mb-3">Recent Activity</h2>
 
      <div class="rounded-xl border border-border bg-surface shadow-sm overflow-hidden"> 
        <table class="w-full"> 
          <thead> 
            <tr class="border-b border-border bg-surface-alt/50"> 
              <th class="px-4 py-2 text-left text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Time</th>
 
              <th class="px-4 py-2 text-left text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Teller</th>
 
              <th class="px-4 py-2 text-left text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Direction</th>
 
              <th class="px-4 py-2 text-left text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Status</th>
 
              <th class="px-4 py-2 text-right text-[0.6rem] font-semibold uppercase tracking-[0.08em] text-text-tertiary">Amount</th>
 </tr>
 </thead>
 
          <tbody> <% recent.each do |t| %> 
              <tr class="border-b border-border/50"> 
                <td class="px-4 py-2 font-mono text-[0.65rem] text-text-tertiary"><%= t.approved_at&.strftime("%b %d, %H:%M") %></td>
 
                <td class="px-4 py-2 text-xs text-text-secondary"><%= t.cash_session.user.email_address %></td>
 
                <td class="px-4 py-2 text-[0.65rem]"><%= t.to_teller? ? "Vault → Teller" :"Teller → Vault" %></td>
 
                <td class="px-4 py-2"> <% if t.approved? %> <span class="text-positive text-xs font-semibold">Approved</span> <% else %> <span class="text-warning text-xs font-semibold">Rejected</span> <% end %> </td>
 
                <td class="px-4 py-2 text-right font-mono text-xs font-semibold tabular-nums"><%= Money.from_cents(t.amount_cents,"PHP").format %></td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 </div>
 <% end %> </div>
 
