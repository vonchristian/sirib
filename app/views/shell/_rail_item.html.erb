<% is_active = local_assigns[:active] || false %>
<% badge_color = case local_assigns[:badge]
  when "OPEN" then "bg-emerald-500"
  when "BALANCING" then "bg-amber-500"
  else "bg-gray-600"
end %>

<button type="button"
        data-action="click->rail#select"
        data-rail-workspace-param="<%= local_assigns[:workspace] %>"
        data-rail-landing-param="<%= local_assigns[:landing] %>"
        title="<%= local_assigns[:label] %>"
        class="group relative flex items-center justify-center w-12 h-12 mx-auto rounded-sm transition-all duration-150 <%= is_active ? 'bg-accent-dim' : 'hover:bg-tertiary' %>"
        style="<%= is_active ? 'background: var(--accent-dim);' : '' %>">
  <% if is_active %>
    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
  <% end %>
  <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= is_active ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <%= icons[local_assigns[:icon]]&.html_safe %>
  </svg>
  <% if local_assigns[:badge].present? %>
    <span class="absolute top-1.5 right-1.5 flex h-2.5 w-2.5">
      <span class="absolute inline-flex h-full w-full rounded-full <%= badge_color %> opacity-75 animate-ping"></span>
      <span class="relative inline-flex rounded-full h-2.5 w-2.5 <%= badge_color %>"></span>
    </span>
  <% end %>
</button>