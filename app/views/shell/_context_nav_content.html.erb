<% role = Current.user&.role || "unknown" %>
<% current_path = request.path %>
<% cash_session = Current.cash_session %>

<%
  active_rail = case current_path
    when /\A\/deposits/ then "deposits"
    when /\A\/loans/ then "loans"
    when /\A\/equity/ then "equity"
    when /\A\/members/, /\A\/applications/ then "members"
    when /\A\/treasury/ then "treasury"
    when /\A\/accounting/, /\A\/external/ then "accounting"
    when /\A\/reports/, "/dashboard/reports" then "reports"
    when /\A\/management/ then "management"
    else "members"
    end
%>

<div class="space-y-6" data-sidebar-target="contextNavContent">
  <%# DEPOSITS SECTION %>
  <% if ["teller", "treasurer", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'deposits' ? 'active' : '' %>" data-rail-section="deposits">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Deposits</span>
      </div>
      <%= render "shell/sidebar_link", path: "/deposits/savings", label: "Savings Accounts", icon: "wallet", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/deposits/time_deposits", label: "Time Deposits", icon: "clock", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/deposits/fixed_deposits", label: "Fixed Deposits", icon: "lock", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/deposits/transactions", label: "Transactions", icon: "arrows-right-left", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/deposits/interest", label: "Interest Posting", icon: "calculator", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/deposits/statements", label: "Statements", icon: "document", current_path: current_path %>
    </div>
  <% end %>

  <%# LOANS SECTION %>
  <% if ["loan_officer", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'loans' ? 'active' : '' %>" data-rail-section="loans">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125V9.75c0 .621-.504 1.125-1.125 1.125H20.25m0 0v.75c0 .414-.336.75-.75.75H3.75"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Loans</span>
      </div>
      <%= render "shell/sidebar_link", path: "/loans/applications", label: "Loan Applications", icon: "document-text", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/loans/evaluation", label: "Credit Evaluation", icon: "clipboard-check", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/loans/accounts", label: "Loan Accounts", icon: "folder", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/loans/schedules", label: "Repayment Schedules", icon: "calendar", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/loans/collateral", label: "Collateral Mgmt", icon: "shield", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/loans/reports", label: "Loan Reports", icon: "chart-bar", current_path: current_path %>
    </div>
  <% end %>

  <%# EQUITY SECTION %>
  <% if ["accountant", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'equity' ? 'active' : '' %>" data-rail-section="equity">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Equity</span>
      </div>
      <%= render "shell/sidebar_link", path: "/equity/capital", label: "Share Capital", icon: "currency-dollar", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/equity/subscriptions", label: "Subscriptions", icon: "user-plus", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/equity/dividends", label: "Dividend Distribution", icon: "gift", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/equity/ledger", label: "Equity Ledger", icon: "book-open", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/equity/reports", label: "Equity Reports", icon: "chart-bar", current_path: current_path %>
    </div>
  <% end %>

  <%# MEMBERS SECTION %>
  <% if ["teller", "loan_officer", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'members' ? 'active' : '' %>" data-rail-section="members">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Members</span>
      </div>
      <%= render "shell/sidebar_link", path: "/applications", label: "Applications", icon: "user-plus", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/members", label: "Member List", icon: "list", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/members/profile", label: "Member Profile", icon: "user", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/members/kyc", label: "KYC Verification", icon: "shield-check", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/members/reports", label: "Member Reports", icon: "document-report", current_path: current_path %>
    </div>
  <% end %>

  <%# TREASURY SECTION %>
  <% if ["treasurer", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'treasury' ? 'active' : '' %>" data-rail-section="treasury">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5Z"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Treasury</span>
        <% if cash_session&.status == "open" %>
          <span class="ml-auto text-[9px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded-sm" style="background: rgba(34, 197, 94, 0.15); color: #22c55e;">Open</span>
        <% elsif cash_session&.status == "balancing" %>
          <span class="ml-auto text-[9px] font-mono uppercase tracking-wider px-1.5 py-0.5 rounded-sm" style="background: rgba(251, 191, 36, 0.15); color: #fbbf24;">Balancing</span>
        <% end %>
      </div>
      <%= render "shell/sidebar_link", path: "/treasury/cash_sessions", label: "Cash Sessions", icon: "cash", current_path: current_path, badge: cash_session_status_badge(cash_session) %>
      <%= render "shell/sidebar_link", path: "/treasury/position", label: "Cash Position", icon: "chart-bar", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/treasury/balancing", label: "Teller Balancing", icon: "scale", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/treasury/vault", label: "Vault Management", icon: "lock-closed", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/treasury/reports", label: "Treasury Reports", icon: "document-report", current_path: current_path %>
    </div>
  <% end %>

  <%# ACCOUNTING SECTION %>
  <% if ["accountant", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'accounting' ? 'active' : '' %>" data-rail-section="accounting">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Accounting</span>
      </div>
      <%= render "shell/sidebar_link", path: "/accounting/entries", label: "Journal Entries", icon: "document-text", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/accounting/balance_sheet", label: "Balance Sheet", icon: "scale", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/accounting/income_statement", label: "Income Statement", icon: "trending-up", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/accounting/cash_flow", label: "Cash Flow", icon: "arrows-right-left", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/accounting/trial_balance", label: "Trial Balance", icon: "table-cells", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/external/accounts", label: "External Bank Accounts", icon: "building-office", current_path: current_path %>
    </div>
  <% end %>

  <%# REPORTS SECTION %>
  <% if ["manager", "accountant", "treasurer"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'reports' ? 'active' : '' %>" data-rail-section="reports">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125Z"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Reports</span>
      </div>
      <%= render "shell/sidebar_link", path: "/dashboard/reports", label: "Financial Reports", icon: "currency-dollar", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/reports/regulatory", label: "Regulatory Reports", icon: "shield", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/reports/operational", label: "Operational Dashboard", icon: "chart-bar", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/reports/audit", label: "Audit Logs", icon: "clipboard-document-check", current_path: current_path %>
    </div>
  <% end %>

  <%# MANAGEMENT SECTION %>
  <% if ["admin", "manager"].include?(role) %>
    <div class="space-y-0.5 <%= active_rail == 'management' ? 'active' : '' %>" data-rail-section="management">
      <div class="flex items-center gap-2 px-3 py-2">
        <svg class="w-3.5 h-3.5" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
        </svg>
        <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Management</span>
      </div>
      <%= render "shell/sidebar_link", path: "/management/dashboard", label: "Operations Dashboard", icon: "home", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/branches", label: "Branches", icon: "building-office", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/policies", label: "Policies", icon: "document", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/approval_workflows", label: "Approval Workflows", icon: "check-circle", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/configurations", label: "Configurations", icon: "cog", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/alerts", label: "Alerts", icon: "bell", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/audit_logs", label: "Audit Log", icon: "clipboard-document-list", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/entry_templates", label: "Entry Templates", icon: "document-text", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/management/settings", label: "System Settings", icon: "adjustments", current_path: current_path %>
      <div class="my-2 mx-3" style="height: 1px; background: var(--border-color);"></div>
      <div class="px-3 py-1">
        <span class="text-[9px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">External Banking</span>
      </div>
      <%= render "shell/sidebar_link", path: "/external/banks", label: "Banks", icon: "building-office", current_path: current_path %>
      <%= render "shell/sidebar_link", path: "/external/accounts", label: "Bank Accounts", icon: "wallet", current_path: current_path %>
    </div>
  <% end %>
</div>