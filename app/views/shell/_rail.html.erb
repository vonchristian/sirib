<% role = Current.user&.role || "unknown" %>
<% current_path = request.path %>
<% cash_session = Current.cash_session %>

<nav class="space-y-0.5">
  <%# Deposits - Teller, Treasurer, Manager %>
  <% if ["teller", "treasurer", "manager"].include?(role) %>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="deposits"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/deposits') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/deposits') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/deposits') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818l.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Deposits</span>
      </button>
      <span class="rail-tooltip">Deposits</span>
    </div>
  <% end %>

  <%# Loans - Loan Officer, Manager %>
  <% if ["loan_officer", "manager"].include?(role) %>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="loans"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/loans') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/loans') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/loans') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125V9.75c0 .621-.504 1.125-1.125 1.125H20.25m0 0v.75c0 .414-.336.75-.75.75H3.75"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Loans</span>
      </button>
      <span class="rail-tooltip">Loans</span>
    </div>
  <% end %>

  <%# Equity - Accountant, Manager %>
  <% if ["accountant", "manager"].include?(role) %>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="equity"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/equity') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/equity') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/equity') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 21v-8.25M15.75 21v-8.25M8.25 21v-8.25M3 9l9-6 9 6m-1.5 12V10.332A48.36 48.36 0 0012 9.75c-2.551 0-5.056.2-7.5.582V21M3 21h18M12 6.75h.008v.008H12V6.75z"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Equity</span>
      </button>
      <span class="rail-tooltip">Equity</span>
    </div>
  <% end %>

  <%# Members - Teller, Loan Officer, Manager %>
  <% if ["teller", "loan_officer", "manager"].include?(role) %>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="members"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/members') || current_path.start_with?('/applications') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/members') || current_path.start_with?('/applications') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/members') || current_path.start_with?('/applications') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 002.625.372 9.337 9.337 0 004.121-.952 4.125 4.125 0 00-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 018.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0111.964-3.07M12 6.375a3.375 3.375 0 11-6.75 0 3.375 3.375 0 016.75 0zm8.25 2.25a2.625 2.625 0 11-5.25 0 2.625 2.625 0 015.25 0z"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Members</span>
      </button>
      <span class="rail-tooltip">Members</span>
    </div>
  <% end %>

  <%# Treasury - Treasurer, Manager %>
  <% if ["treasurer", "manager"].include?(role) %>
    <div class="my-2 mx-1" style="height: 1px; background: var(--border-color);"></div>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="treasury"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/treasury') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/treasury') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/treasury') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 8.25h19.5M2.25 9h19.5m-16.5 5.25h6m-6 2.25h3m-3.75 3h15a2.25 2.25 0 002.25-2.25V6.75A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25v10.5A2.25 2.25 0 004.5 19.5Z"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Treasury</span>
        <% if cash_session&.status == "open" || cash_session&.status == "balancing" %>
          <span class="absolute top-1 right-1 flex h-2.5 w-2.5">
            <span class="absolute inline-flex h-full w-full rounded-full <%= cash_session.status == 'open' ? 'bg-emerald-500' : 'bg-amber-500' %> opacity-75 animate-ping"></span>
            <span class="relative inline-flex rounded-full h-2.5 w-2.5 <%= cash_session.status == 'open' ? 'bg-emerald-500' : 'bg-amber-500' %>"></span>
          </span>
        <% end %>
      </button>
      <span class="rail-tooltip">Treasury</span>
    </div>
  <% end %>

  <%# Accounting - Accountant, Manager %>
  <% if ["accountant", "manager"].include?(role) %>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="accounting"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/accounting') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/accounting') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/accounting') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Accounting</span>
      </button>
      <span class="rail-tooltip">Accounting</span>
    </div>
  <% end %>

  <%# Reports - Manager, Accountant, Treasurer %>
  <% if ["manager", "accountant", "treasurer"].include?(role) %>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="reports"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.include?('/reports') || current_path == '/dashboard/reports' ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.include?('/reports') || current_path == '/dashboard/reports' %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.include?('/reports') || current_path == '/dashboard/reports' ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125Z"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Reports</span>
      </button>
      <span class="rail-tooltip">Reports</span>
    </div>
  <% end %>

  <%# Management - Admin, Manager %>
  <% if ["admin", "manager"].include?(role) %>
    <div class="my-2 mx-1" style="height: 1px; background: var(--border-color);"></div>
    <div class="rail-item relative">
      <button type="button"
              data-action="click->sidebar#selectRail"
              data-rail-id="management"
              class="flex flex-col items-center justify-center w-12 min-h-12 mx-auto rounded-sm transition-all duration-150 hover:bg-tertiary py-1.5"
              style="<%= current_path.start_with?('/management') ? 'background: var(--accent-dim);' : '' %>">
        <% if current_path.start_with?('/management') %>
          <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-8 rounded-r" style="background: var(--accent); box-shadow: 0 0 12px var(--accent);"></div>
        <% end %>
        <svg class="w-5 h-5 transition-transform duration-150 group-hover:scale-110" style="<%= current_path.start_with?('/management') ? 'color: var(--accent);' : 'color: var(--text-muted);' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12c0 1.268-.63 2.39-1.593 3.068a3.745 3.745 0 01-1.043 3.296 3.745 3.745 0 01-3.296 1.043A3.745 3.745 0 0112 21c-1.268 0-2.39-.63-3.068-1.593a3.746 3.746 0 01-3.296-1.043 3.745 3.745 0 01-1.043-3.296A3.745 3.745 0 013 12c0-1.268.63-2.39 1.593-3.068a3.745 3.745 0 011.043-3.296 3.746 3.746 0 013.296-1.043A3.746 3.746 0 0112 3c1.268 0 2.39.63 3.068 1.593a3.746 3.746 0 013.296 1.043 3.746 3.746 0 011.043 3.296A3.745 3.745 0 0121 12z"/>
        </svg>
        <span class="text-[10px] leading-tight text-muted text-center mt-0.5">Mgmt</span>
      </button>
      <span class="rail-tooltip">Management</span>
    </div>
  <% end %>
</nav>