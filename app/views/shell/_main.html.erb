<%= render"shell/mobile_header" %> <main class="flex-1 overflow-y-auto" style="background: var(--bg-primary);"> <div class="px-6 py-6 sm:px-8 lg:px-10"> <% if content_for?(:breadcrumbs) %> <%= yield :breadcrumbs %> <% end %> <% if flash.any? %> <div class="mb-6 space-y-2 animate-fade-in"> <% flash.each do |type, msg| %> <div class="flex items-center gap-3 rounded-sm border px-4 py-3 text-sm font-medium <%= type == 'notice' ? 'border-primary/30 bg-primary/10 text-primary-400' : 'border-red-500/30 bg-red-500/10 text-red-400' %>" data-flash-message> <% if type == 'notice' %> <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg> <% else %> <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z"/></svg> <% end %> <span class="flex-1"><%= msg %></span> <button type="button" class="opacity-60 hover:opacity-100 transition-opacity flex-shrink-0" onclick="this.parentElement.remove()"> <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg> </button> </div> <% end %> </div> <% end %> <div data-controller="turbo-frame"> <%= yield %> </div> </div> </main>