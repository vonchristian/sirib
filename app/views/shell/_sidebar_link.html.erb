<a href="<%= local_assigns[:path] %>"
   class="group flex items-center gap-3 rounded-sm px-3 py-2.5 text-sm transition-all duration-150 relative
          <%= active ? 'text-accent font-medium' : 'text-secondary hover:text-primary hover:bg-tertiary' %>"
   style="<%= active ? 'color: var(--accent); background: var(--accent-dim);' : '' %>">
  <% if active %>
    <div class="absolute left-0 top-1/2 -translate-y-1/2 w-0.5 h-5 rounded-r" style="background: var(--accent); box-shadow: 0 0 8px var(--accent);"></div>
  <% end %>
  <svg class="w-4 h-4 flex-shrink-0 transition-transform duration-150 <%= active ? '' : 'group-hover:scale-110' %>" style="<%= active ? 'color: var(--accent);' : '' %>" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
    <%= icons[local_assigns[:icon]]&.html_safe || icons["document"] %>
  </svg>
  <span class="flex-1"><%= local_assigns[:label] %></span>
  <% if local_assigns[:badge].present? %>
    <span class="text-[10px] font-semibold px-1.5 py-0.5 rounded-sm font-mono uppercase tracking-wider
          <%= local_assigns[:badge] == "OPEN" ? 'bg-emerald-500/20 text-emerald-400' : local_assigns[:badge] == "BALANCING" ? 'bg-amber-500/20 text-amber-400' : 'bg-gray-700/50 text-gray-400' %>">
      <%= local_assigns[:badge] %>
    </span>
  <% end %>
</a>