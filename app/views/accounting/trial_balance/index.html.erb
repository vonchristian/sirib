<% content_for :page_title, "Trial Balance" %>
<% content_for :page_subtitle, "As of #{@as_of_date.strftime('%B %d, %Y')}" %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="space-y-6">
  <%= turbo_stream_from "accounting_balances" %>

  <div class="flex items-center justify-between">
    <div>
      <h1 class="text-xl font-semibold text-text-primary">Trial Balance</h1>
      <p class="text-sm text-text-tertiary mt-0.5">As of <%= @as_of_date.strftime("%B %d, %Y") %></p>
    </div>
  </div>

  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900">
    <%= form_tag accounting_trial_balance_path, method: :get, data: { controller: "balance-sheet-form", turbo_frame: "_top" }, class: "flex flex-wrap items-end gap-4 px-5 py-4 sm:px-6" do %>
      <div>
        <label class="block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1">As of Date</label>
        <%= date_field_tag :as_of_date, @as_of_date, data: { action: "change->balance-sheet-form#submit" }, class: "block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
      </div>
    <% end %>
  </div>

  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900 overflow-hidden">
    <div>
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-border dark:border-gray-800">
            <th class="px-6 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500">Code</th>
            <th class="px-6 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500">Account</th>
            <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">Debits</th>
            <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">Credits</th>
            <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">Net Balance</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-gray-800">
          <% if @result[:accounts].any? %>
            <% type_headers = {
              "asset" => "ASSETS",
              "liability" => "LIABILITIES",
              "equity" => "EQUITY",
              "revenue" => "REVENUE",
              "expense" => "EXPENSES"
            } %>
            <% @result[:accounts].group_by { |l| l[:account].account_type }.each do |type, lines| %>
              <tr class="bg-surface-alt dark:bg-gray-800/40">
                <td colspan="5" class="px-6 py-2 text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500">
                  <%= type_headers[type] || type.upcase %>
                  <span class="font-normal normal-case ml-1">(<%= lines.length %>)</span>
                </td>
              </tr>
              <% lines.each do |line| %>
                <tr class="hover:bg-surface-alt/50 dark:hover:bg-gray-800/20">
                  <td class="px-6 py-2.5 text-xs font-mono text-text-tertiary dark:text-gray-400"><%= line[:account].account_code %></td>
                  <td class="px-6 py-2.5 text-sm text-text-primary dark:text-white">
                    <%= link_to line[:account].name, accounting_account_path(line[:account]), class: "hover:text-primary transition-colors" %>
                  </td>
                  <td class="px-6 py-2.5 text-right text-sm font-mono tabular-nums text-text-primary dark:text-white">
                    <%= line[:debit_cents] > 0 ? Money.new(line[:debit_cents], "PHP").format : "—" %>
                  </td>
                  <td class="px-6 py-2.5 text-right text-sm font-mono tabular-nums text-text-primary dark:text-white">
                    <%= line[:credit_cents] > 0 ? Money.new(line[:credit_cents], "PHP").format : "—" %>
                  </td>
                  <td class="px-6 py-2.5 text-right text-sm font-mono tabular-nums <%= line[:net_debit_cents] > 0 ? 'text-danger' : (line[:net_credit_cents] > 0 ? 'text-positive' : 'text-text-tertiary') %>">
                    <% if line[:net_debit_cents] > 0 %>
                      <%= Money.new(line[:net_debit_cents], "PHP").format %> Dr
                    <% elsif line[:net_credit_cents] > 0 %>
                      <%= Money.new(line[:net_credit_cents], "PHP").format %> Cr
                    <% else %>
                      —
                    <% end %>
                  </td>
                </tr>
              <% end %>
            <% end %>
          <% else %>
            <tr>
              <td colspan="5" class="px-6 py-12 text-center text-sm text-text-tertiary dark:text-gray-500">
                No entries found as of <%= @as_of_date.strftime("%B %d, %Y") %>
              </td>
            </tr>
          <% end %>
        </tbody>
        <tfoot>
          <tr class="bg-surface-alt dark:bg-gray-800/40 border-t-2 border-text-secondary dark:border-gray-500">
            <td colspan="2" class="px-6 py-3 text-sm font-semibold text-text-primary dark:text-white">Totals</td>
            <td class="px-6 py-3 text-right text-sm font-semibold font-mono tabular-nums text-danger"><%= Money.new(@result[:total_debit_cents], "PHP").format %></td>
            <td class="px-6 py-3 text-right text-sm font-semibold font-mono tabular-nums text-positive"><%= Money.new(@result[:total_credit_cents], "PHP").format %></td>
            <td class="px-6 py-3 text-right"></td>
          </tr>
        </tfoot>
      </table>
    </div>
  </div>

  <div class="flex items-center gap-3 rounded-md border px-4 py-3 text-sm <%= @result[:balanced] ? 'border-positive/20 bg-positive-50 text-positive dark:bg-emerald-900/20 dark:text-emerald-400' : 'border-danger/20 bg-danger-50 text-danger dark:bg-red-900/20 dark:text-red-400' %>">
    <% if @result[:balanced] %>
      <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
      </svg>
      <span><strong>Balanced.</strong> Total Debits (<%= Money.new(@result[:total_debit_cents], "PHP").format %>) equals Total Credits (<%= Money.new(@result[:total_credit_cents], "PHP").format %>)</span>
    <% else %>
      <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v3.75m9-.75a9 9 0 1 1-18 0 9 9 0 0 1 18 0Zm-9 3.75h.008v.008H12v-.008Z" />
      </svg>
      <span><strong>Unbalanced.</strong> Total Debits (<%= Money.new(@result[:total_debit_cents], "PHP").format %>) does not equal Total Credits (<%= Money.new(@result[:total_credit_cents], "PHP").format %>)</span>
    <% end %>
  </div>
</div>
