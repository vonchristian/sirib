<% content_for :page_title, "Balance Sheet" %>
<% content_for :page_subtitle, "As of #{@as_of_date.strftime('%B %d, %Y')}" %>

<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="space-y-6">
  <%= turbo_stream_from "accounting_balances" %>

  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900">
    <%= form_tag accounting_balance_sheet_path, method: :get, data: { controller: "balance-sheet-form", turbo_frame: "_top" }, class: "flex flex-wrap items-end gap-4 px-5 py-4 sm:px-6" do %>
      <div>
        <label class="block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1">As of Date</label>
        <%= date_field_tag :as_of_date, @as_of_date, data: { action: "change->balance-sheet-form#submit" }, class: "block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1">Compare to</label>
        <%= select_tag :comparison, options_for_select({ "None" => "none", "Prior Month" => "prior_period", "Prior Quarter" => "prior_quarter", "Prior Year" => "prior_year" }, @comparison), data: { action: "change->balance-sheet-form#submit" }, class: "block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
      </div>

      <% if @compare_date %>
        <div class="flex items-center gap-1.5 text-xs text-text-tertiary dark:text-gray-500 ml-auto">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          Comparative period: <%= @compare_date.strftime("%b %d, %Y") %>
        </div>
      <% end %>
    <% end %>
  </div>

  <% if @report.present? %>
    <% total_assets = @report[0][:total].to_f %>
    <% total_liabilities = @report.size > 1 ? @report[1][:total].to_f : 0 %>
    <% total_equity = @report.size > 2 ? @report[2][:total].to_f : 0 %>
    <% grand_total = total_assets + total_liabilities + total_equity %>
    <% if grand_total > 0 %>
      <% assets_pct = (total_assets / grand_total * 100).round(1) %>
      <% liab_pct = (total_liabilities / grand_total * 100).round(1) %>
      <% equity_pct = (total_equity / grand_total * 100).round(1) %>
      <div class="rounded-md border border-border bg-surface p-5 dark:border-gray-800 dark:bg-gray-900">
        <p class="text-xs font-semibold uppercase tracking-wider text-text-tertiary mb-4">Portfolio Composition</p>
        <div class="flex items-center gap-8">
          <div class="relative flex-shrink-0">
            <div class="h-28 w-28 rounded-full"
                 style="background: conic-gradient(#93c5fd 0% <%= assets_pct %>%,
                                                  #fcd34d <%= assets_pct %>% <%= (assets_pct + liab_pct) %>%,
                                                  #86efac <%= (assets_pct + liab_pct) %>% 100%);">
            </div>
            <div class="absolute inset-2 flex items-center justify-center rounded-full bg-surface dark:bg-gray-900">
              <span class="text-xs font-semibold text-text-tertiary">100%</span>
            </div>
          </div>
          <div class="space-y-2 text-xs">
            <div class="flex items-center gap-2">
              <span class="inline-block h-2.5 w-2.5 rounded-sm" style="background:#93c5fd"></span>
              <span class="text-text-secondary">Assets</span>
              <span class="font-medium text-text-primary tabular-nums"><%= @report[0][:total].format %></span>
              <span class="text-text-tertiary">(<%= assets_pct %>%)
            </div>
            <div class="flex items-center gap-2">
              <span class="inline-block h-2.5 w-2.5 rounded-sm" style="background:#fcd34d"></span>
              <span class="text-text-secondary">Liabilities</span>
              <span class="font-medium text-text-primary tabular-nums"><%= @report.size > 1 ? @report[1][:total].format : Money.new(0, "PHP").format %></span>
              <span class="text-text-tertiary">(<%= liab_pct %>%)
            </div>
            <div class="flex items-center gap-2">
              <span class="inline-block h-2.5 w-2.5 rounded-sm" style="background:#86efac"></span>
              <span class="text-text-secondary">Equity</span>
              <span class="font-medium text-text-primary tabular-nums"><%= @report.size > 2 ? @report[2][:total].format : Money.new(0, "PHP").format %></span>
              <span class="text-text-tertiary">(<%= equity_pct %>%)
            </div>
          </div>
        </div>
      </div>
    <% end %>
  <% end %>

  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900 overflow-hidden">
    <div>
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-border dark:border-gray-800">
            <th class="px-6 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500">Account</th>
            <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">
              <%= @as_of_date.strftime("%b %d, %Y") %>
            </th>
            <% if @compare_date %>
              <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">
                <%= @compare_date.strftime("%b %d, %Y") %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-gray-800">
          <% @report.each do |section| %>
            <%= render "section", section: section, compare: @compare_date.present? %>
          <% end %>

          <tr class="bg-surface-alt dark:bg-gray-800/40">
            <td class="px-6 py-3 text-sm font-semibold text-text-primary dark:text-white">
              Total Liabilities & Equity
            </td>
            <% if @report.size >= 2 %>
              <% total_le = @report[1..].sum(Money.new(0, "PHP")) { |s| s[:total] } %>
              <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white border-t-2 border-text-secondary dark:border-gray-500">
                <%= total_le.format %>
              </td>
              <% if @compare_date %>
                <% total_le_cmp = @report[1..].sum(Money.new(0, "PHP")) { |s| s[:total_compare] || Money.new(0, "PHP") } %>
                <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white border-t-2 border-text-secondary dark:border-gray-500">
                  <%= total_le_cmp.format %>
                </td>
              <% end %>
            <% else %>
              <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white border-t-2 border-text-secondary dark:border-gray-500">—</td>
              <% if @compare_date %>
                <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white border-t-2 border-text-secondary dark:border-gray-500">—</td>
              <% end %>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <% if @report.present? %>
    <% total_assets = @report[0][:total] %>
    <% total_le = @report[1..].sum(Money.new(0, "PHP")) { |s| s[:total] } %>
    <% if total_assets == total_le && total_assets.positive? %>
      <div class="flex items-center gap-2 rounded-md border border-positive/20 bg-positive-50 px-4 py-3 text-sm text-positive dark:bg-emerald-900/20 dark:text-emerald-400">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span>Balanced: Total Assets (<%= total_assets.format %>) equals Total Liabilities & Equity (<%= total_le.format %>)</span>
      </div>
    <% end %>
  <% end %>

  <div class="rounded-md border border-border bg-surface px-5 py-3.5 dark:border-gray-800 dark:bg-gray-900">
    <h3 class="text-[11px] font-semibold text-text-secondary dark:text-gray-400 mb-3 uppercase tracking-wider">Chart of Accounts Legend</h3>
    <div class="flex flex-wrap gap-5 text-xs text-text-tertiary dark:text-gray-400">
      <div class="flex items-center gap-2">
        <span class="inline-block h-2.5 w-2.5 rounded-sm bg-primary-100 dark:bg-primary-900/40"></span>
        <span>Asset</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-2.5 w-2.5 rounded-sm bg-warning-50 dark:bg-amber-900/40"></span>
        <span>Liability</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-2.5 w-2.5 rounded-sm bg-positive-50 dark:bg-emerald-900/40"></span>
        <span>Equity</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-2.5 w-2.5 rounded-sm bg-gray-200 dark:bg-gray-700"></span>
        <span>Contra Account (deduction)</span>
      </div>
    </div>
  </div>
</div>
