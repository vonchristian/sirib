<% content_for :page_title, "Balance Sheet" %>
<% content_for :page_subtitle, "As of #{@as_of_date.strftime('%B %d, %Y')}" %>

<div class="animate-fade-in space-y-6">
  <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-900 sm:p-6">
    <%= form_tag accounting_balance_sheet_path, method: :get, data: { controller: "balance-sheet-form", turbo_frame: "_top" }, class: "flex flex-wrap items-end gap-4" do %>
      <div>
        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">As of Date</label>
        <%= date_field_tag :as_of_date, @as_of_date, data: { action: "change->balance-sheet-form#submit" }, class: "rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
      </div>

      <div>
        <label class="block text-xs font-medium text-gray-500 dark:text-gray-400 mb-1">Compare to</label>
        <%= select_tag :comparison, options_for_select({ "None" => "none", "Prior Month" => "prior_period", "Prior Quarter" => "prior_quarter", "Prior Year" => "prior_year" }, @comparison), data: { action: "change->balance-sheet-form#submit" }, class: "rounded-lg border border-gray-300 bg-white px-3 py-2 text-sm text-gray-900 focus:border-blue-500 focus:ring-1 focus:ring-blue-500 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
      </div>

      <% if @compare_date %>
        <div class="flex items-center gap-1.5 text-xs text-gray-400 dark:text-gray-500 ml-auto">
          <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          Comparative period: <%= @compare_date.strftime("%b %d, %Y") %>
        </div>
      <% end %>
    <% end %>
  </div>

  <div class="rounded-xl border border-gray-200 bg-white shadow-sm dark:border-gray-700 dark:bg-gray-900 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-gray-200 bg-gray-50 dark:border-gray-700 dark:bg-gray-800/50">
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400 w-1/2">Account</th>
            <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
              <%= @as_of_date.strftime("%b %d, %Y") %>
            </th>
            <% if @compare_date %>
              <th class="px-6 py-3 text-right text-xs font-semibold uppercase tracking-wider text-gray-500 dark:text-gray-400">
                <%= @compare_date.strftime("%b %d, %Y") %>
              </th>
            <% end %>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100 dark:divide-gray-800">
          <% @report.each do |section| %>
            <%= render "section", section: section, compare: @compare_date.present? %>
          <% end %>

          <tr class="bg-gray-50 dark:bg-gray-800/50">
            <td class="px-6 py-3 text-sm font-bold text-gray-900 dark:text-white">
              Total Liabilities & Equity
            </td>
            <% if @report.size >= 2 %>
              <% total_le = @report[1..].sum(Money.new(0, "PHP")) { |s| s[:total] } %>
              <td class="px-6 py-3 text-right text-sm font-bold tabular-nums text-gray-900 dark:text-white border-t-2 border-gray-400 dark:border-gray-500">
                <%= total_le.format %>
              </td>
              <% if @compare_date %>
                <% total_le_cmp = @report[1..].sum(Money.new(0, "PHP")) { |s| s[:total_compare] || Money.new(0, "PHP") } %>
                <td class="px-6 py-3 text-right text-sm font-bold tabular-nums text-gray-900 dark:text-white border-t-2 border-gray-400 dark:border-gray-500">
                  <%= total_le_cmp.format %>
                </td>
              <% end %>
            <% else %>
              <td class="px-6 py-3 text-right text-sm font-bold tabular-nums text-gray-900 dark:text-white border-t-2 border-gray-400 dark:border-gray-500">—</td>
              <% if @compare_date %>
                <td class="px-6 py-3 text-right text-sm font-bold tabular-nums text-gray-900 dark:text-white border-t-2 border-gray-400 dark:border-gray-500">—</td>
              <% end %>
            <% end %>
          </tr>
        </tbody>
      </table>
    </div>
  </div>

  <% if @report.present? %>
    <% total_assets = @report[0][:total] %>
    <% total_le = @report[1..].sum(Money.new(0, "PHP")) { |s| s[:total] } %>
    <% if total_assets == total_le && total_assets.positive? %>
      <div class="flex items-center gap-2 rounded-lg bg-emerald-50 px-4 py-3 text-sm text-emerald-700 dark:bg-emerald-900/20 dark:text-emerald-400">
        <svg class="h-5 w-5 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
        </svg>
        <span>Balanced: Total Assets (<%= total_assets.format %>) equals Total Liabilities & Equity (<%= total_le.format %>)</span>
      </div>
    <% end %>
  <% end %>

  <div class="rounded-xl border border-gray-200 bg-white p-4 shadow-sm dark:border-gray-700 dark:bg-gray-900">
    <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-3">Chart of Accounts Legend</h3>
    <div class="flex flex-wrap gap-6 text-xs text-gray-500 dark:text-gray-400">
      <div class="flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded bg-blue-100 dark:bg-blue-900/40"></span>
        <span>Asset</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded bg-amber-100 dark:bg-amber-900/40"></span>
        <span>Liability</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded bg-emerald-100 dark:bg-emerald-900/40"></span>
        <span>Equity</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="inline-block h-3 w-3 rounded bg-gray-200 dark:bg-gray-700"></span>
        <span>Contra Account (deduction)</span>
      </div>
    </div>
  </div>
</div>
