<tr class="hover:bg-gray-50 dark:hover:bg-gray-800/20">
  <td class="px-6 py-2 text-sm font-medium text-gray-700 dark:text-gray-300" style="padding-left: <%= 40 + depth * 48 %>px">
    <span class="text-xs text-gray-400 dark:text-gray-500 mr-1.5"><%= group[:ledger].account_code %></span>
    <%= group[:ledger].name %>
  </td>
  <td class="px-6 py-2 text-right text-sm font-medium tabular-nums text-gray-700 dark:text-gray-300">
    <%= group[:total].format %>
  </td>
  <% if compare %>
    <td class="px-6 py-2 text-right text-sm font-medium tabular-nums text-gray-700 dark:text-gray-300">
      <%= group[:total_compare]&.format || "—" %>
    </td>
  <% end %>
</tr>

<% group[:accounts].each do |row| %>
  <tr class="<%= row[:account].contra ? 'text-gray-400 dark:text-gray-500' : 'text-gray-500 dark:text-gray-400' %>">
    <td class="px-6 py-1.5 text-xs" style="padding-left: <%= 80 + depth * 32 %>px">
      <%= row[:account].account_code %>
      <span class="ml-1"><%= row[:account].name %></span>
      <% if row[:account].contra %>
        <span class="ml-1.5 inline-flex items-center rounded-full bg-gray-100 px-1.5 py-0.5 text-[10px] font-medium text-gray-500 dark:bg-gray-800 dark:text-gray-400">contra</span>
      <% end %>
    </td>
    <td class="px-6 py-1.5 text-right text-xs tabular-nums">
      <%= row[:account].contra ? "(#{row[:balance].abs.format})" : row[:balance].format %>
    </td>
    <% if compare %>
      <td class="px-6 py-1.5 text-right text-xs tabular-nums">
        <% if row[:balance_compare] %>
          <%= row[:account].contra ? "(#{row[:balance_compare].abs.format})" : row[:balance_compare].format %>
        <% else %>
          —
        <% end %>
      </td>
    <% end %>
  </tr>
<% end %>

<% group[:children].each do |child| %>
  <%= render "ledger_group", group: child, compare: compare, depth: depth + 1 %>
<% end %>
