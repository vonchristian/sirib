<tr class="hover:bg-surface-alt /30 transition-colors"> 
  <td class="px-6 py-2 text-sm font-medium text-text-primary" style="padding-left: <%= 40 + depth * 48 %>px"> <span class="text-xs text-text-tertiary mr-1.5"><%= group[:ledger].account_code %></span> <%= group[:ledger].name %> </td>
 
  <td class="px-6 py-2 text-right text-sm font-medium tabular-nums text-text-primary"> <%= group[:total].format %> </td>
 <% if compare %> 
    <td class="px-6 py-2 text-right text-sm font-medium tabular-nums text-text-primary"> <%= group[:total_compare]&.format ||"—" %> </td>
 <% end %> </tr>
 <% group[:accounts].each do |row| %> 
  <tr class="<%= row[:account].contra ? 'text-text-tertiary ' : 'text-text-secondary ' %>"> 
    <td class="px-6 py-1.5 text-xs" style="padding-left: <%= 80 + depth * 32 %>px"> <span class="tabular-nums"><%= row[:account].account_code %></span> <span class="ml-1"><%= row[:account].name %></span> <% if row[:account].contra %> <span class="ml-1.5 inline-flex items-center rounded-full bg-surface-alt px-1.5 py-0.5 text-[10px] font-medium text-text-tertiary">contra</span> <% end %> </td>
 
    <td class="px-6 py-1.5 text-right text-xs tabular-nums"> <%= row[:account].contra ? "(#{row[:balance].abs.format})" : row[:balance].format %> </td>
 <% if compare %> 
      <td class="px-6 py-1.5 text-right text-xs tabular-nums"> <% if row[:balance_compare] %> <%= row[:account].contra ? "(#{row[:balance_compare].abs.format})" : row[:balance_compare].format %> <% else %> — <% end %> </td>
 <% end %> </tr>
 <% end %> <% group[:children].each do |child| %> <%= render"ledger_group", group: child, compare: compare, depth: depth + 1 %> <% end %> 
