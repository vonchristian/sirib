<% content_for :page_title, "Journal Entry ##{@entry.reference_number}" %>
<% content_for :page_subtitle, "Accounting Entry Details" %>

<div class="flex items-center justify-between mb-6">
  <div>
    <nav class="text-xs text-text-tertiary mb-1">
      <%= link_to "Journal Entries", accounting_journal_entries_path, class: "hover:text-primary" %>
      <span class="mx-1">/</span>
      <span class="text-text-secondary"><%= @entry.reference_number %></span>
    </nav>
  </div>
  <div class="flex items-center gap-2">
    <% if @entry.reversible? %>
      <%= button_to "Reverse Entry", reverse_accounting_journal_entry_path(@entry),
                    method: :post,
                    class: "rounded-md border border-danger px-4 py-2 text-xs font-semibold text-danger hover:bg-danger/10 transition-colors",
                    data: { turbo_confirm: "Are you sure you want to reverse this entry?" } %>
    <% end %>
    <%= link_to "Back", accounting_journal_entries_path, class: "rounded-md border border-border bg-surface px-4 py-2 text-xs font-semibold text-text-secondary hover:bg-surface-alt transition-colors" %>
  </div>
</div>

<div class="grid grid-cols-3 gap-6">
  <div class="col-span-2 space-y-6">
    <div class="rounded-lg border border-border bg-surface p-6">
      <div class="flex items-start justify-between mb-4">
        <div>
          <h2 class="text-lg font-semibold text-text-primary"><%= @entry.description %></h2>
          <p class="text-xs text-text-tertiary mt-1 font-mono">
            Reference: <span class="text-primary"><%= @entry.reference_number %></span>
          </p>
        </div>
        <div class="flex items-center gap-2">
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= status_class(@entry.status) %>">
            <%= @entry.status.titleize %>
          </span>
          <span class="inline-flex items-center px-3 py-1 rounded-full text-xs font-medium <%= entry_type_class(@entry.entry_type) %>">
            <%= @entry.entry_type.titleize %>
          </span>
        </div>
      </div>

      <div class="grid grid-cols-4 gap-4 text-xs text-text-secondary mb-6">
        <div>
          <p class="font-medium text-text-tertiary">Posted At</p>
          <p class="text-text-primary"><%= l(@entry.posted_at, format: :long) %></p>
        </div>
        <div>
          <p class="font-medium text-text-tertiary">Branch</p>
          <p class="text-text-primary"><%= @entry.branch&.name || "—" %></p>
        </div>
        <div>
          <p class="font-medium text-text-tertiary">Source Module</p>
          <p class="text-text-primary"><%= @entry.source_module.titleize.gsub("_", " ") %></p>
        </div>
        <div>
          <p class="font-medium text-text-tertiary">Template</p>
          <p class="text-text-primary"><%= @entry_template&.name || "Manual Entry" %></p>
        </div>
      </div>

      <h3 class="text-xs font-semibold text-text-primary uppercase tracking-wider mb-3">Entry Lines</h3>
      <div class="overflow-hidden rounded-lg border border-border">
        <table class="w-full text-sm">
          <thead>
            <tr class="bg-surface-alt text-left text-xs text-text-tertiary uppercase tracking-wider">
              <th class="px-4 py-3 font-medium">Account</th>
              <th class="px-4 py-3 font-medium">Direction</th>
              <th class="px-4 py-3 font-medium text-right">Amount</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-border">
            <% @entry.amount_lines.each do |line| %>
              <tr class="hover:bg-surface-alt transition-colors">
                <td class="px-4 py-3 text-text-primary">
                  <div class="flex items-center gap-2">
                    <span class="font-mono text-xs text-text-tertiary"><%= line.account.account_code %></span>
                    <span><%= line.account.name %></span>
                  </div>
                </td>
                <td class="px-4 py-3">
                  <span class="<%= line.debit? ? "text-danger" : "text-success" %> font-medium"><%= line.amount_type.titleize %></span>
                </td>
                <td class="px-4 py-3 text-right font-mono <%= line.debit? ? "text-danger" : "text-success" %>">
                  <%= number_to_currency(line.amount_cents.to_f / 100, unit: "₱") %>
                </td>
              </tr>
            <% end %>
          </tbody>
          <tfoot class="bg-surface-alt text-xs font-semibold">
            <tr>
              <td class="px-4 py-3 text-text-primary" colspan="2">Totals</td>
              <td class="px-4 py-3 text-right font-mono">
                <span class="text-danger">Dr: <%= number_to_currency(@entry.amount_lines.debit.total.to_f / 100, unit: "₱") %></span>
                <span class="mx-2">|</span>
                <span class="text-success">Cr: <%= number_to_currency(@entry.amount_lines.credit.total.to_f / 100, unit: "₱") %></span>
              </td>
            </tr>
          </tfoot>
        </table>
      </div>
    </div>

    <% if @entry.reversal_of || @entry.reversed_entry %>
      <div class="rounded-lg border border-border bg-surface p-6">
        <h3 class="text-xs font-semibold text-text-primary uppercase tracking-wider mb-3">Reversal Information</h3>
        <div class="space-y-3">
          <% if @entry.reversal_of %>
            <div class="flex items-center justify-between p-3 bg-surface-alt rounded-lg">
              <div>
                <p class="text-xs text-text-tertiary">Reversed Entry</p>
                <p class="text-sm font-mono text-text-primary"><%= @entry.reversal_of.reference_number %></p>
              </div>
              <%= link_to "View Original", accounting_journal_entry_path(@entry.reversal_of), class: "text-xs text-primary hover:text-primary-700" %>
            </div>
          <% end %>
          <% if @entry.reversed_entry %>
            <div class="flex items-center justify-between p-3 bg-surface-alt rounded-lg">
              <div>
                <p class="text-xs text-text-tertiary">Reversed By</p>
                <p class="text-sm font-mono text-text-primary"><%= @entry.reversed_entry.reference_number %></p>
              </div>
              <%= link_to "View Reversal", accounting_journal_entry_path(@entry.reversed_entry), class: "text-xs text-primary hover:text-primary-700" %>
            </div>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>

  <div class="space-y-6">
    <div class="rounded-lg border border-border bg-surface p-4" data-controller="audit-trail">
      <h3 class="text-xs font-semibold text-text-primary uppercase tracking-wider mb-3 flex items-center gap-2" data-testid="audit-trail">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/>
        </svg>
        Audit Trail
      </h3>
      <div class="space-y-3">
        <div class="flex items-start gap-3">
          <div class="mt-1 w-2 h-2 rounded-full bg-green-500"></div>
          <div class="flex-1">
            <p class="text-xs font-medium text-text-primary">Created</p>
            <p class="text-xs text-text-tertiary"><%= l(@entry.created_at, format: :long) %></p>
            <p class="text-xs text-text-tertiary"><%= @entry.created_by&.full_name || "System" %></p>
          </div>
        </div>

        <% if @entry.updated_at != @entry.created_at %>
          <div class="flex items-start gap-3">
            <div class="mt-1 w-2 h-2 rounded-full bg-blue-500"></div>
            <div class="flex-1">
              <p class="text-xs font-medium text-text-primary">Updated</p>
              <p class="text-xs text-text-tertiary"><%= l(@entry.updated_at, format: :long) %></p>
            </div>
          </div>
        <% end %>

        <% if @entry.reversed_at %>
          <div class="flex items-start gap-3">
            <div class="mt-1 w-2 h-2 rounded-full bg-red-500"></div>
            <div class="flex-1">
              <p class="text-xs font-medium text-text-primary">Reversed</p>
              <p class="text-xs text-text-tertiary"><%= l(@entry.reversed_at, format: :long) %></p>
              <p class="text-xs text-text-tertiary">Reason: <%= @entry.description %></p>
            </div>
          </div>
        <% end %>

        <% if @entry.posted_at && @entry.created_at != @entry.posted_at %>
          <div class="flex items-start gap-3">
            <div class="mt-1 w-2 h-2 rounded-full bg-purple-500"></div>
            <div class="flex-1">
              <p class="text-xs font-medium text-text-primary">Posted</p>
              <p class="text-xs text-text-tertiary"><%= l(@entry.posted_at, format: :long) %></p>
            </div>
          </div>
        <% end %>
      </div>

      <div class="mt-4 pt-4 border-t border-border">
        <p class="text-xs text-text-tertiary mb-2">Entry ID</p>
        <p class="text-xs font-mono text-text-secondary"><%= @entry.id %></p>
      </div>
    </div>

    <div class="rounded-lg border border-border bg-surface p-4">
      <h3 class="text-xs font-semibold text-text-primary uppercase tracking-wider mb-3">Quick Actions</h3>
      <div class="space-y-2">
        <button type="button"
                onclick="window.print()"
                class="w-full flex items-center gap-2 rounded-md border border-border bg-surface-alt px-3 py-2 text-xs text-text-secondary hover:bg-surface transition-colors">
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.052-.72.096m.72-.096a42.415 42.415 0 0110.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.052.72.096m-.72-.096L17.66 18m0 0l.229 2.523a1.125 1.125 0 01-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0021 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 00-1.913-.247M6.34 18H5.25A2.25 2.25 0 013 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 011.913-.247m10.5 0a48.536 48.536 0 00-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5zm-3 0h.008v.008H15V10.5z"/>
          </svg>
          Print Entry
        </button>
        <%= link_to accounting_journal_entries_path(format: :csv, start_date: @entry.posted_at.to_date, end_date: @entry.posted_at.to_date),
                    class: "w-full flex items-center gap-2 rounded-md border border-border bg-surface-alt px-3 py-2 text-xs text-text-secondary hover:bg-surface transition-colors" do %>
          <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75V16.5M12 12l-3-3m0 0l3 3m-3-3v9"/>
          </svg>
          Export CSV
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Helper methods for status classes %>
<% def status_class(status) %>
  <% case status %>
  <% when "posted" then "bg-green-100 text-green-800" %>
  <% when "pending" then "bg-yellow-100 text-yellow-800" %>
  <% when "reversed" then "bg-red-100 text-red-800" %>
  <% else "bg-gray-100 text-gray-800" %>
  <% end %>
<% end %>

<%# Helper methods for entry type classes %>
<% def entry_type_class(type) %>
  <% case type %>
  <% when "manual" then "bg-blue-100 text-blue-800" %>
  <% when "system" then "bg-purple-100 text-purple-800" %>
  <% when "interest" then "bg-amber-100 text-amber-800" %>
  <% when "fees" then "bg-orange-100 text-orange-800" %>
  <% when "reversal" then "bg-red-100 text-red-800" %>
  <% when "adjustment" then "bg-indigo-100 text-indigo-800" %>
  <% else "bg-gray-100 text-gray-800" %>
  <% end %>
<% end %>