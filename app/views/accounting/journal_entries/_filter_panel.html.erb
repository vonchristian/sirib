<div class="w-72 flex-shrink-0" data-controller="journal-filter">
  <div class="bg-surface rounded-lg border border-border p-4 sticky top-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-text-primary">Filters</h3>
      <button type="button"
              data-action="journal-filter#reset"
              class="text-xs text-text-tertiary hover:text-text-secondary transition-colors">
        Reset
      </button>
    </div>

    <%= form_tag accounting_journal_entries_path,
                  method: :get,
                  data: { journal_filter_target: "form", turbo_frame: "entries_table" },
                  class: "space-y-4" do %>

      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Date Range</label>
        <div class="grid grid-cols-2 gap-2">
          <input type="date"
                 name="start_date"
                 value="<%= params[:start_date] || 1.month.ago.to_date.iso8601 %>"
                 data-testid="start-date"
                 class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                 data-journal-filter-target="startDate"
                 onchange="this.form.requestSubmit()">
          <input type="date"
                 name="end_date"
                 value="<%= params[:end_date] || Date.current.iso8601 %>"
                 data-testid="end-date"
                 class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                 data-journal-filter-target="endDate"
                 onchange="this.form.requestSubmit()">
        </div>
      </div>

      <% if local_assigns[:branches].present? %>
        <div>
          <label class="block text-xs font-medium text-text-secondary mb-1">Branch</label>
          <select name="branch_id"
                  data-testid="branch-filter"
                  class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                  onchange="this.form.requestSubmit()">
            <option value="">All Branches</option>
            <% branches.each do |branch| %>
              <option value="<%= branch.id %>" <%= params[:branch_id].to_i == branch.id ? "selected" : "" %>>
                <%= branch.name %>
              </option>
            <% end %>
          </select>
        </div>
      <% end %>

      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Entry Type</label>
        <select name="entry_type"
                class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                onchange="this.form.requestSubmit()">
          <option value="">All Types</option>
          <% Accounting::Entry.entry_types.keys.each do |type| %>
            <option value="<%= type %>" <%= params[:entry_type] == type ? "selected" : "" %>>
              <%= type.titleize %>
            </option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Status</label>
        <select name="status"
                class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                onchange="this.form.requestSubmit()">
          <option value="">All Statuses</option>
          <% Accounting::Entry.statuses.keys.each do |status| %>
            <option value="<%= status %>" <%= params[:status] == status ? "selected" : "" %>>
              <%= status.titleize %>
            </option>
          <% end %>
        </select>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Source Module</label>
        <select name="source_module"
                class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                onchange="this.form.requestSubmit()">
          <option value="">All Sources</option>
          <% Accounting::Entry.source_modules.keys.each do |module_name| %>
            <option value="<%= module_name %>" <%= params[:source_module] == module_name ? "selected" : "" %>>
              <%= module_name.titleize.gsub("_", " ") %>
            </option>
          <% end %>
        </select>
      </div>

      <% if local_assigns[:accounts].present? %>
        <div>
          <label class="block text-xs font-medium text-text-secondary mb-1">Account</label>
          <select name="account_id"
                  class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                  onchange="this.form.requestSubmit()">
            <option value="">All Accounts</option>
            <% accounts.each do |account| %>
              <option value="<%= account.id %>" <%= params[:account_id].to_i == account.id ? "selected" : "" %>>
                <%= account.name %> (<%= account.account_code %>)
              </option>
            <% end %>
          </select>
        </div>
      <% end %>

      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Amount Range</label>
        <div class="grid grid-cols-2 gap-2">
          <input type="number"
                 name="amount_min"
                 value="<%= params[:amount_min] %>"
                 placeholder="Min"
                 class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none">
          <input type="number"
                 name="amount_max"
                 value="<%= params[:amount_max] %>"
                 placeholder="Max"
                 class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none">
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-text-secondary mb-1">Reference Number</label>
        <input type="text"
               name="reference_number"
               value="<%= params[:reference_number] %>"
               placeholder="Search reference..."
               class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none">
      </div>

      <% if local_assigns[:users].present? %>
        <div>
          <label class="block text-xs font-medium text-text-secondary mb-1">Created By</label>
          <select name="created_by_id"
                  class="w-full rounded-md border border-border bg-surface-alt py-1.5 px-2 text-xs text-text-primary focus:border-primary focus:ring-1 focus:ring-primary outline-none"
                  onchange="this.form.requestSubmit()">
            <option value="">All Users</option>
            <% users.each do |user| %>
              <option value="<%= user.id %>" <%= params[:created_by_id].to_i == user.id ? "selected" : "" %>>
                <%= user.full_name || user.email_address %>
              </option>
            <% end %>
          </select>
        </div>
      <% end %>

      <div class="flex items-center gap-2">
        <input type="checkbox"
               name="has_attachments"
               id="has_attachments"
               value="true"
               <%= params[:has_attachments] == "true" ? "checked" : "" %>
               class="rounded border-border bg-surface-alt text-primary focus:ring-primary"
               onchange="this.form.requestSubmit()">
        <label for="has_attachments" class="text-xs text-text-secondary">Has Attachments</label>
      </div>

      <div class="flex items-center gap-2">
        <input type="checkbox"
               name="inter_branch"
               id="inter_branch"
               value="true"
               <%= params[:inter_branch] == "true" ? "checked" : "" %>
               class="rounded border-border bg-surface-alt text-primary focus:ring-primary"
               onchange="this.form.requestSubmit()">
        <label for="inter_branch" class="text-xs text-text-secondary">Inter-branch</label>
      </div>

      <div class="flex gap-2 pt-2">
        <button type="submit"
                data-testid="apply-filters"
                class="flex-1 rounded-md bg-primary px-3 py-1.5 text-xs font-semibold text-white hover:bg-primary-700 transition-colors">
          Apply Filters
        </button>
      </div>

      <% if local_assigns[:saved_filters].present? %>
        <div class="border-t border-border pt-3">
          <div class="flex items-center justify-between mb-2">
            <span class="text-xs font-medium text-text-secondary">Saved Filters</span>
            <button type="button"
                    data-action="click->journal-filter#toggleSavePanel"
                    class="text-xs text-primary hover:text-primary-700">
              + Save
            </button>
          </div>

          <div data-journal-filter-target="savePanel" class="hidden mb-3">
            <div class="flex gap-2">
              <input type="text"
                     name="filter_name"
                     placeholder="Filter name..."
                     class="flex-1 rounded-md border border-border bg-surface-alt py-1 px-2 text-xs text-text-primary focus:border-primary outline-none">
              <button type="button"
                      data-action="click->journal-filter#saveFilter"
                      class="rounded-md bg-primary px-2 py-1 text-xs font-semibold text-white hover:bg-primary-700">
                Save
              </button>
            </div>
            <div class="mt-2 flex items-center gap-2">
              <input type="checkbox" name="is_shared" id="filter_is_shared" class="rounded border-border">
              <label for="filter_is_shared" class="text-xs text-text-tertiary">Share with team</label>
            </div>
          </div>

          <div id="saved-filters-list">
            <%= render "accounting/journal_entries/saved_filters_list", filters: saved_filters %>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
</div>