<%= turbo_frame_tag "entry_detail" do %>
  <div class="bg-surface rounded-lg border border-border p-4 h-fit sticky top-4">
    <div class="flex items-center justify-between mb-4">
      <h3 class="text-sm font-semibold text-text-primary">Entry Details</h3>
      <button type="button"
              data-action="click->journal-entries#clearDetail"
              class="p-1 text-text-tertiary hover:text-text-secondary transition-colors">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
        </svg>
      </button>
    </div>

    <div class="space-y-4">
      <div>
        <p class="text-xs text-text-tertiary">Reference</p>
        <p class="text-sm font-mono text-primary"><%= @entry.reference_number %></p>
      </div>

      <div>
        <p class="text-xs text-text-tertiary">Description</p>
        <p class="text-sm text-text-primary"><%= @entry.description %></p>
      </div>

      <div class="grid grid-cols-2 gap-3">
        <div>
          <p class="text-xs text-text-tertiary">Status</p>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= status_class(@entry.status) %>">
            <%= @entry.status.titleize %>
          </span>
        </div>
        <div>
          <p class="text-xs text-text-tertiary">Type</p>
          <span class="inline-flex items-center px-2 py-0.5 rounded text-xs font-medium <%= entry_type_class(@entry.entry_type) %>">
            <%= @entry.entry_type.titleize %>
          </span>
        </div>
      </div>

      <div>
        <p class="text-xs text-text-tertiary">Branch</p>
        <p class="text-sm text-text-primary"><%= @entry.branch&.name || "—" %></p>
      </div>

      <div>
        <p class="text-xs text-text-tertiary">Source</p>
        <p class="text-sm text-text-primary"><%= @entry.source_module.titleize.gsub("_", " ") %></p>
      </div>

      <div>
        <p class="text-xs text-text-tertiary">Posted</p>
        <p class="text-sm text-text-primary"><%= l(@entry.posted_at, format: :short) %></p>
      </div>

      <div class="border-t border-border pt-4">
        <p class="text-xs text-text-tertiary mb-2">Amount Lines</p>
        <div class="space-y-2 max-h-48 overflow-y-auto">
          <% @entry.amount_lines.each do |line| %>
            <div class="flex items-center justify-between text-xs">
              <span class="text-text-secondary truncate flex-1"><%= line.account.name %></span>
              <span class="<%= line.debit? ? 'text-danger' : 'text-success' %> font-mono ml-2">
                <%= line.debit? ? 'DR' : 'CR' %> <%= number_to_currency(line.amount_cents.to_f / 100, unit: "₱") %>
              </span>
            </div>
          <% end %>
        </div>
        <div class="flex justify-between text-xs font-semibold mt-2 pt-2 border-t border-border">
          <span class="text-danger">DR: <%= number_to_currency(@entry.amount_lines.debit.total.to_f / 100, unit: "₱") %></span>
          <span class="text-success">CR: <%= number_to_currency(@entry.amount_lines.credit.total.to_f / 100, unit: "₱") %></span>
        </div>
      </div>

      <div class="flex gap-2 pt-2">
        <%= link_to "View Full Details",
                    accounting_journal_entry_path(@entry),
                    class: "flex-1 rounded-md bg-primary px-3 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors text-center" %>
      </div>
    </div>
  </div>
<% end %>

