<div class="space-y-1 max-h-40 overflow-y-auto">
  <% filters.each do |filter| %>
    <div class="flex items-center justify-between group">
      <%= link_to accounting_journal_entries_path(filter.apply),
                  class: "flex-1 text-xs px-2 py-1 rounded hover:bg-surface-alt transition-colors truncate #{filter.is_default? ? 'text-primary font-medium' : 'text-text-secondary'}" do %>
        <span class="truncate"><%= filter.name %></span>
        <% if filter.is_default? %>
          <span class="ml-1 text-[10px] text-primary">(Default)</span>
        <% end %>
      <% end %>
      <% if filter.user == Current.user || Current.user.admin? %>
        <%= button_to accounting_journal_entry_path(filter, format: :turbo_stream),
                      method: :delete,
                      form: { data: { turbo_confirm: "Delete this filter?" } },
                      class: "hidden group-hover:block p-1 text-text-tertiary hover:text-danger" do %>
          <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        <% end %>
      <% end %>
    </div>
  <% end %>
  <% if filters.empty? %>
    <p class="text-xs text-text-tertiary px-2 py-1">No saved filters</p>
  <% end %>
</div>