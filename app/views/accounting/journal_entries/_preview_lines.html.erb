<%= turbo_frame_tag "preview" do %>
  <div class="mt-6 rounded-lg border border-border bg-surface p-6">
    <h3 class="text-sm font-semibold text-text-primary mb-3">Preview</h3>

    <div class="overflow-hidden rounded-lg border border-border">
      <table class="w-full text-sm">
        <thead>
          <tr class="bg-surface-alt text-left text-xs text-text-tertiary uppercase tracking-wider">
            <th class="px-4 py-2 font-medium">Account</th>
            <th class="px-4 py-2 font-medium">Direction</th>
            <th class="px-4 py-2 font-medium text-right">Amount</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border">
          <% lines.each do |line| %>
            <tr class="hover:bg-surface-alt transition-colors">
              <td class="px-4 py-2 text-text-primary"><%= line[:account].name %></td>
              <td class="px-4 py-2">
                <span class="<%= line[:direction] == "debit" ? "text-danger" : "text-success" %>"><%= line[:direction].titleize %></span>
              </td>
              <td class="px-4 py-2 text-right font-mono"><%= number_to_currency(line[:amount_cents].to_f / 100, unit: "₱") %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% total_debit = lines.select { |l| l[:direction] == "debit" }.sum { |l| l[:amount_cents] } %>
    <% total_credit = lines.select { |l| l[:direction] == "credit" }.sum { |l| l[:amount_cents] } %>
    <p class="text-xs text-text-tertiary mt-2 text-right">
      Debit: <%= number_to_currency(total_debit.to_f / 100, unit: "₱") %> |
      Credit: <%= number_to_currency(total_credit.to_f / 100, unit: "₱") %>
    </p>

    <%= form_tag accounting_journal_entries_path, method: :post, class: "mt-4" do %>
      <%= hidden_field_tag :template_id, params[:template_id] %>
      <%= hidden_field_tag :amount, params[:amount] %>
      <%= submit_tag "Confirm & Post", class: "rounded-md bg-primary px-4 py-2 text-xs font-semibold text-white hover:bg-primary-700 transition-colors cursor-pointer",
           data: { turbo_confirm: "Are you sure you want to post this entry?" } %>
    <% end %>
  </div>
<% end %>
