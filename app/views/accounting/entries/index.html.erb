<% content_for :page_title, "Journal Entries" %>
<% content_for :page_subtitle, "Browse, search, and export entries" %>

<div class="space-y-6" data-controller="entries-filter">
  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900">
    <%= form_tag accounting_entries_path, method: :get, class: "px-5 py-4 sm:px-6 space-y-4" do %>
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-5">
        <div class="sm:col-span-1">
          <%= label_tag :q, "Search", class: "block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1" %>
          <%= text_field_tag :q, params[:q], placeholder: "Description or reference...", data: { action: "input->entries-filter#submitDelayed" }, class: "block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
        </div>
        <div>
          <%= label_tag :from_date, "From", class: "block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1" %>
          <%= date_field_tag :from_date, params[:from_date], data: { action: "change->entries-filter#submit" }, class: "block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
        </div>
        <div>
          <%= label_tag :to_date, "To", class: "block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1" %>
          <%= date_field_tag :to_date, params[:to_date], data: { action: "change->entries-filter#submit" }, class: "block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200" %>
        </div>
        <div class="flex items-end gap-2">
          <%= link_to "Clear", accounting_entries_path, class: "rounded-md border border-border px-3 py-1.5 text-sm font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400" %>
        </div>
        <div class="flex items-end justify-end">
          <%= link_to new_accounting_entry_path, class: "rounded-md bg-primary px-3 py-1.5 text-sm font-medium text-white hover:bg-primary-600 transition-colors inline-flex items-center gap-1.5" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            New Entry
          <% end %>
        </div>
      </div>

      <div class="flex flex-wrap gap-2">
        <% periods = [
          ["Today", Date.current],
          ["This Week", Date.current.beginning_of_week],
          ["This Month", Date.current.beginning_of_month],
          ["This Quarter", Date.current.beginning_of_quarter],
          ["This Year", Date.current.beginning_of_year],
        ] %>
        <% periods.each do |label, date| %>
          <%= link_to label, accounting_entries_path(from_date: date, to_date: Date.current, q: params[:q]), class: "rounded-full border border-border px-3 py-1 text-xs font-medium text-text-secondary hover:bg-primary/10 hover:border-primary/30 transition-colors #{'bg-primary/10 border-primary/30 text-primary' if params[:from_date] == date.to_s && params[:to_date] == Date.current.to_s && params[:q].blank?} dark:border-gray-600 dark:text-gray-400" %>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="flex items-center justify-between">
    <p class="text-sm text-text-secondary dark:text-gray-400">
      <%= @pagy.count %> entries found
    </p>
    <div class="flex items-center gap-3">
      <%= link_to accounting_entries_path(format: :csv, q: params[:q], from_date: params[:from_date], to_date: params[:to_date]), class: "inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400" do %>
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 16.5v2.25A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75V16.5M16.5 12 12 16.5m0 0L7.5 12m4.5 4.5V3"/></svg>
        CSV
      <% end %>
      <button onclick="window.print()" class="inline-flex items-center gap-1.5 rounded-md border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400">
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z"/></svg>
        Print
      </button>
    </div>
  </div>

  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900 overflow-hidden">
    <table class="min-w-full text-sm">
      <thead>
        <tr class="border-b border-border dark:border-gray-800">
          <th class="px-5 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-28">Date</th>
          <th class="px-5 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">Reference</th>
          <th class="px-5 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500">Description</th>
          <th class="px-5 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-36">Debit</th>
          <th class="px-5 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-36">Credit</th>
          <th class="px-5 py-3 text-center text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-20"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border dark:divide-gray-800">
        <% if @entries.any? %>
          <% @entries.each do |entry| %>
            <% debit_total = entry.debit_amount_lines.sum(:amount_cents) %>
            <% credit_total = entry.credit_amount_lines.sum(:amount_cents) %>
            <tr data-href="<%= accounting_entry_path(entry) %>" data-action="click->entries-filter#visitRow" class="hover:bg-surface-alt dark:hover:bg-gray-800/30 transition-colors cursor-pointer">
              <td class="px-5 py-3 text-xs text-text-primary dark:text-gray-200 whitespace-nowrap tabular-nums">
                <%= entry.posted_at.strftime("%b %d, %Y") %>
              </td>
              <td class="px-5 py-3">
                <code class="text-xs font-mono text-text-tertiary dark:text-gray-400"><%= entry.reference_number %></code>
              </td>
              <td class="px-5 py-3 text-sm text-text-primary dark:text-gray-200 max-w-xs truncate">
                <%= entry.description %>
              </td>
              <td class="px-5 py-3 text-right text-sm tabular-nums text-text-primary dark:text-gray-200">
                <% if debit_total > 0 %>
                  <span class="font-mono"><%= number_to_currency(debit_total / 100.0, unit: "PHP ") %></span>
                <% end %>
              </td>
              <td class="px-5 py-3 text-right text-sm tabular-nums text-text-primary dark:text-gray-200">
                <% if credit_total > 0 %>
                  <span class="font-mono"><%= number_to_currency(credit_total / 100.0, unit: "PHP ") %></span>
                <% end %>
              </td>
              <td class="px-5 py-3 text-center">
                <span class="inline-flex items-center gap-1 text-xs font-medium text-primary">
                  <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="m9 12.75 3 3m0 0 3-3m-3 3v-7.5M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
                </span>
              </td>
            </tr>
          <% end %>
        <% else %>
          <tr>
            <td colspan="6" class="px-5 py-10 text-center text-sm text-text-tertiary dark:text-gray-500">
              No entries found
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>

  <% if @pagy.pages > 1 %>
    <div class="flex justify-center">
      <%= render "shared/pagination", pagy: @pagy %>
    </div>
  <% end %>
</div>
