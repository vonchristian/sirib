<% content_for :page_title, "New Journal Entry" %>
<% content_for :page_subtitle, "Record a balanced journal entry" %>

<div class="max-w-3xl mx-auto">
  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900">
    <%= form_tag accounting_entries_path, method: :post, data: { controller: "entry-form", action: "submit->entry-form#disableSubmit" }, class: "space-y-0" do %>
      <% if @entry.errors.any? %>
        <div class="px-6 py-4 bg-danger/10 border-b border-danger/20 dark:border-danger/30 space-y-2">
          <h3 class="text-sm font-semibold text-danger"><%= pluralize(@entry.errors.count, "error") %> prohibited this entry from being saved:</h3>
          <ul class="list-disc list-inside text-sm text-danger dark:text-red-400">
            <% @entry.errors.base.each do |message| %>
              <li><%= message %></li>
            <% end %>
            <% @entry.attributes.reject { |k, _| [:created_at, :updated_at].include?(k) }.each do |key, value| %>
              <% @entry.errors.full_messages_for(key.to_sym).each do |message| %>
                <li><%= message %></li>
              <% end %>
            <% end %>
          </ul>
        </div>
      <% end %>

      <div class="px-6 py-5 border-b border-border dark:border-gray-800 space-y-4">
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
          <div<% if @entry.errors[:reference_number].any? %> class="relative"<% end %>>
            <%= label_tag :reference_number, "Reference #", for: "entry_reference_number", class: "block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1" %>
            <%= text_field_tag "entry[reference_number]", @entry.reference_number, id: "entry_reference_number", class: "block w-full rounded-md border bg-surface px-3 py-1.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200#{' border-danger' if @entry.errors[:reference_number].any?}", placeholder: "Required", autocomplete: "off" %>
            <% if @entry.errors[:reference_number].any? %>
              <p class="mt-1 text-xs text-danger"><%= @entry.errors.full_messages_for(:reference_number).first %></p>
            <% end %>
          </div>
          <div<% if @entry.errors[:posted_at].any? %> class="relative"<% end %>>
            <%= label_tag :posted_at, "Date", for: "entry_posted_at", class: "block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1" %>
            <%= date_field_tag "entry[posted_at]", @entry.posted_at&.to_date || Date.current, id: "entry_posted_at", class: "block w-full rounded-md border bg-surface px-3 py-1.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200#{' border-danger' if @entry.errors[:posted_at].any?}" %>
            <% if @entry.errors[:posted_at].any? %>
              <p class="mt-1 text-xs text-danger"><%= @entry.errors.full_messages_for(:posted_at).first %></p>
            <% end %>
          </div>
        </div>
        <div<% if @entry.errors[:description].any? %> class="relative"<% end %>>
          <%= label_tag :description, "Description", for: "entry_description", class: "block text-xs font-medium text-text-secondary dark:text-gray-400 mb-1" %>
          <%= text_area_tag "entry[description]", @entry.description, id: "entry_description", rows: 2, class: "block w-full rounded-md border bg-surface px-3 py-1.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 dark:border-gray-600 dark:bg-gray-800 dark:text-gray-200#{' border-danger' if @entry.errors[:description].any?}", placeholder: "Required" %>
          <% if @entry.errors[:description].any? %>
            <p class="mt-1 text-xs text-danger"><%= @entry.errors.full_messages_for(:description).first %></p>
          <% end %>
        </div>
      </div>

      <div class="px-6 py-5 border-b border-border dark:border-gray-800">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-sm font-semibold text-text-primary dark:text-white">Amount Lines</h3>
          <button type="button" data-action="entry-form#addLine" class="rounded-md border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400 inline-flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v6m3-3H9m12 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/></svg>
            Add Line
          </button>
        </div>

        <div class="space-y-3" data-entry-form-target="lines">
          <%= render "line" %>
        </div>

        <div class="flex items-center justify-end gap-8 pt-4 border-t border-border dark:border-gray-800 mt-4">
          <div class="text-right">
            <span class="text-xs font-medium text-text-tertiary dark:text-gray-400">Debit Total</span>
            <p class="text-lg font-semibold tabular-nums text-text-primary dark:text-white" data-entry-form-target="debitTotal">PHP 0.00</p>
          </div>
          <div class="text-right">
            <span class="text-xs font-medium text-text-tertiary dark:text-gray-400">Credit Total</span>
            <p class="text-lg font-semibold tabular-nums text-text-primary dark:text-white" data-entry-form-target="creditTotal">PHP 0.00</p>
          </div>
          <div class="text-right">
            <span class="text-xs font-medium text-text-tertiary dark:text-gray-400">Difference</span>
            <p class="text-lg font-semibold tabular-nums" data-entry-form-target="difference">PHP 0.00</p>
          </div>
        </div>
      </div>

      <div class="px-6 py-4 flex items-center justify-end gap-3">
        <%= link_to "Cancel", accounting_journal_entries_path, class: "rounded-md border border-border px-4 py-2 text-sm font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400" %>
        <%= submit_tag "Create Entry", data: { disable_with: "Saving..." }, class: "rounded-md bg-primary px-4 py-2 text-sm font-medium text-white hover:bg-primary-600 transition-colors cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>
