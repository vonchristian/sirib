<% content_for :page_title, "Journal Entry" %>
<% content_for :page_subtitle, "#{@entry.reference_number} — #{@entry.description}" %>

<div class="space-y-6" data-controller="balance-sheet-form">
  <div class="rounded-md border border-border bg-surface dark:border-gray-800 dark:bg-gray-900">
    <div class="px-6 py-5 border-b border-border dark:border-gray-800">
      <div class="flex items-start justify-between">
        <div class="space-y-2">
          <div class="flex items-center gap-3">
            <h1 class="text-lg font-semibold text-text-primary dark:text-white"><%= @entry.description %></h1>
            <span class="rounded-full bg-primary-50 px-2.5 py-0.5 text-xs font-medium text-primary dark:bg-primary-900/30 dark:text-primary-300"><%= @entry.reference_number %></span>
          </div>
          <div class="flex items-center gap-4 text-sm text-text-tertiary dark:text-gray-400">
            <span class="inline-flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 0 1 2.25-2.25h13.5A2.25 2.25 0 0 1 21 7.5v11.25m-18 0A2.25 2.25 0 0 0 5.25 21h13.5A2.25 2.25 0 0 0 21 18.75m-18 0v-7.5A2.25 2.25 0 0 1 5.25 9h13.5A2.25 2.25 0 0 1 21 11.25v7.5"/></svg>
              <%= @entry.posted_at.strftime("%B %d, %Y") %>
            </span>
            <span class="inline-flex items-center gap-1.5">
              <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12h3.75M9 15h3.75M9 18h3.75m3 .75H18a2.25 2.25 0 0 0 2.25-2.25V6.108c0-1.135-.845-2.098-1.976-2.192a48.424 48.424 0 0 0-1.123-.08m-5.801 0c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m0 0H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V9.375c0-.621-.504-1.125-1.125-1.125H8.25ZM6.75 12h.008v.008H6.75V12Zm0 3h.008v.008H6.75V15Zm0 3h.008v.008H6.75V18Z"/></svg>
              <%= pluralize(@entry.amount_lines.size, "line") %>
            </span>
          </div>
        </div>
        <div class="flex items-center gap-2">
          <%= link_to accounting_entries_path, class: "rounded-md border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400 inline-flex items-center gap-1.5" do %>
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M9 15 3 9m0 0 6-6M3 9h12a6 6 0 0 1 0 12h-3"/></svg>
            Back
          <% end %>
          <button onclick="window.print()" class="rounded-md border border-border px-3 py-1.5 text-xs font-medium text-text-secondary hover:bg-surface-alt transition-colors dark:border-gray-600 dark:text-gray-400 inline-flex items-center gap-1.5">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M6.72 13.829c-.24.03-.48.062-.72.096m.72-.096a42.415 42.415 0 0 1 10.56 0m-10.56 0L6.34 18m10.94-4.171c.24.03.48.062.72.096m-.72-.096L17.66 18m0 0 .229 2.523a1.125 1.125 0 0 1-1.12 1.227H7.231c-.662 0-1.18-.568-1.12-1.227L6.34 18m11.318 0h1.091A2.25 2.25 0 0 0 21 15.75V9.456c0-1.081-.768-2.015-1.837-2.175a48.055 48.055 0 0 0-1.913-.247M6.34 18H5.25A2.25 2.25 0 0 1 3 15.75V9.456c0-1.081.768-2.015 1.837-2.175a48.041 48.041 0 0 1 1.913-.247m10.5 0a48.536 48.536 0 0 0-10.5 0m10.5 0V3.375c0-.621-.504-1.125-1.125-1.125h-8.25c-.621 0-1.125.504-1.125 1.125v3.659M18 10.5h.008v.008H18V10.5Zm-3 0h.008v.008H15V10.5Z"/></svg>
            Print
          </button>
        </div>
      </div>
    </div>

    <table class="min-w-full text-sm">
      <thead>
        <tr class="border-b border-border dark:border-gray-800 bg-surface-alt/50 dark:bg-gray-800/20">
          <th class="px-6 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-24">Code</th>
          <th class="px-6 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500">Account</th>
          <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">Debit</th>
          <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-500 w-44">Credit</th>
        </tr>
      </thead>
      <tbody class="divide-y divide-border dark:divide-gray-800">
        <% @entry.amount_lines.includes(:account).each do |line| %>
          <tr class="hover:bg-surface-alt dark:hover:bg-gray-800/30 transition-colors">
            <td class="px-6 py-2.5 text-xs font-mono text-text-tertiary dark:text-gray-400"><%= line.account.account_code %></td>
            <td class="px-6 py-2.5 text-sm text-text-primary dark:text-gray-200"><%= line.account.name %></td>
            <td class="px-6 py-2.5 text-right text-sm tabular-nums text-text-primary dark:text-gray-200 font-mono">
              <%= line.debit? ? number_to_currency(line.amount_cents / 100.0, unit: "PHP ") : "" %>
            </td>
            <td class="px-6 py-2.5 text-right text-sm tabular-nums text-text-primary dark:text-gray-200 font-mono">
              <%= line.credit? ? number_to_currency(line.amount_cents / 100.0, unit: "PHP ") : "" %>
            </td>
          </tr>
        <% end %>
      </tbody>
      <tfoot>
        <tr class="border-t-2 border-border-strong dark:border-gray-600 bg-surface-alt/80 dark:bg-gray-800/40">
          <td colspan="2" class="px-6 py-3 text-sm font-semibold text-text-primary dark:text-white">Total</td>
          <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white font-mono">
            <%= number_to_currency(@entry.amount_lines.debit.total / 100.0, unit: "PHP ") %>
          </td>
          <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white font-mono">
            <%= number_to_currency(@entry.amount_lines.credit.total / 100.0, unit: "PHP ") %>
          </td>
        </tr>
      </tfoot>
    </table>
  </div>
</div>
