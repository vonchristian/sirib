<% content_for :page_title,"Income Statement" %> <% content_for :page_subtitle,"For the period ending #{@as_of_date.strftime('%B %d, %Y')}" %> <% content_for :head do %> <meta name="turbo-cache-control" content="no-cache"> <% end %> <div class="space-y-6"> <%= turbo_stream_from"accounting_balances" %> <div class="rounded-md border border-border bg-surface"> <%= form_tag accounting_income_statement_path, method: :get, data: { controller:"balance-sheet-form", turbo_frame:"_top" }, class:"flex flex-wrap items-end gap-4 px-5 py-4 sm:px-6" do %> <div> <label class="block text-xs font-medium text-text-secondary mb-1">As of Date</label> <%= date_field_tag :as_of_date, @as_of_date, data: { action:"change->balance-sheet-form#submit" }, class:"block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %> </div> <div> <label class="block text-xs font-medium text-text-secondary mb-1">Compare to</label> <%= select_tag :comparison, options_for_select({"None" =>"none","Prior Month" =>"prior_period","Prior Quarter" =>"prior_quarter","Prior Year" =>"prior_year" }, @comparison), data: { action:"change->balance-sheet-form#submit" }, class:"block w-full rounded-md border border-border bg-surface px-3 py-1.5 text-sm text-text-primary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %> </div> <% if @compare_date %> <div class="flex items-center gap-1.5 text-xs text-text-tertiary ml-auto"> <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" /> </svg> Comparative period: <%= @compare_date.strftime("%b %d, %Y") %> </div> <% end %> <% end %> </div> <div class="rounded-md border border-border bg-surface overflow-hidden"> <div> <table class="min-w-full text-sm"> <thead> <tr class="border-b border-border"> <th class="px-6 py-3 text-left text-[11px] font-semibold uppercase tracking-wider text-text-tertiary">Account</th> <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary w-44"> <%= @as_of_date.strftime("%b %d, %Y") %> </th> <% if @compare_date %> <th class="px-6 py-3 text-right text-[11px] font-semibold uppercase tracking-wider text-text-tertiary w-44"> <%= @compare_date.strftime("%b %d, %Y") %> </th> <% end %> </tr> </thead> <tbody class="divide-y divide-border"> <% @report.each do |section| %> <%= render"section", section: section, compare: @compare_date.present? %> <% end %> <tr class="bg-surface-alt /40"> <td class="px-6 py-3 text-sm font-semibold text-text-primary"> Net Income (Loss) </td> <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums border-t-2 border-text-secondary <%= @net_income.negative? ? 'text-danger' : 'text-positive' %>"> <%= @net_income.format %> </td> <% if @compare_date %> <td class="px-6 py-3 text-right text-sm font-semibold tabular-nums border-t-2 border-text-secondary <%= @compare_net_income&.negative? ? 'text-danger' : 'text-positive' %>"> <%= @compare_net_income&.format ||"—" %> </td> <% end %> </tr> </tbody> </table> </div> </div> <div class="rounded-md border border-border bg-surface px-5 py-3.5"> <h3 class="text-[11px] font-semibold text-text-secondary mb-3 uppercase tracking-wider">Chart of Accounts Legend</h3> <div class="flex flex-wrap gap-5 text-xs text-text-tertiary"> <div class="flex items-center gap-2"> <span class="inline-block h-2.5 w-2.5 rounded-sm bg-primary-100 dark:bg-primary-900/40"></span> <span>Revenue</span> </div> <div class="flex items-center gap-2"> <span class="inline-block h-2.5 w-2.5 rounded-sm bg-warning-50 dark:bg-amber-900/40"></span> <span>Expense</span> </div> <div class="flex items-center gap-2"> <span class="inline-block h-2.5 w-2.5 rounded-sm bg-surface-alt"></span> <span>Contra Account (deduction)</span> </div> </div> </div> </div> 