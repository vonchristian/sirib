<tr class="bg-surface-alt dark:bg-gray-800/50">
  <td colspan="<%= compare ? 3 : 2 %>" class="px-6 py-2.5 text-xs font-bold uppercase tracking-widest text-text-secondary dark:text-gray-400">
    <%= section[:name] %>
  </td>
</tr>

<% section[:ledger_groups].each do |group| %>
  <%= render "ledger_group", group: group, compare: compare, depth: 0 %>
<% end %>

<tr>
  <td class="px-6 py-2.5 text-sm font-semibold text-text-primary dark:text-white" style="padding-left: 40px">
    Total <%= section[:name] %>
  </td>
  <td class="px-6 py-2.5 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white border-t border-border-strong dark:border-gray-600">
    <%= section[:total].format %>
  </td>
  <% if compare %>
    <td class="px-6 py-2.5 text-right text-sm font-semibold tabular-nums text-text-primary dark:text-white border-t border-border-strong dark:border-gray-600">
      <%= section[:total_compare]&.format || "—" %>
    </td>
  <% end %>
</tr>
