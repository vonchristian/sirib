<tr class="bg-gray-100/80 dark:bg-gray-800/80">
  <td colspan="<%= compare ? 3 : 2 %>" class="px-6 py-3 text-xs font-bold uppercase tracking-widest text-gray-500 dark:text-gray-400">
    <%= section[:name] %>
  </td>
</tr>

<% section[:ledger_groups].each do |group| %>
  <%= render "ledger_group", group: group, compare: compare, depth: 0 %>
<% end %>

<tr>
  <td class="px-6 py-3 pl-10 text-sm font-bold text-gray-900 dark:text-white">
    Total <%= section[:name] %>
  </td>
  <td class="px-6 py-3 text-right text-sm font-bold tabular-nums text-gray-900 dark:text-white border-t border-gray-300 dark:border-gray-600">
    <%= section[:total].format %>
  </td>
  <% if compare %>
    <td class="px-6 py-3 text-right text-sm font-bold tabular-nums text-gray-900 dark:text-white border-t border-gray-300 dark:border-gray-600">
      <%= section[:total_compare]&.format || "—" %>
    </td>
  <% end %>
</tr>
