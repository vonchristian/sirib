<tr class="bg-surface-alt /40"> 
  <td colspan="<%= compare ? 3 : 2 %>" class="px-6 py-2.5 text-xs font-bold uppercase tracking-widest text-text-secondary"> <%= section[:name] %> </td>
 </tr>
 <% section[:ledger_groups].each do |group| %> <%= render"ledger_group", group: group, compare: compare, depth: 0 %> <% end %> 
<tr> 
  <td class="px-6 py-2.5 text-sm font-semibold text-text-primary" style="padding-left: 40px"> Total <%= section[:name] %> </td>
 
  <td class="px-6 py-2.5 text-right text-sm font-semibold tabular-nums text-text-primary border-t-2 border-border-strong"> <%= section[:total].format %> </td>
 <% if compare %> 
    <td class="px-6 py-2.5 text-right text-sm font-semibold tabular-nums text-text-primary border-t-2 border-border-strong"> <%= section[:total_compare]&.format ||"—" %> </td>
 <% end %> </tr>
 
