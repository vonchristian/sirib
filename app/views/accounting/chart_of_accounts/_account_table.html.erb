<% if accounts.any? %> 
  <table class="w-full text-sm" data-testid="accounts-table"> 
    <thead> 
      <tr class="border-b border-border text-left text-[10px] uppercase tracking-wider" style="color: var(--text-muted);"> 
        <th class="px-4 py-2.5 font-medium">Code</th>
 
        <th class="px-4 py-2.5 font-medium">Name</th>
 
        <th class="px-4 py-2.5 font-medium">Ledger</th>
 
        <th class="px-4 py-2.5 font-medium">Type</th>
 
        <th class="px-4 py-2.5 font-medium text-right">Balance</th>
 
        <th class="px-4 py-2.5 font-medium">Status</th>
 
        <th class="px-4 py-2.5 font-medium">Postable</th>
 </tr>
 </thead>
 
    <tbody class="divide-y divide-border"> <% accounts.each do |account| %> 
        <tr class="hover:bg-surface-alt/50 transition-colors cursor-pointer" data-href="<%= accounting_account_path(account) %>" data-action="click->chart-of-accounts#navigateToAccount keydown->chart-of-accounts#navigateOnEnter" data-account-id="<%= account.id %>" tabindex="0" data-testid="account-row"> 
          <td class="px-4 py-2.5 font-mono text-xs" style="color: var(--text-secondary);"> <%= link_to account.account_code, accounting_account_path(account), class:"text-primary hover:text-primary/80 transition-colors", data: { action:"click->chart-of-accounts#ignore" } %> </td>
 
          <td class="px-4 py-2.5 text-sm font-medium" style="color: var(--text-primary);"><%= account.name %></td>
 
          <td class="px-4 py-2.5 text-xs" style="color: var(--text-tertiary);"><%= account.ledger.name %></td>
 
          <td class="px-4 py-2.5"> <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium capitalize" style="background: var(--bg-tertiary); color: var(--text-secondary);"> <%= account.account_type %> </span> </td>
 
          <td class="px-4 py-2.5 text-right font-mono text-xs tabular-nums" style="color: var(--text-primary);"> <%= account.balance.format %> </td>
 
          <td class="px-4 py-2.5"> <% if account.active? %> <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-success/10 text-success" data-testid="account-status-active">Active</span> <% else %> <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-danger/10 text-danger" data-testid="account-status-inactive">Inactive</span> <% end %> </td>
 
          <td class="px-4 py-2.5"> <% if account.postable? %> <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium text-text-tertiary" data-testid="account-postable-yes">Yes</span> <% else %> <span class="inline-flex items-center px-1.5 py-0.5 rounded text-[10px] font-medium bg-amber-500/10 text-amber-500" data-testid="account-postable-no">No</span> <% end %> </td>
 </tr>
 <% end %> </tbody>
 </table>
 <% else %> 
  <div class="flex items-center justify-center h-full" data-testid="accounts-empty-state"> 
    <div class="text-center py-12"> <svg class="w-10 h-10 mx-auto mb-3" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1"> <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/> </svg> 
      <p class="text-sm font-medium" style="color: var(--text-primary);">No accounts found</p>
 
      <p class="text-xs mt-1" style="color: var(--text-tertiary);">Try adjusting your filters or search query.</p>
 </div>
 </div>
 <% end %> 
