<% if ledgers.any? || accounts.any? %> 
  <div class="py-1"> <% if ledgers.any? %> 
      <div class="px-3 py-1.5"> <span class="text-[9px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Ledgers</span> </div>
 <% ledgers.each do |ledger| %> <button type="button" data-action="click->chart-of-accounts#selectLedgerFromSearch" data-ledger-id="<%= ledger.id %>" class="w-full flex items-center gap-2 px-3 py-2 text-xs hover:bg-tertiary transition-colors text-left"> <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: var(--accent);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"> <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 014.5 9.75h15A2.25 2.25 0 0121.75 12v.75m-8.69-6.44l-2.12-2.12a1.5 1.5 0 00-1.061-.44H4.5A2.25 2.25 0 002.25 6v12a2.25 2.25 0 002.25 2.25h15A2.25 2.25 0 0021.75 18V9a2.25 2.25 0 00-2.25-2.25h-5.379a1.5 1.5 0 01-1.06-.44z"/> </svg> <span class="font-mono text-[10px]" style="color: var(--text-tertiary);"><%= ledger.account_code %></span> <span style="color: var(--text-primary);"><%= ledger.name %></span> </button> <% end %> <% end %> <% if accounts.any? %> 
      <div class="px-3 py-1.5 mt-1"> <span class="text-[9px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Accounts</span> </div>
 <% accounts.each do |account| %> <button type="button" data-action="click->chart-of-accounts#selectAccountFromSearch" data-account-id="<%= account.id %>" class="w-full flex items-center gap-2 px-3 py-2 text-xs hover:bg-tertiary transition-colors text-left"> <svg class="w-3.5 h-3.5 flex-shrink-0" style="color: var(--text-tertiary);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"> <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/> </svg> <span class="font-mono text-[10px]" style="color: var(--text-tertiary);"><%= account.account_code %></span> <span style="color: var(--text-primary);"><%= account.name %></span> <span class="ml-auto text-[10px]" style="color: var(--text-tertiary);"><%= account.ledger.name %></span> </button> <% end %> <% end %> </div>
 <% else %> 
  <div class="px-3 py-6 text-center"> 
    <p class="text-xs" style="color: var(--text-tertiary);">No results found</p>
 </div>
 <% end %> 
