<div class="flex-shrink-0 px-4 py-2.5 border-b border-border flex items-center gap-3 flex-wrap" style="background: var(--bg-secondary);"> <span class="text-[10px] font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Filters</span> <select name="account_type" data-action="change->chart-of-accounts#filter" class="text-xs rounded-md border border-border bg-surface px-2.5 py-1.5 text-text-primary focus:outline-none focus:ring-1 focus:ring-primary/30 focus:border-primary" data-testid="filter-account-type"> <option value="">All Types</option> <option value="asset" <%="selected" if filters[:account_type] =="asset" %>>Asset</option> <option value="liability" <%="selected" if filters[:account_type] =="liability" %>>Liability</option> <option value="equity" <%="selected" if filters[:account_type] =="equity" %>>Equity</option> <option value="revenue" <%="selected" if filters[:account_type] =="revenue" %>>Revenue</option> <option value="expense" <%="selected" if filters[:account_type] =="expense" %>>Expense</option> </select> <select name="status" data-action="change->chart-of-accounts#filter" class="text-xs rounded-md border border-border bg-surface px-2.5 py-1.5 text-text-primary focus:outline-none focus:ring-1 focus:ring-primary/30 focus:border-primary" data-testid="filter-status"> <option value="">All Statuses</option> <option value="active" <%="selected" if filters[:status] =="active" %>>Active</option> <option value="inactive" <%="selected" if filters[:status] =="inactive" %>>Inactive</option> </select> <label class="flex items-center gap-1.5 text-xs" style="color: var(--text-secondary);"> <input type="checkbox" name="contra" value="true" data-action="change->chart-of-accounts#filter" class="rounded border-border text-primary focus:ring-primary/30" data-testid="filter-contra" <%="checked" if filters[:contra] =="true" %>> Contra </label> <label class="flex items-center gap-1.5 text-xs" style="color: var(--text-secondary);"> <input type="checkbox" name="non_postable" value="true" data-action="change->chart-of-accounts#filter" class="rounded border-border text-primary focus:ring-primary/30" data-testid="filter-non-postable" <%="checked" if filters[:non_postable] =="true" %>> Non-Postable </label> <button type="button" data-action="click->chart-of-accounts#clearFilters" class="text-xs px-2 py-1 rounded-sm hover:bg-tertiary transition-colors" style="color: var(--text-tertiary);"> Clear </button> </div> 