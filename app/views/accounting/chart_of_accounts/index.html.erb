<% content_for :page_title,"Chart of Accounts" %> 
<div class="h-full flex flex-col" data-controller="chart-of-accounts" data-chart-of-accounts-search-url-value="<%= accounting_search_chart_of_accounts_path %>" data-chart-of-accounts-accounts-url-value="<%= accounting_accounts_chart_of_accounts_path %>"> <%# Global Search Bar %> 
  <div class="flex-shrink-0 px-4 py-3 border-b border-border" style="background: var(--bg-primary);"> 
    <div class="relative max-w-xl"> <svg class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4" style="color: var(--text-muted);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"> <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-5.197-5.197m0 0A7.5 7.5 0 105.196 5.196a7.5 7.5 0 0010.607 10.607z"/> </svg> <input type="search" data-chart-of-accounts-target="searchInput" data-action="input->chart-of-accounts#search keydown->chart-of-accounts#handleSearchKeydown" placeholder="Search account name, code, or ledger..." class="w-full pl-10 pr-4 py-2.5 text-sm rounded-lg border border-border bg-surface text-text-primary placeholder-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/30 focus:border-primary transition-colors"> 
      <div data-chart-of-accounts-target="searchResults" class="hidden absolute top-full left-0 right-0 mt-1 rounded-lg border border-border bg-surface shadow-lg z-50 max-h-96 overflow-y-auto"></div>
 </div>
 </div>
 <%# Main Layout: Filter Bar + Account Table %> 
  <div class="flex-1 flex flex-col overflow-hidden"> <%= render"accounting/chart_of_accounts/filter_bar", filters: @filters %> 
    <div class="flex-1 overflow-y-auto" data-chart-of-accounts-target="accountTable"> <%= render"accounting/chart_of_accounts/account_table", accounts: @accounts %> </div>
 </div>
 </div>
 
