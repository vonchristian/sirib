<div class="rounded-lg border border-border bg-surface p-4" data-controller="audit-timeline" data-testid="audit-trail"> 
  <h3 class="text-xs font-semibold text-text-secondary uppercase tracking-wider mb-4 flex items-center gap-1.5"> <svg class="w-3.5 h-3.5 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"> <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 11-18 0 9 9 0 0118 0z"/> </svg> Activity Timeline </h3>
 <% if @audit_entries.any? %> 
    <div class="relative" data-audit-timeline-target="list"> 
      <div class="absolute left-4 top-0 bottom-0 w-px bg-border"></div>
 <% @audit_entries.group_by { |e| e.posted_at.to_date }.each do |date, entries| %> 
        <div class="mb-4 last:mb-0"> 
          <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-2 pl-1"> <%= date == Date.current ? "Today" : date == Date.yesterday ? "Yesterday" : l(date, format: :long) %> </p>
 
          <div class="space-y-3"> <% entries.each do |entry| %> 
              <div class="relative flex gap-3 pl-6" data-audit-timeline-target="entry"> 
                <div class="absolute left-3 top-1.5 w-1.5 h-1.5 rounded-full bg-border-strong z-10"></div>
 
                <div class="flex-1 min-w-0"> 
                  <div class="flex items-start justify-between gap-2"> 
                    <div class="min-w-0"> 
                      <p class="text-sm font-medium text-text-primary truncate"> <%= entry.created_by&.email_address&.split("@")&.first %> </p>
 
                      <p class="text-xs text-text-tertiary mt-0.5"> <%= entry.description.presence || entry.reference_number.presence ||"Entry posted" %> </p>
 </div>
 
                    <p class="text-xs text-text-tertiary whitespace-nowrap flex-shrink-0 font-mono"> <%= l(entry.posted_at, format: :ledger).split(",").last %> </p>
 </div>
 <% if entry.reference_number.present? && entry.description != entry.reference_number %> 
                    <p class="text-xs text-text-tertiary mt-0.5"> Ref: <%= entry.reference_number %> </p>
 <% end %> </div>
 </div>
 <% end %> </div>
 </div>
 <% end %> </div>
 <% if @pagy_audit.page < @pagy_audit.pages %> 
      <div data-audit-timeline-target="sentinel" data-account-id="<%= @account.id %>" data-next-page="<%= @pagy_audit.page + 1 %>"> 
        <div class="flex justify-center py-3"> 
          <div class="w-3 h-3 border border-border-strong border-t-transparent rounded-full animate-spin"></div>
 </div>
 </div>
 <% else %> 
      <div data-audit-timeline-target="end"> 
        <p class="text-xs text-text-tertiary text-center py-3">End of activity</p>
 </div>
 <% end %> <% else %> 
    <p class="text-sm text-text-tertiary text-center py-4">No activity recorded yet.</p>
 <% end %> </div>
 
