<% audit_entries.group_by { |e| e.posted_at.to_date }.each do |date, entries| %>
  <div class="mb-4 last:mb-0">
    <p class="text-xs font-semibold text-text-tertiary uppercase tracking-wider mb-2 pl-1">
      <%= date == Date.current ? "Today" : date == Date.yesterday ? "Yesterday" : l(date, format: :long) %>
    </p>
    <div class="space-y-3">
      <% entries.each do |entry| %>
        <div class="relative flex gap-3 pl-6" data-audit-timeline-target="entry">
          <div class="absolute left-3 top-1.5 w-2 h-2 rounded-full bg-primary border-2 border-surface z-10"></div>
          <div class="flex-1 min-w-0">
            <div class="flex items-start justify-between gap-2">
              <div class="min-w-0">
                <p class="text-sm font-medium text-text-primary truncate">
                  <%= entry.created_by&.email_address&.split("@")&.first %>
                </p>
                <p class="text-xs text-text-tertiary mt-0.5">
                  <%= entry.description.presence || entry.reference_number.presence || "Entry posted" %>
                </p>
              </div>
              <p class="text-xs text-text-tertiary whitespace-nowrap flex-shrink-0 font-mono">
                <%= l(entry.posted_at, format: :ledger).split(", ").last %>
              </p>
            </div>
            <% if entry.reference_number.present? && entry.description != entry.reference_number %>
              <p class="text-xs text-text-tertiary mt-0.5">
                Ref: <%= entry.reference_number %>
              </p>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% if pagy.page < pagy.pages %>
  <div data-audit-timeline-target="sentinel"
       data-account-id="<%= local_assigns[:account_id] %>"
       data-next-page="<%= pagy.page + 1 %>">
    <div class="flex justify-center py-3">
      <div class="w-4 h-4 border-2 border-primary border-t-transparent rounded-full animate-spin"></div>
    </div>
  </div>
<% else %>
  <div data-audit-timeline-target="end">
    <p class="text-xs text-text-tertiary text-center py-3">End of activity</p>
  </div>
<% end %>