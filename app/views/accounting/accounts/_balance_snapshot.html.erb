<div class="rounded-lg border border-border bg-surface p-4" data-testid="balance-snapshot">
  <h3 class="text-[10px] font-semibold text-text-primary uppercase tracking-wider mb-3 flex items-center gap-1.5">
    <svg class="w-3.5 h-3.5 text-text-tertiary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
      <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5"/>
    </svg>
    Balance Snapshot
  </h3>

  <div class="space-y-2.5">
    <div class="flex items-center justify-between">
      <span class="text-xs text-text-tertiary">Opening Balance</span>
      <span class="text-xs font-mono text-text-secondary font-medium"><%= summary[:opening].format %></span>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-xs text-text-tertiary">Total Debits</span>
      <span class="text-xs font-mono text-danger font-medium"><%= summary[:total_debits].format %></span>
    </div>
    <div class="flex items-center justify-between">
      <span class="text-xs text-text-tertiary">Total Credits</span>
      <span class="text-xs font-mono text-success font-medium"><%= summary[:total_credits].format %></span>
    </div>
    <div class="border-t border-border pt-2 flex items-center justify-between">
      <span class="text-xs text-text-tertiary">Net Movement</span>
      <span class="text-xs font-mono <%= summary[:net_movement].negative? ? 'text-danger' : 'text-success' %> font-medium">
        <%= summary[:net_movement].format %>
      </span>
    </div>
    <div class="border-t border-border pt-2 flex items-center justify-between">
      <span class="text-xs font-semibold text-text-primary">Current Balance</span>
      <span class="text-sm font-semibold font-mono text-text-primary"><%= summary[:current_balance].format %></span>
    </div>
  </div>
</div>
