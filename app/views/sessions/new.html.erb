<div class="flex min-h-screen flex-col bg-surface-alt"> 
  <div class="flex flex-1 flex-col justify-center px-6 py-12 sm:mx-auto sm:w-full sm:max-w-sm"> 
    <div class="animate-fade-in-up text-center"> 
      <div class="flex justify-center"> 
        <div class="flex h-11 w-11 items-center justify-center rounded-md bg-primary shadow-sm"> <svg class="h-6 w-6 text-white" viewBox="0 0 40 40" fill="none"> <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/> <circle cx="20" cy="20" r="10" fill="currentColor" opacity="0.85"/> <circle cx="20" cy="20" r="4" fill="white"/> </svg> </div>
 </div>
 
      <h2 class="mt-5 text-xl font-semibold tracking-tight text-text-primary">Sign in to Sirib</h2>
 
      <p class="mt-1 text-sm text-text-secondary">Enter your credentials to continue</p>
 </div>
 <% if alert = flash[:alert] %> 
      <div class="animate-fade-in-up mt-6"> 
        <div class="rounded-md border border-danger/20 bg-danger-50 px-4 py-2.5 text-sm font-medium text-danger"><%= alert %></div>
 </div>
 <% end %> <% if notice = flash[:notice] %> 
      <div class="animate-fade-in-up mt-6"> 
        <div class="rounded-md border border-primary/20 bg-primary-50 px-4 py-2.5 text-sm font-medium text-primary-700"><%= notice %></div>
 </div>
 <% end %> 
    <div class="animate-fade-in-up-1 mt-8"> 
      <div class="rounded-md border border-border bg-surface px-6 py-8"> <%= form_with url: session_url, class:"space-y-5", data: { turbo: false } do |form| %> 
          <div> <%= form.label :email_address,"Email address or Employee ID", class:"block text-xs font-medium text-text-secondary mb-1.5" %> <%= form.text_field :email_address, required: true, autofocus: true, autocomplete:"username", placeholder:"you@example.com or employee ID", value: params[:email_address], class:"block w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %> </div>
 
          <div> <%= form.label :password, class:"block text-xs font-medium text-text-secondary mb-1.5" %> <%= form.password_field :password, required: true, autocomplete:"current-password", placeholder:"Enter your password", maxlength: 72, class:"block w-full rounded-md border border-border bg-surface px-3.5 py-2.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary" %> </div>
 
          <div> <%= form.submit"Sign in", class:"flex w-full justify-center rounded-md bg-primary px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-colors" %> </div>
 <% end %> </div>
 
      <p class="mt-6 text-center text-sm text-text-secondary"> <%= link_to"Forgot your password?", new_password_path, class:"font-medium text-primary hover:text-primary-700 dark:text-primary-400 transition-colors" %> </p>
 </div>
 </div>
 
  <footer class="py-8 text-center"> 
    <p class="text-xs text-text-tertiary">Sirib — Cooperative Banking Platform</p>
 </footer>
 </div>
 
