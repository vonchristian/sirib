<div class="relative flex min-h-screen flex-col bg-surface-alt">
  <%# Background gradient blobs — subtle security vibe %>
  <div class="landing-blob landing-blob-3 pointer-events-none fixed" style="top: -10rem; right: -10rem; opacity: 0.15;"></div>
  <div class="landing-blob landing-blob-4 pointer-events-none fixed" style="bottom: -10rem; left: -10rem; opacity: 0.15;"></div>

  <div class="relative z-10 flex flex-1 flex-col justify-center px-6 py-12 sm:mx-auto sm:w-full sm:max-w-sm">
    <div class="animate-fade-in-up text-center">
      <div class="flex justify-center">
        <div class="flex items-center justify-center">
          <%= render "shared/logo", size: "lg", class: "text-primary" %>
        </div>
      </div>
      <h2 class="mt-5 text-xl font-semibold tracking-tight text-text-primary">Sign in to Sirib</h2>
      <p class="mt-1 text-sm text-text-secondary">Enter your credentials to continue</p>
      <div class="mt-3 inline-flex items-center gap-1.5 rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
        <svg class="h-3 w-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Your connection is secure
      </div>
    </div>

    <% if alert = flash[:alert] %>
      <div class="animate-fade-in-up mt-6" data-controller="dismiss" data-dismiss-target>
        <div class="flex items-center gap-3 rounded-md border border-danger/20 bg-danger-50 px-4 py-3">
          <svg class="shrink-0 h-4 w-4 text-danger" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="10"/><path d="M12 8v4"/><path d="M12 16h.01"/>
          </svg>
          <span class="flex-1 text-sm font-medium text-danger"><%= alert %></span>
          <button data-action="dismiss#dismiss" class="shrink-0 text-danger/60 hover:text-danger transition-colors">&times;</button>
        </div>
      </div>
    <% end %>

    <div class="animate-fade-in-up-1 mt-8">
      <div class="rounded-xl border border-border bg-surface px-6 py-8 shadow-sm">
        <%= form_with url: session_url, class: "space-y-5", data: { turbo: false }, onsubmit: "this.querySelector('button[type=submit]').disabled = true" do |form| %>
          <div>
            <%= form.label :email_address, "Email address or Employee ID", class: "block text-xs font-medium text-text-secondary mb-1.5" %>
            <div class="relative">
              <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-text-tertiary">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>
                </svg>
              </span>
              <%= form.text_field :email_address, required: true, autofocus: true, autocomplete: "username", placeholder: "you@example.com or employee ID", value: params[:email_address], class: "block w-full rounded-lg border border-border bg-surface py-2.5 pl-10 pr-3.5 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow" %>
            </div>
          </div>

          <div>
            <%= form.label :password, class: "flex items-center justify-between" do %>
              <span class="block text-xs font-medium text-text-secondary">Password</span>
            <% end %>
            <div class="relative mt-1.5" data-controller="password-visibility">
              <%= form.password_field :password, required: true, autocomplete: "current-password", placeholder: "Enter your password", maxlength: 72, class: "block w-full rounded-lg border border-border bg-surface py-2.5 pl-10 pr-10 text-sm text-text-primary placeholder:text-text-tertiary focus:outline-none focus:ring-2 focus:ring-primary/20 focus:border-primary transition-shadow", data: { password_visibility_target: "input" } %>
              <span class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3 text-text-tertiary">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>
                </svg>
              </span>
              <button type="button" data-action="password-visibility#toggle" data-password-visibility-target="toggle" class="absolute inset-y-0 right-0 flex items-center pr-3 text-text-tertiary hover:text-text-secondary transition-colors" aria-label="Toggle password visibility">
                <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-password-visibility-target="eye">
                  <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
                </svg>
                <svg class="hidden h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" data-password-visibility-target="eyeOff">
                  <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-11-8-11-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 11 8 11 8a18.5 18.5 0 0 1-2.16 3.19"/><path d="M14.12 14.12a3 3 0 1 1-4.24-4.24"/><path d="M2 2l20 20"/>
                </svg>
              </button>
            </div>
            <p class="mt-1.5 text-xs text-text-tertiary">Passwords are encrypted in transit and at rest</p>
          </div>

          <%= form.submit "Sign in", class: "flex w-full cursor-pointer justify-center rounded-lg bg-primary px-3 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-primary-700 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-primary transition-all disabled:cursor-not-allowed disabled:opacity-60" %>
        <% end %>
      </div>

      <p class="mt-6 text-center text-sm text-text-secondary">
        <svg class="-ml-0.5 inline h-3.5 w-3.5 align-text-bottom text-text-tertiary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        <%= link_to "Forgot your password?", new_password_path, class: "ml-1 font-medium text-primary hover:text-primary-700 transition-colors" %>
      </p>

      <% if flash[:alert]&.include?("Try again later") %>
        <p class="mt-4 text-center text-xs text-text-tertiary">
          Too many attempts? Wait a few minutes and try again.
        </p>
      <% end %>
    </div>

    <footer class="mt-12 text-center">
      <p class="text-xs text-text-tertiary">
        <svg class="-ml-1 inline-block h-3 w-3 align-text text-text-tertiary" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
          <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
        </svg>
        Encrypted connection · Sirib — Cooperative Banking Platform
      </p>
    </footer>
  </div>
</div>