<% content_for :page_title, "Settings" %>
<% content_for :page_subtitle, "Manage your account and system preferences" %>

<div class="animate-fade-in">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
    <div class="px-6 py-5">
      <h2 class="text-sm font-semibold text-text-primary dark:text-white">Profile</h2>
      <p class="mt-1 text-sm text-text-secondary dark:text-gray-400">Manage your account information</p>
    </div>
    <div class="border-t border-border px-6 py-5 dark:border-gray-700">
      <dl class="divide-y divide-border dark:divide-gray-800">
        <div class="flex items-center justify-between py-4">
          <dt class="text-sm font-medium text-text-primary dark:text-white">Email</dt>
          <dd class="text-sm text-text-secondary dark:text-gray-400"><%= Current.user.email_address %></dd>
        </div>
        <div class="flex items-center justify-between py-4">
          <dt class="text-sm font-medium text-text-primary dark:text-white">Role</dt>
          <dd class="text-sm text-text-secondary dark:text-gray-400"><%= Current.user.role&.titleize %></dd>
        </div>
        <div class="flex items-center justify-between py-4">
          <dt class="text-sm font-medium text-text-primary dark:text-white">Password</dt>
          <dd class="text-sm text-text-secondary dark:text-gray-400">
            <%= link_to "Change password", new_password_path, class: "font-medium text-primary hover:text-primary-700 dark:text-primary-400 transition-colors" %>
          </dd>
        </div>
      </dl>
    </div>
  </div>
</div>
