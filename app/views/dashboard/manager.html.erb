<% content_for :page_title, "Manager Dashboard" %>
<% content_for :page_subtitle, "Overview of your cooperative" %>

<div class="animate-fade-in space-y-6">
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="rounded-lg border border-border bg-surface px-5 py-5 dark:border-gray-700 dark:bg-gray-900">
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary dark:bg-primary-900/30 dark:text-primary-300">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0 1 15.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 0 0 3 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125V9.75c0 .621-.504 1.125-1.125 1.125H20.25m0 0v.75c0 .414-.336.75-.75.75H3.75" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-text-secondary dark:text-gray-400 uppercase tracking-wide">Active Loans</p>
          <p class="mt-0.5 text-2xl font-semibold text-text-primary dark:text-white tabular-nums"><%= @active_loans_count %></p>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-border bg-surface px-5 py-5 dark:border-gray-700 dark:bg-gray-900">
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-warning-50 text-warning dark:bg-amber-900/30 dark:text-amber-300">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15M12 9l-3 3m0 0 3 3m-3-3h12.75" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-text-secondary dark:text-gray-400 uppercase tracking-wide">Pending Disbursement</p>
          <p class="mt-0.5 text-2xl font-semibold text-text-primary dark:text-white tabular-nums"><%= @pending_disbursements_count %></p>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-border bg-surface px-5 py-5 dark:border-gray-700 dark:bg-gray-900">
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-positive-50 text-positive dark:bg-emerald-900/30 dark:text-emerald-300">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-text-secondary dark:text-gray-400 uppercase tracking-wide">Today's Collections</p>
          <p class="mt-0.5 text-2xl font-semibold text-text-primary dark:text-white tabular-nums"><%= @todays_collections.format %></p>
        </div>
      </div>
    </div>

    <div class="rounded-lg border border-border bg-surface px-5 py-5 dark:border-gray-700 dark:bg-gray-900">
      <div class="flex items-center gap-4">
        <div class="flex h-10 w-10 items-center justify-center rounded-lg bg-primary-50 text-primary dark:bg-primary-900/30 dark:text-primary-300">
          <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 19.128a9.38 9.38 0 0 0 2.625.372 9.337 9.337 0 0 0 4.121-.952 4.125 4.125 0 0 0-7.533-2.493M15 19.128v-.003c0-1.113-.285-2.16-.786-3.07M15 19.128v.106A12.318 12.318 0 0 1 8.624 21c-2.331 0-4.512-.645-6.374-1.766l-.001-.109a6.375 6.375 0 0 1 11.964-3.07M12 6.375a3.375 3.375 0 1 1-6.75 0 3.375 3.375 0 0 1 6.75 0Zm8.25 2.25a2.625 2.625 0 1 1-5.25 0 2.625 2.625 0 0 1 5.25 0Z" />
          </svg>
        </div>
        <div>
          <p class="text-xs font-medium text-text-secondary dark:text-gray-400 uppercase tracking-wide">Total Members</p>
          <p class="mt-0.5 text-2xl font-semibold text-text-primary dark:text-white tabular-nums"><%= @total_members_count %></p>
        </div>
      </div>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-6">
      <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
        <div class="flex items-center justify-between border-b border-border px-6 py-4 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-text-primary dark:text-white">Pending Tasks</h2>
          <a href="/dashboard/tasks" class="text-sm font-medium text-primary hover:text-primary-700 dark:text-primary-400 transition-colors">View all</a>
        </div>
        <div class="divide-y divide-border">
          <% if @pending_applications.any? %>
            <% @pending_applications.each do |app| %>
              <div class="flex items-center gap-4 px-6 py-3.5">
                <div class="flex h-5 w-5 flex-shrink-0 items-center justify-center rounded-full border-2 border-gray-300 transition-colors hover:border-primary-400 dark:border-gray-600"></div>
                <div class="flex-1 min-w-0">
                  <p class="text-sm font-medium text-text-primary dark:text-white">Review application — <%= app.member&.name || "Unknown" %></p>
                  <p class="text-xs text-text-tertiary dark:text-gray-400"><%= app.loan_product&.name || "Loan" %> · <%= number_to_currency(app.amount_cents.to_f / 100, unit: "PHP ") %></p>
                </div>
                <span class="inline-flex items-center rounded-full bg-warning-50 px-2 py-0.5 text-xs font-medium text-warning ring-1 ring-inset ring-warning/20 dark:bg-amber-900/30 dark:text-amber-400"><%= app.status %></span>
              </div>
            <% end %>
          <% else %>
            <div class="px-6 py-8 text-center text-sm text-text-tertiary">No pending applications</div>
          <% end %>
        </div>
      </div>

      <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
        <div class="border-b border-border px-6 py-4 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-text-primary dark:text-white">Recent Activity</h2>
        </div>
        <div class="divide-y divide-border">
          <% @recent_payments.each do |payment| %>
            <div class="flex items-center gap-4 px-6 py-3.5">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-positive-50 text-positive dark:bg-emerald-900/30 dark:text-emerald-300">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-text-primary dark:text-white">Payment received — <span class="font-medium"><%= payment.loan.member.name %></span></p>
                <p class="text-xs text-text-tertiary dark:text-gray-400"><%= time_ago_in_words(payment.created_at) %> ago · <%= payment.amount.format %></p>
              </div>
            </div>
          <% end %>
          <% @recent_members.each do |member| %>
            <div class="flex items-center gap-4 px-6 py-3.5">
              <div class="flex h-8 w-8 items-center justify-center rounded-lg bg-primary-50 text-primary dark:bg-primary-900/30 dark:text-primary-300">
                <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9" />
                </svg>
              </div>
              <div class="flex-1 min-w-0">
                <p class="text-sm text-text-primary dark:text-white">New member registered — <span class="font-medium"><%= member.name %></span></p>
                <p class="text-xs text-text-tertiary dark:text-gray-400"><%= time_ago_in_words(member.created_at) %> ago</p>
              </div>
            </div>
          <% end %>
          <% if @recent_payments.empty? && @recent_members.empty? %>
            <div class="px-6 py-8 text-center text-sm text-text-tertiary">No recent activity</div>
          <% end %>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
        <div class="border-b border-border px-6 py-4 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-text-primary dark:text-white">Schedule</h2>
        </div>
        <div class="px-6 py-4 space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-primary"></span>
              <span class="text-sm text-text-secondary dark:text-gray-300">Team standup</span>
            </div>
            <span class="text-xs text-text-tertiary dark:text-gray-500">9:00 AM</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-positive"></span>
              <span class="text-sm text-text-secondary dark:text-gray-300">Disbursement review</span>
            </div>
            <span class="text-xs text-text-tertiary dark:text-gray-500">10:30 AM</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-warning"></span>
              <span class="text-sm text-text-secondary dark:text-gray-300">Member meeting</span>
            </div>
            <span class="text-xs text-text-tertiary dark:text-gray-500">2:00 PM</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-gray-300 dark:bg-gray-600"></span>
              <span class="text-sm text-text-secondary dark:text-gray-300">End-of-day report</span>
            </div>
            <span class="text-xs text-text-tertiary dark:text-gray-500">5:00 PM</span>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
        <div class="border-b border-border px-6 py-4 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-text-primary dark:text-white">Productivity</h2>
        </div>
        <div class="px-6 py-4 space-y-5">
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-sm text-text-secondary dark:text-gray-300">Tasks completed</span>
              <span class="text-sm font-semibold text-text-primary dark:text-white tabular-nums">12/16</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-full w-3/4 rounded-full bg-primary"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-sm text-text-secondary dark:text-gray-300">On-time rate</span>
              <span class="text-sm font-semibold text-text-primary dark:text-white tabular-nums">88%</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-full w-[88%] rounded-full bg-positive"></div>
            </div>
          </div>
          <div class="flex items-start gap-2 rounded-lg bg-warning-50 px-3 py-2.5 dark:bg-amber-900/20">
            <svg class="h-4 w-4 flex-shrink-0 mt-0.5 text-warning" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18" />
            </svg>
            <p class="text-xs font-medium text-warning dark:text-amber-300">You're 2 tasks behind schedule. Focus on high-priority items.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
