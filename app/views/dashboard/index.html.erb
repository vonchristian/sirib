<% content_for :page_title, "Dashboard" %>
<% content_for :page_subtitle, "Overview of your cooperative" %>

<div class="animate-fade-in space-y-6">
  <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 xl:grid-cols-4">
    <div class="stat-card">
      <p class="stat-label">Active Loans</p>
      <p class="stat-value">—</p>
      <span class="inline-flex items-center gap-1 mt-1.5 text-xs font-medium text-positive">
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>
        </svg>
        <span>+12% vs last month</span>
      </span>
    </div>

    <div class="stat-card">
      <p class="stat-label">Pending Disbursement</p>
      <p class="stat-value">—</p>
      <span class="inline-flex items-center gap-1 mt-1.5 text-xs font-medium text-danger">
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>
        </svg>
        <span>-8% vs last month</span>
      </span>
    </div>

    <div class="stat-card">
      <p class="stat-label">Today's Collections</p>
      <p class="stat-value">—</p>
    </div>

    <div class="stat-card">
      <p class="stat-label">Total Members</p>
      <p class="stat-value">—</p>
      <span class="inline-flex items-center gap-1 mt-1.5 text-xs font-medium text-positive">
        <svg class="h-3 w-3" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18 9 11.25l4.306 4.306a11.95 11.95 0 0 1 5.814-5.518l2.74-1.22m0 0-5.94-2.281m5.94 2.28-2.28 5.941"/>
        </svg>
        <span>+3 this week</span>
      </span>
    </div>
  </div>

  <div class="grid grid-cols-1 gap-6 lg:grid-cols-3">
    <div class="lg:col-span-2 space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="card-header-title">Pending Tasks</h2>
          <a href="/dashboard/tasks" class="text-xs font-medium text-primary hover:text-primary-700 transition-colors">View all</a>
        </div>
        <div class="divide-y divide-border">
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full border-2 border-border-strong transition-colors hover:border-primary-300 dark:border-gray-600 cursor-pointer"></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">Review loan application #LA-2024-001</p>
              <p class="text-xs text-text-tertiary mt-0.5">Due today</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-warning-50 text-warning">High</span>
          </div>
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full border-2 border-border-strong transition-colors hover:border-primary-300 dark:border-gray-600 cursor-pointer"></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">Approve disbursement for Maria Santos</p>
              <p class="text-xs text-text-tertiary mt-0.5">Due tomorrow</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-warning-50 text-warning">High</span>
          </div>
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full border-2 border-border-strong transition-colors hover:border-primary-300 dark:border-gray-600 cursor-pointer"></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">Verify collateral documents</p>
              <p class="text-xs text-text-tertiary mt-0.5">Due in 3 days</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-primary-50 text-primary">Medium</span>
          </div>
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-4 w-4 flex-shrink-0 items-center justify-center rounded-full border-2 border-border-strong transition-colors hover:border-primary-300 dark:border-gray-600 cursor-pointer"></div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">End-of-day cash session reconciliation</p>
              <p class="text-xs text-text-tertiary mt-0.5">Due in 5 days</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-surface-alt text-text-tertiary">Low</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-header-title">Recent Activity</h2>
        </div>
        <div class="divide-y divide-border">
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-7 w-7 items-center justify-center rounded bg-positive-50 text-positive dark:bg-emerald-900/30 dark:text-emerald-300">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v12m-3-2.818.879.659c1.171.879 3.07.879 4.242 0 1.172-.879 1.172-2.303 0-3.182C13.536 12.219 12.768 12 12 12c-.725 0-1.45-.22-2.003-.659-1.106-.879-1.106-2.303 0-3.182s2.9-.879 4.006 0l.415.33M21 12a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">Payment received — <span class="font-medium">Juan Dela Cruz</span></p>
              <p class="text-xs text-text-tertiary mt-0.5">2 hours ago</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-positive-50 text-positive">Completed</span>
          </div>
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-7 w-7 items-center justify-center rounded bg-primary-50 text-primary dark:bg-primary-900/30 dark:text-primary-300">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">Loan disbursed — <span class="font-medium">#LN-2024-089</span></p>
              <p class="text-xs text-text-tertiary mt-0.5">4 hours ago</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-primary-50 text-primary">Approved</span>
          </div>
          <div class="flex items-center gap-4 px-6 py-3">
            <div class="flex h-7 w-7 items-center justify-center rounded bg-warning-50 text-warning dark:bg-amber-900/30 dark:text-amber-300">
              <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" d="M15.75 9V5.25A2.25 2.25 0 0 0 13.5 3h-6a2.25 2.25 0 0 0-2.25 2.25v13.5A2.25 2.25 0 0 0 7.5 21h6a2.25 2.25 0 0 0 2.25-2.25V15m3 0 3-3m0 0-3-3m3 3H9"/>
              </svg>
            </div>
            <div class="flex-1 min-w-0">
              <p class="text-sm text-text-primary">New member registered — <span class="font-medium">Ana Reyes</span></p>
              <p class="text-xs text-text-tertiary mt-0.5">Yesterday</p>
            </div>
            <span class="inline-flex items-center gap-1.5 rounded-full px-2.5 py-0.5 text-xs font-medium leading-5 whitespace-nowrap bg-warning-50 text-warning">Pending</span>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="card">
        <div class="card-header">
          <h2 class="card-header-title">Today's Schedule</h2>
        </div>
        <div class="p-5 space-y-3">
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-primary"></span>
              <span class="text-sm text-text-secondary">Team standup</span>
            </div>
            <span class="text-xs text-text-tertiary">9:00 AM</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-positive"></span>
              <span class="text-sm text-text-secondary">Disbursement review</span>
            </div>
            <span class="text-xs text-text-tertiary">10:30 AM</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-warning"></span>
              <span class="text-sm text-text-secondary">Member meeting</span>
            </div>
            <span class="text-xs text-text-tertiary">2:00 PM</span>
          </div>
          <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
              <span class="flex h-2 w-2 rounded-full bg-border-strong"></span>
              <span class="text-sm text-text-secondary">End-of-day report</span>
            </div>
            <span class="text-xs text-text-tertiary">5:00 PM</span>
          </div>
        </div>
      </div>

      <div class="card">
        <div class="card-header">
          <h2 class="card-header-title">Productivity</h2>
        </div>
        <div class="p-5 space-y-4">
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs text-text-secondary">Tasks completed</span>
              <span class="text-xs font-semibold text-text-primary tabular-nums">12/16</span>
            </div>
            <div class="h-1.5 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-full w-3/4 rounded-full bg-primary"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1.5">
              <span class="text-xs text-text-secondary">On-time rate</span>
              <span class="text-xs font-semibold text-text-primary tabular-nums">88%</span>
            </div>
            <div class="h-1.5 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-full w-[88%] rounded-full bg-positive"></div>
            </div>
          </div>
          <div class="flex items-start gap-2.5 rounded-md bg-warning-50 px-3 py-2.5 dark:bg-amber-900/20">
            <svg class="h-3.5 w-3.5 flex-shrink-0 mt-0.5 text-warning" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 18v-5.25m0 0a6.01 6.01 0 0 0 1.5-.189m-1.5.189a6.01 6.01 0 0 1-1.5-.189m3.75 7.478a12.06 12.06 0 0 1-4.5 0m3.75 2.383a14.406 14.406 0 0 1-3 0M14.25 18v-.192c0-.983.658-1.823 1.508-2.316a7.5 7.5 0 1 0-7.517 0c.85.493 1.509 1.333 1.509 2.316V18"/>
            </svg>
            <p class="text-xs font-medium text-warning dark:text-amber-300">You're 2 tasks behind schedule. Focus on high-priority items.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
