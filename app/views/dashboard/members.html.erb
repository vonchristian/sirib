<% content_for :page_title, "Members" %>
<% content_for :page_subtitle, "Manage cooperative member profiles" %>

<div class="animate-fade-in">
  <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900 overflow-hidden">
    <div class="overflow-x-auto">
      <table class="min-w-full text-sm">
        <thead>
          <tr class="border-b border-border dark:border-gray-700">
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-400">Name</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-400">Email</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-400">Status</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-400">Member Since</th>
            <th class="px-6 py-3 text-left text-xs font-semibold uppercase tracking-wider text-text-tertiary dark:text-gray-400">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-border dark:divide-gray-800">
          <tr class="hover:bg-surface-alt dark:hover:bg-gray-800/30 transition-colors">
            <td class="px-6 py-4 whitespace-nowrap text-sm font-medium text-text-primary dark:text-white">—</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-text-secondary dark:text-gray-400">—</td>
            <td class="px-6 py-4 whitespace-nowrap">
              <span class="inline-flex items-center rounded-full bg-positive-50 px-2 py-0.5 text-xs font-medium text-positive ring-1 ring-inset ring-positive/20 dark:bg-emerald-900/30 dark:text-emerald-400">Active</span>
            </td>
            <td class="px-6 py-4 whitespace-nowrap text-sm text-text-tertiary dark:text-gray-500">—</td>
            <td class="px-6 py-4 whitespace-nowrap text-sm">
              <a href="#" class="font-medium text-primary hover:text-primary-700 dark:text-primary-400 transition-colors">View</a>
            </td>
          </tr>
        </tbody>
      </table>
    </div>
  </div>
</div>
