          <a href="/treasury/time_deposits" class="text-sm font-medium text-primary hover:text-primary-700 dark:text-primary-400 transition-colors">View all</a>
        </div>
        <div class="divide-y divide-border">
          <div class="flex items-center justify-between px-6 py-3.5">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-text-primary dark:text-white">TD-2024-001</p>
              <p class="text-xs text-text-tertiary dark:text-gray-400">Juan Dela Cruz</p>
            </div>
            <div class="text-right">
              <p class="text-sm font-semibold text-text-primary dark:text-white">PHP 100,000.00</p>
              <p class="text-xs text-text-tertiary dark:text-gray-400">Matures Dec 15, 2024</p>
            </div>
          </div>
          <div class="flex items-center justify-between px-6 py-3.5">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-text-primary dark:text-white">TD-2024-002</p>
              <p class="text-xs text-text-tertiary dark:text-gray-400">Maria Santos</p>
            </div>
            <div class="text-right">
              <p class="text-sm font-semibold text-text-primary dark:text-white">PHP 250,000.00</p>
              <p class="text-xs text-text-tertiary dark:text-gray-400">Matures Jan 20, 2025</p>
            </div>
          </div>
          <div class="flex items-center justify-between px-6 py-3.5">
            <div class="flex-1 min-w-0">
              <p class="text-sm font-medium text-text-primary dark:text-white">TD-2024-003</p>
              <p class="text-xs text-text-tertiary dark:text-gray-400">Pedro Reyes</p>
            </div>
            <div class="text-right">
              <p class="text-sm font-semibold text-text-primary dark:text-white">PHP 50,000.00</p>
              <p class="text-xs text-text-tertiary dark:text-gray-400">Matures Jun 30, 2025</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="space-y-6">
      <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
        <div class="border-b border-border px-6 py-4 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-text-primary dark:text-white">Cash Position</h2>
        </div>
        <div class="px-6 py-4 space-y-4">
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-text-secondary dark:text-gray-300">Operating Cash</span>
              <span class="text-sm font-semibold text-text-primary dark:text-white tabular-nums">—</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-full w-3/5 rounded-full bg-primary"></div>
            </div>
          </div>
          <div>
            <div class="flex items-center justify-between mb-1">
              <span class="text-sm text-text-secondary dark:text-gray-300">Time Deposits</span>
              <span class="text-sm font-semibold text-text-primary dark:text-white tabular-nums">—</span>
            </div>
            <div class="h-2 overflow-hidden rounded-full bg-gray-100 dark:bg-gray-800">
              <div class="h-full w-2/5 rounded-full bg-positive"></div>
            </div>
          </div>
        </div>
      </div>

      <div class="rounded-lg border border-border bg-surface dark:border-gray-700 dark:bg-gray-900">
        <div class="border-b border-border px-6 py-4 dark:border-gray-700">
          <h2 class="text-sm font-semibold text-text-primary dark:text-white">Quick Actions</h2>
        </div>
        <div class="px-6 py-4 space-y-2">
          <a href="/treasury/time_deposits/new" class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-text-secondary hover:bg-gray-100 hover:text-text-primary dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3" />
            </svg>
            New Time Deposit
          </a>
          <a href="/treasury/time_deposit_products/new" class="flex items-center gap-3 rounded-md px-3 py-2 text-sm text-text-secondary hover:bg-gray-100 hover:text-text-primary dark:text-gray-400 dark:hover:bg-gray-800 dark:hover:text-gray-200 transition-colors">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m0 0-3-3m3 3 3-3" />
            </svg>
            Create Product
          </a>
        </div>
      </div>
    </div>
