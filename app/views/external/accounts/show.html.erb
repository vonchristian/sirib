<% content_for :page_title, @account.account_name %>
<% content_for :breadcrumbs do %>
  <nav class="flex items-center gap-2 text-sm mb-4">
    <%= link_to @bank.name, external_bank_path(@bank), class: "text-text-tertiary hover:text-text-primary" %>
    <span class="text-text-tertiary">/</span>
    <span class="text-text-primary"><%= @account.account_name %></span>
  </nav>
<% end %>
<div class="animate-fade-in">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-text-primary"><%= @account.account_name %></h1>
      <p class="text-sm text-text-tertiary mt-0.5"><%= @bank.name %> • <%= @account.account_number_encrypted&.last(4)&.rjust(16, "*") || "****" %></p>
    </div>
    <div class="flex items-center gap-2">
      <%= link_to "Upload Statement", new_external_bank_account_document_path(@bank, @account), class: "btn-ghost" %>
      <%= button_to "Interest Earned Template", external_bank_account_entry_template_path(@bank, @account), method: :post, class: "btn-ghost cursor-pointer" %>
      <%= link_to "Reconcile", external_bank_account_reconciliation_path(@bank, @account), class: "btn-primary" %>
    </div>
  </div>
  <div class="grid grid-cols-1 lg:grid-cols-4 gap-4 mb-6">
    <div class="card p-4">
      <p class="text-xs text-text-tertiary uppercase tracking-wider mb-1">Balance</p>
      <p class="text-xl font-bold font-mono text-text-primary"><%= number_to_currency(@account.current_balance.to_f, unit: "") %> <span class="text-sm font-normal text-text-tertiary"><%= @account.currency %></span></p>
    </div>
    <div class="card p-4">
      <p class="text-xs text-text-tertiary uppercase tracking-wider mb-1">Transactions</p>
      <p class="text-lg font-semibold text-text-primary"><%= @account.transactions.count %></p>
    </div>
    <div class="card p-4">
      <p class="text-xs text-text-tertiary uppercase tracking-wider mb-1">Documents</p>
      <p class="text-lg font-semibold text-text-primary"><%= @documents.count %></p>
    </div>
    <div class="card p-4">
      <p class="text-xs text-text-tertiary uppercase tracking-wider mb-1">Status</p>
      <span class="badge <%= @account.status == 'active' ? 'badge-success' : 'badge-warning' %> capitalize"><%= @account.status %></span>
    </div>
  </div>
  <div class="card">
    <div class="p-4 border-b border-border flex items-center justify-between">
      <h2 class="text-sm font-semibold text-text-primary">Recent Transactions</h2>
      <span class="text-xs text-text-tertiary"><%= @transactions.count %> shown</span>
    </div>
    <% if @transactions.any? %>
      <table class="table">
        <thead>
          <tr>
            <th>Date</th>
            <th>Description</th>
            <th>Reference</th>
            <th class="text-right">Debit</th>
            <th class="text-right">Credit</th>
            <th class="text-right">Balance</th>
            <th>Status</th>
          </tr>
        </thead>
        <tbody>
          <% @transactions.each do |tx| %>
            <tr>
              <td class="whitespace-nowrap"><%= tx.transaction_date %></td>
              <td class="max-w-xs truncate"><%= tx.description %></td>
              <td class="font-mono text-xs"><%= tx.reference_number || "—" %></td>
              <td class="text-right font-mono text-danger"><%= tx.debit? ? number_to_currency(tx.amount, unit: "") : "—" %></td>
              <td class="text-right font-mono text-success"><%= tx.credit? ? number_to_currency(tx.amount, unit: "") : "—" %></td>
              <td class="text-right font-mono"><%= tx.running_balance ? number_to_currency(tx.running_balance, unit: "") : "—" %></td>
              <td><%= tx.reconciled? ? "Matched" : "Unmatched" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    <% else %>
      <div class="p-8 text-center">
        <p class="text-sm text-text-tertiary mb-3">No transactions yet</p>
        <%= link_to "Upload Statement", new_external_bank_account_document_path(@bank, @account), class: "btn-primary text-xs" %>
      </div>
    <% end %>
  </div>
</div>