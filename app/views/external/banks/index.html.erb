<% content_for :page_title, "External Banks" %>
<div class="animate-fade-in">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-text-primary">External Banks</h1>
      <p class="text-sm text-text-tertiary mt-0.5">Manage external bank connections</p>
    </div>
    <%= link_to "Add Bank", new_external_bank_path, class: "btn-primary" %>
  </div>
  <% if @banks.any? %>
    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>Bank Name</th>
            <th>Code</th>
            <th>Country</th>
            <th>Accounts</th>
            <th>Status</th>
            <th class="text-right">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @banks.each do |bank| %>
            <tr>
              <td><%= link_to bank.name, external_bank_path(bank), class: "font-medium text-text-primary hover:text-primary" %></td>
              <td><%= bank.code || "—" %></td>
              <td><%= bank.country %></td>
              <td><%= bank.accounts.count %></td>
              <td><span class="badge <%= bank.status == 'active' ? 'badge-success' : 'badge-warning' %> capitalize"><%= bank.status %></span></td>
              <td class="text-right"><%= link_to "View", external_bank_path(bank), class: "btn-ghost text-xs" %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% else %>
    <div class="rounded-lg border-2 border-dashed border-border bg-surface-alt px-6 py-16 text-center">
      <p class="text-sm text-text-tertiary mb-4">No external banks configured</p>
      <%= link_to "Add Bank", new_external_bank_path, class: "btn-primary" %>
    </div>
  <% end %>
</div>
