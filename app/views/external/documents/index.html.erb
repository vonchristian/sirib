<% content_for :page_title,"Documents — #{@account.account_name}" %> 
<div class="animate-fade-in"> 
  <div class="flex items-center justify-between mb-6"> 
    <div> 
      <h1 class="text-xl font-semibold text-text-primary">Documents</h1>
 
      <p class="text-sm text-text-tertiary mt-0.5"><%= @account.account_name %></p>
 </div>
 <%= link_to"Upload Document", new_external_bank_account_document_path(@bank, @account), class:"btn-primary" %> </div>
 <% if @documents.any? %> 
    <div class="table-container"> 
      <table class="table"> 
        <thead> 
          <tr> 
            <th>File</th>
 
            <th>Type</th>
 
            <th>Period</th>
 
            <th>Status</th>
 
            <th>Uploaded</th>
 
            <th class="text-right">Actions</th>
 </tr>
 </thead>
 
        <tbody> <% @documents.each do |doc| %> 
            <tr> 
              <td><%= link_to doc.file.filename.to_s, external_bank_account_document_path(@bank, @account, doc), class:"font-medium text-text-primary hover:text-primary" %></td>
 
              <td><span class="badge capitalize"><%= doc.document_type %></span></td>
 
              <td class="text-sm"><%= doc.period %></td>
 
              <td> <% sc = case doc.processing_status; when "parsed" then"badge-success"; when "failed" then"badge-danger"; when "processing" then"badge-warning"; else"badge-secondary"; end %> <span class="badge <%= sc %> capitalize"><%= doc.processing_status %></span> </td>
 
              <td class="text-sm"><%= time_ago_in_words(doc.created_at) %> ago</td>
 
              <td class="text-right"><%= button_to"Delete", external_bank_account_document_path(@bank, @account, doc), method: :delete, class:"btn-ghost text-xs text-danger", data: { turbo_confirm:"Delete #{doc.file.filename}?" } %></td>
 </tr>
 <% end %> </tbody>
 </table>
 </div>
 <% else %> 
    <div class="rounded-lg border-2 border-dashed border-border bg-surface-alt px-6 py-16 text-center"> 
      <p class="text-sm text-text-tertiary mb-4">No documents uploaded yet</p>
 <%= link_to"Upload Statement", new_external_bank_account_document_path(@bank, @account), class:"btn-primary" %> </div>
 <% end %> </div>
