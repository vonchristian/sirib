<% content_for :page_title, "Reconciliation — #{@account.account_name}" %>
<% content_for :breadcrumbs do %>
  <nav class="flex items-center gap-2 text-sm mb-4">
    <%= link_to @account.account_name, external_bank_account_path(@bank, @account), class: "text-text-tertiary hover:text-text-primary" %>
    <span class="text-text-tertiary">/</span>
    <span class="text-text-primary">Reconciliation</span>
  </nav>
<% end %>
<div class="animate-fade-in">
  <div class="flex items-center justify-between mb-6">
    <div>
      <h1 class="text-xl font-semibold text-text-primary">Reconciliation</h1>
      <p class="text-sm text-text-tertiary mt-0.5"><%= @account.account_name %> — <%= @bank.name %></p>
    </div>
    <div class="flex items-center gap-2">
      <span class="text-xs text-text-tertiary">Balance: <span class="font-mono text-text-primary"><%= number_to_currency(@account.current_balance.to_f, unit: "") %> <%= @account.currency %></span></span>
    </div>
  </div>

  <% if @selected_transaction.present? %>
    <div class="card mb-6 p-4 border border-active">
      <div class="flex items-center justify-between mb-4">
        <h2 class="text-sm font-semibold text-text-primary">Matching Transaction ##<%= @selected_transaction.id %></h2>
        <%= link_to "Cancel", external_bank_account_reconciliation_path(@bank, @account), class: "btn-ghost text-xs" %>
      </div>
      <div class="grid grid-cols-4 gap-4 mb-4 p-3 bg-surface-alt rounded">
        <div><p class="text-xs text-text-tertiary">Date</p><p class="text-sm font-medium text-text-primary"><%= @selected_transaction.transaction_date %></p></div>
        <div><p class="text-xs text-text-tertiary">Description</p><p class="text-sm font-medium text-text-primary truncate"><%= @selected_transaction.description %></p></div>
        <div><p class="text-xs text-text-tertiary">Amount</p><p class="text-sm font-mono font-medium <%= @selected_transaction.debit? ? 'text-danger' : 'text-success' %>"><%= @selected_transaction.debit? ? "−" : "+" %><%= number_to_currency(@selected_transaction.amount, unit: "") %></p></div>
        <div><p class="text-xs text-text-tertiary">Allocated</p><p class="text-sm font-mono text-text-primary"><%= number_to_currency(@selected_transaction.reconciled_amount / 100.0, unit: "") %> / <%= number_to_currency(@selected_transaction.amount, unit: "") %></p></div>
      </div>

      <%= form_with url: allocate_external_bank_account_reconciliation_path(@bank, @account), method: :post, class: "space-y-3" do |f| %>
        <%= hidden_field_tag :transaction_id, @selected_transaction.id %>
        <div class="flex items-end gap-3">
          <div class="flex-1">
            <%= label_tag :journal_entry_id, "Journal Entry", class: "input-label" %>
            <%= select_tag :journal_entry_id, options_for_select(@journal_entries.map { |e| ["##{e.id} — #{e.description&.truncate(40)}", e.id] }), { include_blank: "Select entry", class: "input" } %>
          </div>
          <div class="w-40">
            <%= label_tag :allocated_amount_cents, "Amount (cents)", class: "input-label" %>
            <%= number_field_tag :allocated_amount_cents, (@selected_transaction.amount_cents - @selected_transaction.reconciled_amount), class: "input", min: 1 %>
          </div>
          <div><%= f.submit "Allocate", class: "btn-primary" %></div>
        </div>
      <% end %>

      <% if @selected_allocations.present? %>
        <div class="mt-4">
          <h3 class="text-xs text-text-tertiary uppercase tracking-wider mb-2">Allocations</h3>
          <div class="space-y-2">
            <% @selected_allocations.each do |al| %>
              <div class="flex items-center justify-between p-2 bg-surface-alt rounded text-sm">
                <span class="text-text-primary">Entry ##{al.journal_entry_id} — <%= number_to_currency(al.allocated_amount, unit: "") %></span>
                <div class="flex items-center gap-2">
                  <span class="badge <%= al.status == 'confirmed' ? 'badge-success' : 'badge-warning' %> capitalize"><%= al.status %></span>
                  <% if al.suggested? %>
                    <%= button_to "Confirm", confirm_allocation_external_bank_account_reconciliation_path(@bank, @account, allocation_id: al.id), class: "btn-ghost text-xs" %>
                    <%= button_to "Reject", reject_allocation_external_bank_account_reconciliation_path(@bank, @account, allocation_id: al.id), class: "btn-ghost text-xs text-danger" %>
                  <% end %>
                </div>
              </div>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
    <div class="card">
      <div class="p-4 border-b border-border"><h2 class="text-sm font-semibold text-text-primary">External Transactions</h2></div>
      <div class="divide-y divide-border max-h-[70vh] overflow-y-auto">
        <% @transactions.each do |tx| %>
          <div class="p-3 hover:bg-surface-alt transition-colors <%= @selected_transaction == tx ? 'bg-accent-dim' : '' %>">
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-tertiary"><%= tx.transaction_date %></p>
                <p class="text-sm font-medium text-text-primary truncate"><%= tx.description %></p>
                <% if tx.reference_number.present? %><p class="text-xs font-mono text-text-tertiary">Ref: <%= tx.reference_number %></p><% end %>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-sm font-mono <%= tx.debit? ? 'text-danger' : 'text-success' %>"><%= tx.debit? ? "−" : "+" %><%= number_to_currency(tx.amount, unit: "") %></p>
                <p class="text-xs text-text-tertiary"><%= tx.reconciled? ? "Matched" : "Unmatched" %></p>
              </div>
            </div>
            <div class="mt-2">
              <%= link_to "Match", external_bank_account_reconciliation_path(@bank, @account, transaction_id: tx.id), class: "btn-ghost text-xs" %>
            </div>
          </div>
        <% end %>
        <% if @transactions.empty? %>
          <div class="p-8 text-center text-sm text-text-tertiary">No transactions found</div>
        <% end %>
      </div>
    </div>

    <div class="card">
      <div class="p-4 border-b border-border"><h2 class="text-sm font-semibold text-text-primary">Journal Entries</h2></div>
      <div class="divide-y divide-border max-h-[70vh] overflow-y-auto">
        <% @journal_entries.each do |entry| %>
          <div class="p-3 hover:bg-surface-alt transition-colors">
            <div class="flex items-start justify-between gap-2">
              <div class="flex-1 min-w-0">
                <p class="text-xs text-text-tertiary">#<%= entry.id %> — <%= entry.posted_at&.to_date %></p>
                <p class="text-sm font-medium text-text-primary truncate"><%= entry.description %></p>
                <p class="text-xs font-mono text-text-tertiary"><%= entry.reference_number %></p>
              </div>
              <div class="text-right flex-shrink-0">
                <p class="text-sm font-mono text-text-primary"><%= number_to_currency(entry.amount_lines.sum(:amount_cents) / 100.0, unit: "") %></p>
              </div>
            </div>
            <% if @selected_transaction.present? %>
              <div class="mt-2">
                <%= button_to "Match to Selected", allocate_external_bank_account_reconciliation_path(@bank, @account), params: { transaction_id: @selected_transaction.id, journal_entry_id: entry.id, allocated_amount_cents: @selected_transaction.amount_cents - @selected_transaction.reconciled_amount }, class: "btn-ghost text-xs" %>
              </div>
            <% end %>
          </div>
        <% end %>
        <% if @journal_entries.empty? %>
          <div class="p-8 text-center text-sm text-text-tertiary">No journal entries found</div>
        <% end %>
      </div>
    </div>
  </div>
</div>