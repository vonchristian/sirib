10.6 Test Patterns

```ruby
RSpec.describe "database check constraints" do
  it "prevents zero-amount amount_lines" do
    line = build(:accounting_amount_line, amount_cents: 0)
    expect { line.save(validate: false) }
      .to raise_error(ActiveRecord::StatementInvalid)
  end

  it "prevents unbalanced entry status values" do
    entry = build(:accounting_entry, status: "invalid_status")
    expect { entry.save(validate: false) }
      .to raise_error(ActiveRecord::StatementInvalid)
  end
end
```

