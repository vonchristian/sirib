```ruby
def up
  # Check for violating rows before adding constraint
  violation = LoanPayment
    .where("principal_cents + interest_cents + penalty_cents != amount_cents")
    .count
  raise "Data integrity: #{violation} loan payments violate allocation constraint" if violation > 0
  # ... add constraints
end
