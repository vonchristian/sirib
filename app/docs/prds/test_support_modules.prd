6.5 Playwright Page Object

```typescript
// tests/helpers/page_objects/journal_entries.ts
import { Page, Locator } from '@playwright/test';

export class JournalEntryListPage {
  readonly page: Page;
  readonly firstRowViewButton: Locator;
  readonly searchInput: Locator;
  readonly emptyState: Locator;

  constructor(page: Page) {
    this.page = page;
    this.firstRowViewButton = page.locator('[data-testid="journal-entry-row"]').first().locator('a:has-text("View")');
    this.searchInput = page.locator('[data-testid="journal-entries-search"]');
    this.emptyState = page.locator('[data-testid="empty-state"]');
  }

  async goto() {
    await this.page.goto('/accounting/journal_entries');
    await this.page.waitForLoadState('networkidle');
  }

  async clickFirstView() {
    await this.firstRowViewButton.click();
    await this.page.waitForLoadState('networkidle');
  }

  async search(query: string) {
    await this.searchInput.fill(query);
    await this.searchInput.press('Enter');
    await this.page.waitForLoadState('networkidle');
  }
}
```

6.6 Playwright Auth Helper

```typescript
// tests/helpers/auth.ts
import { Page, request } from '@playwright/test';
import path from 'path';

const STORAGE_STATE_PATH = path.join(__dirname, '../../playwright/.auth/user.json');

export async function loginAsAdmin(page: Page) {
  await page.goto('/sessions/new');
  await page.fill('[name="email"]', 'admin@example.com');
  await page.fill('[name="password"]', 'password123');
  await page.click('button:has-text("Sign in")');
  await page.waitForLoadState('networkidle');
  await page.context().storageState({ path: STORAGE_STATE_PATH });
}

export async function loginAsTeller(page: Page) {
  await page.goto('/sessions/new');
  await page.fill('[name="email"]', 'teller@example.com');
  await page.fill('[name="password"]', 'password123');
  await page.click('button:has-text("Sign in")');
  await page.waitForLoadState('networkidle');
}
```

7. Migration Plan

- Create the support modules incrementally — one per PR
- RSpec support files are auto-loaded by `config.autoload_paths` or `Dir[Rails.root.join('spec/support/**/*.rb')]`
- Add the glob require to `spec/rails_helper.rb`
- Update existing tests to use support modules as they are touched by other work
- Playwright helpers are created alongside the test files they support
- No data migration needed

8. Risks & Mitigations

Risk: Glob autoloading of `spec/support/**/*.rb` causes load-order issues
Mitigation: If modules depend on each other, name them with explicit prefixes (e.g., `00_auth_helpers.rb`, `01_cooperative_helpers.rb`). Or use `require_dependency` within each file.

Risk: Existing tests break when support modules change
Mitigation: Support modules are additive — existing tests can continue working without changes. They only break if an existing test name conflicts with a new method.

Risk: Playwright page objects are too abstract and slow down test writing
Mitigation: Create page objects only for the most repeated patterns (auth, journal entries, balance sheet, member search). Keep them lightweight.

9. Definition of Done

- `spec/support/` contains at least 3 RSpec support modules: `auth_helpers.rb`, `cooperative_helpers.rb`, `time_helpers.rb`
- `spec/rails_helper.rb` includes `Dir[Rails.root.join('spec/support/**/*.rb')].each { |f| require f }`
- Factory traits exist for: `:with_entries`, `:with_pending_entry`, `:with_running_balance`, `:contra_account`
- Playwright helpers exist: `tests/helpers/auth.ts` with `loginAsAdmin()` and `loginAsTeller()`
- Playwright page objects exist: `tests/helpers/page_objects/journal_entries.ts`
- At least 5 existing tests have been updated to use the new support modules (proving adoption)
- All existing tests pass with no new failures

10. Codebase Implementation Details

10.1 File Manifest

- `spec/support/auth_helpers.rb` — new
- `spec/support/cooperative_helpers.rb` — new
- `spec/support/time_helpers.rb` — new
- `spec/factories/accounting/entries.rb` — add traits
- `spec/factories/accounting/accounts.rb` — add traits
- `spec/factories/accounting/running_balances.rb` — add traits
- `spec/rails_helper.rb` — add support glob
- `tests/helpers/auth.ts` — new
- `tests/helpers/page_objects/journal_entries.ts` — new

10.2 Existing Patterns to Follow

- Rails helper: Follow `spec/rails_helper.rb` line 10 — `Dir[Rails.root.join("spec/support/**/*.rb")].sort.each { |f| require f }` — already has the require, just create the files
- Test pattern: Follow `spec/services/accounting/post_entry_service_spec.rb` — `let!`, `described_class.run!`, `expect { }.to change`
- Factory: Follow `spec/factories/accounting/entries.rb` — `FactoryBot.define`, `association`, `trait`, `after(:build)`
- Playwright: Follow `tests/journal_entries/happy_path.spec.js` — `test.describe`, `test`, `page.locator`, `page.goto`

10.3 Auth Helper Implementation

```ruby
# spec/support/auth_helpers.rb
module AuthHelpers
  def sign_in(user = nil)
    user ||= create(:user)
    post session_path, params: { email: user.email, password: "password123" }
    follow_redirect! if respond_to?(:follow_redirect!)
    user
  end

  def auth_headers(user = nil)
    user ||= sign_in
    session = user.sessions.last
    { "Authorization" => "Bearer #{session&.token || 'test-token'}" }
  end
end

RSpec.configure do |config|
  config.include AuthHelpers, type: :request
  config.include AuthHelpers, type: :controller
end
```

