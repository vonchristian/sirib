10.5 Factory Traits

```ruby
# spec/factories/accounting/entries.rb - add traits
FactoryBot.define do
  factory :accounting_entry, class: "Accounting::Entry" do
    # existing attributes...
    trait :posted do
      status { "posted" }
      posted_at { Time.current }
    end

    trait :pending do
      status { "pending" }
    end

    trait :reversed do
      status { "reversed" }
      reversed_at { Time.current }
    end

    trait :with_debit_and_credit do
      after(:create) do |entry|
        create(:accounting_amount_line, :debit, entry: entry)
        create(:accounting_amount_line, :credit, entry: entry)
      end
    end
  end
end
```

