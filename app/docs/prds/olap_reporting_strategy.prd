10.7 Test Patterns

```ruby
RSpec.describe Reporting::TrialBalance do
  it "returns balances as integers" do
    create(:accounting_entry, :posted)
    described_class.refresh
    entry = described_class.first
    expect(entry.balance_cents).to be_an(Integer)
  end

  it "is read-only" do
    expect(described_class.new).to be_readonly
  end

  it "provides cooperative-scoped data" do
    coop = create(:cooperative)
    create(:accounting_entry, :posted, cooperative: coop)
    described_class.refresh
    expect(described_class.by_cooperative(coop).count).to eq(Accounting::Account.count)
  end
end
```

