10.6 Test Patterns

```ruby
# spec/services/accounting/update_running_balances_spec.rb
RSpec.describe Accounting::UpdateRunningBalances do
  let(:asset) { create(:accounting_account, account_type: :asset) }
  let(:liability) { create(:accounting_account, account_type: :liability) }
  let(:entry) {
    Accounting::Entry.build(
      description: "test",
      debits: [{ account: asset, amount: 10000 }],
      credits: [{ account: liability, amount: 10000 }]
    )
  }

  it "locks accounts before updating balances" do
    expect(Accounting::Account).to receive(:lock).with("FOR UPDATE").and_call_original
    entry.save!
    described_class.run!(entry: entry)
  end
end
```

