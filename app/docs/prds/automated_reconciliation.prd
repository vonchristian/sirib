10.7 Test Patterns

```ruby
RSpec.describe Reconciliation::DebitsEqualCreditsCheck do
  it "passes when all entries are balanced" do
    create(:accounting_entry, :posted)  # factory creates balanced entry
    failures = described_class.run!(as_of_date: Date.current)
    expect(failures).to be_empty
  end

  it "detects unbalanced entries" do
    entry = create(:accounting_entry, :pending)
    # Manually create unbalanced line via direct SQL
    ActiveRecord::Base.connection.execute(<<~SQL)
      INSERT INTO accounting_amount_lines
      (entry_id, account_id, amount_cents, amount_type, cooperative_id, created_at, updated_at)
      VALUES (#{entry.id}, #{create(:accounting_account).id}, 500, 0, #{entry.cooperative_id},
              NOW(), NOW())
    SQL

    failures = described_class.run!(as_of_date: Date.current)
    expect(failures).not_to be_empty
  end
end
```

