10.4 Swap-Table Rebuild Service

```ruby
# app/services/accounting/rebuild_running_balances_service.rb — updated
module Accounting
  class RebuildRunningBalancesService < ActiveInteraction::Base
    TEMP_TABLE = "running_balances_new"

    def execute
      create_temp_table
      rebuild_into_temp
      swap_tables
      recreate_indexes
      drop_old_table
    end

    private

    def create_temp_table
      execute("CREATE TABLE #{TEMP_TABLE} (LIKE running_balances INCLUDING ALL)")
    end

    def rebuild_into_temp
      Accounting::Account.find_each do |account|
        compute_and_insert_balances(account, TEMP_TABLE)
      end
    end

    def swap_tables
      execute("ALTER TABLE running_balances RENAME TO running_balances_old")
      execute("ALTER TABLE #{TEMP_TABLE} RENAME TO running_balances")
    end

    def recreate_indexes
      execute("CREATE UNIQUE INDEX ... ON running_balances (...)") # re-add indexes
    end

    def drop_old_table
      execute("DROP TABLE IF EXISTS running_balances_old")
    end

    def execute(sql)
      ActiveRecord::Base.connection.execute(sql)
    end
  end
end
```

10.5 Test Patterns

```ruby
RSpec.describe Accounting::UpdateRunningBalances do
  let(:entry) { create(:accounting_entry, :posted) }

  it "updates running balances synchronously" do
    expect(Accounting::RunningBalance).to receive(:find_or_initialize_by).at_least(:once)
    described_class.run!(entry: entry)
  end

  it "locks accounts" do
    expect(Accounting::Account).to receive(:lock).with("FOR UPDATE").and_call_original
    described_class.run!(entry: entry)
  end
end
```

