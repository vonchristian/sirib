```

10.4 Job Retry Pattern

```ruby
# app/jobs/application_job.rb
class ApplicationJob < ActiveJob::Base
  include CooperativeJob

  retry_on ActiveRecord::Deadlocked, wait: :exponentially_longer, attempts: 3
  retry_on ActiveRecord::StaleObjectError, wait: :exponentially_longer, attempts: 3 do |job, error|
    # Log and dead-letter after 3 retries
    Rails.logger.error("Job #{job.class} failed: stale object #{error.message}")
  end
end
```

10.5 Backfill for Existing Rows

```sql
-- Run in db/migrate or as a post-migration rake task
UPDATE accounting_entries SET lock_version = 0 WHERE lock_version IS NULL;
UPDATE accounting_amount_lines SET lock_version = 0 WHERE lock_version IS NULL;
-- ... repeat for each table
```

10.6 Test Patterns

```ruby
RSpec.describe Accounting::Entry do
  it "supports optimistic locking" do
    e1 = create(:accounting_entry)
    e2 = Accounting::Entry.find(e1.id)

    e1.update!(description: "updated by A")

    expect { e2.update!(description: "updated by B") }
      .to raise_error(ActiveRecord::StaleObjectError)
  end
end
```

