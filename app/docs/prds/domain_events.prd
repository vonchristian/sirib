10.6 Migrating Existing Event Creation

Before:
```ruby
Lending::LoanEvent.create!(
  loan: loan, event_type: "disbursed",
  metadata: { amount_cents: 10000 }
)
```

After:
```ruby
LoanDisbursed.new(
  aggregate: loan,
  actor: Current.user,
  amount_cents: 10000,
  disbursement_method: "cash",
  disbursed_to_account_id: account.id
).tap(&:validate!).save!
```

10.7 Test Patterns

```ruby
RSpec.describe LoanDisbursed do
  let(:loan) { create(:loan) }
  let(:user) { create(:user) }

  subject(:event) {
    described_class.new(
      aggregate: loan,
      actor: user,
      amount_cents: 100000,
      disbursement_method: "cash",
      disbursed_to_account_id: 1
    )
  }

  it "validates amount_cents" do
    event.amount_cents = 0
    expect(event).not_to be_valid
  end

  it "saves as LoanEvent record" do
    record = event.save!
    expect(record.event_type).to eq("loan_disbursed")
  end

  it "replays on loan" do
    event.replay(loan)
    expect(loan.reload).to be_disbursed
    expect(loan.outstanding_principal_cents).to eq(100000)
  end
end
```

